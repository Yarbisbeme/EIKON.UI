@using EIKON.UI.Interfaces

 @inject NavigationManager Navigation
@inject IMockService<Trhem000Dto> MockEmpresasService
@inject IMockService<LoginDto> MockLoginService

@inject IJSRuntime JS
<nav class="e-navbar">
    <div class="e-nav-logo">
        <button>
            <i class="fi fi-tr-sidebar-flip"></i>
        </button>
        <div class="logo">
            <img src="/images/image.png" alt="" />
        </div>
    </div>
    <div class="right">
        <button @onclick="ToggleOpenActionsMenu" style="border-radius:4px;border:1px solid #E5E5EA;color:#6C757D !important; font-weight:bold;height:40px;padding:0 5px; background-color:transparent;">
            Acciones
        </button>
        <div class="config">
            <button>
                <i class="fi fi-rr-bell"></i>
            </button>
        </div>

        <div class="user" @onclick="ToggleOpenUserMenu">
            <div class="user-avatar">
                <img src="https://images.pexels.com/photos/27860822/pexels-photo-27860822/free-photo-of-looking-green.jpeg?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=1"
                alt="User picture" loading="lazy" />
            </div>
            <div class="user-options @(UserMenuOpen ? "menu-open" : "menu-closed")">
                <i class="fi fi-rr-angle-small-down"></i>
            </div>
        </div>
    </div>

    <div class="actions @(ActionsMenu ? "open" : "closed")">
        <div style="display:flex; gap:10px; align-items:center;cursor:pointer;">
            <i class="fi fi-tr-file-upload" style="font-size:24px; line-height:0%"></i>
            <span>Importar</span>
        </div>
        <div style="display:flex; gap:10px; align-items:center;cursor:pointer;">
            <i class="fi fi-tr-file-download" style="font-size:24px; line-height:0%"></i>
            <span>Exportar</span>
        </div>
        <div style="display:flex; gap:10px; align-items:center;cursor:pointer;">
            <i class="fi fi-tr-print" style="font-size:24px; line-height:0%"></i>
            <span>Importar</span>
        </div>
    </div>

    <div class="user-menu @(UserMenuOpen ? "open" : "closed")">
        <div class="user" @onclick="NavigateToCounterComponent">
            <div class="user-avatar">
                <img src="https://images.pexels.com/photos/27860822/pexels-photo-27860822/free-photo-of-looking-green.jpeg?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=1"
                alt="User picture" loading="lazy" />
            </div>
            <div class="user-info">
                <span class="user-name">@nombre</span>
                <span class="user-company">@empresa</span>
            </div>
        </div>

        <div class="options">
            <div class="color-palette">
                <div class="settings">
                    <i class="fi fi-tr-swatchbook"></i>
                    <div class="settings-label">Color Principal:</div>
                </div>

                <div class="settings-control">
                    <div class="color-split">
                        <div class="color-preview" style="background-color: var(--naranja-eikon-normal)"></div>
                        <div class="color-code">
                            #859fkd
                            <i class="fi fi-rr-angle-small-down"></i>
                        </div>
                    </div>
                </div>
            </div>
            <div class="language">

                <div class="settings">
                    <i class="fi fi-tr-language-exchange"></i>
                    <div class="settings-label">Idioma:</div>
                </div>
                <div class="select">
                    <select name="company" id="company">
                        <option value="1">Español</option>
                        <option value="2">Ingles</option>
                    </select>
                    <i class="icon fi fi-rr-angle-small-down"></i>
                </div>
            </div>
        </div>

        <hr />
        <div class="logout" @onclick="NavigateToLogin">
            <i class="fi fi-tr-sign-out-alt"></i>
            Cerrar sesión
        </div>
    </div>
</nav>


