@namespace EIKON.UI.Components

<div class="modal" style="display:@(IsVisible ? "block" : "none");">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">@Title</h5>
                <button type="button" class="close" @onclick="Close">
                    <span>&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <p>@Message</p>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="Cancel">Aceptar</button>
             </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public string Title { get; set; } = "Eikon Información";
    [Parameter] public string Message { get; set; } = "Haga clic en Aceptar";
    [Parameter] public EventCallback<bool> OnConfirm { get; set; }
    private bool IsVisible { get; set; } = false;

    public void Show()
    {
        IsVisible = true;
       // StateHasChanged();
    }

    public void Close()
    {
        IsVisible = false;
       // StateHasChanged();
    }

   

    private async Task Cancel()
    {
        IsVisible = false;
        await OnConfirm.InvokeAsync(false); // Llama a la acción de cancelación
    }
}


