    async Task ActualizarReq()
    {
        var dataItem = SelectedRq;
        //dataItem.OfEstatus = Estatus;


        //dataItem.AnCodigo = "";
        dataItem.ReqCreate = "S";
        dataItem.Reqaprobad = new DateTime(1971, 1, 1);

        dataItem.EmEmpresa = "01";
        dataItem.FwCodigo = "001";
        dataItem.Maenume = "99999999";
        dataItem.PasUserid = auth.userId;


        dataItem.Reqedad = 0;

        dataItem.Reqfec1 = DateTime.Now;

        // dataItem.Reqfechaprobable = dataItem.FechaTopeContrato;
        dataItem.Reqqtycomp = dataItem.Reqqty;
        dataItem.Reqqtycont = dataItem.Reqqty;
        //dataItem.Reqqtyprof = dataItem.Reqqty;
        dataItem.Reqsexo = " ";
        dataItem.Reqsue1 = 0;
        dataItem.Reqsuel = 0;
        dataItem.LastupDate = DateTime.Now;
        if (dataItem.Reqesta == "A" || dataItem.Reqesta == "C")
        {
            dataItem.Reqaprobad = DateTime.Now;
        }
        else
        {
            dataItem.Reqaprobad = new DateTime(1971, 1, 1);
        }

        if (SelectedRq.IdentityColumn == 0)
        {
            if(dataItem.Reqnume==null)
                dataItem.Reqnume = "00000000";           // Asignar un valor por defecto
            if (dataItem.AnCodigo == null)
                dataItem.AnCodigo = " ";
            dataItem.Reqfech = DateTime.Now;
            dataItem.Camnume = "0000000"; // Asignar un valor por defecto
            dataItem.ChangedBy = "EikonBl";
            dataItem.CreatedBy = auth.userId;
            dataItem.CreatedOn = DateTime.Now;
            dataItem.Reqesta = "N"; // Estatus de la requisición
            try
            {
                var ret0 = await api.FRHrq010DtoInsert(dataItem); //insertar requisición
                alertInfo.Show("Requisición Insertada!!!");
                // IsInfoVisible = true;
                await CargarDatos();
                //ActiveTabIndex = 0; // Cambiar de pestaña
                if (dataItem.Reqesta == "A" || dataItem.Reqesta == "C")
                {
                    ActiveTabIndex = 1; // Cambiar a la pestaña de Aprobadas
                }
                else
                {
                    ActiveTabIndex = 0; // Cambiar a la pestaña req en proceso
                }
            }
            catch (ApiException ex)
            {

                alertInfo.Show("Requisición NO Insertada: Error 1: > " + ex.Message, "warning");
            }
            catch (Exception ex)
            {

                alertInfo.Show("Requisición No Insertada: Error 2: > " + ex.Message, "error");
            }

            //dataue = new List<Frhue000Dto>();
            //nv.NavigateTo("/WFRHSU204");
        }
        else
        {
            try
            {
                dataItem.ChangedBy = auth.userId;
                dataItem.ChangedOn=DateTime.Now;
                var ret = await api.FRHrq010DtoUpdate(SelectedRq.IdentityColumn, dataItem); // update req
                alertInfo.Show("Requisición Actualizada!!!");
                // IsInfoVisible = true;
                await CargarDatos();
                if (dataItem.Reqesta == "A" || dataItem.Reqesta == "C")
                {
                    ActiveTabIndex = 1; // Cambiar a la pestaña de Aprobadas
                }
                else
                {
                    ActiveTabIndex = 0; // Cambiar a la pestaña req en proceso
                }

            }
            catch (ApiException ex)
            {

                alertInfo.Show("Requisición Actualizada con estatus: " + ex.StatusCode, "warning");
            }
            catch (Exception ex)
            {

                alertInfo.Show("Requisición No Actualizada Error 4 ..." + ex.Message, "error");
            }

            // nv.NavigateTo("/WFRHSU204");
        }

    }
