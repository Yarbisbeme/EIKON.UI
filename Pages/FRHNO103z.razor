    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Solo ejecutar la llamada una vez, cuando el componente se renderiza por primera vez
            //Token = await auth.GetTokenAsync();
            Token = auth.tkn;
            if (string.IsNullOrEmpty(Token))
            {
                Token = await auth.GetTokenAsync();
            }
            if (string.IsNullOrEmpty(Token))
            {
                nv.NavigateTo("/index");
            }
            api.SetToken(Token);
            StateHasChanged();  // Forzar un nuevo renderizado si es necesario
            //api.SetToken(Token);
            await CargarDatos();
        }
    }
    protected override async Task OnInitializedAsync()
    {
        DateTime currentDateTime = DateTime.Now;


        if (string.IsNullOrEmpty(Token))
        {
            //api.ObtenerTokenAsync();
            // Token = api.GetToken();
            // Token = await auth.GetTokenAsync();
            Token = auth.tkn;
            if (string.IsNullOrEmpty(Token))
            {
                //Token = await auth.GetTokenAsync();
                return;
            }
            api.SetToken(Token);
        }

        ApiBaseUrl = api.GetApiBaseUrl();

        var tipo = auth.tipo;

        await CargarDatos();
    }
    async Task CargarDatos()
    {

        if (Token != null)
        {
            ApiBaseUrl = api.GetApiBaseUrl();
            // data = await api.GetFrhpu010Dtos();
            trhwc010 = (List<Trhwc010Dto>)await api.GetTrhwc010Dtos();
           // data = (List<Trhgr010Dto>)await api.Trhgr010DtoGetAll(Token);
            trhwc010Selected = trhwc010.FirstOrDefault() ?? new Trhwc010Dto();
            await InvokeAsync(StateHasChanged);
        }

    }
