@page "/FRHNO103x"

@using EIKON.UI.Components
@using DevExpress.Blazor
@using System.Net.Http.Json
@using System.Net.Http.Headers
@using EIKON.UI.Interfaces
@using DevExpress.AspNetCore.Reporting
@using DevExpress.XtraReports.UI
@using System.ComponentModel.DataAnnotations

@layout MainLayout
@inject HttpClient HttpClient
@inject EIKON.UI.Services.EikonDataServices api
@inject EIKON.UI.Services.AuthenticationService auth
@inject NavigationManager nv
@inject IJSRuntime JS

<div class="page">
    <Breadcrumb Title="Tipos de Transacciones" BackUrl="/dash" />
    
    <div class="page-header">
        <div class="page-toolbar">
            <Toolbar formulario="FRHxxx999" OnClose="HandleClose" />
        </div>
    </div>
    @if (trhwc010Selected == null)

    {

        <p><em>Loading...</em></p>

    }

    else

    {

        <div class="form-container">
            <!-- Sección Superior - Información Básica -->
        <div class="basic-info-section">
            <!-- Primera Fila -->
            <div class="form-row">
                <div class="input-field">
                    <label>Código</label>
                    <DxTextBox @bind-Text="@trhwc010Selected.WcCodigo"
                               ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Never">
                        <Buttons>
                            <DxEditorButton IconCssClass="fi fi-rr-search" 
                                           Click="@OnSearchCodigoClick" />
                        </Buttons>
                    </DxTextBox>
                </div>
                <div class="input-field wide">
                    <label>Descripción</label>
                    <DxTextBox @bind-Text="@trhwc010Selected.WcDescri" />
                </div>
                <div class="toolbar-actions">
                    <DxButton IconCssClass="fi fi-rr-undo" 
                             CssClass="icon-btn secondary-btn" 
                             Click="@OnUndoClick" />
                    <DxButton IconCssClass="fi fi-rr-chart-line-up" 
                             CssClass="icon-btn info-btn" 
                             Click="@OnChartClick" />
                </div>
            </div>

            <!-- Segunda Fila -->
            <div class="form-row">
                <div class="input-field">
                    <label>Descrip. Corta</label>
                    <DxTextBox @bind-Text="@trhwc010Selected.WcExeNam" />
                </div>
                <div class="input-field">
                    <label>Alterno</label>
                    <DxTextBox @bind-Text="@trhwc010Selected.WcDescri" />
                </div>
                <div class="input-field">
                    <label>Etiqueta</label>
                    <DxComboBox Data="@EtiquetaList"
                                @bind-Value="@trhwc010Selected.WzOrdenal"
                                NullText="Seleccionar"
                               TextFieldName="Name" 
                               ValueFieldName="Id" />
                </div>
                <div class="toolbar-actions">
                    <DxButton IconCssClass="fi fi-rr-list-check" 
                             CssClass="icon-btn success-btn" 
                             Click="@OnListClick" />
                    <DxButton IconCssClass="fi fi-rr-menu-burger" 
                             CssClass="icon-btn warning-btn" 
                             Click="@OnMenuClick" />
                </div>
            </div>

            <!-- Tercera Fila - Radio Buttons y Orden/Prioridad -->
            <div class="form-row">
                <div class="radio-group-section">
                    <div class="radio-group">
                        <label class="group-title">Tipo</label>
                        <div class="radio-options">
                            <DxRadioGroup @bind-Value="@trhwc010Selected.WcTipoTr"
                                          Items="@TipoOptions" 
                                         ValueFieldName="Value"
                                         TextFieldName="Text"
                                        Layout="RadioGroupLayout.Horizontal" />
                        </div>
                    </div>
                    <div class="radio-group">
                        <label class="group-title">Estatus</label>
                        <div class="radio-options">
                            <DxRadioGroup @bind-Value="@trhwc010Selected.WcEstatus"
                                              Items="@EstatusOptions"
                                              ValueFieldName="Value"
                                         TextFieldName="Text"
                                          Layout="RadioGroupLayout.Horizontal" />
                        </div>
                    </div>
                </div>
                <div class="number-fields">
                    <div class="input-field small">
                        <label>Orden</label>
                        <DxSpinEdit @bind-Value="@trhwc010Selected.WcOrden" 
                                   MinValue="0" 
                                   MaxValue="999" />
                    </div>
                    <div class="input-field small">
                        <label>Prioridad</label>
                        <DxSpinEdit @bind-Value="@trhwc010Selected.WcPrioridad" 
                                   MinValue="0" 
                                   MaxValue="999" />
                    </div>
                </div>
            </div>
        </div>

        <!-- Sección Principal - Single Tab Layout -->
        <div class="main-section">
            <DxTabs @bind-ActiveTabIndex="@ActiveTabIndex" CssClass="main-tabs">
                <DxTabPage Text="Definición">
                    <div class="tab-content">
                        <div class="definition-layout">
                            <!-- Columna Izquierda - Definición -->
                            <div class="definition-left-column">
                                <div class="definition-group">
                                    <label class="group-title">Origen</label>
                                    <div class="checkbox-vertical-group">
                                        <DxCheckBox @bind-Checked="@OrigenCalculoOption">Cálculo</DxCheckBox>
                                        <DxCheckBox @bind-Checked="@OrigenManualOption">Manual</DxCheckBox>
                                        <DxCheckBox @bind-Checked="@OrigenFijoOption">Fijo</DxCheckBox>
                                    </div>
                                </div>

                                <div class="definition-group">
                                    <label class="group-title">Duración</label>
                                    <div class="checkbox-vertical-group">
                                        <DxCheckBox @bind-Checked="@DuracionPermanenteOption">Permanente</DxCheckBox>
                                        <DxCheckBox @bind-Checked="@DuracionAmortizableOption">Amortizable</DxCheckBox>
                                        <DxCheckBox @bind-Checked="@DuracionContratoOption">Contrato</DxCheckBox>
                                    </div>
                                </div>

                                <div class="definition-group">
                                    <div class="checkbox-options">
                                        <SNCheckBox Label="Infotep" @bind-Value="@trhwc010Selected.WcInfotep" />
                                        <SNCheckBox Label="Riesgo Laboral" @bind-Value="@trhwc010Selected.WcAcci" />
                                        <SNCheckBox Label="Transacción Afp" @bind-Value="@trhwc010Selected.WcIsrafp" />
                                        <SNCheckBox Label="Idss" @bind-Value="@trhwc010Selected.WcIdss" />
                                        <SNCheckBox Label="Usa C. Costos" @bind-Value="@trhwc010Selected.WcCentroc" />
                                        <SNCheckBox Label="Ajustar/Reclamar" @bind-Value="@trhwc010Selected.WcCentroc" />
                                        <SNCheckBox Label="Transacción ARS" @bind-Value="@trhwc010Selected.WcCentroc" />
                                        @* <SNCheckBox Label="Usa C. Costos" @bind-Value="@trhwc010Selected.WcCentroc" />
                                        <SNCheckBox Label="Usa C. Costos" @bind-Value="@trhwc010Selected.WcCentroc" />
                                        <SNCheckBox Label="Usa C. Costos" @bind-Value="@trhwc010Selected.WcCentroc" />
                                        <SNCheckBox Label="Usa C. Costos" @bind-Value="@trhwc010Selected.WcCentroc" />
                                        <DxCheckBox @bind-Checked="@InfetepOption">Infotep</DxCheckBox>
                                        <DxCheckBox @bind-Checked="@RiesgoLaboralOption">Riesgo Laboral</DxCheckBox>
                                        <DxCheckBox @bind-Checked="@TransaccionArsOption">Transacción Afp</DxCheckBox>
                                        <DxCheckBox @bind-Checked="@IdssOption">Idss</DxCheckBox>
                                        <DxCheckBox @bind-Checked="@UsaCostosOption">Usa C. Costos</DxCheckBox>
                                        <DxCheckBox @bind-Checked="@AjustarReclamarOption">Ajustar/Reclamar</DxCheckBox>
                                        <DxCheckBox @bind-Checked="@TransaccionArsOption2">Transacción ARS</DxCheckBox> *@
                                    </div>
                                </div>
                            </div>

                            <!-- Columna Central - ISR y Opciones -->
                            <div class="definition-center-column">
                                <div class="isr-section">
                                    <label>ISR</label>
                                    <DxTextBox @bind-Text="@IsrValue" 
                                              CssClass="isr-input" />
                                </div>

                                <div class="checkbox-options">
                                    <SNCheckBox @bind-Value="@trhwc010Selected.WcTisr" Label="Exención Mensual "/>
                                    <SNCheckBox @bind-Value="@trhwc010Selected.WcIsrproy" Label="No proyectar " />
                                    <SNCheckBox @bind-Value="@trhwc010Selected.WcPropose" Label="Proponer en generación " />
                                    <SNCheckBox @bind-Value="@trhwc010Selected.WcInvisib" Label="Transacción Invisible " />
                                    <SNCheckBox @bind-Value="@trhwc010Selected.WcIngreg" Label="Ingreso regular " />
                                    <SNCheckBox @bind-Value="@trhwc010Selected.WcNoisr" Label="No considerada para isr " />
                                    <SNCheckBox @bind-Value="@trhwc010Selected.WcInterfa" Label="En Interfaz " />
                                    <SNCheckBox @bind-Value="@trhwc010Selected.WcCambiar" Label="Cambiar en Verificación " />
                                </div>

                                <div class="calculation-options">
                                    <DxCheckBox @bind-Checked="@PresentarAcumuladoOption">Presentar Acumulado</DxCheckBox>
                                    <div class="radio-inline-group">
                                        <DxRadioGroup @bind-Value="@PresentarValue" 
                                                     Data="@PresentarOptions" 
                                                     ValueFieldName="Value"
                                                     TextFieldName="Text"
                                                     TData="RadioOption"
                                                     TValue="string"
                                                     Orientation="Orientation.Horizontal" />
                                    </div>
                                    <DxCheckBox @bind-Checked="@NeutralizaOption">Neutraliza</DxCheckBox>
                                    <DxCheckBox @bind-Checked="@NetoPeriodoOption">Neto Período</DxCheckBox>
                                    <DxCheckBox @bind-Checked="@ConsiderariaGastoOption">Consideraría gasto</DxCheckBox>
                                </div>
                            </div>
                            
                            <!-- Columna Derecha - Relaciones y Partidas -->
                            <div class="definition-right-column">
                                <!-- Sección de Relaciones -->
                                <div class="relations-compact">
                                    <label class="group-title">Relaciones</label>
                                    <div class="relation-links-vertical">
                                        <DxButton Text="Beneficio" 
                                                 CssClass="relation-btn-compact" 
                                                 Click="@OnBeneficioClick" />
                                        <DxButton Text="Tipo Plan" 
                                                 CssClass="relation-btn-compact" 
                                                 Click="@OnTipoPlanClick" />
                                        <DxButton Text="Plan Salud" 
                                                 CssClass="relation-btn-compact" 
                                                 Click="@OnPlanSaludClick" />
                                        <DxButton Text="Contabilidad" 
                                                 CssClass="relation-btn-compact" 
                                                 Click="@OnContabilidadClick" />
                                        <DxButton Text="Contratos" 
                                                 CssClass="relation-btn-compact" 
                                                 Click="@OnContratosClick" />
                                        <DxButton Text="Acciones" 
                                                 CssClass="relation-btn-compact" 
                                                 Click="@OnAccionesClick" />
                                        <DxButton Text="Asistencia" 
                                                 CssClass="relation-btn-compact" 
                                                 Click="@OnAsistenciaClick" />
                                    </div>
                                    
                                    <!-- Icono decorativo -->
                                    <div class="relation-icon-compact">
                                        <DxButton IconCssClass="fi fi-rr-settings-sliders" 
                                                 CssClass="icon-btn-medium info-btn" 
                                                 Click="@OnRelationSettingsClick" />
                                    </div>
                                </div>
                            </div>
                        </div>
                        
                        <!-- Sección Inferior - Partidas -->
                        <div class="partidas-bottom">
                            <div class="partidas-row">
                                <div class="input-field">
                                    <label>Partida Contraria</label>
                                    <DxTextBox @bind-Text="@PartidaContrariaValue"
                                              ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Never">
                                        <Buttons>
                                            <DxEditorButton IconCssClass="fi fi-rr-search" 
                                                           Click="@OnSearchPartidaClick" />
                                        </Buttons>
                                    </DxTextBox>
                                </div>
                                
                                <div class="input-field">
                                    <label>Complem/ISRneto</label>
                                    <DxTextBox @bind-Text="@ComplementIsrValue"
                                              ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Never">
                                        <Buttons>
                                            <DxEditorButton IconCssClass="fi fi-rr-search" 
                                                           Click="@OnSearchComplementClick" />
                                        </Buttons>
                                    </DxTextBox>
                                </div>
                                
                                <div class="input-field">
                                    <label>Si Genera desc</label>
                                    <DxComboBox Data="@GeneraDescList" 
                                               @bind-Value="@SelectedGeneraDesc" 
                                               NullText="Seleccionar"
                                               TextFieldName="Name" 
                                               ValueFieldName="Id" />
                                </div>
                            </div>
                        </div>
                    </div>
                </DxTabPage>
            </DxTabs>
        </div>
    </div>
    }
</div>

<style>
    /* Container principal */
    .form-container {
        display: flex;
        flex-direction: column;
        gap: 20px;
        margin-top: 10px;
    }

    /* Sección de información básica */
    .basic-info-section {
        display: flex;
        flex-direction: column;
        gap: 15px;
        padding: 20px;
        background-color: #f8f9fa;
    }

    /* Form rows */
    .form-row {
        display: flex;
        gap: 20px;
        align-items: flex-end;
    }

    /* Input fields */
    .input-field {
        display: flex;
        flex-direction: column;
        gap: 5px;
        flex: 1;
        min-width: 120px;
    }

    .input-field.wide {
        flex: 2;
    }

    .input-field.small {
        flex: 0 0 100px;
    }

    .input-field label {
        font-weight: 500;
        color: #333;
        font-size: 13px;
        margin-bottom: 5px;
    }

    /* Toolbar actions */
    .toolbar-actions {
        display: flex;
        gap: 8px;
        flex: 0 0 auto;
        align-items: flex-end;
        padding-bottom: 5px;
    }

    /* Radio groups */
    .radio-group-section {
        display: flex;
        gap: 30px;
        flex: 2;
    }

    .radio-group {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .group-title {
        font-weight: 600;
        color: #333;
        font-size: 13px;
        margin-bottom: 5px;
    }

    .radio-options {
        display: flex;
        gap: 15px;
    }

    .number-fields {
        display: flex;
        gap: 15px;
        flex: 1;
    }

    /* Main section with tabs */
    .main-section {
        background-color: white;
    }

    /* Tabs styling */
    .main-tabs .dx-tabs-nav-item.dx-tabs-nav-item-selected {
        background-color: #dc3545 !important;
        color: white !important;
        border-color: #dc3545 !important;
    }

    .main-tabs .dx-tabs-nav-item {
        background-color: #f8f9fa !important;
        color: #666 !important;
        border: 1px solid #e0e0e0 !important;
        padding: 12px 20px !important;
        font-weight: 500 !important;
    }

    .main-tabs .dx-tabs-nav-item:hover:not(.dx-tabs-nav-item-selected) {
        background-color: #e9ecef !important;
    }

    .main-tabs .dx-tabs-content {
        padding: 25px !important;
        border: none !important;
        min-height: 400px;
    }

    /* Tab content */
    .tab-content {
        height: 100%;
    }

    /* Definición tab - New Layout */
    .definition-layout {
        display: flex;
        gap: 25px;
        height: 100%;
        margin-bottom: 25px;
    }

    .definition-left-column {
        flex: 0 0 140px;
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    .definition-center-column {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 15px;
    }
    
    .definition-right-column {
        flex: 0 0 120px;
        display: flex;
        flex-direction: column;
    }

    .definition-group {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .checkbox-vertical-group {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .checkbox-options {
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    /* ISR section */
    .isr-section {
        display: flex;
        flex-direction: column;
        gap: 8px;
        margin-bottom: 20px;
    }

    .isr-input {
        max-width: 200px;
    }

    /* Calculation options */
    .calculation-options {
        display: flex;
        flex-direction: column;
        gap: 12px;
        margin-top: 20px;
    }

    .radio-inline-group {
        margin-left: 20px;
    }

    /* Partidas bottom section */
    .partidas-bottom {
        border-top: 1px solid #e0e0e0;
        padding-top: 20px;
        margin-top: 20px;
    }
    
    .partidas-row {
        display: flex;
        gap: 20px;
        align-items: flex-end;
    }

    /* Relations compact */
    .relations-compact {
        display: flex;
        flex-direction: column;
        gap: 8px;
        height: 100%;
    }

    .relation-links-vertical {
        display: flex;
        flex-direction: column;
        gap: 4px;
        flex: 1;
    }

    .relation-btn-compact {
        width: 100%;
        padding: 4px 8px;
        background-color: #f8f9fa;
        border: 1px solid #e0e0e0;
        color: #495057;
        font-weight: 400;
        font-size: 11px;
        transition: all 0.3s ease;
        text-align: left;
    }

    .relation-btn-compact:hover {
        background-color: #e9ecef;
        color: #dc3545;
    }

    .relation-icon-compact {
        display: flex;
        justify-content: center;
        margin-top: 8px;
    }

    .icon-btn-medium {
        width: 28px;
        height: 28px;
        min-width: 28px;
        font-size: 14px;
    }

    /* Botones */
    .icon-btn {
        width: 32px;
        height: 32px;
        min-width: 32px;
        padding: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 6px;
        transition: all 0.3s ease;
    }

    .secondary-btn {
        background-color: #6c757d;
        border-color: #6c757d;
        color: white;
    }

    .secondary-btn:hover {
        background-color: #5a6268;
        border-color: #545b62;
    }

    .info-btn {
        background-color: #17a2b8;
        border-color: #17a2b8;
        color: white;
    }

    .info-btn:hover {
        background-color: #138496;
        border-color: #117a8b;
    }

    .success-btn {
        background-color: #28a745;
        border-color: #28a745;
        color: white;
    }

    .success-btn:hover {
        background-color: #218838;
        border-color: #1e7e34;
    }

    .warning-btn {
        background-color: #ffc107;
        border-color: #ffc107;
        color: #212529;
    }

    .warning-btn:hover {
        background-color: #e0a800;
        border-color: #d39e00;
    }

    /* DevExpress Components */
    .dx-textbox,
    .dx-combobox,
    .dx-spin-edit {
        border-radius: 4px !important;
    }

    .dx-textbox-container,
    .dx-combobox-container,
    .dx-spin-edit-container {
        border: 1px solid #ced4da !important;
        border-radius: 4px !important;
    }

    .dx-textbox-container:focus-within,
    .dx-combobox-container:focus-within,
    .dx-spin-edit-container:focus-within {
        border-color: #dc3545 !important;
        box-shadow: 0 0 0 0.2rem rgba(220, 53, 69, 0.25) !important;
    }

    /* Radio buttons and checkboxes */
    .dx-radiobutton-checked .dx-radiobutton-icon {
        background-color: #dc3545 !important;
        border-color: #dc3545 !important;
    }

    .dx-checkbox-checked .dx-checkbox-icon {
        background-color: #dc3545 !important;
        border-color: #dc3545 !important;
    }

    .dx-radiobutton:hover .dx-radiobutton-icon,
    .dx-checkbox:hover .dx-checkbox-icon {
        border-color: #dc3545 !important;
    }

    /* Responsive Design */
    media (max-width: 1024px) {
        .definition-layout {
            flex-direction: column;
            gap: 20px;
        }

        .definition-left-column,
        .definition-right-column {
            flex: none;
        }
        
        .partidas-row {
            flex-direction: column;
            gap: 15px;
        }
    }

    media (max-width: 768px) {
        .basic-info-section {
            padding: 15px;
        }

        .form-row {
            flex-direction: column;
            gap: 15px;
        }

        .radio-group-section {
            flex-direction: column;
            gap: 20px;
        }

        .number-fields {
            flex-direction: row;
            justify-content: flex-start;
        }

        .main-tabs .dx-tabs-content {
            padding: 15px !important;
        }
        
        .definition-layout {
            flex-direction: column;
        }
        
        .partidas-row {
            flex-direction: column;
        }

        .relation-icon-compact {
            margin-top: 10px;
        }
    }

    media (max-width: 480px) {
        .form-container {
            gap: 15px;
        }

        .basic-info-section {
            padding: 15px;
        }

        .toolbar-actions {
            flex-direction: row;
            justify-content: center;
            gap: 5px;
        }

        .icon-btn {
            width: 28px;
            height: 28px;
            min-width: 28px;
        }

        .main-tabs .dx-tabs-content {
            min-height: 300px;
        }
    }
</style>

@code {

    // **- private string[] // **- ToolbarOptions = { "add", "save", "remove", "leave" };

    // Tab control
    private int ActiveTabIndex { get; set; } = 0;

    // Campos básicos
    private string CodigoValue { get; set; } = "";
    private string DescripcionValue { get; set; } = "";
    private string DescripcionCortaValue { get; set; } = "";
    private string AlternoValue { get; set; } = "";
    private int? SelectedEtiqueta { get; set; }
    private int OrdenValue { get; set; } = 0;
    private int PrioridadValue { get; set; } = 0;

    // Radio button values
    private string TipoValue { get; set; } = "Ingreso";
    private string EstatusValue { get; set; } = "Activo";

    // Definición - Opciones de origen
    private bool OrigenCalculoOption { get; set; } = false;
    private bool OrigenManualOption { get; set; } = false;
    private bool OrigenFijoOption { get; set; } = false;

    // Definición - Opciones de duración
    private bool DuracionPermanenteOption { get; set; } = false;
    private bool DuracionAmortizableOption { get; set; } = false;
    private bool DuracionContratoOption { get; set; } = false;

    // Definición - Otras opciones
    private bool InfetepOption { get; set; } = false;
    private bool RiesgoLaboralOption { get; set; } = false;
    private bool TransaccionArsOption { get; set; } = false;
    private bool TransaccionArsOption2 { get; set; } = false;
    private bool IdssOption { get; set; } = false;
    private bool UsaCostosOption { get; set; } = false;
    private bool AjustarReclamarOption { get; set; } = false;

    // Definición - ISR y cálculos
    private string IsrValue { get; set; } = "";
    private bool ExencionMensualOption { get; set; } = false;
    private bool NoProyectarOption { get; set; } = false;
    private bool ProponerGeneracionOption { get; set; } = false;
    private bool TransaccionInvisibleOption { get; set; } = false;
    private bool IngresoRegularOption { get; set; } = false;
    private bool NoConsideradaIsrOption { get; set; } = false;
    private bool EnInterinasOption { get; set; } = false;
    private bool CambiarVerificacionOption { get; set; } = false;
    private bool PresentarAcumuladoOption { get; set; } = false;
    private bool NeutralizaOption { get; set; } = false;
    private bool NetoPeriodoOption { get; set; } = false;
    private bool ConsiderariaGastoOption { get; set; } = false;
    private string PresentarValue { get; set; } = "Corriente";

    // Partidas
    private string PartidaContrariaValue { get; set; } = "";
    private string ComplementIsrValue { get; set; } = "";
    private int? SelectedGeneraDesc { get; set; }

    // Listas de datos
    private List<OptionItem> EtiquetaList = new List<OptionItem>
    {
        new OptionItem { Id = 1, Name = "Salario" },
