@page "/FRHCL108"
@layout MainLayout
@inject IJSRuntime JSRuntime

@inject HttpClient HttpClient

@inject EIKON.UI.Services.EikonDataServices api
@inject EIKON.UI.Services.AuthenticationService auth
@inject NavigationManager nv
<ConfirmDialog @ref="confirmDialog" Title="Confirmar Eliminación"
               Message="¿Seguro deseas eliminar esta categoria?"
               OnConfirm="OnConfirmDelete" />
<DxTabs ActiveTabIndex="@ActiveTabIndex" ActiveTabIndexChanged="@OnActiveTabIndexChanged">
        <DxTabPage Text="Formulario">

<div class="page">
    <Breadcrumb Title="Clase de Puesto" BackUrl="/dash" />
    
    <div class="page-header">
        <div class="page-toolbar">
          @*   <Toolbar formulario="FRHxxx999" OnClose="HandleClose" /> *@
                    <Toolbar formulario="FRHCL108" OnProccess="BuscarGrupo" OnAdd="Agregar" OnSave="Guarda" OnRemove="Eliminar" OnAudit="OnAuditPopup" OnClose="HandleClose" />

        </div>
    </div>
    @if (clases == null)

    {

        <p><em>Loading...</em></p>

    }

    else

    {

        <div class="form-container">
            <!-- Sección Principal -->
        <div class="main-section">
            <!-- Primera Fila -->
            <div class="form-row">
                <div class="input-field">
                    <label>Código Clase</label>
                    <DxTextBox @bind-Text="@editModel.NpCodigo"
                               ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Never" ReadOnly>
                        <Buttons>
                            <DxEditorButton IconCssClass="fi fi-rr-search" 
                                           Click="@OnSearchCodigoClick" />
                        </Buttons>
                    </DxTextBox>
                </div>  </div>

            <!-- Segunda Fila -->
            <div class="form-row">
                <div class="input-field wide">
                    <label>Nombre Clase</label>
                    <DxTextBox @bind-Text="@editModel.NpDescri" />
                </div>
            </div>

            <!-- Tercera Fila -->
            <div class="form-row">
                <div class="input-field">
                    <label>Próxima Clase</label>
                    <DxComboBox Data="clases"
                                ValueFieldName="NpCodigo"
                                TextFieldName="NpDescri"
                                ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                                EditFormat="{0} {1}"
                                SearchMode="@ListSearchMode.AutoSearch"
                                SearchFilterCondition="@ListSearchFilterCondition.Contains"
                                @bind-Value="editModel.NpProximo">
                        <Columns>
                            <DxListEditorColumn FieldName="NpCodigo" Caption="Código" />
                            <DxListEditorColumn FieldName="NpDescri" Caption="Descripcion" />
                        </Columns>
                    </DxComboBox>
                </div>
            </div>

            <!-- Cuarta Fila -->
            <div class="form-row">
                <div class="input-field wide">
                    <label>Categoría</label>
                    <DxComboBox Data="categorias"
                                ValueFieldName="CtCodigo"
                                TextFieldName="CtDescri"
                                ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                                EditFormat="{0} {1}"
                                SearchMode="@ListSearchMode.AutoSearch"
                                SearchFilterCondition="@ListSearchFilterCondition.Contains"
                                @bind-Value="editModel.CtCodigo">
                        <Columns>
                            <DxListEditorColumn FieldName="CtCodigo" Caption="Código" />
                            <DxListEditorColumn FieldName="CtDescri" Caption="Descripcion" />
                        </Columns>
                    </DxComboBox>
                </div>
                <div class="toolbar-right-actions">
                    <DxButton IconCssClass="fi fi-rr-settings" 
                             CssClass="icon-btn secondary-btn" 
                             Click="@OnSettingsClick" />
                    <DxButton IconCssClass="fi fi-rr-envelope" 
                             CssClass="icon-btn info-btn" 
                             Click="@OnMailClick" />
                </div>
            </div>

            <!-- Quinta Fila -->
            <div class="form-row">
                <div class="input-field wide">
                    <label>Grupo Ocupacional</label>
                    <DxComboBox Data="grupos"
                                ValueFieldName="GrCodigo"
                                TextFieldName="GrDescri"
                                ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                                EditFormat="{0} {1}"
                                SearchMode="@ListSearchMode.AutoSearch"
                                SearchFilterCondition="@ListSearchFilterCondition.Contains"
                                @bind-Value="editModel.GrCodigo">
                        <Columns>
                            <DxListEditorColumn FieldName="GrCodigo" Caption="Código" />
                            <DxListEditorColumn FieldName="GrDescri" Caption="Descripcion" />
                        </Columns>
                    </DxComboBox>
                </div>
            </div>

            <!-- Sexta Fila -->
            <div class="form-row">
                <div class="input-field wide">
                    <label>Perfil entrenamiento</label>
                    <DxComboBox Data="perfil"
                                ValueFieldName="PcCodigo"
                                TextFieldName="PcDescri"
                                ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                                EditFormat="{0} {1}"
                                SearchMode="@ListSearchMode.AutoSearch"
                                SearchFilterCondition="@ListSearchFilterCondition.Contains"
                                @bind-Value="editModel.PcCodigo">
                        <Columns>
                            <DxListEditorColumn FieldName="PcCodigo" Caption="Código" />
                            <DxListEditorColumn FieldName="PcDescri" Caption="Descripcion" />
                        </Columns>
                    </DxComboBox>
                </div>
            </div>

            <!-- Séptima Fila - Campos numéricos y fechas -->
            <div class="form-row">
                <div class="numeric-group">
                    <div class="input-field small">
                        <label>Puntos</label>
                        <DxSpinEdit @bind-Value="@editModel.NpPuntos" 
                                   MinValue="0" 
                                   MaxValue="999" />
                    </div>
                    <div class="input-field small">
                        <label>Prueba (Meses)</label>
                        <DxSpinEdit @bind-Value="@editModel.NpPeriodo" 
                                   MinValue="0" 
                                   MaxValue="12" />
                        
                    </div>
                  @*   <div class="input-field small">
                        
                        <DxSpinEdit @bind-Value="@MesesValue" 
                                   MinValue="0" 
                                   MaxValue="999" />
                    </div> *@
                </div>
            </div>

            <!-- Octava Fila - Fechas -->
            <div class="form-row">
                <div class="date-group">
                    <div class="input-field">
                        <label>Creado</label>
                        <DxDateEdit @bind-Date="@editModel.NpDesde" 
                                   NullText="dd/mm/yyyy">
                           @*  <Buttons>
                                <DxEditorButton IconCssClass="fi fi-rr-calendar" />
                            </Buttons> *@
                        </DxDateEdit>
                    </div>
                    <div class="input-field">
                        <label>Vigencia</label>
                        <DxDateEdit @bind-Date="@editModel.NpHasta" 
                                   NullText="dd/mm/yyyy">
                            @* <Buttons>
                                <DxEditorButton IconCssClass="fi fi-rr-calendar" />
                            </Buttons> *@
                        </DxDateEdit>
                    </div>
                    <div class="status-group">
                        @* <SNCheckBox @bind-Value="@editModel.NpEstatus" Label="Activo"/> *@
                        <DxCheckBox CheckType="CheckType.Checkbox" 
                                    @bind-Checked="@editModel.NpEstatus">
                                        Activo</DxCheckBox>
                    </div>
                </div>
            </div>
        </div>
    </div>
    }
</div>
    </DxTabPage>
        <DxTabPage Text="Lista de Clase de Puestos">
            <div class="header">
                <div style="display:flex;width:auto;gap:20px;">

                <Breadcrumb Title="Clase de Puestos" BackUrl="/dash" />



                </div>
                <Toolbar formulario="FRHCL108" OnClose="Cancel" />

            </div>
            <DxGrid Data="@clases" @ref="MyGrid"
                    CssClass="mw-1100"
                   
                    EditMode="GridEditMode.EditRow">
                <Columns>
                    <DxGridCommandColumn Width="60px" VisibleIndex="2">
                        <HeaderTemplate>
                            <a class="text-primary" @onclick="@(() => OpenForm())" style="text-decoration: none;" href="javascript:void(0);"><i class="fi fi-rr-plus"></i></a>
                        </HeaderTemplate>
                        <CellDisplayTemplate>

                            <a class="text-primary" @onclick="@(() => SelectRow((Trhnp010Dto)context.DataItem))" style="text-decoration: none;" href="javascript:void(0);"><i class="fi fi-rr-edit"></i></a>
                        </CellDisplayTemplate>
                    </DxGridCommandColumn>
                    <DxGridDataColumn Caption="Id" FieldName="NpCodigo" Width="100px" VisibleIndex="3" />
                    <DxGridDataColumn Caption="Descripción" FieldName="NpDescri" Width="300px" VisibleIndex="4" />

                    @* <DxGridDataColumn FieldName="OfCodigo" Caption="ID Oficina"/> *@
                    <DxGridDataColumn Caption="Categoría" FieldName="CtCodigo" Width="160px" VisibleIndex="5">
                        <EditSettings>
                            <DxComboBoxSettings Data="categorias"
                                                ValueFieldName="CtCodigo"
                                                TextFieldName="CtDescri"
                                                ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                                                EditFormat="{0} {1}">
                                <Columns>
                                    <DxListEditorColumn FieldName="CtCodigo" Caption="Código" />
                                    <DxListEditorColumn FieldName="CtDescri" Caption="Descripción" />

                                </Columns>
                            </DxComboBoxSettings>
                        </EditSettings>
                    </DxGridDataColumn>
                    @* <DxGridDataColumn FieldName="UbCodigo" Caption="ID Ubicac" /> *@
                    <DxGridDataColumn Caption="Grupo Ocupacional" FieldName="GrCodigo" Width="260px" VisibleIndex="6">
                        <EditSettings>
                            <DxComboBoxSettings Data="grupos"
                                                ValueFieldName="GrCodigo"
                                                TextFieldName="GrDescri"
                                                ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                                                EditFormat="{0} {1}">
                                <Columns>
                                    <DxListEditorColumn FieldName="GrCodigo" Caption="Código" />
                                    <DxListEditorColumn FieldName="GrDescri" Caption="Descripción" />

                                </Columns>
                            </DxComboBoxSettings>
                        </EditSettings>
                    </DxGridDataColumn>
                    @*             <DxGridDataColumn FieldName="JoNumber" Caption="Id Puesto" />
 *@            <DxGridDataColumn Caption="Perfil" FieldName="PcCodigo" Width="260px" VisibleIndex="7">
                        <EditSettings>
                            <DxComboBoxSettings Data="perfil"
                                                ValueFieldName="PcCodigo"
                                                TextFieldName="PcDescri"
                                                ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                                                EditFormat="{0} {1}">
                                <Columns>
                                    <DxListEditorColumn FieldName="PcCodigo" Caption="Código" />
                                    <DxListEditorColumn FieldName="PcDescri" Caption="Descripción" />

                                </Columns>
                            </DxComboBoxSettings>
                        </EditSettings>
                    </DxGridDataColumn>
                    <DxGridDataColumn FieldName="IdentityColumn" Width="150px" Caption="#">

                    </DxGridDataColumn>
                    <!-- Columna para el botón -->




                </Columns>
            </DxGrid>
        </DxTabPage>

</DxTabs>
<DxPopup @bind-Visible="@isPopupVisible"
         HeaderText="@popupTitle"
         ShowCloseButton="true"
         ShowFooter="true"
         Width="600px">
    <BodyTemplate Context="popupCtx">
        <EditForm Context="editpop" Model="@editModel">
            <DataAnnotationsValidator />
            <DxFormLayout>
                <DxFormLayoutItem Caption="Creado por:">
                    <DxTextBox @bind-Text="@editModel.CreatedBy" ReadOnly />
                </DxFormLayoutItem>
                <DxFormLayoutItem Caption="Creado el:">
                    <DxDateEdit @bind-Date="@editModel.CreatedOn" ReadOnly />
                </DxFormLayoutItem>
                <DxFormLayoutItem Caption="Modificado por:">
                    <DxTextBox @bind-Text="@editModel.ChangedBy" ReadOnly />
                </DxFormLayoutItem>
                <DxFormLayoutItem Caption="Modificado el:">
                    <DxDateEdit @bind-Date="@editModel.ChangedOn" ReadOnly />
                </DxFormLayoutItem>
            </DxFormLayout>
        </EditForm>
    </BodyTemplate>
    <FooterTemplate>
        @*         <DxButton RenderStyle="ButtonRenderStyle.Primary"
                  Text="Guardar"
                  Click="GuardarDatos" /> *@
        <DxButton Text="Salir" RenderStyle="ButtonRenderStyle.Secondary" Click="@OnCancelPopup" />
    </FooterTemplate>
</DxPopup>

<style>
    /* Container principal */
    .form-container {
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    /* Sección principal */
    .main-section {
        display: flex;
        flex-direction: column;
        gap: 18px;
    }

    /* Form rows */
    .form-row {
        display: flex;
        gap: 20px;
        align-items: flex-end;
        min-height: 60px;
    }

    /* Input fields */
    .input-field {
        display: flex;
        flex-direction: column;
        gap: 6px;
        flex: 1;
        min-width: 150px;
    }

    .input-field.wide {
        flex: 3;
    }

    .input-field.small {
        flex: 1;
        min-width: 120px;
    }

    .input-field label {
        font-weight: 500;
        color: #333;
        font-size: 13px;
        margin-bottom: 5px;
    }

    /* Toolbar actions */
    .toolbar-actions {
        display: flex;
        gap: 8px;
        flex: 0 0 auto;
        align-items: flex-end;
        padding-bottom: 5px;
    }

    .toolbar-right-actions {
        display: flex;
        gap: 8px;
        flex: 0 0 auto;
        align-items: flex-end;
        padding-bottom: 5px;
    }

    /* Grupos especializados */
    .numeric-group {
        display: flex;
        gap: 20px;
        flex: 1;
        width: 100%;
        align-items: flex-end;
    }

    .date-group {
        display: flex;
        gap: 20px;
        flex: 3;
        align-items: flex-end;
    }

    .status-group {
        display: flex;
        align-items: center;
    }

    /* Botones */
    .icon-btn {
        width: 36px;
        height: 36px;
        min-width: 36px;
        padding: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 6px;
        transition: all 0.3s ease;
    }

    .icon-btn:hover {
        transform: translateY(-1px);
    }

    .success-btn {
        background-color: #28a745;
        border-color: #28a745;
        color: white;
    }

    .success-btn:hover {
        background-color: #218838;
        border-color: #1e7e34;
    }

    .primary-btn {
        background-color: #dc3545;
        border-color: #dc3545;
        color: white;
    }

    .primary-btn:hover {
        background-color: #c82333;
        border-color: #bd2130;
    }

    .danger-btn {
        background-color: #dc3545;
        border-color: #dc3545;
        color: white;
    }

    .danger-btn:hover {
        background-color: #c82333;
        border-color: #bd2130;
    }

    .info-btn {
        background-color: #17a2b8;
        border-color: #17a2b8;
        color: white;
    }

    .info-btn:hover {
        background-color: #138496;
        border-color: #117a8b;
    }

    .warning-btn {
        background-color: #ffc107;
        border-color: #ffc107;
        color: #212529;
    }

    .warning-btn:hover {
        background-color: #e0a800;
        border-color: #d39e00;
    }

    .secondary-btn {
        background-color: #6c757d;
        border-color: #6c757d;
        color: white;
    }

    .secondary-btn:hover {
        background-color: #5a6268;
        border-color: #545b62;
    }

    /* DevExpress Components */
    .dx-textbox,
    .dx-spin-edit,
    .dx-date-edit {
        border-radius: 6px !important;
    }

    .dx-textbox-container,
    .dx-spin-edit-container,
    .dx-date-edit-container {
        border: 1px solid #ced4da !important;
        border-radius: 6px !important;
        transition: all 0.3s ease !important;
    }

    .dx-textbox-container:focus-within,
    .dx-spin-edit-container:focus-within,
    .dx-date-edit-container:focus-within {
        border-color: #dc3545 !important;
        box-shadow: 0 0 0 0.2rem rgba(220, 53, 69, 0.25) !important;
    }

    /* Checkboxes */
    .dx-checkbox {
        font-size: 14px;
        font-weight: 500;
    }

    .dx-checkbox-checked .dx-checkbox-icon {
        background-color: #dc3545 !important;
        border-color: #dc3545 !important;
    }

    .dx-checkbox:hover .dx-checkbox-icon {
        border-color: #dc3545 !important;
    }


    /* Responsive Design */
    media (max-width: 1024px) {
        .form-row {
            flex-wrap: wrap;
            gap: 15px;
        }

        .numeric-group,
        .date-group {
            flex-wrap: wrap;
            gap: 15px;
        }

        .toolbar-actions,
        .toolbar-right-actions {
            flex-wrap: wrap;
            gap: 6px;
        }
    }

    media (max-width: 768px) {
        .main-section {
            padding: 20px;
        }

        .form-row {
            flex-direction: column;
            gap: 15px;
            align-items: stretch;
        }

        .input-field {
            min-width: auto;
        }

        .input-field.wide {
            flex: 1;
        }

        .toolbar-actions,
        .toolbar-right-actions {
            justify-content: center;
            flex-direction: row;
            flex-wrap: wrap;
        }

        .numeric-group,
        .date-group {
            flex-direction: column;
            gap: 15px;
        }

        .status-group {
            padding-bottom: 0;
            justify-content: center;
        }
    }

    media (max-width: 480px) {
        .form-container {
            gap: 15px;
        }

        .main-section {
            padding: 15px;
            gap: 15px;
        }

        .icon-btn {
            width: 32px;
            height: 32px;
            min-width: 32px;
        }

        .toolbar-actions,
        .toolbar-right-actions {
            gap: 4px;
        }

        .form-row {
            min-height: auto;
        }
    }
</style>

@code {
    // **- private string[] // **- ToolbarOptions = { "add", "save", "remove", "leave" };
    public int ActiveTabIndex { get; set; } = 0; // Set initial active tab (0-indexed)
    public Alert2 alertInfo { get; set; } = new Alert2();
    private ConfirmDialog confirmDialog;
    void OnActiveTabIndexChanged(int newIndex)
    {
        ActiveTabIndex = newIndex;
        // You can add logic here to handle tab changes, e.g., load data based on the selected tab.
    }
    // Campos del formulario
    private List<Trhnp010Dto> clases { get; set; }
    private Trhnp010Dto editModel { get; set; }
    
    private List<Trhgr010Dto> grupos { get; set; }
    private Trhgr010Dto grupoSeleccionado { get; set; }

    private List<Trhct010Dto> categorias { get; set; }
    private Trhct010Dto categoriaSeleccionada { get; set; }

    private List<Trhpc000Dto> perfil { get; set; }
    private Trhpc000Dto perfilSeleccionado { get; set; }

    public string Token { get; set; } = "";
    public string ApiBaseUrl { get; set; } = "";
    
    private bool IsNewRecord = false;
    private bool isPopupVisible = false;
    private string popupTitle = "Grupo Ocupacional";
    DxGrid? MyGrid;

    private string CodigoClaseValue { get; set; } = "";
    private string NombreClaseValue { get; set; } = "";
    private string ProximaClaseValue { get; set; } = "";
    private string CategoriaValue { get; set; } = "";
    private string GrupoOcupacionalValue { get; set; } = "";
    private string PerfilEntrenamientoValue { get; set; } = "";
    
    // Campos numéricos
    private int PuntosValue { get; set; } = 0;
    private int PruebaValue { get; set; } = 0;
    private int MesesValue { get; set; } = 0;
    
    // Campos de fecha
    private DateTime? CreadoValue { get; set; } = DateTime.Now;
    private DateTime? VigenciaValue { get; set; }
    
    // Opciones de checkbox
    private bool ActivoOption { get; set; } = true;
    
    // Event handlers
    private void OnSearchCodigoClick() => Console.WriteLine("Buscar código clase");
    private void OnAddClick() => Console.WriteLine("Agregar nuevo");
    private void OnSaveClick() => Console.WriteLine("Guardar");
    private void OnDeleteClick() => Console.WriteLine("Eliminar");
    private void OnHomeClick() => Console.WriteLine("Inicio");
    private void OnRefreshClick() => Console.WriteLine("Actualizar");
    private void OnSearchProximaClick() => Console.WriteLine("Buscar próxima clase");
    private void OnSettingsClick() => Console.WriteLine("Configuración");
    private void OnMailClick() => Console.WriteLine("Correo");
    
    private async Task HandleClose()
    {
        await JSRuntime.InvokeVoidAsync("alert", "¡Clase de Puesto guardada!");
    }
    protected void Agregar()
    {
        editModel = new Trhnp010Dto();
        editModel.EmEmpresa = "01";
        // alertInfo.Show("Crear Nuevo Grupo Ocupacional!!!");
        // editModel.IdentityColumn = 0;
        // editModel.CreatedBy = "N";
        // editModel.CreatedOn = DateTime.Today;
        // editModel.ChangedOn = DateTime.Today;
        // editModel.ChangedBy = "N";
        // StateHasChanged();
    }

    protected async Task Guarda()
    {
        try
        {

            if (editModel.IdentityColumn == 0)
            {   
                editModel.CreatedBy = auth.userId.ToString().Trim();
                editModel.CreatedOn = DateTime.Now;
                editModel.ChangedBy = auth.userId;
                editModel.ChangedOn = DateTime.Now;
                var ret0 = await api.npAddAsync(editModel, Token);
                await CargarDatos();
                ActiveTabIndex = 1; // Cambiar a la pestaña de busqueda de oficinas
                //StateHasChanged();
                alertInfo.Show("Agregado con exito!!!", "success");
            }
            else
            {
                editModel.ChangedBy = auth.userId;
                editModel.ChangedOn = DateTime.Now;
                var ret = await api.npUpdateAsync(editModel, Token);
                ActiveTabIndex = 1; // Cambiar a la pestaña de busqueda de oficinas
                //StateHasChanged();
                alertInfo.Show("Modificado con exito!!!", "success");
            }
        }
        catch (Exception ex)
        {
            ActiveTabIndex = 1;
           // StateHasChanged();
            Console.Write("Esto es un error al guardar..." + ex.Message);
        }
    }

    protected void Eliminar()
    {
        confirmDialog.Show();
    }

    void BuscarGrupo()
    {
        ActiveTabIndex = 1; // Cambiar a la pestaña de busqueda de oficinas
    }

    private void OnCancelPopup()
    {
        isPopupVisible = false;
    }

    private void OnAuditPopup()
    {
        isPopupVisible = true;
    }
    private async Task OnConfirmDelete(bool confirmed)
    {
        if (confirmed)
        {
            try
            {
                // Lógica de eliminación si el usuario confirma
                editModel.NpEstatus = false;
                var ret = await api.npUpdateAsync(editModel, Token);
                ActiveTabIndex = 1; // Cambiar a la pestaña de busqueda de oficinas
                //StateHasChanged();
            }
            catch (Exception ex)
            {
                ActiveTabIndex = 1; // Cambiar a la pestaña de busqueda de oficinas
                //StateHasChanged();
                Console.WriteLine("Error al eliminar..." + ex.Message);
            }
        }
        else
        {
            alertInfo.Show("Eliminación cancelada");
        }
    }
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Solo ejecutar la llamada una vez, cuando el componente se renderiza por primera vez
            //Token = await auth.GetTokenAsync();
            Token = auth.tkn;
            if (string.IsNullOrEmpty(Token))
            {
                Token = await auth.GetTokenAsync();
            }
            if (string.IsNullOrEmpty(Token))
            {
                nv.NavigateTo("/index");
            }
            api.SetToken(Token);
            auth.SetToken(Token);   
            //StateHasChanged();  // Forzar un nuevo renderizado si es necesario
            //api.SetToken(Token);
            await CargarDatos();
        }
    }
    private void OpenForm()
    {
        // SelectedItem = item;
        nv.NavigateTo("/FRHCL108");

    }
    private async Task SelectRow(Trhnp010Dto ofic)
    {


        editModel = ofic;
        ActiveTabIndex = 0;


    }
    private void Cancel()
    {
        //alertInfo.Show("Cancelando Busqueda!!!", "warning");
        ActiveTabIndex = 0;
    }
    async Task OnEditModelSaving(GridEditModelSavingEventArgs e)
    {
        if (e.IsNew)
        {
            nv.NavigateTo("/FRHCL108");
            
        }
