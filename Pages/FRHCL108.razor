    async Task CargarDatos()
    {
        if (Token != null)
        {
            ApiBaseUrl = api.GetApiBaseUrl();
            HttpClient.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", Token);
            clases = await api.Trhnp010DtoGetAll(Token);
            editModel = clases.FirstOrDefault();
            categorias = await api.Trhct010DtoGetAll(Token);
            categoriaSeleccionada = categorias.FirstOrDefault();
            grupos = await api.Trhgr010DtoGetAll(Token);
            grupoSeleccionado = grupos.FirstOrDefault();
            perfil = await api.Trhpc000DtoGetAll(Token);
            perfilSeleccionado = perfil.FirstOrDefault();
