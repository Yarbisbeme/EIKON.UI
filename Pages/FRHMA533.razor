@page "/FRHMA533"

@using EIKON.UI.Components
@using DevExpress.Blazor
@using System.Net.Http.Json
@using System.Net.Http.Headers
@using EIKON.UI.Interfaces
@using DevExpress.AspNetCore.Reporting
@using DevExpress.XtraReports.UI
@using System.ComponentModel.DataAnnotations

@layout MainLayout
@inject HttpClient HttpClient
@inject EIKON.UI.Services.EikonDataServices api
@inject EIKON.UI.Services.AuthenticationService auth
@inject NavigationManager nv
@inject IJSRuntime JS

<div class="page">
    <Breadcrumb Title="FRHMA533 - Encabezados" BackUrl="/dash" />
    
    <div class="page-header">
        <div class="page-toolbar">
            <Toolbar formulario="FRHxxx999" OnClose="HandleClose" />
        </div>
    </div>

    <div class="form-container">
        <!-- Primera Fila - Código y Descripción -->
        <div class="form-row">
            <div class="input-field">
                <label>Código</label>
                <DxTextBox @bind-Text="@CodigoValue"
                           ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Never">
                    <Buttons>
                        <DxEditorButton IconCssClass="fi fi-rr-search" 
                                       Click="@OnSearchCodigoClick" />
                    </Buttons>
                </DxTextBox>
            </div>
            <div class="input-field wide">
                <label>Descripción</label>
                <DxTextBox @bind-Text="@DescripcionValue" />
            </div>
        </div>

        <!-- Segunda Fila - Tipo Transacción -->
        <div class="form-row">
            <div class="tipo-transaccion-section">
                <label class="section-title">Tipo Transacción</label>
                <div class="radio-options">
                    <DxRadioGroup @bind-Value="@TipoTransaccionValue" 
                                 TData="string"
                                 TValue="string"
                                 Orientation="Orientation.Horizontal">
                        <Items>
                            <DxRadioGroupItem Text="Ingreso" Value="@("Ingreso")" />
                            <DxRadioGroupItem Text="Deducción" Value="@("Deduccion")" />
                        </Items>
                    </DxRadioGroup>
                </div>
            </div>
        </div>

        <!-- Grid Section -->
        <div class="grid-section">
            <DxGrid Data="@EncabezadosData" CssClass="custom-grid">
                <Columns>
                    <DxGridDataColumn FieldName="Codigo" Caption="Código" Width="200px" />
                    <DxGridDataColumn FieldName="Descripcion" Caption="Descripción" Width="100%" />
                </Columns>
            </DxGrid>
        </div>
    </div>
</div>

<style>
    /* Container principal */
    .form-container {
        display: flex;
        flex-direction: column;
        gap: 25px;
        padding: 20px 0;
        width: 100%;
    }

    /* Form rows */
    .form-row {
        display: flex;
        gap: 20px;
        align-items: flex-end;
        min-height: 60px;
    }

    /* Input fields */
    .input-field {
        display: flex;
        flex-direction: column;
        gap: 6px;
        flex: 1;
        min-width: 150px;
    }

    .input-field.wide {
        flex: 3;
    }

    .input-field label {
        font-weight: 500;
        color: #333;
        font-size: 13px;
        margin-bottom: 5px;
    }

    /* Tipo Transacción section */
    .tipo-transaccion-section {
        display: flex;
        flex-direction: column;
        gap: 12px;
        flex: 1;
    }

    .section-title {
        font-weight: 600;
        color: #333;
        font-size: 14px;
        margin-bottom: 8px;
    }

    .radio-options {
        display: flex;
        gap: 25px;
        align-items: center;
        flex-wrap: wrap;
    }

    /* Grid section */
    .grid-section {
        margin-top: 20px;
        border: 1px solid #dee2e6;
        border-radius: 8px;
        overflow: hidden;
        min-height: 400px;
    }

    .custom-grid {
        border: none;
        border-radius: 0;
        min-height: 400px;
    }

    /* DevExpress Components */
    .dx-textbox {
        border-radius: 6px !important;
    }

    .dx-textbox-container {
        border: 1px solid #ced4da !important;
        border-radius: 6px !important;
        transition: all 0.3s ease !important;
    }

    .dx-textbox-container:focus-within {
        border-color: #dc3545 !important;
        box-shadow: 0 0 0 0.2rem rgba(220, 53, 69, 0.25) !important;
    }

    /* Radio buttons */
    .dx-radiobutton {
        font-size: 14px;
        font-weight: 500;
        margin-right: 15px;
    }

    .dx-radiobutton-checked .dx-radiobutton-icon {
        background-color: #dc3545 !important;
        border-color: #dc3545 !important;
    }

    .dx-radiobutton:hover .dx-radiobutton-icon {
        border-color: #dc3545 !important;
    }

    /* Search button styling */
    .dx-editor-button {
        background-color: #6c757d !important;
        border-color: #6c757d !important;
        color: white !important;
        border-radius: 4px !important;
    }

    .dx-editor-button:hover {
        background-color: #5a6268 !important;
        border-color: #545b62 !important;
    }

    /* Grid específico */
    .dx-grid-header-content {
        background-color: #f8f9fa !important;
        font-weight: 600 !important;
        color: #333 !important;
        border-bottom: 2px solid #dee2e6 !important;
    }

    .dx-grid-data-row:nth-child(even) {
        background-color: #f8f9fa !important;
    }

    .dx-grid-data-row:hover {
        background-color: rgba(220, 53, 69, 0.05) !important;
    }

    .dx-grid-data-row td {
        padding: 12px 8px !important;
        border-bottom: 1px solid #e9ecef !important;
    }

    /* Grid container */
    .dx-grid-container {
        border: none !important;
    }

    /* Responsive Design */
    media (max-width: 1024px) {
        .form-container {
            padding: 15px;
            gap: 20px;
        }

        .form-row {
            flex-wrap: wrap;
            gap: 15px;
        }

        .radio-options {
            gap: 18px;
        }

        .grid-section {
            min-height: 350px;
        }
    }

    media (max-width: 768px) {
        .form-container {
            padding: 15px;
            gap: 15px;
        }

        .form-row {
            flex-direction: column;
            gap: 15px;
            align-items: stretch;
            min-height: auto;
        }

        .input-field {
            min-width: auto;
        }

        .input-field.wide {
            flex: 1;
        }

        .radio-options {
            gap: 15px;
        }

        .grid-section {
            min-height: 300px;
        }
    }

    media (max-width: 480px) {
        .form-container {
            gap: 12px;
            padding: 12px;
        }

        .form-row {
            gap: 12px;
        }

        .radio-options {
            gap: 10px;
        }

        .dx-radiobutton {
            margin-right: 8px;
        }

        .grid-section {
            min-height: 250px;
        }

        .section-title {
            font-size: 13px;
        }
    }
</style>

@code {
    // **- private string[] // **- ToolbarOptions = { "add", "save", "remove", "leave" };
    
    // Campos del formulario
    private string CodigoValue { get; set; } = "";
    private string DescripcionValue { get; set; } = "";
    private string TipoTransaccionValue { get; set; } = "Ingreso";

    // Datos del grid
    private List<EncabezadoItem> EncabezadosData = new List<EncabezadoItem>
    {
        new EncabezadoItem { Codigo = "ING001", Descripcion = "Sueldo Base" },
        new EncabezadoItem { Codigo = "ING002", Descripcion = "Horas Extras" },
        new EncabezadoItem { Codigo = "ING003", Descripcion = "Bonificaciones" },
        new EncabezadoItem { Codigo = "DED001", Descripcion = "Seguro Social" },
        new EncabezadoItem { Codigo = "DED002", Descripcion = "Impuesto sobre la Renta" },
        new EncabezadoItem { Codigo = "DED003", Descripcion = "Préstamos" }
    };

    public class RadioOption
    {
        public string Value { get; set; } = "";
        public string Text { get; set; } = "";
    }

    public class EncabezadoItem
    {
        public string Codigo { get; set; } = "";
        public string Descripcion { get; set; } = "";
    }
    
    // Event handlers
    private void OnSearchCodigoClick() => Console.WriteLine("Buscar código");
    
    private async Task HandleClose()
    {
        await JS.InvokeVoidAsync("alert", "¡Encabezado guardado exitosamente!");
    }
}