@page "/FRHNO210"

@using EIKON.UI.Components
@using DevExpress.Blazor
@using System.Net.Http.Json
@using System.Net.Http.Headers
@using EIKON.UI.Interfaces
@using DevExpress.AspNetCore.Reporting
@using DevExpress.XtraReports.UI
@using System.ComponentModel.DataAnnotations

@layout MainLayout
@inject HttpClient HttpClient
@inject EIKON.UI.Services.EikonDataServices api
@inject EIKON.UI.Services.AuthenticationService auth
@inject NavigationManager nv
@inject IJSRuntime JS

<div class="page">
    <Breadcrumb Title="FRHNO210 - Generación de Entradas Contables" BackUrl="/dash" />
    
    <div class="page-header">
        <div class="page-toolbar">
            <Toolbar formulario="FRHxxx999" OnClose="HandleClose" />
        </div>
    </div>

    <div class="form-container">
        <!-- Primera Fila - Año -->
        <div class="form-row">
            <div class="input-field">
                <label>Año</label>
                <DxComboBox Data="@AnosList" 
                           @bind-Value="@SelectedAno" 
                           NullText="Seleccionar año"
                           TextFieldName="Name" 
                           ValueFieldName="Id" />
            </div>
        </div>

        <!-- Segunda Fila - Nómina -->
        <div class="form-row">
            <div class="input-field wide">
                <label>Nómina</label>
                <DxComboBox Data="@NominasList" 
                           @bind-Value="@SelectedNomina" 
                           NullText="Seleccionar nómina"
                           TextFieldName="Name" 
                           ValueFieldName="Id" />
            </div>
        </div>

        <!-- Tercera Fila - Cierres -->
        <div class="form-row">
            <div class="input-field wide">
                <label>Cierres</label>
                <DxComboBox Data="@CierresList" 
                           @bind-Value="@SelectedCierre" 
                           NullText="Seleccionar cierre"
                           TextFieldName="Name" 
                           ValueFieldName="Id" />
            </div>
        </div>

        <!-- Cuarta Fila - Período -->
        <div class="form-row">
            <div class="periodo-group">
                <div class="input-field">
                    <label>Período(s)</label>
                    <div class="periodo-options">
                        <DxRadioGroup @bind-Value="@PeriodoValue" 
                                     Data="@PeriodoOptions" 
                                     ValueFieldName="Value"
                                     TextFieldName="Text"
                                     TData="RadioOption"
                                     TValue="string"
                                     Orientation="Orientation.Horizontal" />
                    </div>
                </div>
            </div>
        </div>

        <!-- Quinta Fila - Todos -->
        <div class="form-row">
            <div class="checkbox-section">
                <DxCheckBox @bind-Checked="@TodosOption">Todos</DxCheckBox>
            </div>
            <div class="input-field wide">
                <DxTextBox @bind-Text="@TodosValue" 
                          NullText="Especificar criterios..." />
            </div>
            <div class="toolbar-actions">
                <DxButton IconCssClass="fi fi-rr-search" 
                         CssClass="icon-btn secondary-btn" 
                         Click="@OnSearchTodosClick" />
            </div>
        </div>

        <!-- Sexta Fila - Transacciones -->
        <div class="form-row">
            <div class="transacciones-section">
                <label class="group-title">Transacciones</label>
                <div class="transacciones-options">
                    <DxCheckBox @bind-Checked="@TodasTransaccionesOption">Todas</DxCheckBox>
                    <DxCheckBox @bind-Checked="@NegacionTransaccionesOption">Negación</DxCheckBox>
                </div>
            </div>
        </div>

        <!-- Séptima Fila - Campo de transacciones -->
        <div class="form-row">
            <div class="input-field wide">
                <DxTextBox @bind-Text="@TransaccionesValue" 
                          NullText="Especificar transacciones..." />
            </div>
            <div class="toolbar-actions">
                <DxButton IconCssClass="fi fi-rr-search" 
                         CssClass="icon-btn secondary-btn" 
                         Click="@OnSearchTransaccionesClick" />
            </div>
        </div>

        <!-- Novena Fila - Nombre -->
        <div class="form-row">
            <div class="input-field wide">
                <label>Nombre</label>
                <DxTextBox @bind-Text="@NombreValue" 
                          NullText="Nombre del archivo..." />
            </div>
            <div class="nombre-buttons">
                <DxButton IconCssClass="fi fi-rr-check" 
                         CssClass="icon-btn success-btn" 
                         Click="@OnCheckNombreClick" />
                <DxButton IconCssClass="fi fi-rr-cross" 
                         CssClass="icon-btn danger-btn" 
                         Click="@OnClearNombreClick" />
            </div>
        </div>
    </div>
</div>

<style>
    /* Container principal */
    .form-container {
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    /* Form rows */
    .form-row {
        display: flex;
        gap: 20px;
        align-items: flex-end;
        min-height: 60px;
    }

    /* Input fields */
    .input-field {
        display: flex;
        flex-direction: column;
        gap: 6px;
        flex: 1;
        min-width: 150px;
    }

    .input-field.wide {
        flex: 3;
    }

    .input-field label {
        font-weight: 500;
        color: #333;
        font-size: 13px;
        margin-bottom: 5px;
    }

    /* Período específico */
    .periodo-group {
        display: flex;
        flex-direction: column;
        gap: 8px;
        flex: 1;
    }

    .periodo-options {
        display: flex;
        gap: 20px;
    }

    /* Checkbox section */
    .checkbox-section {
        display: flex;
        align-items: center;
        flex: 0 0 80px;
        padding-bottom: 5px;
    }

    /* Transacciones section */
    .transacciones-section {
        display: flex;
        flex-direction: column;
        gap: 8px;
        flex: 1;
    }

    .group-title {
        font-weight: 600;
        color: #333;
        font-size: 13px;
        margin-bottom: 5px;
    }

    .transacciones-options {
        display: flex;
        gap: 20px;
    }

    /* Disco section */
    .disco-section {
        display: flex;
        flex-direction: column;
        gap: 8px;
        flex: 1;
        align-items: center;
    }

    .disco-buttons {
        display: flex;
        gap: 8px;
        justify-content: center;
    }

    .disco-label {
        font-weight: 500;
        color: #333;
        font-size: 13px;
        text-align: center;
    }

    /* Nombre buttons */
    .nombre-buttons {
        display: flex;
        gap: 8px;
        flex: 0 0 auto;
        align-items: flex-end;
        padding-bottom: 5px;
    }

    /* Toolbar actions */
    .toolbar-actions {
        display: flex;
        gap: 8px;
        flex: 0 0 auto;
        align-items: flex-end;
        padding-bottom: 5px;
    }

    /* Botones */
    .icon-btn {
        width: 36px;
        height: 36px;
        min-width: 36px;
        padding: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 6px;
        transition: all 0.3s ease;
    }

    .icon-btn:hover {
        transform: translateY(-1px);
    }

    .success-btn {
        background-color: #28a745;
        border-color: #28a745;
        color: white;
    }

    .success-btn:hover {
        background-color: #218838;
        border-color: #1e7e34;
    }

    .primary-btn {
        background-color: #dc3545;
        border-color: #dc3545;
        color: white;
    }

    .primary-btn:hover {
        background-color: #c82333;
        border-color: #bd2130;
    }

    .danger-btn {
        background-color: #dc3545;
        border-color: #dc3545;
        color: white;
    }

    .danger-btn:hover {
        background-color: #c82333;
        border-color: #bd2130;
    }

    .info-btn {
        background-color: #17a2b8;
        border-color: #17a2b8;
        color: white;
    }

    .info-btn:hover {
        background-color: #138496;
        border-color: #117a8b;
    }

    .warning-btn {
        background-color: #ffc107;
        border-color: #ffc107;
        color: #212529;
    }

    .warning-btn:hover {
        background-color: #e0a800;
        border-color: #d39e00;
    }

    .secondary-btn {
        background-color: #6c757d;
        border-color: #6c757d;
        color: white;
    }

    .secondary-btn:hover {
        background-color: #5a6268;
        border-color: #545b62;
    }

    /* DevExpress Components */
    .dx-textbox,
    .dx-combobox,
    .dx-spin-edit {
        border-radius: 6px !important;
    }

    .dx-textbox-container,
    .dx-combobox-container,
    .dx-spin-edit-container {
        border: 1px solid #ced4da !important;
        border-radius: 6px !important;
        transition: all 0.3s ease !important;
    }

    .dx-textbox-container:focus-within,
    .dx-combobox-container:focus-within,
    .dx-spin-edit-container:focus-within {
        border-color: #dc3545 !important;
        box-shadow: 0 0 0 0.2rem rgba(220, 53, 69, 0.25) !important;
    }

    /* Radio buttons and checkboxes */
    .dx-radiobutton-checked .dx-radiobutton-icon {
        background-color: #dc3545 !important;
        border-color: #dc3545 !important;
    }

    .dx-checkbox-checked .dx-checkbox-icon {
        background-color: #dc3545 !important;
        border-color: #dc3545 !important;
    }

    .dx-radiobutton:hover .dx-radiobutton-icon,
    .dx-checkbox:hover .dx-checkbox-icon {
        border-color: #dc3545 !important;
    }

    /* Responsive Design */
    media (max-width: 1024px) {
        .form-container {
            max-width: 100%;
        }
        
        .form-row {
            flex-wrap: wrap;
            gap: 15px;
        }

        .disco-buttons {
            flex-wrap: wrap;
        }
    }

    media (max-width: 768px) {
        .form-container {
            padding: 15px;
        }

        .form-row {
            flex-direction: column;
            gap: 15px;
            align-items: stretch;
            min-height: auto;
        }

        .input-field {
            min-width: auto;
        }

        .input-field.wide {
            flex: 1;
        }

        .checkbox-section {
            flex: 1;
            padding-bottom: 0;
        }

        .disco-section {
            align-items: stretch;
        }

        .periodo-options,
        .transacciones-options {
            flex-direction: column;
            gap: 10px;
        }
    }

    media (max-width: 480px) {
        .form-container {
            gap: 15px;
            padding: 15px;
        }

        .form-row {
            gap: 12px;
        }

        .icon-btn {
            width: 32px;
            height: 32px;
            min-width: 32px;
        }

        .disco-buttons,
        .toolbar-actions,
        .nombre-buttons {
            gap: 4px;
        }
    }
</style>

@code {
    // **- private string[] // **- ToolbarOptions = { "add", "save", "remove", "leave" };
    
    // Campos del formulario
    private int? SelectedAno { get; set; } = 2025;
    private int? SelectedNomina { get; set; }
    private int? SelectedCierre { get; set; }
    private string PeriodoValue { get; set; } = "Abierto";
    private bool TodosOption { get; set; } = true;
    private string TodosValue { get; set; } = "";
    private bool TodasTransaccionesOption { get; set; } = true;
    private bool NegacionTransaccionesOption { get; set; } = false;
    private string TransaccionesValue { get; set; } = "";
    private string NombreValue { get; set; } = "";

    // Listas de datos
    private List<OptionItem> AnosList = new List<OptionItem>
    {
        new OptionItem { Id = 2023, Name = "2023" },
        new OptionItem { Id = 2024, Name = "2024" },
        new OptionItem { Id = 2025, Name = "2025" }
    };

    private List<OptionItem> NominasList = new List<OptionItem>
    {
        new OptionItem { Id = 1, Name = "Nómina General" },
        new OptionItem { Id = 2, Name = "Nómina Especial" },
        new OptionItem { Id = 3, Name = "Nómina Quincenal" }
    };

    private List<OptionItem> CierresList = new List<OptionItem>
    {
        new OptionItem { Id = 1, Name = "Cierre Mensual" },
        new OptionItem { Id = 2, Name = "Cierre Quincenal" },
        new OptionItem { Id = 3, Name = "Cierre Anual" }
    };

    private List<RadioOption> PeriodoOptions = new List<RadioOption>
    {
        new RadioOption { Value = "Abierto", Text = "Abierto" },
        new RadioOption { Value = "Cerrado", Text = "Cerrado" }
    };

    public class OptionItem
    {
        public int Id { get; set; }
        public string Name { get; set; } = "";
    }

    public class RadioOption
    {
        public string Value { get; set; } = "";
        public string Text { get; set; } = "";
    }
    
    // Event handlers
    private void OnSearchTodosClick() => Console.WriteLine("Buscar todos");
    private void OnSearchTransaccionesClick() => Console.WriteLine("Buscar transacciones");
    private void OnSearchDiscoClick() => Console.WriteLine("Buscar disco");
    private void OnRefreshDiscoClick() => Console.WriteLine("Actualizar disco");
    private void OnSettingsDiscoClick() => Console.WriteLine("Configurar disco");
    private void OnDiskClick() => Console.WriteLine("Disco");
    private void OnCheckNombreClick() => Console.WriteLine("Confirmar nombre");
    private void OnClearNombreClick() => Console.WriteLine("Limpiar nombre");
    
    private async Task HandleClose()
    {
        await JS.InvokeVoidAsync("alert", "¡Entradas contables generadas!");
    }
}