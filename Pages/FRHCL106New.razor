    }

    media (max-width: 768px) {
        .form-container {
            padding: 15px;
            gap: 15px;
        }

        .form-row {
            flex-direction: column;
            gap: 15px;
            align-items: stretch;
            min-height: auto;
        }

        .input-field {
            min-width: auto;
        }

        .input-field.wide {
            flex: 1;
        }

        .checkbox-field {
            min-height: auto;
            padding-top: 10px;
        }

        .date-with-button {
            flex-direction: column;
            align-items: stretch;
            gap: 10px;
        }

        .date-btn {
            width: 100% !important;
            min-width: auto !important;
        }

        .grid-section {
            margin-top: 10px;
            overflow-x: auto;
        }

        .grupos-grid {
            min-width: 500px;
        }

        .grid-actions {
            flex-direction: column;
            gap: 10px;
        }

        .grid-actions .dx-button {
            width: 100%;
            min-width: auto;
        }
    }

    media (max-width: 480px) {
        .form-container {
            gap: 12px;
            padding: 12px;
        }

        .form-row {
            gap: 12px;
        }

        .grid-section {
            margin-top: 8px;
        }

        .input-field label {
            font-size: 12px;
        }

        .grupos-grid .dx-cell,
        .grupos-grid .dx-header-cell {
            padding: 8px 10px;
            font-size: 13px;
        }

        .sidebar-action-btn {
            width: 36px !important;
            height: 36px !important;
            min-width: 36px !important;
            font-size: 14px !important;
        }
    }
</style>

@code {
    // **- private string[] // **- ToolbarOptions = { "add", "save", "remove", "leave" };
    
    // Campos del formulario
    private string CodigoValue { get; set; } = "";
    private string DescripcionValue { get; set; } = "";
    private DateTime? CreadoValue { get; set; } = DateTime.Now;
    private DateTime? VigenciaValue { get; set; } = DateTime.Now.AddYears(1);
    private bool ActivoOption { get; set; } = true;
    private bool RequireOption { get; set; } = false;
    
    // Grid data
    private List<GrupoOcupacional> GruposOcupacionalesData = new List<GrupoOcupacional>
    {
        new GrupoOcupacional { Codigo = "01", Descripcion = "EJECUTIVOS" },
        new GrupoOcupacional { Codigo = "02", Descripcion = "GERENCIA SENIOR" },
        new GrupoOcupacional { Codigo = "03", Descripcion = "GERENCIA MEDIA" },
        new GrupoOcupacional { Codigo = "04", Descripcion = "ESPECIALISTAS" },
        new GrupoOcupacional { Codigo = "05", Descripcion = "SUPERVISORES" },
        new GrupoOcupacional { Codigo = "06", Descripcion = "CLERICALES" },
        new GrupoOcupacional { Codigo = "07", Descripcion = "OPERACIONES" },
        new GrupoOcupacional { Codigo = "08", Descripcion = "OPERACION" }
    };

    public class GrupoOcupacional
    {
        public string Codigo { get; set; } = "";
        public string Descripcion { get; set; } = "";
    }
    
    // Event handlers
    private void OnSearchCodigoClick() => Console.WriteLine("Buscar código");
    private void OnCalendarClick() => Console.WriteLine("Abrir calendario creado");
    private void OnVigenciaCalendarClick() => Console.WriteLine("Abrir calendario vigencia");
    private void OnDuplicateClick() => Console.WriteLine("Duplicar registro");
    private void OnSettingsClick() => Console.WriteLine("Abrir configuración");
    private void OnDocumentClick() => Console.WriteLine("Generar documento");
    
    private void OnAddItemClick()
    {
        var newItem = new GrupoOcupacional 
        { 
            Codigo = GetNextCodigo(), 
            Descripcion = string.IsNullOrEmpty(DescripcionValue) ? "Nuevo Grupo" : DescripcionValue
        };
        GruposOcupacionalesData.Add(newItem);
        StateHasChanged();
    }
    
    private void OnEditItemClick()
    {
        Console.WriteLine("Función de editar grupo");
    }
    
    private void OnDeleteItemClick()
    {
        if (GruposOcupacionalesData.Any())
        {
            // Por simplicidad, elimina el último elemento
            GruposOcupacionalesData.RemoveAt(GruposOcupacionalesData.Count - 1);
            StateHasChanged();
        }
    }
    
    private string GetNextCodigo()
    {
        var maxCodigo = GruposOcupacionalesData
            .Where(x => int.TryParse(x.Codigo, out _))
            .Select(x => int.Parse(x.Codigo))
            .DefaultIfEmpty(0)
            .Max();
        return (maxCodigo + 1).ToString("00");
    }
    
    private async Task HandleClose()
    {
        await JS.InvokeVoidAsync("alert", "¡Grupos ocupacionales guardados exitosamente!");
    }
}