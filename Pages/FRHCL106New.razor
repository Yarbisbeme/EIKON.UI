@page "/FRHCL106New"


@layout MainLayout
@inject HttpClient HttpClient
@inject EIKON.UI.Services.EikonDataServices api
@inject EIKON.UI.Services.AuthenticationService auth
@inject NavigationManager nv
@inject IJSRuntime JS

<div class="page">
    <Breadcrumb Title="Grupos ocupacionales" BackUrl="/dash" />
    
    <div class="page-header">
        <div class="page-toolbar">
            <Toolbar formulario="FRHCL106" OnClose="HandleClose" />
        </div>
    </div>

    <div class="form-container">
        <!-- Primera Fila - Código y Descripción -->
        <div class="form-row">
            <div class="input-field">
                <label>Código</label>
                <DxTextBox @bind-Text="@CodigoValue"
                           ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Never">
                    <Buttons>
                        <DxEditorButton IconCssClass="fi fi-rr-search" 
                                       Click="OnSearchCodigoClick" />
                    </Buttons>
                </DxTextBox>
            </div>
            <div class="input-field wide">
                <label>Descripción</label>
                <DxTextBox @bind-Text="@DescripcionValue" />
            </div>
        </div>

        <!-- Segunda Fila - Creado, Activo y Toolbar lateral -->
        <div class="form-row-with-sidebar">
            <div class="input-fields-section">
                <div class="form-row">
                    <div class="input-field">
                        <label>Creado</label>
                        <div class="date-with-button">
                            <DxDateEdit @bind-Date="@CreadoValue" 
                                       DisplayFormat="d"
                                       NullText="--/--/----" />
                        </div>
                    </div>
                    <div class="checkbox-field">
                        <DxCheckBox @bind-Checked="@ActivoOption">Activo</DxCheckBox>
                    </div>
                </div>
                
                <div class="form-row">
                    <div class="input-field">
                        <label>Vigencia</label>
                        <div class="date-with-button">
                            <DxDateEdit @bind-Date="@VigenciaValue" 
                                       DisplayFormat="d"
                                       NullText="--/--/----" />
                        </div>
                    </div>
                    <div class="checkbox-field">
                        <DxCheckBox @bind-Checked="@RequireOption">¿Puede este grupo hacer requisición?</DxCheckBox>
                    </div>
                </div>
            </div>
        </div>

        <!-- Grid de Grupos Ocupacionales -->
        <div class="grid-section">
            <DxGrid Data="@GruposOcupacionalesData" 
                   CssClass="grupos-grid"
                   ShowPager="true"
                   PageSize="10"
                   ShowFilterRow="false"
                   ShowHeaderFilter="false"
                   AllowColumnResizing="true">
                <Columns>
                    <DxGridDataColumn FieldName="Codigo" 
                                    Caption="Código" 
                                    Width="100px">
                    </DxGridDataColumn>
                    <DxGridDataColumn FieldName="Descripcion" 
                                    Caption="Descripción" 
                                    MinWidth="200">
                    </DxGridDataColumn>
                </Columns>
            </DxGrid>
        </div>
    </div>
</div>

<style>
    /* Container principal */
    .form-container {
        display: flex;
        flex-direction: column;
        gap: 25px;
    }

    /* Form rows */
    .form-row {
        display: flex;
        gap: 20px;
        align-items: flex-end;
        min-height: 60px;
    }

    .form-row-with-sidebar {
        display: flex;
        gap: 20px;
        align-items: flex-start;
    }

    .input-fields-section {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    /* Input fields */
    .input-field {
        display: flex;
        flex-direction: column;
        gap: 6px;
        flex: 1;
        min-width: 150px;
    }

    .input-field.wide {
        flex: 3;
    }

    .input-field label {
        font-weight: 500;
        color: #333;
        font-size: 13px;
        margin-bottom: 5px;
    }

    /* Date with button */
    .date-with-button {
        display: flex;
        gap: 8px;
        align-items: center;
    }

    .date-btn {
        flex: 0 0 auto;
        min-width: 36px !important;
        width: 36px !important;
        height: 36px !important;
        padding: 0 !important;
    }

    /* Checkbox fields */
    .checkbox-field {
        display: flex;
        align-items: center;
        flex: 1;
        min-height: 60px;
    }

    /* Action sidebar */
    .action-sidebar {
        flex: 0 0 50px;
        display: flex;
        flex-direction: column;
        gap: 12px;
        align-items: center;
        padding-top: 25px;
    }

    .sidebar-action-btn {
        width: 44px !important;
        height: 44px !important;
        min-width: 44px !important;
        padding: 0 !important;
        border-radius: 8px !important;
        display: flex !important;
        align-items: center !important;
        justify-content: center !important;
        font-size: 16px !important;
        transition: all 0.3s ease !important;
    }

    .sidebar-action-btn:hover {
        transform: translateY(-2px) !important;
        box-shadow: 0 4px 8px rgba(0,0,0,0.15) !important;
    }

    /* Grid section */
    .grid-section {
        margin-top: 15px;
        border: 1px solid #e0e0e0;
        border-radius: 8px;
        overflow: hidden;
        background-color: white;
    }

    .grupos-grid {
        width: 100%;
        min-height: 300px;
        border: none;
    }

    /* Grid styling */
    .grupos-grid .dx-datagrid {
        border: none;
        font-family: inherit;
    }

    .grupos-grid .dx-datagrid-headers {
        background-color: #f8f9fa;
        border-bottom: 2px solid #dc3545;
    }

    .grupos-grid .dx-datagrid-header-panel {
        background-color: #f8f9fa;
    }

    .grupos-grid .dx-header-row {
        background-color: #f8f9fa;
        font-weight: 600;
        color: #333;
    }

    .grupos-grid .dx-row {
        border-bottom: 1px solid #f0f0f0;
    }

    .grupos-grid .dx-row:hover {
        background-color: rgba(220, 53, 69, 0.05);
    }

    .grupos-grid .dx-selection .dx-row {
        background-color: rgba(220, 53, 69, 0.1) !important;
    }

    .grupos-grid .dx-cell {
        padding: 12px 15px;
        border-right: 1px solid #f0f0f0;
    }

    .grupos-grid .dx-header-cell {
        padding: 15px;
        font-weight: 600;
        color: #333;
        background-color: #f8f9fa;
        border-right: 1px solid #e0e0e0;
    }

    /* Grid actions */
    .grid-actions {
        display: flex;
        gap: 10px;
