    /* Checkboxes */
    .dx-checkbox {
        font-size: 14px;
        font-weight: 500;
    }

    .dx-checkbox-checked .dx-checkbox-icon {
        background-color: #dc3545 !important;
        border-color: #dc3545 !important;
    }

    .dx-checkbox:hover .dx-checkbox-icon {
        border-color: #dc3545 !important;
    }

    /* Button styling */
    .dx-button-mode-contained.dx-button-default {
        background-color: #6c757d !important;
        border-color: #6c757d !important;
        color: white !important;
    }

    .dx-button-mode-contained.dx-button-default:hover {
        background-color: #5a6268 !important;
        border-color: #545b62 !important;
    }

    .dx-button-mode-contained.dx-button-success {
        background-color: #28a745 !important;
        border-color: #28a745 !important;
    }

    .dx-button-mode-contained.dx-button-success:hover {
        background-color: #218838 !important;
        border-color: #1e7e34 !important;
    }

    .dx-button-mode-contained.dx-button-danger {
        background-color: #dc3545 !important;
        border-color: #dc3545 !important;
    }

    .dx-button-mode-contained.dx-button-danger:hover {
        background-color: #c82333 !important;
        border-color: #bd2130 !important;
    }

    /* Responsive Design */
    media (max-width: 1024px) {
        .form-container {
            padding: 15px;
            gap: 20px;
        }

        .form-row {
            flex-wrap: wrap;
            gap: 15px;
        }

        .form-row-with-sidebar {
            flex-direction: column;
            gap: 20px;
        }

        .action-sidebar {
            flex-direction: row;
            justify-content: center;
            padding-top: 0;
        }

        .grid-section {
            margin-top: 12px;
        }

        .grid-actions {
            flex-wrap: wrap;
            gap: 8px;
        }

        .grid-actions .dx-button {
