@layout MainLayout
@page "/FRHCA102"
@inject IJSRuntime JSRuntime

<div class="page">

    <Breadcrumb Title="Registro de Asistencias, Permisos y Tardanzas" BackUrl="/dash" />
    <div class="page-header">
        <div class="page-toolbar">
            <Toolbar formulario="FRHxxx999" OnAdd="HandleAdd" OnSave="HandleSave" OnClose="HandleClose" />
        </div>
    </div>

    <div class="frhca102-form">

        <!-- Employee Information Section -->
        <div class="employee-info">
            <div class="info-row-1">
                <div class="input small-input">
                    <label for="numero">Número</label>
                    <DxTextBox @bind-Text="@Numero"
                               NullText="Número"
                               ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Never">
                        <Buttons>
                            <DxEditorButton IconCssClass="fi fi-rr-search"
                                            Click="@OnSearchNumero"
                                            Tooltip="Buscar empleado" />
                        </Buttons>
                    </DxTextBox>
                </div>

                <div class="input">
                    <label for="empleado">Empleado</label>
                    <DxTextBox @bind-Text="@Empleado" NullText="Empleado" />
                </div>

                    @* <DxButton Text="Enviar a Expediente" *@
                    @*           IconCssClass="fi fi-rr-paper-plane" *@
                    @*           Click="@OnEnviarExpediente"/> *@
            </div>

            <div class="info-row-2">
                <div class="input small-input">
                    <label for="turno">Turno</label>
                    <DxTextBox @bind-Text="@Turno" NullText="Turno" />
                </div>

                <div class="input">
                    <label for="fIngreso">F. Ingreso</label>
                    <DxDateEdit @bind-Date="@FIngreso"
                                DisplayFormat="dd/MM/yyyy"
                                NullText="//" />
                </div>
            </div>

            <div class="info-row-3">
                <div class="input small-input">
                    <label for="antiguedad">Antigüedad</label>
                    <DxTextBox @bind-Text="@Antiguedad" NullText="" />
                </div>

                <div class="input">
                    <label for="antiguedadAcumulada">Antigüedad Acumulada</label>
                    <DxTextBox @bind-Text="@AntiguedadAcumulada" NullText="" />
                </div>
            </div>

            <div class="info-row-4">
                <div class="input small-input">
                    <label for="noControl">No Control</label>
                    <DxTextBox @bind-Text="@NoControl" NullText="" />
                </div>

                <div class="input">
                    <label for="registrado">Registrado</label>
                    <DxDateEdit @bind-Date="@Registrado"
                                DisplayFormat="dd/MM/yyyy"
                                NullText="//" />
                </div>

                <DxCheckBox style="min-width:fit-content;" @bind-Checked="@FijarTipo">Fijar Tipo</DxCheckBox>
            </div>

            <div class="info-row-5">
                <div class="input">
                    <label for="tipoRegistro">Tipo registro</label>
                    <DxTextBox @bind-Text="@TipoRegistro"
                               NullText="Tipo registro"
                               ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Never">
                        <Buttons>
                            <DxEditorButton IconCssClass="fi fi-rr-search"
                                            Click="@OnSearchTipoRegistro"
                                            Tooltip="Buscar tipo" />
                        </Buttons>
                    </DxTextBox>
                </div>
            </div>

            <div class="info-row-6">
                <div class="input">
                    <label for="enfermedad">Enfermedad</label>
                    <DxTextBox @bind-Text="@Enfermedad"
                               NullText="Enfermedad"
                               ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Never">
                        <Buttons>
                            <DxEditorButton IconCssClass="fi fi-rr-search"
                                            Click="@OnSearchEnfermedad"
                                            Tooltip="Buscar enfermedad" />
                        </Buttons>
                    </DxTextBox>
                </div>
            </div>
        </div>

        <!-- Three Panels Section -->
        <div class="panels-section">
            <!-- Asistencia Panel -->
            <div class="panel asistencia-panel">
                <div class="panel-header">
                    <DxCheckBox @bind-Checked="@AsistenciaEnabled">Asistencia</DxCheckBox>
                </div>
                <div class="panel-body">
                    <div class="input">
                        <label>Desde</label>
                        <DxDateEdit @bind-Date="@AsistenciaDesde"
                                    DisplayFormat="dd/MM/yyyy"
                                    NullText="//"
                                    Enabled="@AsistenciaEnabled" />
                    </div>
                    <div class="input">
                        <label>Días</label>
                        <DxSpinEdit @bind-Value="@AsistenciaDias"
                                    DisplayFormat="N2"
                                    MinValue="0"
                                    NullText="0.00"
                                    Enabled="@AsistenciaEnabled" />
                    </div>
                    <div class="input">
                        <label>Hasta</label>
                        <DxDateEdit @bind-Date="@AsistenciaHasta"
                                    DisplayFormat="dd/MM/yyyy"
                                    NullText="//"
                                    Enabled="@AsistenciaEnabled" />
                    </div>
                    <div class="input">
                        <label>Aplica</label>
                        <DxDateEdit @bind-Date="@AsistenciaAplica"
                                    DisplayFormat="dd/MM/yyyy"
                                    NullText="//"
                                    Enabled="@AsistenciaEnabled" />
                    </div>
                    <div class="input">
                        <label>Comentario</label>
                        <DxMemo @bind-Text="@AsistenciaComentario"
                                Rows="3"
                                NullText="Comentario..."
                                Enabled="@AsistenciaEnabled" />
                    </div>
                </div>
            </div>

            <!-- Permisos Panel -->
            <div class="panel permisos-panel">
                <div class="panel-header">
                    <DxCheckBox @bind-Checked="@PermisosEnabled">Permisos</DxCheckBox>
                </div>
                <div class="panel-body">
                    <div class="input">
                        <label>Fecha</label>
                        <DxDateEdit @bind-Date="@PermisosFecha"
                                    DisplayFormat="dd/MM/yyyy"
                                    NullText="//"
                                    Enabled="@PermisosEnabled" />
                    </div>
                    <div class="input">
                        <label>Desde</label>
                        <DxTimeEdit @bind-Time="@PermisosDesde"
                                    DisplayFormat="HH:mm"
                                    NullText="00:00"
                                    Enabled="@PermisosEnabled" />
                    </div>
                    <div class="input">
                        <label>Hasta</label>
                        <DxTimeEdit @bind-Time="@PermisosHasta"
                                    DisplayFormat="HH:mm"
                                    NullText="00:00"
                                    Enabled="@PermisosEnabled" />
                    </div>
                    <div class="input">
                        <label>Horas</label>
                        <DxSpinEdit @bind-Value="@PermisosHoras"
                                    DisplayFormat="N2"
                                    MinValue="0"
                                    NullText="0.00"
                                    Enabled="@PermisosEnabled" />
                    </div>
                </div>
            </div>

            <!-- Tardanza Panel -->
            <div class="panel tardanza-panel">
                <div class="panel-header">
                    <DxCheckBox @bind-Checked="@TardanzaEnabled">Tardanza</DxCheckBox>
                </div>
                <div class="panel-body">
                    <div class="input">
                        <label>Fecha</label>
                        <DxDateEdit @bind-Date="@TardanzaFecha"
                                    DisplayFormat="dd/MM/yyyy"
                                    NullText="//"
                                    Enabled="@TardanzaEnabled" />
                    </div>
                    <div class="input">
                        <label>Hora Llegada</label>
                        <DxTimeEdit @bind-Time="@TardanzaHoraLlegada"
                                    DisplayFormat="HH:mm"
                                    NullText="00:00"
                                    Enabled="@TardanzaEnabled" />
                    </div>
                    <div class="input">
                        <label>Horas perdidas</label>
                        <DxSpinEdit @bind-Value="@TardanzaHorasPerdidas"
                                    DisplayFormat="N2"
                                    MinValue="0"
                                    NullText="0.00"
                                    Enabled="@TardanzaEnabled" />
                    </div>
                    <div class="input">
                        <label>¿Pagado?</label>
                        <div style="display:flex; gap:10px;">
                        <DxRadio GroupName="accion"
                                 @bind-GroupValue="@TardanzaPagado"
                                 Value="@("Si")">
                            Si
                        </DxRadio>
                        <DxRadio GroupName="accion"
                                 @bind-GroupValue="@TardanzaPagado"
                                 Value="@("No")">
                            No
                        </DxRadio>
                        </div>
                    </div>
                    <div class="input">
                        <label>Costo</label>
                        <DxSpinEdit @bind-Value="@TardanzaCosto"
                                    DisplayFormat="N2"
                                    MinValue="0"
                                    NullText="0.00"
                                    Enabled="@TardanzaEnabled" />
                    </div>
                    <div class="input">
                        <DxCheckBox @bind-Checked="@TardanzaProponerNomina"
                                    Enabled="@TardanzaEnabled">Proponer en nómina</DxCheckBox>
                    </div>
                    <div class="input">
                        <label>Cant. Periodos.</label>
                        <DxSpinEdit @bind-Value="@TardanzaCantPeriodos"
                                    MinValue="0"
                                    NullText="0"
                                    Enabled="@TardanzaEnabled" />
                    </div>
                </div>
            </div>
        </div>

        <!-- Grid Section -->
        <div class="grid-section">
            <DxGrid Data="@RegistrosList"
                    CssClass="registros-grid"
                    ShowGroupPanel="false">
                <Columns>
                    <DxGridSelectionColumn Width="40px" />
                    <DxGridDataColumn FieldName="NoControl" Caption="NoControl" Width="100%" />
                    <DxGridDataColumn FieldName="IcTipo" Caption="IcTipo" Width="100%" />
                    <DxGridDataColumn FieldName="DscTipo" Caption="DscTipo" Width="100%" />
                    <DxGridDataColumn FieldName="Registro" Caption="Registro" Width="100%" />
                    <DxGridDataColumn FieldName="Desde" Caption="Desde" Width="100%" />
                    <DxGridDataColumn FieldName="Hasta" Caption="Hasta" Width="100%" />
                </Columns>
            </DxGrid>
        </div>

    </div>

</div>

@code {
