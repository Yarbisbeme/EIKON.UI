@inject IJSRuntime JSRuntime
@inject NavigationManager nv;

<PageTitle>Opciones Menu</PageTitle>
<h1>Mantenimiento Trhis000...</h1>

@if (data == null)
{
    <p><em>Loading...</em></p>
}
else
{
    <DxGrid Data="@data" @ref="MyGrid"
            CssClass="mw-1100"
            EditModelSaving="OnEditModelSaving"
                EditMode="GridEditMode.EditRow"
            DataItemDeleting="OnDataItemDeleting">
        <Columns>
            <DxGridCommandColumn Width="60px" >
                <HeaderTemplate>
                    <a class="text-primary" @onclick="@(() => MyGrid.StartEditNewRowAsync())" style="text-decoration: none;" href="javascript:void(0);"><i class="fi fi-rr-plus"></i></a>
                </HeaderTemplate>
                <CellDisplayTemplate>
                    <a class="text-primary" @onclick="@(() => MyGrid.StartEditRowAsync(context.VisibleIndex))" style="text-decoration: none;" href="javascript:void(0);"><i class="fi fi-rr-edit"></i></a>
                    <a class="text-primary" @onclick="@(() => MyGrid.ShowDataItemDeleteConfirmation(context.DataItem))" style="text-decoration: none;" href="javascript:void(0);"><i class="fi fi-rr-trash"></i></a>
                </CellDisplayTemplate>
               </DxGridCommandColumn>
            <DxGridDataColumn Caption="Id" FieldName="IsCodigo" Width="260px"  />
            <DxGridDataColumn Caption="Descripción" FieldName="IsDescri" Width="300px" />
           @*  <DxGridDataColumn Caption="NzCodigo" FieldName="NzCodigo" /> *@
           @*  <DxDataGridComboBoxColumn Field="NzCodigo"
                                      Caption="Modulo"
                                      Data="@modulos"
                                      TextField="NzDescri"
                                      ValueField="NzCodigo" itemtype="string" >
            </DxDataGridComboBoxColumn> *@
            <DxGridDataColumn FieldName="NzCodigo" Caption="Modulo" Width="300px">
                <EditSettings>
                    <DxComboBoxSettings Data="modulos"
                                        ValueFieldName="NzCodigo"
                                        TextFieldName="NzDescri"
                                        FilteringMode="DataGridFilteringMode.Contains"
                                        ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto" />
                </EditSettings>
            </DxGridDataColumn>
            <DxGridDataColumn Caption="Tipo" FieldName="IsTipo" />
            <DxGridDataColumn Caption="Formulario" FieldName="IsForm" />
            <DxGridDataColumn FieldName="IsSueldo" Caption="Visible" />
            <DxGridDataColumn Caption="Grupo" FieldName="MCodigo" />

        </Columns>
    </DxGrid>
    
}

