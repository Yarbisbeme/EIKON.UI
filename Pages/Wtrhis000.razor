        void SetNewValues(Trhis000Dto dataItem, Trhis000Dto newValues)
        {
            dataItem.IsCodigo = newValues.IsCodigo;
            dataItem.IsDescri = newValues.IsDescri;
            dataItem.NzCodigo = newValues.NzCodigo; 
            dataItem.MCodigo = newValues.MCodigo;

