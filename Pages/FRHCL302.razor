@page "/FRHCL302"
@using DevExpress.Blazor
@using System.Net.Http.Json
@using System.Net.Http.Headers
@using EIKON.UI.Interfaces
@using DevExpress.AspNetCore.Reporting
@using DevExpress.XtraReports.UI
@using EIKON.UI.Components

@inject HttpClient HttpClient
@inject EIKON.UI.Services.EikonDataServices api
@inject EIKON.UI.Services.AuthenticationService auth

@inject NavigationManager nv
@inject IJSRuntime JS

<PageTitle>Reportes Generales</PageTitle>

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Administración de Puestos - Reportes Generales</title>
    <style>
         body {
             font-family: Arial, sans-serif;
             background-color: #f4f4f4;
         }

         .container {
             width: 95%;
             margin: 0 auto;
             background-color: #e9e9e9;
             padding: 10px;
             border-radius: 8px;
             box-shadow: 0px 0px 10px rgba(0, 0, 0, 0.1);
         }

         h1 {
             font-size: 18px;
             color: #333;
             text-align: center;
             margin-bottom: 5px;
         }

         .form-group {
             margin-bottom: 4px;
         }

             .form-group label {
                 display: block;
                 font-weight: bold;
                 margin-bottom: 4px;
             }

             .form-group input, .form-group select {
                 width: 80%;
                 padding: 4px;
                 box-sizing: border-box;
             }

                 .form-group input[type="checkbox"] {
                     width: 50%;
                 }

         .form-row {
             display: flex;
             justify-content: space-between;
         }

             .form-row .form-group {
                 width: 48%;
             }

         .actions {
             text-align: right;

             margin-top: 10px;
         }

             .actions button {
                 padding: 10px 15px;
                 margin: 0 5px;
                 cursor: pointer;
             }

         .checkitem > label {
             display: inline-block;
             width: calc(100% - 20px);
             vertical-align: middle;
         }

         .checkitem > input[type=checkbox] {
             display: inline-block;
             width: 15px;
             height: 25%;
             vertical-align: middle;
         }

         .checkitem > input[type=radio] {
             display: inline-block;
             width: 15px;
             height: 25%;
             vertical-align: middle;

         }

         table {
             width: 100%;
             margin-top: 15px;
             border-collapse: collapse;
         }

         table, th, td {
             border: 1px solid #ccc;
         }

         th, td {
             padding: 8px;
             text-align: left;
         }

        .hidden {
             display: none;
         }

         .Ahdn {
             display: none;
         }

         .Uhdn {
             display: none;
         }

         .Dhdn {
             display: none;
         }

         .Shdn {
             display: none;
         }

         .Phdn {
             display: none;
         }
    </style>
</head>
<body>
    <div class="container">
        <h1>SIRH - Reportes Generales</h1>
        <div class="row">
            <div class="form-group col-md-2">

                <DxCheckBox CheckType="CheckType.Checkbox" Checked="@EsPorFecha" CheckedExpression="@(() => EsPorFecha)"
                            CheckedChanged="@((bool value) => hdFechas(value))">Fechas</DxCheckBox>
            </div>
            <div class="form-group col-md-3">
                <DxDateEdit id="Fecha1" Date="@fecha1" Enabled="@EnabledFec"></DxDateEdit>
            </div>
            <div class="form-group col-md-3">
                <DxDateEdit id="Fecha2" Date="@fecha2" Enabled="@EnabledFec"></DxDateEdit>
            </div>
        </div>
    </div>
</body>
@code {
    public string fecha1 { get; set; }
    public string fecha2 { get; set; }
    bool EsPorFecha { get; set; } = false;
    bool EnabledFec { get; set; } = false;
    //bool EnabledFe2 { get; set; } = false;
   
    private void hdFechas(bool value)
    {
        EsPorFecha = value;
        EnabledFec = EsPorFecha;
        // EnabledFe2 = EsPorFecha;

    }
    // private rrhel006 report;
    // async Task ReporteRrwel006()
    // {
    //     var data = await api.GetDataRrhel006("A");
    //     report = new rrhel006();
    //    //- report.LoadData(data);
    // }
}
