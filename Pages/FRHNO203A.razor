                var  Estatus = await HttpClient.GetStringAsync(ApiBaseUrl + "Api/EikonPayRollProcess/PayRollState");
                if (!string.IsNullOrEmpty(Estatus))
                {
                    TxtEstatus = DateTime.Now.ToString() + " : "+ Estatus;
                }
