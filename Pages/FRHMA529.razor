@page "/FRHMA529"
@page "/FRHMA529/{id:int}"

@using EIKON.UI.Components
@using DevExpress.Blazor
@using System.Net.Http.Json
@using System.Net.Http.Headers
@using EIKON.UI.Interfaces
@using System.ComponentModel.DataAnnotations

@layout MainLayout
@inject NavigationManager nv
@inject IJSRuntime JS

<div class="page">
    <Breadcrumb Title="FRHMA529 - SIRH - Definición de grupos presupuestarios" BackUrl="/dash" />
    <div class="page-header">

        <div class="page-search">
            <div class="input-search">
                <label for="user">Código</label>
                <DxTextBox @bind-Text="@codigo"
                           NullText="Código"
                           ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Never">
                    <Buttons>
                        <DxEditorButton IconCssClass="fi fi-rr-search" />
                    </Buttons>
                </DxTextBox>
            </div>

        </div>

        <div class="page-toolbar">
            <Toolbar formulario="FRHxxx999" />
        </div>
    </div>

    <div class="form-container">
        <!-- Sección Principal -->
        <div class="main-section">

            <!-- Segunda fila: Descripción -->
            <div class="form-row">
                <div class="form-field full-width">
                    <label>Descripción</label>
                    <DxTextBox @bind-Text="@GrupoPresupuestario.Descripcion" />
                </div>
            </div>

            <!-- Tercera fila: Programa -->
            <div class="form-row">
                <div class="form-field full-width">
                    <label>Programa</label>
                    <DxComboBox Data="@programasList"
                                @bind-Value="@GrupoPresupuestario.ProgramaId"
                                TextFieldName="Descripcion"
                                ValueFieldName="Id"
                                NullText="Seleccionar programa"
                                ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Never" />
                </div>
            </div>

            <!-- Cuarta fila: Sub-Programa -->
            <div class="form-row">
                <div class="form-field full-width">
                    <label>Sub-Programa</label>
                    <DxComboBox Data="@subProgramasList"
                                @bind-Value="@GrupoPresupuestario.SubProgramaId"
                                TextFieldName="Descripcion"
                                ValueFieldName="Id"
                                NullText="Seleccionar sub-programa"
                                Enabled="@(GrupoPresupuestario.ProgramaId.HasValue)"
                                ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Never" />
                </div>
            </div>

            <!-- Quinta fila: Proyecto -->
            <div class="form-row">
                <div class="form-field">
                    <label>Proyecto</label>
                    <div style="display:flex; gap:5px; align-items:center;">
                        <DxComboBox Data="@proyectosList"
                                    @bind-Value="@GrupoPresupuestario.ProyectoId"
                                    TextFieldName="Descripcion"
                                    ValueFieldName="Id"
                                    NullText="Seleccionar proyecto"
                                    style="flex: 1;"
                                    ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Never" />
                    </div>
                </div>
            </div>

            <!-- Sexta fila: Cuenta -->
            <div class="form-row">
                <div class="form-field">
                    <label>Cuenta</label>
                    <DxTextBox @bind-Text="@GrupoPresupuestario.Cuenta"
                               style="width: 200px;" />
                </div>
            </div>

            <!-- Séptima fila: Descripción detallada -->
            <div class="form-row">
                <div class="form-field full-width">
                    <label>Descripción detallada</label>
                    <DxMemo @bind-Text="@GrupoPresupuestario.DescripcionDetallada"
                            Rows="8"
                            style="width: 100%; min-height: 200px;"
                            NullText="Ingrese la descripción detallada del grupo presupuestario..." />
                </div>
            </div>
        </div>
    </div>
</div>


@code {
    [Parameter]
    public int id { get; set; }
    private string codigo { get; set; } = "00000001";

    // Toolbar options
    // **- private string[] // **- ToolbarOptions = { "add", "save", "remove", "leave" };

    // Data objects
    private GrupoPresupuestarioDto GrupoPresupuestario { get; set; } = new GrupoPresupuestarioDto();

    // Data lists
    private List<ProgramaDto> programasList { get; set; } = new List<ProgramaDto>();
    private List<SubProgramaDto> subProgramasList { get; set; } = new List<SubProgramaDto>();
    private List<ProyectoDto> proyectosList { get; set; } = new List<ProyectoDto>();

    protected override async Task OnInitializedAsync()
    {
        await LoadPlaceholderData();
    }

    // Load placeholder data
    private async Task LoadPlaceholderData()
    {
        // Simulate API delay
        await Task.Delay(100);

        // Load programas
        programasList = new List<ProgramaDto>
        {
            new ProgramaDto { Id = 1, Descripcion = "Programa de Recursos Humanos" },
            new ProgramaDto { Id = 2, Descripcion = "Programa de Tecnología" },
            new ProgramaDto { Id = 3, Descripcion = "Programa de Capacitación" },
            new ProgramaDto { Id = 4, Descripcion = "Programa de Desarrollo Organizacional" },
            new ProgramaDto { Id = 5, Descripcion = "Programa de Bienestar Social" }
        };

        // Load sub-programas
        subProgramasList = new List<SubProgramaDto>
        {
            new SubProgramaDto { Id = 1, Descripcion = "Sub-programa de Nómina", ProgramaId = 1 },
            new SubProgramaDto { Id = 2, Descripcion = "Sub-programa de Selección", ProgramaId = 1 },
            new SubProgramaDto { Id = 3, Descripcion = "Sub-programa de Infraestructura TI", ProgramaId = 2 },
            new SubProgramaDto { Id = 4, Descripcion = "Sub-programa de Software", ProgramaId = 2 },
            new SubProgramaDto { Id = 5, Descripcion = "Sub-programa de Certificaciones", ProgramaId = 3 }
        };

        // Load proyectos
        proyectosList = new List<ProyectoDto>
        {
            new ProyectoDto { Id = 1, Descripcion = "Proyecto de Modernización SIRH" },
            new ProyectoDto { Id = 2, Descripcion = "Proyecto de Automatización de Nómina" },
            new ProyectoDto { Id = 3, Descripcion = "Proyecto de Portal de Empleados" },
            new ProyectoDto { Id = 4, Descripcion = "Proyecto de Business Intelligence" },
            new ProyectoDto { Id = 5, Descripcion = "Proyecto de Migración de Datos" }
        };

        // Initialize main object
        GrupoPresupuestario = new GrupoPresupuestarioDto
            {
                Codigo = "GP001",
                Descripcion = "Grupo Principal de RRHH",
                Cuenta = "1001-001",
                DescripcionDetallada = "Este grupo presupuestario está destinado a la gestión y administración de los recursos humanos de la organización, incluyendo salarios, beneficios, capacitación y desarrollo del personal."
            };

        StateHasChanged();
    }

    // Search handlers
    private async Task BuscarCodigo()
    {
        await JS.InvokeVoidAsync("alert", "Buscar código - Funcionalidad pendiente");
    }

    private async Task AbrirCarpeta()
    {
        await JS.InvokeVoidAsync("alert", "Abrir carpeta - Funcionalidad pendiente");
    }

    private async Task BuscarProyecto()
    {
        await JS.InvokeVoidAsync("alert", "Buscar proyecto - Funcionalidad pendiente");
    }

    // DTOs
    public class GrupoPresupuestarioDto
    {
        public string Codigo { get; set; } = "";
        public string Descripcion { get; set; } = "";
        public int? ProgramaId { get; set; }
        public int? SubProgramaId { get; set; }
        public int? ProyectoId { get; set; }
        public string Cuenta { get; set; } = "";
        public string DescripcionDetallada { get; set; } = "";
    }

    public class ProgramaDto
    {
        public int Id { get; set; }
        public string Descripcion { get; set; } = "";
    }

    public class SubProgramaDto
    {
        public int Id { get; set; }
        public string Descripcion { get; set; } = "";
        public int ProgramaId { get; set; }
    }

    public class ProyectoDto
    {
        public int Id { get; set; }
        public string Descripcion { get; set; } = "";
    }
}