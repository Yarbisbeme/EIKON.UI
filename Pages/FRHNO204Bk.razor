    void Grid_CustomizeElement(GridCustomizeElementEventArgs e)
    {
        if (e.ElementType == GridElementType.DataRow && e.Grid.GetRowValue(e.VisibleIndex, "WcTipoTr").ToString().Contains("I"))
        {
            e.CssClass = "highlighted-item-I";
        }
        else
        {
            e.CssClass = "highlighted-item-D";
        }
        if (e.ElementType == GridElementType.DataRow && e.Grid.GetRowValue(e.VisibleIndex, "WcInvisib").ToString().Contains("S"))
        {
            e.CssClass = "highlighted-item-inv";
        }
    }


