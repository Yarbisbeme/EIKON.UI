@page "/FRHUT126"

@using EIKON.UI.Components
@using DevExpress.Blazor
@using System.Net.Http.Json
@using System.Net.Http.Headers
@using EIKON.UI.Interfaces
@using DevExpress.AspNetCore.Reporting
@using DevExpress.XtraReports.UI
@using System.ComponentModel.DataAnnotations

@layout MainLayout
@inject HttpClient HttpClient
@inject EIKON.UI.Services.EikonDataServices api
@inject EIKON.UI.Services.AuthenticationService auth
@inject NavigationManager nv
@inject IJSRuntime JS

<div class="page">
    <Breadcrumb Title="FRHUT126 - SIRH - Interfase con otras aplicaciones" BackUrl="/dash" />
    
    <div class="page-header">
        <div class="page-toolbar">
            <Toolbar formulario="FRHxxx999" OnClose="HandleClose" />
        </div>
    </div>

    <div class="form-container">
        <!-- Primera Fila - Código y Descripción -->
        <div class="form-row">
            <div class="input-field">
                <label>Código</label>
                <DxTextBox @bind-Text="@CodigoValue"
                           ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Never">
                    <Buttons>
                        <DxEditorButton IconCssClass="fi fi-rr-search" 
                                       Click="@OnSearchCodigoClick" />
                    </Buttons>
                </DxTextBox>
            </div>
            <div class="input-field wide">
                <label>Descripción</label>
                <DxTextBox @bind-Text="@DescripcionValue" />
            </div>
        </div>

        <!-- Sección de Tabs - Script y Formato Salida -->
        <div class="tabs-section">
            <DxTabs @bind-ActiveTabIndex="@ActiveTabIndex" CssClass="custom-tabs">
                <DxTabPage Text="Script" CssClass="tab-page">
                    <Content>
                        <div class="tab-content">
                            <DxMemo @bind-Value="@ScriptValue" 
                                   Rows="18" 
                                   NullText="Escriba el script aquí..." 
                                   CssClass="script-memo" />
                        </div>
                    </Content>
                </DxTabPage>
                <DxTabPage Text="Formato salida" CssClass="tab-page">
                    <Content>
                        <div class="tab-content">
                            <DxMemo @bind-Value="@FormatoSalidaValue" 
                                   Rows="18" 
                                   NullText="Defina el formato de salida aquí..." 
                                   CssClass="formato-memo" />
                        </div>
                    </Content>
                </DxTabPage>
            </DxTabs>
        </div>

        <!-- Tercera Fila - Ruta -->
        <div class="form-row">
            <div class="input-field full-width">
                <label>Ruta</label>
                <DxTextBox @bind-Text="@RutaValue" 
                          NullText="Especifique la ruta de destino..." />
            </div>
        </div>
    </div>
</div>

<style>
    /* Container principal */
    .form-container {
        display: flex;
        flex-direction: column;
        gap: 25px;
        padding: 20px 0;
    }

    /* Form rows */
    .form-row {
        display: flex;
        gap: 20px;
        align-items: flex-end;
        min-height: 60px;
    }

    /* Input fields */
    .input-field {
        display: flex;
        flex-direction: column;
        gap: 6px;
        flex: 1;
        min-width: 150px;
    }

    .input-field.wide {
        flex: 2;
    }

    .input-field.full-width {
        flex: 1;
        width: 100%;
    }

    .input-field label {
        font-weight: 500;
        color: #333;
        font-size: 13px;
        margin-bottom: 5px;
    }

    /* Tabs section - Script y Formato Salida */
    .tabs-section {
        margin-top: 15px;
        border: 1px solid #e0e0e0;
        border-radius: 8px;
        overflow: hidden;
    }

    .custom-tabs {
        border: none;
    }

    .tab-content {
        padding: 20px;
        background-color: transparent;
    }

    .script-memo,
    .formato-memo {
        width: 100%;
        border: none;
        background-color: transparent;
    }

    .script-memo .dx-memo-container,
    .formato-memo .dx-memo-container {
        background-color: transparent !important;
        border: 1px solid #ced4da !important;
        border-radius: 6px !important;
        min-height: 450px !important;
    }

    .script-memo .dx-memo-container .dx-texteditor-input {
        font-family: 'Consolas', 'Monaco', 'Courier New', monospace !important;
        font-size: 13px !important;
        line-height: 1.5 !important;
        background-color: #f8f9fa !important;
        color: #333 !important;
    }

    .formato-memo .dx-memo-container .dx-texteditor-input {
        font-family: 'Consolas', 'Monaco', 'Courier New', monospace !important;
        font-size: 13px !important;
        line-height: 1.5 !important;
        background-color: #fff !important;
        color: #333 !important;
    }

    /* DevExpress Components */
    .dx-textbox,
    .dx-memo {
        border-radius: 6px !important;
    }

    .dx-textbox-container,
    .dx-memo-container {
        border: 1px solid #ced4da !important;
        border-radius: 6px !important;
        transition: all 0.3s ease !important;
    }

    .dx-textbox-container:focus-within,
    .dx-memo-container:focus-within {
        border-color: #dc3545 !important;
        box-shadow: 0 0 0 0.2rem rgba(220, 53, 69, 0.25) !important;
    }

    /* Search button styling */
    .dx-editor-button {
        background-color: #6c757d !important;
        border-color: #6c757d !important;
        color: white !important;
        border-radius: 4px !important;
    }

    .dx-editor-button:hover {
        background-color: #5a6268 !important;
        border-color: #545b62 !important;
    }

    /* Tabs específicos */
    .dx-tabs-header {
        background-color: #f8f9fa !important;
        border-bottom: 1px solid #e0e0e0 !important;
    }

    .dx-tab {
        border: none !important;
        background-color: transparent !important;
        color: #6c757d !important;
        font-weight: 500 !important;
    }

    .dx-tab:hover {
        background-color: rgba(220, 53, 69, 0.1) !important;
        color: #dc3545 !important;
    }

    .dx-tab-active {
        background-color: #dc3545 !important;
        color: white !important;
        border-radius: 6px 6px 0 0 !important;
    }

    .dx-tab-content {
        border: none !important;
        padding: 0 !important;
    }

    /* Responsive Design */
    media (max-width: 1024px) {
        .tabs-section {
            margin-top: 12px;
        }

        .script-memo .dx-memo-container,
        .formato-memo .dx-memo-container {
            min-height: 350px !important;
        }
    }

    media (max-width: 1024px) {
        .form-container {
            padding: 15px;
            gap: 20px;
        }

        .form-row {
            flex-wrap: wrap;
            gap: 15px;
        }

        .tab-content {
            padding: 15px;
        }
    }

    media (max-width: 768px) {
        .form-container {
            padding: 15px;
            gap: 15px;
        }

        .form-row {
            flex-direction: column;
            gap: 15px;
            align-items: stretch;
            min-height: auto;
        }

        .input-field {
            min-width: auto;
        }

        .input-field.wide {
            flex: 1;
        }

        .tabs-section {
            margin-top: 10px;
        }

        .tab-content {
            padding: 15px;
        }

        .script-memo .dx-memo-container,
        .formato-memo .dx-memo-container {
            min-height: 300px !important;
        }

        .script-memo .dx-memo-container .dx-texteditor-input,
        .formato-memo .dx-memo-container .dx-texteditor-input {
            font-size: 12px !important;
        }
    }

    media (max-width: 480px) {
        .form-container {
            gap: 12px;
            padding: 12px;
        }

        .form-row {
            gap: 12px;
        }

        .tabs-section {
            margin-top: 8px;
        }

        .tab-content {
            padding: 12px;
        }

        .script-memo .dx-memo-container,
        .formato-memo .dx-memo-container {
            min-height: 250px !important;
        }

        .input-field label {
            font-size: 12px;
        }
    }
</style>

@code {
    // **- private string[] // **- ToolbarOptions = { "add", "save", "remove", "leave" };
    
    // Campos del formulario
    private string CodigoValue { get; set; } = "";
    private string DescripcionValue { get; set; } = "";
    private string ScriptValue { get; set; } = "";
    private string FormatoSalidaValue { get; set; } = "";
    private string RutaValue { get; set; } = "";
    
    // Tab index
    private int ActiveTabIndex { get; set; } = 0;
    
    // Event handlers
    private void OnSearchCodigoClick() => Console.WriteLine("Buscar código");
    
    private async Task HandleClose()
    {
        await JS.InvokeVoidAsync("alert", "¡Interfase guardada exitosamente!");
    }
}