@layout MainLayoutLogin
@page "/"
@using DevExpress.Blazor
@using System.Net.Http.Json
@using System.Net.Http.Headers
@using EIKON.UI.Interfaces
@using Microsoft.AspNetCore.Http
@inject HttpClient HttpClient
@inject EIKON.UI.Services.EikonDataServices api
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime
@inject EIKON.UI.Services.AuthenticationService auth
@inject IMockService<Trhem000Dto> MockEmpresasService
@inject IMockService<LoginDto> MockLoginService

<Alert2 @ref="alertInfo" Message="Usuario o Contraseña no encontrados" Title="Error" TypeAlert="error"></Alert2>
<div class="e-login">
    <div class="container">
        <nav class="e-nav">
            <div class="e-nav-logo">
                <img src="/images/image.png" alt="" />
            </div>
            <div class="e-nav-links">
                <ul>
                    <li>
                        <a href="">
                            <i class="fi fi-tr-folder-open"></i>
                            <span>Directorio</span>
                        </a>
                    </li>
                    <li>
                        <a href="">
                            <i class="fi fi-tr-lightbulb-on"></i>
                            <span>Sugerencias</span>
                        </a>
                    </li>
                </ul>
            </div>
        </nav>
        <div class="e-login-body">
            <div class="left">
                <DxCarousel Data="@CarouselItems"
                            CssClass="login-carousel"
                            AutoPlay="true"
                            AutoPlayInterval="100"
                            ShowNavigationButtons="true"
                            ShowIndicators="true"
                            AnimationDuration="100"
                            Loop="true">
                    <ItemTemplate>
                        @{
                            var carouselItem = (CarouselItem)context.DataItem;
                        }
                        <div class="carousel-item">
                            <img src="@carouselItem.ImageUrl" alt="@carouselItem.Title" />
                            @if (!string.IsNullOrEmpty(carouselItem.Title) || !string.IsNullOrEmpty(carouselItem.Description))
                            {
                                <div class="carousel-caption">
                                    @if (!string.IsNullOrEmpty(carouselItem.Title))
                                    {
                                        <h3>@carouselItem.Title</h3>
                                    }
                                    @if (!string.IsNullOrEmpty(carouselItem.Description))
                                    {
                                        <p>@carouselItem.Description</p>
                                    }
                                </div>
                            }
                        </div>
                    </ItemTemplate>
                </DxCarousel>
            </div>
            <div class="middle">
                <div class="line"></div>
            </div>
            <div class="right">
                <div class="e-img">
                    <img src="/images/48.png
                " alt="" />
                </div>
                <h1>¡Qué bueno verte de nuevo!</h1>
                <p class="subtitle">
                    Accede para continuar gestionando el talento de tu organización
                </p>
                @if (login == null)

                {

                    <p><em>Loading...</em></p>

                }

                else

                {

                    <div class="login-form">
                        <div class="input">
                            <label for="user">Usuario</label>
                            <DxTextBox Id="userText" @bind-Text="@user" @onchange="BuscaEmpresas" placeholder="ID del usuario"></DxTextBox>
                            @*    <input type="text" id="user" placeholder="ID del usuario" /> *@
                        </div>
                        <div class="input">
                            <label for="password">Contraseña</label>
                            <DxTextBox Id="userPass" @bind-Text="@pass" Password="true" placeholder="Ingrese su contraseña"></DxTextBox>
                            @* <input type="password" id="password" placeholder="Ingrese su contraseña" /> *@
                        </div>
                        <div class="select">
                            
                            @* <select name="company" id="company">
                            <option value="">Seleccione una empresa</option>
                            <option value="1">Empresa Eikon 1</option>
                            <option value="2">Empresa Eikon 2</option>
                        </select> *@
                            @if (empresas == null || empresas.Count() == 0)
                            {
                                    <p>Digite su Usuario y Contraseña...</p>
                                }
                                        else {
                                <label for="company">Empresa</label>
                                    <DxComboBox id="empresa" Data="@empresas" ValueFieldName="EmCodigo" TextFieldName="EmDescri" @bind-Value="empresa" ValidationEnabled="true"
                                    ShowValidationIcon="true"
                            ShowValidationSuccessState="true"
                            Enabled="@CbEmpresa"></DxComboBox>
                            <DxButton Text="Iniciar Sesión" CssClass="form-btn" Click="ConfirmLogin" />

                                        }
                            @* <i class="icon fi fi-rr-angle-small-down"></i> *@
                        </div>
                        @*                     <button type="button" class="form-btn">Iniciar Sesión</button>

 *@
                        
                        @* <button id="btnLogin" @onclick="ConfirmLogin" class="btn btn-primary" disabled="@(empresas == null)">Iniciar Sesión</button> *@

                    </div>

                }
                <p class="login-support">
                    ¿Necesita ayuda adicional? Contáctenos en
                    <span> support@nombrereal.com </span>
                </p>
            </div>
        </div>
    </div>

</div>
@code {

    public Alert2 alertInfo { get; set; } = new Alert2();

    public class CarouselItem
    {
        public string ImageUrl { get; set; }
        public string Title { get; set; }
        public string Description { get; set; }
    }

    private List<CarouselItem> CarouselItems { get; set; } = new()
    {
        new CarouselItem
        {
            ImageUrl = "/images/img1.svg",
            Title = "",
            Description = ""
        },
        new CarouselItem
        {
            ImageUrl = "/images/img2.svg",
            Title = "Gestión de Talento",
            Description = "Administra el talento de tu organización..."
        },
        new CarouselItem
        {
            ImageUrl = "/images/img3.svg",
            Title = "Eventos y Noticias",
            Description = "Mantente informado sobre las últimas novedades"
        }
    };
    public bool CbEmpresa { get; set; } = false;
    public string user { get; set; } = "00000376";
    public string pass { get; set; } = "eikon";
    public string nombre { get; set; } = " ";
    public string Token { get; set; } = "";
    public string empresa { get; set; } = "01";
    private IEnumerable<LoginDto> login { get; set; } = Enumerable.Empty<LoginDto>();
    private List<DxMnItemDto> MenuItems;
    private IEnumerable<Trhem000Dto> empresas;
    //var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
    //var user = authState.User;
    protected override async Task OnInitializedAsync()
    {
        empresas = new List<Trhem000Dto>();

        // private  IHttpContextAccessor _httpContextAccessor;
        // HttpContext httpContext = null;
        user = "";
        //await JSRuntime.InvokeVoidAsync("sessionStorage.clear");
        //empresas = api.Trhem000PorUsurio(user);
        //httpContext.Session.SetString("token", "s");

        // EikonDataServices eikonDataServices =  null;
    }
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {

        if (firstRender)

        {

            // Solo ejecutar la llamada una vez, cuando el componente se renderiza por primera vez

            // Token = await auth.GetTokenAsync();

            await JSRuntime.InvokeVoidAsync("cookieInterop.deleteCookie", "AuthToken"); // 7 días de expiración

            await JSRuntime.InvokeVoidAsync("sessionStorage.removeItem", "authToken");

            await JSRuntime.InvokeVoidAsync("sessionStorage.clear");


            StateHasChanged();  // Forzar un nuevo renderizado si es necesario

            // api.SetToken(Token);

            login = api.Frhma010Login("xx", "xx", "00");

        }
    }
    private async void ConfirmLogin()
    {
        //var auth = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        try
        {
            login = api.Frhma010Login(user, pass, empresa);
            nombre = login.FirstOrDefault().UsrName;
            api.SetUser(user);
            var authToken = login.FirstOrDefault().UsrTk;

            // Llama al método JS Interop para establecer la cookie
            await JSRuntime.InvokeVoidAsync("cookieInterop.setCookie", "AuthToken", authToken, 1); // 7 días de expiración
            Token = await auth.GetTokenAsync();
            //StateHasChanged();  // Forzar un nuevo renderizado si es necesario
            api.SetToken(Token);
            api.SetTipo(login.FirstOrDefault().Tipo);
            api.SetPa(login.FirstOrDefault().UsrPa);
            api.SetUser(user);
            api.SetEmpresa(login.FirstOrDefault().UsrEm);
            auth.SetToken(Token);
            auth.tkn = Token;
            //auth.Role = login.FirstOrDefault().UsrPa;
            var ruta = "/dash";
            Navigation.NavigateTo(ruta);

        }
        catch (Exception ex)
        {
            nombre = "Ha ocurrido un error verifique sus datos: " + ex;
            alertInfo.Show(nombre);
            return;
            //MenuItems = await api.GetDxMenuForRole("00000000",Token);
        }

    }

    private void Recuperar()
    {
        Navigation.NavigateTo("/recuperar");
    }
    private async Task BuscaEmpresas(ChangeEventArgs e)
    {   
        try {

        empresas = new List<Trhem000Dto>();
        string valor = e.Value?.ToString();
        empresas = await api.Trhem000PorUsurio(valor);
        CbEmpresa = false;
        if(empresas.Count() > 1)
        {
            CbEmpresa=true;
        }
    }
        catch (Exception ex )
        {
            Console.WriteLine($"Error al cargar datos: {ex.Message}");
        }
    }
}