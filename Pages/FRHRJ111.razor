@layout MainLayout
@page "/FRHRJ111"
@inject NavigationManager Navigation

<div class="page">
    <Breadcrumb Title="Corrección individual de Ponches" BackUrl="/dash" />
    <div class="page-header">
        <div class="page-toolbar">
            <Toolbar formulario="FRHxxx999" OnSave="HandleSave" OnClose="HandleClose" />
        </div>
    </div>

    <div class="frhrj111-form">
        <!-- Sección superior: Empleado y Turno -->
        <div class="employee-section">
            <div class="employee-data">
                <div class="input">
                    <label>Empleado</label>
                    <DxTextBox @bind-Text="@Empleado" NullText="">
                        <Buttons>
                            <DxEditorButton IconCssClass="fi fi-rr-search" Click="@OnSearchEmpleado" />
                        </Buttons>
                    </DxTextBox>
                </div>
                <div class="input">
                    <label>Turno</label>
                    <DxTextBox @bind-Text="@Turno" NullText="" />
                </div>
            </div>
            <div class="employee-details">
                <div class="input">
                    <label>Nombre</label>
                    <DxTextBox @bind-Text="@Nombre" NullText="" ReadOnly="true" />
                </div>
            </div>
            <div class="date-range">
                <div class="input">
                    <label>Desde</label>
                    <DxDateEdit @bind-Date="@FechaDesde" DisplayFormat="dd/MM/yyyy" NullText="//">
                    </DxDateEdit>
                </div>
                <div class="input">
                    <label>Hasta</label>
                    <DxDateEdit @bind-Date="@FechaHasta" DisplayFormat="dd/MM/yyyy" NullText="//">
                    </DxDateEdit>
                </div>
            </div>
        </div>

        <!-- Tabs: Ponches y Transacciones Nómina -->
        <div class="tabs-section">
            <DxTabs @bind-ActiveTabIndex="@ActiveTabIndex">
                <DxTabPage Text="Ponches">
                    <div class="tab-content">
                        <!-- Sección Ponches -->
                        <div class="ponches-section">
                            <div class="ponches-content">
                                <div class="ponches-row-single">
                                    <div class="input">
                                        <label>Tipo Asistencia</label>
                                        <DxComboBox Data="@TipoAsistenciaOptions"
                                                    @bind-Value="@TipoAsistenciaSeleccionado"
                                                    TextFieldName="Text"
                                                    ValueFieldName="Value"
                                                    NullText="Seleccionar" />
                                    </div>
                                </div>
                                <div class="ponches-row">
                                    <div class="input">
                                        <label>Fecha Movimiento</label>
                                        <DxDateEdit @bind-Date="@FechaMovimiento" DisplayFormat="dd/MM/yyyy" NullText="//">
                                        </DxDateEdit>
                                    </div>
                                    <div class="input">
                                        <label>Hora</label>
                                        <DxTextBox @bind-Text="@Hora" NullText="" />
                                    </div>
                                </div>
                                <div class="ponches-row-triple">
                                    <div class="checkbox-wrapper">
                                        <DxCheckBox @bind-Checked="@Pagado">Pagado</DxCheckBox>
                                    </div>
                                    <div class="input">
                                        <label>Tipo</label>
                                        <DxComboBox Data="@TipoOptions"
                                                    @bind-Value="@TipoSeleccionado"
                                                    TextFieldName="Text"
                                                    ValueFieldName="Value"
                                                    NullText="" />
                                    </div>
                                    <div class="input">
                                        <label>FechaHora</label>
                                        <div class="validity-period-inputs" style="display:flex;gap:10px;">
                                            <DxDateEdit @bind-Date="@DateTimeValue"
                                                        CssClass="cw-320"
                                                        IconCssClass="fi fi-rr-search"
                                                        InputId="deOverview" />
                                            <DxTimeEdit @bind-Time="@TimeValue"
                                                        CssClass="cw-320"
                                                        InputId="teOverview" />
                                        </div>
                                    </div>
                                </div>
                                <div class="ponches-row">
                                    <div class="input">
                                        <label>Comentario</label>
                                        <DxMemo @bind-Text="@Comentario" Rows="3" NullText="" />
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Grid de datos -->
                        <div class="ponches-grid-section">
                            <DxGrid Data="@PonchesData" CssClass="ponches-data-grid">
                                <Columns>
                                    <DxGridDataColumn FieldName="IdTipo" Caption="IdTipo" Width="80px" />
                                    <DxGridDataColumn FieldName="Descripcion" Caption="Descripción" />
                                    <DxGridDataColumn FieldName="FechaMov" Caption="Fecha Mov"/>
                                    <DxGridDataColumn FieldName="Dia" Caption="Día" />
                                    <DxGridDataColumn FieldName="Hora" Caption="Hora"/>
                                    <DxGridDataColumn FieldName="Pagado" Caption="Pagado" Width="90px" />
                                    <DxGridDataColumn FieldName="Fuente" Caption="Fuente" Width="100px" />
                                    <DxGridDataColumn FieldName="Tipo" Caption="Tipo" Width="100px" />
                                </Columns>
                            </DxGrid>
                        </div>
                    </div>
                </DxTabPage>

                <DxTabPage Text="Transacciones Nómina">
                    <div class="tab-content">
                        <div class="transactions-content">
                            <!-- TODO: Contenido de transacciones nómina -->
                        </div>
                    </div>
                </DxTabPage>
            </DxTabs>
        </div>
    </div>
</div>

@code {
    // **- private string[] // **- ToolbarOptions = { "save", "close" };
    private int ActiveTabIndex { get; set; } = 0;
    private TimeSpan TimeValue { get; set; } = DateTime.Now.TimeOfDay;
    private DateTime DateTimeValue { get; set; } = DateTime.Now;


    // Datos del empleado
    private string Empleado { get; set; } = "";
    private string Nombre { get; set; } = "";
    private string Turno { get; set; } = "";
    private DateTime? FechaDesde { get; set; }
    private DateTime? FechaHasta { get; set; }

    // Ponches
    private string TipoAsistenciaSeleccionado { get; set; } = "";
    private DateTime? FechaMovimiento { get; set; }
    private string Hora { get; set; } = "";
    private bool Pagado { get; set; } = false;
    private string TipoSeleccionado { get; set; } = "";
    private string FechaHoraValue { get; set; } = "";
    private string Comentario { get; set; } = "";

    // Opciones de dropdowns
    private List<OptionItem> TipoAsistenciaOptions { get; set; } = new()
    {
        new() { Value = "1", Text = "Regular" },
        new() { Value = "2", Text = "Extra" },
        new() { Value = "3", Text = "Falta" }
    };

    private List<OptionItem> TipoOptions { get; set; } = new()
    {
        new() { Value = "E", Text = "Entrada" },
        new() { Value = "S", Text = "Salida" }
    };

    // Datos del grid
    private List<PoncheRecord> PonchesData { get; set; } = new();

    private void OnSearchEmpleado()
    {
        // TODO: Implement employee search logic
    }

    private void HandleSave()
    {
        // Lógica para guardar
    }

    private void HandleClose()
    {
        Navigation.NavigateTo("/dash");
    }

    public class OptionItem
    {
        public string Value { get; set; } = "";
        public string Text { get; set; } = "";
    }

    public class PoncheRecord
    {
        public string IdTipo { get; set; } = "";
        public string Descripcion { get; set; } = "";
        public string FechaMov { get; set; } = "";
        public string Dia { get; set; } = "";
        public string Hora { get; set; } = "";
        public string Pagado { get; set; } = "";
        public string Fuente { get; set; } = "";
        public string Tipo { get; set; } = "";
    }
}
