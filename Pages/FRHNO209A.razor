@page "/FRHNO209A"
@layout MainLayout
@inject IJSRuntime JSRuntime

<div class="page">
    <Breadcrumb Title="FRHNO209A - Importar Planes Descuento" BackUrl="/dash" />
    
    <div class="page-header">
        <div class="page-toolbar">
            <Toolbar formulario="FRHxxx999" OnClose="HandleClose" />
        </div>
    </div>

    <div class="form-container">
        <!-- Sección Principal de Campos -->
        <div class="main-section">
            <!-- Primera Fila -->
            <div class="form-row">
                <div class="input-field">
                    <label>Formato</label>
                    <DxTextBox @bind-Text="@FormatoValue"
                               ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Never">
                        <Buttons>
                            <DxEditorButton IconCssClass="fi fi-rr-search" 
                                           Click="@OnSearchFormatoClick" />
                        </Buttons>
                    </DxTextBox>
                </div>
            </div>

            <!-- Segunda Fila -->
            <div class="form-row">
                <div class="input-field">
                    <label>Tipo de Plan</label>
                    <DxComboBox Data="@TipoPlanList" 
                               @bind-Value="@SelectedTipoPlan" 
                               NullText="Seleccionar tipo"
                               TextFieldName="Name" 
                               ValueFieldName="Id" />
                </div>
            </div>

            <!-- Tercera Fila -->
            <div class="form-row">
                <div class="input-field">
                    <label>Fecha</label>
                    <DxDateEdit @bind-Date="@FechaInicio" 
                               NullText="dd/mm/yyyy"
                               ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Never">
                    
                    </DxDateEdit>
                </div>
                <div class="fin-section">
                    <span class="fin-label">Fin</span>
                    <DxDateEdit @bind-Date="@FechaFin" 
                               NullText="dd/mm/yyyy"
                               ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Never">

                    </DxDateEdit>
                </div>
            </div>

            <!-- Cuarta Fila -->
            <div class="form-row full-width">
                <div class="input-field">
                    <label>Archivo</label>
                    <DxTextBox @bind-Text="@ArchivoValue" />
                </div>
            </div>
        </div>

        <!-- Sección de Opciones Centrales -->
        <div class="center-options-section">
            <div class="options-container">
                <!-- Columna Izquierda -->
                <div class="left-column">
                    <DxCheckBox @bind-Checked="@OkOption">Ok</DxCheckBox>
                    <DxCheckBox @bind-Checked="@ErrorEmpleadosOption">Error en Empleados</DxCheckBox>
                    <DxCheckBox @bind-Checked="@ErrorTransaccionesOption">Error en Transacciones</DxCheckBox>
                </div>
                
                <!-- Columna Central -->
                <div class="center-column">
                    <DxCheckBox @bind-Checked="@OkAltOption">Ok</DxCheckBox>
                    <DxCheckBox @bind-Checked="@ErrorEmpOption">Error Emp.</DxCheckBox>
                    <DxCheckBox @bind-Checked="@ErrorTransacOption">Error Transac.</DxCheckBox>
                </div>

                <!-- Columna Derecha con Botones -->
                <div class="right-column">
                    <div class="aplicar-label">
                        <span>Aplicar a planes</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Sección de Estados -->
        <div class="status-section">
            <div class="status-checkboxes">
                <DxCheckBox @bind-Checked="@RegularOption">Regular</DxCheckBox>
                <DxCheckBox @bind-Checked="@TemporeroOption">Temporero</DxCheckBox>
                <DxCheckBox @bind-Checked="@ExempleadoOption">Exempleado</DxCheckBox>
                <DxCheckBox @bind-Checked="@PensionadosOption">Pensionados</DxCheckBox>
            </div>
        </div>

        <!-- Sección de Reporte -->
        <div class="report-section">
            <div class="report-controls">
                <div class="input-field wide">
                    <label>Reporte</label>
                    <DxTextBox @bind-Text="@ReporteValue" />
                </div>
                <div class="report-actions">
                    <DxButton IconCssClass="fi fi-rr-print" 
                             CssClass="icon-btn info-btn" 
                             Click="@OnPrintReportClick" />
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* Container principal */
    .form-container {
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    /* Sección principal */
    .main-section {
        display: flex;
        flex-direction: column;
        gap: 15px;
        padding: 20px;
        border: 1px solid transparent;
        border-radius: 8px;
    }

    /* Form rows */
    .form-row {
        display: flex;
        gap: 20px;
        align-items: flex-end;
    }

    .form-row.full-width {
        width: 100%;
    }

    /* Input fields con label arriba */
    .input-field {
        display: flex;
        flex-direction: column;
        gap: 5px;
        flex: 1;
    }

    .input-field label {
        font-weight: normal;
        color: #333;
        font-size: 14px;
    }

    .input-field.wide {
        flex: 2;
    }

    /* Sección Fin para fecha */
    .fin-section {
        display: flex;
        flex-direction: column;
        gap: 5px;
        flex: 1;
    }

    .fin-label {
        font-weight: normal;
        color: #333;
        font-size: 14px;
    }

    /* Sección de opciones centrales */
    .center-options-section {
        border: 1px solid #e0e0e0;
        border-radius: 8px;
        padding: 20px;
    }

    .options-container {
        display: flex;
        gap: 30px;
        align-items: flex-start;
    }

    .left-column,
    .center-column {
        display: flex;
        flex-direction: column;
        gap: 12px;
        flex: 1;
    }

    .right-column {
        display: flex;
        flex-direction: column;
        gap: 15px;
        align-items: center;
        flex: 1;
    }

    .action-buttons {
        display: flex;
        gap: 8px;
    }

    .aplicar-label {
        font-weight: 500;
        color: #333;
        font-size: 14px;
        text-align: center;
    }

    /* Sección de estados */
    .status-section {
        border: 1px solid #e0e0e0;
        border-radius: 8px;
        padding: 20px;
    }

    .status-checkboxes {
        display: flex;
        gap: 25px;
        justify-content: flex-start;
        flex-wrap: wrap;
    }

    /* Sección de reporte */
    .report-section {
        border: 1px solid #e0e0e0;
        border-radius: 8px;
        padding: 20px;
    }

    .report-controls {
        display: flex;
        gap: 15px;
        align-items: flex-end;
    }

    .report-actions {
        display: flex;
        gap: 8px;
    }

    /* Botones de acción */
    .action-btn {
        width: 32px;
        height: 32px;
        min-width: 32px;
        padding: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 6px;
    }

    .icon-btn {
        width: 32px;
        height: 32px;
        min-width: 32px;
        padding: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 6px;
    }

    .success-btn {
        background-color: #28a745;
        border-color: #28a745;
        color: white;
    }

    .success-btn:hover {
        background-color: #218838;
        border-color: #1e7e34;
    }

    .error-btn {
        background-color: #dc3545;
        border-color: #dc3545;
        color: white;
    }

    .error-btn:hover {
        background-color: #c82333;
        border-color: #bd2130;
    }

    .info-btn {
        background-color: #17a2b8;
        border-color: #17a2b8;
        color: white;
    }

    .info-btn:hover {
        background-color: #138496;
        border-color: #117a8b;
    }

    .secondary-btn {
        background-color: #6c757d;
        border-color: #6c757d;
        color: white;
    }

    .secondary-btn:hover {
        background-color: #5a6268;
        border-color: #545b62;
    }

    /* Estilos para DevExpress Components */
    .dx-textbox,
    .dx-combobox,
    .dx-date-edit {
        border-radius: 6px !important;
    }

    .dx-textbox-container,
    .dx-combobox-container,
    .dx-date-edit-container {
        border: 1px solid #ced4da !important;
        border-radius: 6px !important;
    }

    .dx-textbox-container:focus-within,
    .dx-combobox-container:focus-within,
    .dx-date-edit-container:focus-within {
        border-color: #007bff !important;
        box-shadow: 0 0 0 0.2rem rgba(0, 123, 255, 0.25) !important;
    }

    /* Responsive Design */
    media (max-width: 768px) {
        .main-section,
        .center-options-section,
        .status-section,
        .report-section {
            padding: 15px;
        }

        .form-row {
            flex-direction: column;
            gap: 15px;
        }

        .options-container {
            flex-direction: column;
            gap: 20px;
            align-items: stretch;
        }

        .right-column {
            align-items: stretch;
        }

        .action-buttons {
            justify-content: center;
        }

        .status-checkboxes {
            flex-direction: column;
            gap: 15px;
        }

        .report-controls {
            flex-direction: column;
            align-items: stretch;
            gap: 15px;
        }

        .report-actions {
            justify-content: center;
        }
    }

    media (max-width: 480px) {
        .form-container {
            gap: 15px;
        }

        .main-section,
        .center-options-section,
        .status-section,
        .report-section {
            padding: 15px;
        }

        .options-container {
            gap: 15px;
        }

        .action-btn,
        .icon-btn {
            width: 28px;
            height: 28px;
            min-width: 28px;
        }

        .status-checkboxes {
            gap: 12px;
        }
    }
</style>

@code {
    // **- private string[] // **- ToolbarOptions = { "add", "save", "remove", "leave" };
    
    // Campos del formulario
    private string FormatoValue { get; set; } = "";
    private int? SelectedTipoPlan { get; set; }
    private DateTime? FechaInicio { get; set; }
    private DateTime? FechaFin { get; set; }
    private string ArchivoValue { get; set; } = "";
    private string ReporteValue { get; set; } = "";
    
    // Opciones de checkboxes - columna izquierda
    private bool OkOption { get; set; } = false;
    private bool ErrorEmpleadosOption { get; set; } = false;
    private bool ErrorTransaccionesOption { get; set; } = false;
    
    // Opciones de checkboxes - columna central
    private bool OkAltOption { get; set; } = false;
    private bool ErrorEmpOption { get; set; } = false;
    private bool ErrorTransacOption { get; set; } = false;
    
    // Estados de empleados
    private bool RegularOption { get; set; } = true;
    private bool TemporeroOption { get; set; } = true;
    private bool ExempleadoOption { get; set; } = true;
    private bool PensionadosOption { get; set; } = true;
    
    // Listas de datos
    private List<TipoPlanItem> TipoPlanList = new List<TipoPlanItem>
    {
        new TipoPlanItem { Id = 1, Name = "PLAN DESCUENTO FIJO" },
        new TipoPlanItem { Id = 2, Name = "PLAN DESCUENTO PORCENTUAL" },
        new TipoPlanItem { Id = 3, Name = "PLAN PRESTAMO" },
        new TipoPlanItem { Id = 4, Name = "PLAN AHORRO" },
        new TipoPlanItem { Id = 5, Name = "PLAN ESPECIAL" }
    };
    
    public class TipoPlanItem
    {
        public int Id { get; set; }
        public string Name { get; set; } = "";
    }
    
    private void OnSearchFormatoClick()
    {
        Console.WriteLine($"Buscando formato: {FormatoValue}");
    }
    
    private void OnDatePickerClick()
    {
        Console.WriteLine("Abriendo selector de fecha inicio");
    }
    
    private void OnDateFinPickerClick()
    {
        Console.WriteLine("Abriendo selector de fecha fin");
    }
    
    private void OnValidateClick()
    {
        Console.WriteLine("Validando importación de planes");
    }
    
    private void OnCancelClick()
    {
        Console.WriteLine("Cancelando importación de planes");
    }
    
    private void OnSettingsClick()
    {
        Console.WriteLine("Abriendo configuración de planes");
    }
    
    private void OnPrintReportClick()
    {
        Console.WriteLine("Imprimiendo reporte de planes");
    }
    
    private async Task HandleClose()
    {
        await JSRuntime.InvokeVoidAsync("alert", "¡Importación de Planes de Descuento guardada!");
    }
}