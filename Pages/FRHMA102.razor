<style>
    /* Container principal */
    .form-container {
        display: flex;
        flex-direction: column;
        gap: 20px;
        margin-top: 10px;
    }

    /* Filas del formulario */
    .form-row {
        display: flex;
        gap: 15px;
        align-items: flex-end;
    }

    .separator-row {
        display: flex;
        align-items: center;
        gap: 15px;
    }

    .separator-line {
        flex: 1;
        height: 1px;
        background-color: #bfbfbf;
    }

    /* Campos de input con label arriba */
    .input-field {
        display: flex;
        flex-direction: column;
        gap: 5px;
    }

    .input-field label {
        font-weight: normal;
        color: #333;
        font-size: 14px;
    }

    /* Tamaños de campos */
    .input-field.full-width {
        flex: 1;
    }

    .input-field.narrow {
        flex: 0 0 200px;
    }

    .input-field.wide {
        flex: 1;
    }

    .input-field.equal {
        flex: 1;
    }

    /* Sección principal con dos columnas */
    .main-section {
        display: flex;
        gap: 30px;
        margin-top: 15px;
    }

    .left-column,
    .right-column {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 20px;
        min-height: 280px; /* Altura mínima igual para ambas columnas */
    }

    .left-column {
        padding: 15px;
        border: 1px solid #e0e0e0;
        border-radius: 8px;
        background-color: transparent;
    }

    /* Status section para igualar alturas */
    .status-section {
        display: flex;
        flex-direction: column;
        gap: 15px;
        height: 100%;
    }

    /* Perfil con iconos */
    .perfil-container {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .perfil-input {
        flex: 1;
    }

    .perfil-actions {
        display: flex;
        gap: 4px;
    }

    .icon-btn {
        width: 32px;
        height: 32px;
        min-width: 32px;
        padding: 0;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .success-btn {
        background-color: #28a745;
        border-color: #28a745;
        color: white;
    }

    .success-btn:hover {
        background-color: #218838;
        border-color: #1e7e34;
    }

    .error-btn {
        background-color: #dc3545;
        border-color: #dc3545;
        color: white;
    }

    .error-btn:hover {
        background-color: #c82333;
        border-color: #bd2130;
    }

    /* Radio buttons en línea */
    .radio-inline {
        display: flex;
        gap: 15px;
        align-items: center;
        margin-top: 5px;
    }

    /* Network Status field - con border pero sin fondo */
    .network-status-field {
        padding: 15px;
        border: 1px solid #e0e0e0;
        border-radius: 8px;
        background-color: transparent;
    }

    /* Status container - solo para Estatus y Extensión */
    .status-container {
        display: flex;
        flex-direction: column;
        gap: 15px;
        padding: 15px;
        border: 1px solid #e0e0e0;
        border-radius: 8px;
        flex: 1;
    }

    /* Tabla */
    .table-section {
        margin-top: 20px;
    }

    .empresa-perfil-grid {
        width: 100%;
        max-height: 200px;
    }

    /* Responsive */
    media (max-width: 768px) {
        .form-row {
            flex-direction: column;
            gap: 10px;
        }

        .input-field.narrow,
        .input-field.wide,
        .input-field.equal {
            flex: 1;
        }

        .main-section {
            flex-direction: column;
            gap: 20px;
        }

        .left-column,
        .right-column {
            min-height: auto;
        }
    }
</style>

