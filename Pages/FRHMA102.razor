    private  bool validarPass()
    {
        if (string.IsNullOrWhiteSpace(trhps000DtoSelected.StrPass) && string.IsNullOrWhiteSpace(trhps000DtoSelected.StrPassConf))
            return true;

        // Si solo uno está vacío → error
        if (string.IsNullOrWhiteSpace(trhps000DtoSelected.StrPass) || string.IsNullOrWhiteSpace(trhps000DtoSelected.StrPassConf))
        {
            JS.InvokeVoidAsync("alert", "Ambos campos deben completarse si se define una contraseña.");
            return false;
        }

        // Validar longitud mínima
        if (trhps000DtoSelected.StrPass.Length < 5)
        {
            JS.InvokeVoidAsync("alert", "La contraseña debe tener al menos 5 caracteres.");
            return false;
        }

        // Validar coincidencia
        if (trhps000DtoSelected.StrPass != trhps000DtoSelected.StrPassConf)
        {
            JS.InvokeVoidAsync("alert", "Las contraseñas no coinciden.");
            return false;
        }
        return true;
    }
