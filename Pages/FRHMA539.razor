@layout MainLayout
@page "/FRHMA539"
@using EIKON.UI.Components
@using DevExpress.Blazor
@using DevExpress.Blazor.Base
@using System.Net.Http.Json
@using System.Net.Http.Headers
@using EIKON.UI.Interfaces
@using DevExpress.AspNetCore.Reporting
@using DevExpress.XtraReports.UI
@using System.ComponentModel.DataAnnotations

@inject NavigationManager nv
@inject IJSRuntime JSRuntime

<div class="page">
    <Breadcrumb Title="FRHMA539 - Análisis de recursos Humanos" BackUrl="/dash" />
    <div class="page-header">
        <div class="page-toolbar">
            <Toolbar formulario="FRHxxx999" OnSave="HandleSave" OnClose="HandleClose" />
        </div>
    </div>
    <div class="frhma539-form">

        <!-- Header Row: Código + Nombre + Activo -->
        <div class="header-row">
            <div class="codigo-nombre-row">
                <div class="input codigo-field">
                    <label>Código</label>
                    <DxTextBox @bind-Text="@Codigo">
                        <Buttons>
                            <DxEditorButton IconCssClass="fi fi-rr-search" Click="@OnSearchCodigo" />
                        </Buttons>
                    </DxTextBox>
                </div>
                <div class="input nombre-field">
                    <label>Nombre</label>
                    <DxTextBox @bind-Text="@Nombre">
                        <Buttons>
                            <DxEditorButton IconCssClass="fi fi-rr-search" Click="@OnSearchNombre" />
                        </Buttons>
                    </DxTextBox>
                </div>
            </div>
            <div class="activo-checkbox">
                <DxCheckBox @bind-Checked="@Activo">Activo</DxCheckBox>
            </div>
        </div>

        <!-- Checkboxes Grid (3x3) -->
        <div class="checkboxes-grid">
            <!-- Row 1 -->
            <DxCheckBox @bind-Checked="@SolicitudExterna" CssClass="grid-checkbox">Solicitud Externa</DxCheckBox>
            <DxCheckBox @bind-Checked="@Entrevistas" CssClass="grid-checkbox">Entrevistas</DxCheckBox>
            <DxCheckBox @bind-Checked="@Reclutador" CssClass="grid-checkbox">Reclutador</DxCheckBox>

            <!-- Row 2 -->
            <DxCheckBox @bind-Checked="@SolicitudInterna" CssClass="grid-checkbox">Solicitud Interna</DxCheckBox>
            <DxCheckBox @bind-Checked="@PruebasPsicometricas" CssClass="grid-checkbox">Pruebas Psicométricas</DxCheckBox>
            <DxCheckBox @bind-Checked="@InvestigacionReferencias" CssClass="grid-checkbox">Investigación de Referencias</DxCheckBox>

            <!-- Row 3 -->
            <DxCheckBox @bind-Checked="@Reclutamientos" CssClass="grid-checkbox">Reclutamientos</DxCheckBox>
            <DxCheckBox @bind-Checked="@ExamenMedico" CssClass="grid-checkbox">Examen Médico</DxCheckBox>
            <DxCheckBox @bind-Checked="@TrabajoSocial" CssClass="grid-checkbox">Trabajo Social</DxCheckBox>
        </div>

        <!-- EMPRESA Section -->
        <div class="empresa-section">
            <label class="section-label">EMPRESA</label>
            <DxMemo @bind-Text="@Proceso"
                    Rows="6"
                    NullText="Ingrese comentarios sobre empresa"
                    CssClass="comment-field" />
        </div>

        <!-- Notificaciones Section -->
        <div class="notificaciones-section">
            <label class="section-label">Notificaciones</label>
            <div class="input">
                <label>Proceso</label>
                <DxMemo @bind-Text="@Proceso"
                        Rows="8"
                        NullText="Proceso"
                        CssClass="proceso-memo" />
            </div>
        </div>

    </div>
</div>

@code {
    // **- private string[] // **- ToolbarOptions = { "save", "close" };

    // Header fields
    private string Codigo { get; set; } = string.Empty;
    private string Nombre { get; set; } = string.Empty;
    private bool Activo { get; set; } = false;

    // Checkboxes - Row 1
    private bool SolicitudExterna { get; set; } = false;
    private bool Entrevistas { get; set; } = false;
    private bool Reclutador { get; set; } = false;

    // Checkboxes - Row 2
    private bool SolicitudInterna { get; set; } = false;
    private bool PruebasPsicometricas { get; set; } = false;
    private bool InvestigacionReferencias { get; set; } = false;

    // Checkboxes - Row 3
    private bool Reclutamientos { get; set; } = false;
    private bool ExamenMedico { get; set; } = false;
    private bool TrabajoSocial { get; set; } = false;

    // Notificaciones
    private string Proceso { get; set; } = string.Empty;

    private void OnSearchCodigo() { }
    private void OnSearchNombre() { }
    private void HandleSave() { }

    private void HandleClose()
    {
        nv.NavigateTo("/dash");
    }
}
