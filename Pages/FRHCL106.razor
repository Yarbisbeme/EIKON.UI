@page "/FRHCL106"

@inject NavigationManager nv;
@inject HttpClient HttpClient
@inject EIKON.UI.Services.EikonDataServices api
@inject EIKON.UI.Services.AuthenticationService auth

<PageTitle>Grupos</PageTitle>
<head>
    <style>
        .hidden {
            display: none;
        }
    </style>
</head>

@if (data == null)
{
    <p><em>Loading...</em></p>
}
    <ConfirmDialog @ref="confirmDialog" Title="Confirmar Eliminación"
                   Message="¿Seguro deseas eliminar este Grupo Ocupacional?"
                   OnConfirm="OnConfirmDelete" />

    <DxTabs ActiveTabIndex="@ActiveTabIndex" ActiveTabIndexChanged="@OnActiveTabIndexChanged">
        <DxTabPage Text="Mantenimiento">
            <div class="header">
                <div style="display:flex;width:auto;gap:20px;">
                    <Breadcrumb Title="Grupos Ocupacionales" BackUrl="/dash" />
                </div>
                <Toolbar formulario="FRHCL106" OnProccess="BuscarGrupo" OnAdd="Agregar" OnSave="Guarda" OnRemove="Eliminar" OnAudit="OnAuditPopup" />
            </div>
            <div class="form-container">
                <!-- Primera Fila - Código y Descripción -->
                <div class="form-row">
                    <div class="input-field">
                        <label>Código</label>
                        <DxTextBox @bind-Text="@editModel.GrCodigo" ReadOnly
                                   ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Never">
                            <Buttons>
                                <DxEditorButton IconCssClass="fi fi-rr-search"
                                                Click="BuscarGrupo" />
                            </Buttons>
                        </DxTextBox>
                    </div>
                    <div class="input-field wide">
                        <label>Descripción</label>
                        <DxTextBox @bind-Text="@editModel.GrDescri" />
                    </div>
                </div>

                <!-- Segunda Fila - Creado, Activo y Toolbar lateral -->
                <div class="form-row-with-sidebar">
                    <div class="input-fields-section">
                        <div class="form-row">
                            <div class="input-field">
                                <label>Creado</label>
                                <div class="date-with-button">
                                    <DxDateEdit @bind-Date="@editModel.GrDesde"
                                                DisplayFormat="d"
                                                NullText="--/--/----" />
                                </div>
                            </div>
                            <div class="checkbox-field">
                                <DxCheckBox @bind-Checked="@editModel.GrEstatus">Activo</DxCheckBox>
                            </div>
                        </div>

                        <div class="form-row">
                            <div class="input-field">
                                <label>Vigencia</label>
                                <div class="date-with-button">
                                    <DxDateEdit @bind-Date="@editModel.GrHasta"
                                                DisplayFormat="d"
                                                NullText="--/--/----" />
                                </div>
                            </div>
                            <div class="checkbox-field">
                                <DxCheckBox @bind-Checked="@editModel.GrIndReq">¿Puede este grupo hacer requisición?</DxCheckBox>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </DxTabPage>
        <DxTabPage Text="Búsqueda de Grupos Ocupacionales">
            <div class="header">
                <div style="display:flex;width:auto;gap:20px;">
                    <Breadcrumb Title="Grupos Ocupacionales" BackUrl="/dash" />
                </div>
            </div>
            <DxGrid Data="@data" @ref="MyGrid"
                    CssClass="mw-1100"
                    EditMode="GridEditMode.EditRow"
                    ShowFilterRow="true" FilterRowCondition="GridFilterRowCondition.Equals">
                <Columns>
                    <DxGridCommandColumn Width="160px" VisibleIndex="1">
                        <CellDisplayTemplate>
                            <a @onclick="@(() => ShowEditRecord((Trhgr010Dto)context.DataItem))" style="text-decoration: none;" href="javascript:void(0);"><i class="fi fi-rr-edit"></i></a>
                        </CellDisplayTemplate>
                    </DxGridCommandColumn>
                    <DxGridDataColumn Caption="GrupoId" FieldName="GrCodigo" Width="80px" VisibleIndex="3" />
                    <DxGridDataColumn Caption="Descripción" FieldName="GrDescri" Width="300px" VisibleIndex="4" />
                    <DxGridDataColumn Caption="Puede Requizar" FieldName="GrIndReq" VisibleIndex="7" Width="130px" />
                    <DxGridDataColumn Caption="Activo" FieldName="GrEstatus" VisibleIndex="8" Width="130px" />
                </Columns>
                <ToolbarTemplate>
                    <DxToolbar>
                        <DxToolbarItem Text="Export to XLSX" Click="ExportXlsx_Click" BeginGroup="true" />
                        <DxToolbarItem Context="itemCtx" Alignment="ToolbarItemAlignment.Right" BeginGroup="true">
                            <Template>
                                <DxCheckBox @bind-Checked="@ExportSelectedRowsOnly">Export Selected Rows Only</DxCheckBox>
                            </Template>
                        </DxToolbarItem>
                    </DxToolbar>
                </ToolbarTemplate>
            </DxGrid>
        </DxTabPage>
    </DxTabs>
