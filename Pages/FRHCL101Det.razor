<PageTitle>Creacion de Cargos</PageTitle>
<h1>Mantenimiento Cargos...</h1>
<Alert2 @ref="alertInfo" TypeAlert="info" Message="Creación de Puestos" />

<DxTabs ActiveTabIndex="@ActiveTabIndex" ActiveTabIndexChanged="@OnActiveTabIndexChanged">
<DxTabPage Text="Mantenimiento">
        <div class="W-100">

            
            <div class="header">
                <span style="font-size:16px; font-weight:300;" class="eikon-primary-text">@Encabezado</span>
                <div style="display:flex; gap:10px">
                </div>

                <Toolbar formulario="FRHxxx999" OnAdd="Agregar" OnSave="Guardar" OnRemove="Eliminar" />
            </div>
        </div>
        <div class="separador">
            <hr />
        </div>
        <div class="container">

            <EditForm data-bind="@SelectedItem" Model="SelectedItem">

                <div class="row">
                    <div class="form-group col-md-4">
                        <label for="puenume">Puesto</label>
                        <DxTextBox id="puenume" @bind-Text="@SelectedItem.Puenume"></DxTextBox>
                    </div>
                    <div class="form-group col-md-4">
                        <label for="puetitu">Título</label>
                        <DxTextBox id="puetitu" @bind-Text="@SelectedItem.Puetitu"></DxTextBox>
                    </div>
                    <div class="form-group col-md-2">
                        <label for="reqnume">Requisición</label>
                        <DxTextBox id="reqnume" @bind-Text="@SelectedItem.Reqnume"></DxTextBox>
                    </div>
                    <div class="form-group col-md-2">
                        <label for="btnBuscar">Buscar Requisición</label>
                        <DxButton Id="btnBuscar" Click="Consulta" Text="Buscar" class="btn btn-info"></DxButton>
                    </div>

                </div>
                <div class="row">

                    <div class="form-group  col-md-4">
                        <label for="Oficina">Oficina</label>
                        <DxComboBox id="Oficina" Data="@oficinas" ValueFieldName="OfCodigo" TextFieldName="OfDescri" @bind-Value="SelectedItem.OfCodigo"></DxComboBox>
                    </div>

                    <div class="form-group  col-md-4">
                        <label for="Ubicacion">Departamento</label>
                        <DxComboBox id="Ubicacion" Data="@ubicaciones" ValueFieldName="UbCodigo" TextFieldName="UbDescri" @bind-Value="SelectedItem.UbCodigo"></DxComboBox>
                    </div>
                    <div class="form-group  col-md-4">
                        <label for="Puesto">Puesto</label>
                        <DxComboBox id="Puesto" Data="@puestos" ValueFieldName="JoNumber" TextFieldName="JoTitulo" @bind-Value="SelectedItem.JoNumber"></DxComboBox>
                    </div>


                </div>
                <div class="row">

                    <div class="form-group  col-md-4">
                        <label for="Clase">Clase</label>
                        <DxComboBox id="Clase" Data="@clases" ValueFieldName="NpCodigo" TextFieldName="NpDescri" @bind-Value="SelectedItem.NpCodigo"></DxComboBox>
                    </div>

                    <div class="form-group  col-md-4">
                        <label for="Categoria">Categoria</label>
                        <DxComboBox id="Categoria" Data="@categorias" ValueFieldName="CtCodigo" TextFieldName="CtDescri" @bind-Value="clase_np.CtCodigo"></DxComboBox>
                    </div>
                    <div class="form-group col-md-4">
                        <label for="create">Fecha Creacion</label>
                        <DxDateEdit id="create" @bind-Date="@SelectedItem.ChangedOn"></DxDateEdit>
                    </div>


                </div>

                <div class="row">

                    <div class="form-group  col-md-4">
                        <label for="sEntrada">Sueldo Entrada</label>
                        <DxSpinEdit id="sEntrada" @bind-Value="@categoria_np.Minent" Mask="n2"></DxSpinEdit>
                    </div>

                    <div class="form-group  col-md-4">
                        <label for="pPrueba">Perido de Prueba en Meses</label>
                        <DxSpinEdit id="pPrueba" @bind-Value="@clase_np.NpPeriodo" Mask="@NumericMask.WholeNumber"></DxSpinEdit>
                    </div>
                    <div class="form-group col-md-4">
                        <label for="presupuesto">Presupuesto</label>
                        <DxSpinEdit id="presupuesto" @bind-Value="@categoria_np.Ptomedio" Mask="n2"></DxSpinEdit>
                    </div>


                </div>

                <div class="row">
                    <div class="form-group col-md-12">
                        <label for="puevaca">Estatus</label>
                        <DxRadioGroup Id="puevaca" CssClass="dxbl-text-edit"
                                      Items="@estatus"
                                      TextFieldName="Text"
                                      ValueFieldName="Value"
                                      @bind-Value="@SelectedItem.Puevaca"
                                      Layout="RadioGroupLayout.Horizontal">
                        </DxRadioGroup>

                    </div>
                </div>

