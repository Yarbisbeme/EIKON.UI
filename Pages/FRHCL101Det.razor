@if (data == null)
{
    <p><em>Loading...</em></p>
}
else
{
    <DxGrid Data="@data" @ref="MyGrid"
            CssClass="mw-1100"
            EditModelSaving="OnEditModelSaving"
                EditMode="GridEditMode.EditRow"
            RowClick="OnRowClick">
        <Columns>
            <DxGridCommandColumn Width="60px" VisibleIndex="2">
                <HeaderTemplate>
                    <a class="text-primary" @onclick="@(() => MyGrid.StartEditNewRowAsync())" style="text-decoration: none;" href="javascript:void(0);"><i class="fi fi-rr-plus"></i></a>
                </HeaderTemplate>
                <CellDisplayTemplate>
                    <a class="text-primary" @onclick="@(() => MyGrid.SelectDataItem(context.DataItem))" style="text-decoration: none;" href="javascript:void(0);"><i class="fi fi-rr-edit"></i></a>
                </CellDisplayTemplate>
               </DxGridCommandColumn>
            <DxGridDataColumn Caption="Id" FieldName="Puenume" Width="100px" VisibleIndex="3" />
            <DxGridDataColumn Caption="Descripción" FieldName="Puetitu" Width="300px" VisibleIndex="4" />
           
            @* <DxGridDataColumn FieldName="OfCodigo" Caption="ID Oficina"/> *@
            <DxGridDataColumn Caption="Oficina" FieldName="OfCodigo" Width="160px" VisibleIndex="5">
                <EditSettings>
                    <DxComboBoxSettings Data="oficinas"
                                        ValueFieldName="OfCodigo"
                                        TextFieldName="OfDescri"
                                        FilteringMode="DataGridFilteringMode.Contains"
                                        ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                                        EditFormat="{1} {2}">
                        <Columns>
                            <DxListEditorColumn FieldName="ofCodigo" Caption="Código" />
                            <DxListEditorColumn FieldName="OfDescri" Caption="Descripción" />
                            <DxListEditorColumn FieldName="EmCodigo" Caption="Empresa" Width="60px" />
                        </Columns>
                    </DxComboBoxSettings>
                </EditSettings>
            </DxGridDataColumn>
            @* <DxGridDataColumn FieldName="UbCodigo" Caption="ID Ubicac" /> *@
            <DxGridDataColumn Caption="Departamento" FieldName="UbCodigo" Width="260px" VisibleIndex="6">
                <EditSettings>
                    <DxComboBoxSettings Data="ubicaciones"
                                        ValueFieldName="UbCodigo"
                                        TextFieldName="UbDescri"
                                        FilteringMode="DataGridFilteringMode.Contains"
                                        ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                                        EditFormat="{1} {2}">
                        <Columns>
                            <DxListEditorColumn FieldName="UbCodigo" Caption="Código" />
                            <DxListEditorColumn FieldName="UbDescri" Caption="Descripción" />
                            <DxListEditorColumn FieldName="EmCodigo" Caption="Empresa" Width="60px" />
                        </Columns>
                    </DxComboBoxSettings>
                </EditSettings>
            </DxGridDataColumn>
@*             <DxGridDataColumn FieldName="JoNumber" Caption="Id Puesto" />
 *@            <DxGridDataColumn Caption="Puesto" FieldName="JoNumber" Width="260px" VisibleIndex="7">
                <EditSettings>
                    <DxComboBoxSettings Data="puestos"
                                        ValueFieldName="JoNumber"
                                        TextFieldName="JoTitulo"
                                        ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                                        EditFormat="{1} {2}">
                        <Columns>
                            <DxListEditorColumn FieldName="JoNumber" Caption="Código" />
                            <DxListEditorColumn FieldName="JoTitulo" Caption="Descripción" />
                            <DxListEditorColumn FieldName="EmCodigo" Caption="Empresa" Width="60px" />
                        </Columns>
                    </DxComboBoxSettings>
                </EditSettings>
            </DxGridDataColumn>
            <DxDataGridColumn FieldName="IdentityColumn" Width="150px" Caption="#">
                
            </DxDataGridColumn>
             <!-- Columna para el botón -->
        



        </Columns>
    </DxGrid>
    
}
