@page "/FRHCL109"

@inject NavigationManager nv;
@inject HttpClient HttpClient
@inject EIKON.UI.Services.EikonDataServices api
@inject EIKON.UI.Services.AuthenticationService auth
@inject IJSRuntime JSRuntime
<PageTitle>Creación de Departamentos/Ubicaciones</PageTitle>
@* <h1>Mantenimiento de Departamentos/Ubicaciones...</h1>
 *@
@if (data == null)
{
    <p><em>Loading...</em></p>
}
else
{
    <Alert2 @ref="alertInfo" TypeAlert="info" Message="Creación de Departamentos" />

 <DxTabs ActiveTabIndex="@ActiveTabIndex" ActiveTabIndexChanged="@OnActiveTabIndexChanged">
        <DxTabPage Text="Formulario">
            <div class="header">

                <div style="display:flex;width:auto;gap:20px;">
                    <Breadcrumb Title="Departamentos / Ubicaciones" BackUrl="/dash" />
                </div>

                <Toolbar formulario="FRHCL109" OnProccess="BuscarOfic" OnAdd="Agregar" OnSave="Guarda" OnRemove="Eliminar" OnLeave="CargarDatos" />

            </div>

            <EditForm data="@Departamentoseleccionada" Model="Departamentoseleccionada" Context="EdtForm">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <DxFormLayout>

                    <DxFormLayoutItem Caption="Id Ubicación" ColSpanLg="4">
                        <DxTextBox id="Ubicaciónid" @bind-Text="Departamentoseleccionada.UbCodigo"
                                   ValidationEnabled="true"
                                   ShowValidationIcon="true"
                                   ShowValidationSuccessState="true"
                                   ReadOnly="true"
                                   
                                   ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Never">
                            <Buttons>
                                <DxEditorButton IconCssClass="fi fi-rr-search"
                                                Click="@BuscarOfic" />
                            </Buttons>
                        </DxTextBox>
                    </DxFormLayoutItem>

                    <DxFormLayoutItem Caption="Descripción" ColSpanLg="4">
                        <DxTextBox @bind-Text="Departamentoseleccionada.UbDescri" />
                    </DxFormLayoutItem>

                    <DxFormLayoutItem Caption="Descripción Alterna" ColSpanLg="4">
                        <DxTextBox @bind-Text="Departamentoseleccionada.UbDesalterno" />
                    </DxFormLayoutItem>

                    <DxFormLayoutItem Caption="Centro de Costo" ColSpanLg="4">
                        <DxComboBox Data="tipoUbicación"
                                    ValueFieldName="CcCodigo"
                                    TextFieldName="CcDescri"
                                    ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                                    EditFormat="{1} {2}"
                                    SearchMode="@ListSearchMode.AutoSearch"
                                    SearchFilterCondition="@ListSearchFilterCondition.Contains"
                                    @bind-Value="Departamentoseleccionada.CcCodigo">
                            <Columns>
                                <DxListEditorColumn FieldName="CcCodigo" Caption="Código" />
                                <DxListEditorColumn FieldName="CcDescri" Caption="Descripción" />
                            </Columns>
                        </DxComboBox>

                    </DxFormLayoutItem>

                    <DxFormLayoutItem Caption="Jerarquía" ColSpanLg="4">
                        <DxComboBox Data="provincias"
                                    ValueFieldName="JaCodigo"
                                    TextFieldName="JaDescri"
                                    ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                                    EditFormat="{1} {2}"
                                    SearchMode="@ListSearchMode.AutoSearch"
                                    SearchFilterCondition="@ListSearchFilterCondition.Contains"
                                    @bind-Value="Departamentoseleccionada.JaCodigo">
                            <Columns>
                                <DxListEditorColumn FieldName="JaCodigo" Caption="Código" />
                                <DxListEditorColumn FieldName="JaDescri" Caption="Descripción" />
                            </Columns>
                        </DxComboBox>
                    </DxFormLayoutItem>

                    <DxFormLayoutItem Caption="Empresa" ColSpanLg="4">
                        <DxComboBox Data="regionales"
                                    ValueFieldName="EmCodigo"
                                    TextFieldName="EmDescri"
                                    ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                                    EditFormat="{0} {1}"
                                    SearchMode="@ListSearchMode.AutoSearch"
                                    SearchFilterCondition="@ListSearchFilterCondition.Contains"
                                    @bind-Value="Departamentoseleccionada.EmEmpresa">
                            <Columns>
                                <DxListEditorColumn FieldName="EmCodigo" Caption="Código" />
                                <DxListEditorColumn FieldName="EmDescri" Caption="Descripcion" />
                            </Columns>
                        </DxComboBox>
                    </DxFormLayoutItem>

                    

                    <DxFormLayoutItem Caption="Teléfono" ColSpanLg="3">
                        <DxTextBox @bind-Text="Departamentoseleccionada.UbPhone" />
                    </DxFormLayoutItem>
                    <DxFormLayoutItem Caption="Extensión" ColSpanLg="3">
                        <DxMemo @bind-Text="Departamentoseleccionada.UbExtension" Rows="3" />
                    </DxFormLayoutItem>

                    <DxFormLayoutItem Caption="Desde" ColSpanLg="3">
                        <DxDateEdit @bind-Date="Departamentoseleccionada.UbDesde" />
                    </DxFormLayoutItem>

                    <DxFormLayoutItem Caption="Hasta" ColSpanLg="3">
                        <DxDateEdit @bind-Date="Departamentoseleccionada.UbHasta" />
                    </DxFormLayoutItem>                    

                    <DxFormLayoutItem Caption="Estatus" ColSpanLg="2">
                        <DxCheckBox @bind-Checked="IsActive" Text="Activo" />
                    </DxFormLayoutItem>

                    @* <DxFormLayoutItem Caption="Empresa" ColSpanLg="4">
                        <DxTextBox @bind-Text="Departamentoseleccionada.EmEmpresa" ReadOnly="true" />
                    </DxFormLayoutItem> *@
                    <input id="hdem" type="hidden" @bind-value="Departamentoseleccionada.EmEmpresa" />
                </DxFormLayout>
   
            </EditForm>
        </DxTabPage>
        <DxTabPage Text="Lista de Ubicaciones">
            <div class="header">
                <div style="display:flex;width:auto;gap:20px;">

                    <Breadcrumb Title="Departamentos / Ubicaciones" BackUrl="/dash" />



                </div>
    @*            <Toolbar formulario="FRHxxx999" OnClose="Cancel" /> *@

            </div>
    <div>
    <DxGrid Data="@data" @ref="MyGrid"
            CssClass="mw-1100"
            EditModelSaving="OnEditModelSaving"
                EditMode="GridEditMode.EditRow"
                    ShowFilterRow="true" AllowColumnReorder>
        <Columns>
            <DxGridCommandColumn Width="60px" VisibleIndex="2">
                <HeaderTemplate>
                    <a class="text-primary" @onclick="@(() => OpenForm())" style="text-decoration: none;" href="javascript:void(0);"><i class="fi fi-rr-plus"></i></a>
                </HeaderTemplate>
                <CellDisplayTemplate>
                            
                    <a class="text-primary" @onclick="@(() => SelectRow((Trhub010Dto)context.DataItem))" style="text-decoration: none;" href="javascript:void(0);"><i class="fi fi-rr-edit"></i></a>
                </CellDisplayTemplate>
               </DxGridCommandColumn>
            <DxGridDataColumn Caption="Id" FieldName="UbCodigo" Width="100px" VisibleIndex="3" />
            <DxGridDataColumn Caption="Descripción" FieldName="UbDescri" Width="300px" VisibleIndex="4" />
            <DxGridDataColumn Caption="Activo" FieldName="UbEstatus" VisibleIndex="8" Width="130px" />

                           
        



        </Columns>
    </DxGrid>
    </div>
            <div class="row">
                <div class="col-4">
                    <div class="overview-chart-item">
                        <div class="text-bg-info">Total Ubicaciones</div>
                        <div class="text-center">@data.Count()</div>
                    </div>
                </div>
                <div class="col-4">
                    <div class="overview-chart-item">
                        <div class="text-bg-primary">Ubicaciones Activas</div>
                        <div class="text-center">@data.Count(es => es.UbEstatus == "S")</div>
                    </div>
                </div>
                <div class="col-4">
                    <div class="text-bg-danger">Ubicaciones Inactivas</div>
                    <div class="text-center">@data.Count(es => es.UbEstatus != "S")</div>
                </div>
            </div>
            <div class="row">
                <div class="col-12">
                    <DxChart Data="@DatosCategorias.Take(300)"
                             Width="100%" Rotated="true" Height="600px">
                        <DxChartTitle Text="Empleados Por Ubicaciones" />
                        <DxChartCommonSeries NameField="@((EstructuraDataPoint s) => s.Etiqueta)"
                                             ArgumentField="@(s => s.Etiqueta)"
                                             ValueField="@(s => s.Valor)"
                                             SummaryMethod="Enumerable.Sum"
                                             SeriesType="ChartSeriesType.Bar" />
                        <DxChartLegend Position="RelativePosition.Inside"
                                       HorizontalAlignment="HorizontalAlignment.Right" Visible="false" />
                        <DxChartTooltip Enabled="true" Position="RelativePosition.Outside">
                            <div class="m-2">
                                <div class="fw-bold text-center">
                                    Depto: @context.Point.SeriesName
                                </div>
                                <div>
                                    @context.Point.Argument: @string.Format("{0:#}", (double)context.Point.Value)
                                </div>
                            </div>
                        </DxChartTooltip>
                    </DxChart>
                </div>
                
                </div>
            
    </DxTabPage>
    
 </DxTabs>

}

