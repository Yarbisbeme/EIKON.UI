    async Task CargarDatos()
    {
        if (Token != null)
        {
            ApiBaseUrl = api.GetApiBaseUrl();
            HttpClient.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", Token);
            data = await api.Trhub010DtoGetByEmpresa("01", Token);
            Departamentoseleccionada = data.FirstOrDefault();
            regionales = await HttpClient.GetFromJsonAsync<List<Trhem000Dto>>(ApiBaseUrl + "Api/Trhem000");
            tipoUbicación = await HttpClient.GetFromJsonAsync<List<Trhcc010Dto>>(ApiBaseUrl + "Api/Trhcc010");
            provincias = await HttpClient.GetFromJsonAsync<List<Trhja000Dto>>(ApiBaseUrl + "Api/Trhja000");

            empleados = await api.Vfrhma000ActivoGetAll(Token);
            var conteoPorDepto = empleados
                .GroupBy(e => e.UbDescri)
                .Select(g => new { Departamento = g.Key, Cantidad = (double)g.Count() })
                .ToList();

            DatosCategorias = conteoPorDepto
                .GroupBy(x => x.Cantidad <= 19 ? "Ubicaciones con menos de 20 empleados" : x.Departamento)
                .Select(g => new EstructuraDataPoint(
                    g.Key,
                    g.Sum(x => (double)x.Cantidad)
                ))
                .ToList();
            // DatosCategorias = empleados
            // .GroupBy(e => e.UbDescri)
            //     .Select(g => new EstructuraDataPoint(g.Key, g.Count()))
            //     .ToList();
            // DatosGruposOcupacionales = empleados
            // .GroupBy(e => e.GrDescri)
            //     .Select(g => new EstructuraDataPoint(g.Key, g.Count()))
            //     .ToList();
            ActiveTabIndex = 1;
            await InvokeAsync(StateHasChanged);
            //await InvokeAsync(StateHasChanged);
            // MyGrid.Reload();
            //puestos = await api.joGetAllAsync(Token);
        }

    }
