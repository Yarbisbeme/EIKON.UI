@page "/FRHNO401"
@layout MainLayout
@inject IJSRuntime JSRuntime

<div class="page">
    <Breadcrumb Title="FRHNO401 - Consulta Acumulados" BackUrl="/dash" />
    
    <div class="page-header">
        <div class="page-search">
            <div class="input-search">
                <label>Empleado</label>
                <DxTextBox @bind-Text="@searchText"
                           NullText="ID Empleado"
                           ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Never">
                    <Buttons>
                        <DxEditorButton IconCssClass="fi fi-rr-search" Click="@OnSearchClick" />
                    </Buttons>
                </DxTextBox>
            </div>
        </div>
        <div class="page-toolbar">
            <Toolbar formulario="FRHxxx999" OnClose="HandleClose" />
        </div>
    </div>

    <div class="form-container">
        <!-- Filtros Principales -->
        <div class="main-filters-section">
            <div class="input-field">
                <label>Nombre</label>
                <DxTextBox @bind-Text="@NombreValue" />
            </div>
            
            <div class="input-field">
                <label>Oficina</label>
                <DxTextBox @bind-Text="@OficinaValue" />
            </div>
            
            <div class="input-field">
                <label>Ubicación</label>
                <DxTextBox @bind-Text="@UbicacionValue" />
            </div>
            
            <div class="input-field">
                <label>Cargo</label>
                <DxTextBox @bind-Text="@CargoValue" />
            </div>
            
            <div class="filter-row">
                <div class="input-field">
                    <label>Nómina</label>
                    <DxComboBox Data="@NominasList" 
                               @bind-Value="@SelectedNomina" 
                               NullText="Seleccionar nómina"
                               TextFieldName="Name" 
                               ValueFieldName="Id" />
                </div>
                <div class="nominas-options">
                    <DxCheckBox @bind-Checked="@TodasNominasOption">¿Todas nóminas?</DxCheckBox>
                </div>
            </div>

            <div class="periodo-section">
                <div class="periodo-row">
                    <div class="input-field narrow">
                        <label>Período</label>
                        <DxSpinEdit @bind-Value="@PeriodoDesde" 
                                   MinValue="0" 
                                   MaxValue="999" />
                    </div>
                    <span class="periodo-separator">Hasta</span>
                    <div class="input-field narrow">
                        <DxSpinEdit @bind-Value="@PeriodoHasta" 
                                   MinValue="0" 
                                   MaxValue="999" />
                    </div>
                    <div class="periodo-options">
                        <DxCheckBox @bind-Checked="@PeriodosEspecificosOption">Periodos específicos</DxCheckBox>
                    </div>
                </div>
            </div>
        </div>

        <!-- Sección Principal con Grid y Resumen -->
        <div class="main-content-section">
            <!-- Grid de Acumulados -->
            <div class="grid-section">
                <div class="grid-headers">
                    <div class="grid-header-left">
                        <h4>Acumulado Vertical</h4>
                    </div>
                    <div class="grid-header-right">
                        <h4>Acumulado Horizontal</h4>
                        <div class="horizontal-headers">
                            <span>Cantidad</span>
                            <span>Monto</span>
                        </div>
                    </div>
                </div>

                <div class="grid-content">
                    <DxGrid Data="@AcumuladosData"
                            PageSize="15"
                            ColumnResizeMode="GridColumnResizeMode.NextColumn"
                            TextWrapEnabled="false"
                            CssClass="acumulados-grid"
                            PagerVisible="false">
                        <Columns>
                            <DxGridDataColumn FieldName="SumCodigo" Caption="Sum.Código" Width="100%" />
                            <DxGridDataColumn FieldName="Descripcion" Caption="Descripción" Width="100%" />
                            <DxGridDataColumn FieldName="Cantidad" Caption="Cantidad" Width="100%" DisplayFormat="N2" TextAlignment="GridTextAlignment.Right" />
                            <DxGridDataColumn FieldName="Monto" Caption="Monto" Width="100%" DisplayFormat="C2" TextAlignment="GridTextAlignment.Right" />
                        </Columns>
                    </DxGrid>
                </div>
            </div>

            <!-- Panel de Resumen -->
            <div class="summary-section">
                <div class="summary-options">
                    <DxCheckBox @bind-Checked="@FijarConsultaOption">Fijar consulta</DxCheckBox>
                    <DxCheckBox @bind-Checked="@HistoricoIngresoOption">Histórico ingreso</DxCheckBox>
                </div>
                
                <div class="summary-checkboxes">
                    <DxCheckBox @bind-Checked="@IngresosOption">Ingresos</DxCheckBox>
                    <DxCheckBox @bind-Checked="@DescuentosOption">Descuentos</DxCheckBox>
                    <DxCheckBox @bind-Checked="@InvisiblesOption">Invisibles</DxCheckBox>
                </div>

                <div class="summary-totals">
                    <div class="summary-title">Resumen</div>
                    
                    <div class="totals-grid">
                        <div class="total-row">
                            <label>Total Ingresos</label>
                            <div class="total-value">@TotalIngresos.ToString("C2")</div>
                        </div>
                        
                        <div class="total-row">
                            <label>Total Egresos</label>
                            <div class="total-value">@TotalEgresos.ToString("C2")</div>
                        </div>
                        
                        <div class="total-row">
                            <label>Total Neto</label>
                            <div class="total-value">@TotalNeto.ToString("C2")</div>
                        </div>
                        
                        <div class="total-row">
                            <label>Transacción</label>
                            <div class="total-value">@Transaccion.ToString("C2")</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Sección de Detalles Inferior -->
        <div class="details-section">
            <div class="details-grid">
                <DxGrid Data="@DetallesData"
                        PageSize="10"
                        ColumnResizeMode="GridColumnResizeMode.NextColumn"
                        TextWrapEnabled="false"
                        CssClass="detalles-grid"
                        PagerVisible="true">
                    <Columns>
                        <DxGridDataColumn FieldName="Batch" Caption="Batch" Width="100%" />
                        <DxGridDataColumn FieldName="Nomina" Caption="¿Nómina No." Width="100%" />
                        <DxGridDataColumn FieldName="Cantidad" Caption="Cantidad" Width="100%" DisplayFormat="N2" TextAlignment="GridTextAlignment.Right" />
                        <DxGridDataColumn FieldName="Monto" Caption="Monto" Width="100%" DisplayFormat="C2" TextAlignment="GridTextAlignment.Right" />
                        <DxGridDataColumn FieldName="Ref" Caption="Ref" Width="100%" />
                    </Columns>
                </DxGrid>
            </div>
        </div>

        <!-- Sección de Reporte -->
        <div class="report-section">
            <div class="report-controls">
                <div class="input-field wide">
                    <label>Reporte</label>
                    <DxTextBox @bind-Text="@ReporteValue" />
                </div>
                <div class="report-actions">
                    <DxButton IconCssClass="fi fi-rr-check" 
                             CssClass="icon-btn success-btn" 
                             Click="@OnValidateReportClick" />
                    <DxButton IconCssClass="fi fi-rr-print" 
                             CssClass="icon-btn info-btn" 
                             Click="@OnPrintReportClick" />
                    <DxButton IconCssClass="fi fi-rr-settings" 
                             CssClass="icon-btn secondary-btn" 
                             Click="@OnConfigReportClick" />
                </div>
            </div>
            <div class="report-checkbox">
                <DxCheckBox @bind-Checked="@EnviarEmpleadoOption">Enviar a Empleado</DxCheckBox>
            </div>
        </div>
    </div>
</div>

<style>
    /* Container principal */
    .form-container {
        display: flex;
        flex-direction: column;
        gap: 20px;
        margin-top: 10px;
    }

    /* Input fields con label arriba */
    .input-field {
        display: flex;
        flex-direction: column;
        gap: 5px;
    }

    .input-field label {
        font-weight: normal;
        color: #333;
        font-size: 14px;
    }

    .input-field.narrow {
        flex: 0 0 80px;
    }

    .input-field.wide {
        flex: 1;
    }

    /* Sección de filtros principales */
    .main-filters-section {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr 1fr;
        gap: 15px;
        padding: 20px;
        border: 1px solid #e0e0e0;
        border-radius: 8px;
    }

    .filter-row {
        grid-column: 1 / -1;
        display: flex;
        gap: 15px;
        align-items: flex-end;
    }

    .nominas-options {
        display: flex;
        align-items: center;
        margin-top: 20px;
    }

    .periodo-section {
        grid-column: 1 / -1;
    }

    .periodo-row {
        display: flex;
        gap: 15px;
        align-items: flex-end;
    }

    .periodo-separator {
        font-size: 14px;
        color: #666;
        margin-bottom: 8px;
        white-space: nowrap;
    }

    .periodo-options {
        display: flex;
        align-items: center;
        margin-bottom: 8px;
    }

    /* Sección principal de contenido */
    .main-content-section {
        display: flex;
        gap: 20px;
        height: 500px;
    }

    .grid-section {
        flex: 2;
        border: 1px solid #e0e0e0;
        border-radius: 8px;
        overflow: hidden;
        display: flex;
        flex-direction: column;
    }

    .grid-headers {
        display: flex;
        background-color: #f8f9fa;
        border-bottom: 1px solid #e0e0e0;
    }

    .grid-header-left {
        flex: 1;
        padding: 12px 15px;
        border-right: 1px solid #e0e0e0;
    }

    .grid-header-left h4 {
        margin: 0;
        font-size: 14px;
        font-weight: 600;
        color: #333;
    }

    .grid-header-right {
        flex: 1;
        padding: 12px 15px;
    }

    .grid-header-right h4 {
        margin: 0 0 8px 0;
        font-size: 14px;
        font-weight: 600;
        color: #333;
    }

    .horizontal-headers {
        display: flex;
        gap: 60px;
        font-size: 12px;
        color: #666;
    }

    .grid-content {
        flex: 1;
        width: 100%;
        overflow: hidden;
    }

    .acumulados-grid {
        height: 100%;
        width: 100%;
    }

    /* Panel de resumen */
    .summary-section {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 20px;
        min-width: 300px;
    }

    .summary-options,
    .summary-checkboxes {
        display: flex;
        flex-direction: column;
        gap: 10px;
        padding: 15px;
        border: 1px solid #e0e0e0;
        border-radius: 6px;
    }

    .summary-totals {
        border: 1px solid #e0e0e0;
        border-radius: 8px;
        padding: 15px;
    }

    .summary-title {
        font-weight: 600;
        font-size: 16px;
        color: #333;
        margin-bottom: 15px;
        text-align: center;
    }

    .totals-grid {
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .total-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 8px 0;
        border-bottom: 1px solid #f0f0f0;
    }

    .total-row:last-child {
        border-bottom: none;
        font-weight: 600;
        background-color: #f8f9fa;
        margin: 5px -15px -15px;
        padding: 12px 15px;
    }

    .total-row label {
        font-size: 14px;
        color: #333;
    }

    .total-value {
        font-weight: 500;
        color: #2c5282;
        font-size: 14px;
    }

    /* Sección de detalles */
    .details-section {
        border: 1px solid #e0e0e0;
        border-radius: 8px;
        padding: 15px;
        height: 300px;
    }

    .details-grid {
        height: 100%;
        width: 100%;
    }

    .detalles-grid {
        width: 100%;
        height: 100%;
    }

    /* Sección de reporte */
    .report-section {
        border: 1px solid #e0e0e0;
        border-radius: 8px;
        padding: 20px;
    }

    .report-controls {
        display: flex;
        gap: 15px;
        align-items: flex-end;
        margin-bottom: 15px;
    }

    .report-checkbox {
        display: flex;
        align-items: center;
        padding-top: 10px;
        border-top: 1px solid #e0e0e0;
    }

    .report-actions {
        display: flex;
        gap: 8px;
    }

    /* Botones de acción */
    .icon-btn {
        width: 36px;
        height: 36px;
        min-width: 36px;
        padding: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 6px;
    }

    .success-btn {
        background-color: #28a745;
        border-color: #28a745;
        color: white;
    }

    .success-btn:hover {
        background-color: #218838;
        border-color: #1e7e34;
    }

    .info-btn {
        background-color: #17a2b8;
        border-color: #17a2b8;
        color: white;
    }

    .info-btn:hover {
        background-color: #138496;
        border-color: #117a8b;
    }

    .secondary-btn {
        background-color: #6c757d;
        border-color: #6c757d;
        color: white;
    }

    .secondary-btn:hover {
        background-color: #5a6268;
        border-color: #545b62;
    }

    /* Responsive Design */
    media (max-width: 1200px) {
        .main-content-section {
            flex-direction: column;
            height: auto;
        }

        .grid-section {
            height: 400px;
        }

        .summary-section {
            min-width: auto;
        }
    }

    media (max-width: 768px) {
        .main-filters-section {
            grid-template-columns: 1fr;
            gap: 15px;
        }

        .filter-row,
        .periodo-section {
            grid-column: 1;
        }

        .periodo-row {
            flex-direction: column;
            align-items: stretch;
            gap: 10px;
        }

        .periodo-separator {
            margin-bottom: 0;
            text-align: center;
        }

        .grid-headers {
            flex-direction: column;
        }

        .grid-header-left {
            border-right: none;
            border-bottom: 1px solid #e0e0e0;
        }

        .horizontal-headers {
            justify-content: space-around;
        }

        .report-controls {
            flex-direction: column;
            align-items: stretch;
            gap: 15px;
        }

        .report-checkbox {
            justify-content: center;
            margin-top: 10px;
        }

        .report-actions {
            justify-content: center;
        }
    }

    media (max-width: 480px) {
        .form-container {
            gap: 15px;
        }

        .main-filters-section,
        .details-section,
        .report-section {
            padding: 15px;
        }

        .summary-totals {
            padding: 12px;
        }

        .icon-btn {
            width: 32px;
            height: 32px;
            min-width: 32px;
        }
    }
</style>

@code {
    // **- private string[] // **- ToolbarOptions = { "add", "save", "remove", "leave" };
    private string searchText { get; set; } = "";
    
    // Campos de filtros
    private string NombreValue { get; set; } = "";
    private string OficinaValue { get; set; } = "";
    private string UbicacionValue { get; set; } = "";
    private string CargoValue { get; set; } = "";
    private int? SelectedNomina { get; set; }
    private bool TodasNominasOption { get; set; } = false;
    
    // Periodo
    private int PeriodoDesde { get; set; } = 0;
    private int PeriodoHasta { get; set; } = 0;
    private bool PeriodosEspecificosOption { get; set; } = false;
    
    // Opciones de resumen
    private bool FijarConsultaOption { get; set; } = false;
    private bool HistoricoIngresoOption { get; set; } = false;
    private bool IngresosOption { get; set; } = true;
    private bool DescuentosOption { get; set; } = true;
    private bool InvisiblesOption { get; set; } = true;
    
    // Totales
    private decimal TotalIngresos { get; set; } = 0.00m;
    private decimal TotalEgresos { get; set; } = 0.00m;
    private decimal TotalNeto { get; set; } = 0.00m;
    private decimal Transaccion { get; set; } = 0.00m;
    
    // Reporte
    private string ReporteValue { get; set; } = "";
    private bool EnviarEmpleadoOption { get; set; } = false;
    
    // Listas de datos
    private List<NominaItem> NominasList = new List<NominaItem>
    {
        new NominaItem { Id = 1, Name = "NOMINA ADMINISTRATIVA" },
        new NominaItem { Id = 2, Name = "NOMINA OPERATIVA" },
        new NominaItem { Id = 3, Name = "NOMINA EJECUTIVA" },
        new NominaItem { Id = 4, Name = "NOMINA ESPECIAL" }
    };

    private List<AcumuladoItem> AcumuladosData = new List<AcumuladoItem>
    {
        new AcumuladoItem { SumCodigo = "001", Descripcion = "SALARIO BASE", Cantidad = 1.00m, Monto = 45000.00m },
        new AcumuladoItem { SumCodigo = "002", Descripcion = "HORAS EXTRAS", Cantidad = 8.00m, Monto = 3600.00m },
        new AcumuladoItem { SumCodigo = "003", Descripcion = "BONO PRODUCTIVIDAD", Cantidad = 1.00m, Monto = 5000.00m },
        new AcumuladoItem { SumCodigo = "101", Descripcion = "IHSS LABORAL", Cantidad = 1.00m, Monto = -1350.00m },
        new AcumuladoItem { SumCodigo = "102", Descripcion = "IR SOBRE SUELDOS", Cantidad = 1.00m, Monto = -4500.00m }
    };

    private List<DetalleItem> DetallesData = new List<DetalleItem>
    {
        new DetalleItem { Batch = "B001", Nomina = "N001", Cantidad = 1.00m, Monto = 45000.00m, Ref = "R001" },
        new DetalleItem { Batch = "B002", Nomina = "N001", Cantidad = 8.00m, Monto = 3600.00m, Ref = "R002" },
        new DetalleItem { Batch = "B003", Nomina = "N001", Cantidad = 1.00m, Monto = 5000.00m, Ref = "R003" }
    };
    
    public class NominaItem
    {
        public int Id { get; set; }
        public string Name { get; set; } = "";
    }
    
    public class AcumuladoItem
    {
        public string SumCodigo { get; set; } = "";
        public string Descripcion { get; set; } = "";
        public decimal Cantidad { get; set; }
        public decimal Monto { get; set; }
    }
    
    public class DetalleItem
    {
        public string Batch { get; set; } = "";
        public string Nomina { get; set; } = "";
        public decimal Cantidad { get; set; }
        public decimal Monto { get; set; }
        public string Ref { get; set; } = "";
    }
    
    protected override void OnInitialized()
    {
        // Calcular totales
        CalculateTotals();
    }
    
    private void CalculateTotals()
    {
        TotalIngresos = AcumuladosData.Where(x => x.Monto > 0).Sum(x => x.Monto);
        TotalEgresos = Math.Abs(AcumuladosData.Where(x => x.Monto < 0).Sum(x => x.Monto));
        TotalNeto = TotalIngresos - TotalEgresos;
        Transaccion = TotalNeto;
    }
    
    private void OnSearchClick()
    {
        Console.WriteLine($"Buscando empleado: {searchText}");
    }
    
    private void OnValidateReportClick()
    {
        Console.WriteLine($"Validando reporte: {ReporteValue}");
    }
    
    private void OnPrintReportClick()
    {
        Console.WriteLine("Imprimiendo reporte");
    }
    
    private void OnConfigReportClick()
    {
        Console.WriteLine("Configurando reporte");
    }
    
    private async Task HandleClose()
    {
        await JSRuntime.InvokeVoidAsync("alert", "¡Consulta de Acumulados guardada!");
    }
}