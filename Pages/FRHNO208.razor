@page "/FRHNO208"
@layout MainLayout
@inject IJSRuntime JSRuntime

<div class="page">
    <Breadcrumb Title="FRHNO208 - Archivo de depósito Banco" BackUrl="/dash" />
    
    <div class="page-header">
        <div class="page-toolbar">
            <Toolbar formulario="FRHxxx999" OnClose="HandleClose" />
        </div>
    </div>

    <div class="form-container">
        <!-- Sección Superior -->
        <div class="top-section">
            <div class="top-row">
                <div class="checkbox-field">
                    <DxCheckBox @bind-Checked="@TodasNominasProcesoOption">Todas las nóminas en proceso</DxCheckBox>
                </div>
                <div class="checkbox-field right">
                    <DxCheckBox @bind-Checked="@CrearFormatoOption">Crear Formato</DxCheckBox>
                </div>
            </div>
        </div>

        <!-- Sección Principal de Campos -->
        <div class="main-section">
            <!-- Primera Fila -->
            <div class="form-row">
                <div class="input-field">
                    <label>Nómina</label>
                    <DxComboBox Data="@NominasList" 
                               @bind-Value="@SelectedNomina" 
                               NullText="Seleccionar nómina"
                               TextFieldName="Name" 
                               ValueFieldName="Id" />
                </div>
            </div>

            <!-- Segunda Fila -->
            <div class="form-row">
                <div class="input-field">
                    <label>Formato</label>
                    <DxComboBox Data="@FormatosList" 
                               @bind-Value="@SelectedFormato" 
                               NullText="Seleccionar formato"
                               TextFieldName="Name" 
                               ValueFieldName="Id" />
                </div>
            </div>

            <!-- Tercera Fila -->
            <div class="form-row">
                <div class="input-field">
                    <label>Versión</label>
                    <DxComboBox Data="@VersionesList" 
                               @bind-Value="@SelectedVersion" 
                               NullText="Seleccionar versión"
                               TextFieldName="Name" 
                               ValueFieldName="Id" />
                </div>
            </div>

            <!-- Cuarta Fila -->
            <div class="form-row">
                <div class="input-field">
                    <label>Fecha</label>
                    <DxDateEdit @bind-Date="@FechaValue" 
                               NullText="dd/mm/yyyy"
                               ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Never">
                        <Buttons>
                            <DxEditorButton IconCssClass="fi fi-rr-calendar" 
                                           Click="@OnDatePickerClick" />
                        </Buttons>
                    </DxDateEdit>
                </div>
            </div>
        </div>

        <!-- Sección Total a enviar -->
        <div class="total-section">
            <div class="total-row">
                <div class="total-label">Total a enviar</div>
                <div class="total-inputs">
                    <div class="input-field narrow">
                        <DxSpinEdit @bind-Value="@TotalCantidadValue" 
                                   MinValue="0" 
                                   MaxValue="999999"
                                   DisplayFormat="N0" />
                    </div>
                    <div class="input-field">
                        <DxSpinEdit @bind-Value="@TotalMontoValue" 
                                   MinValue="0m" 
                                   MaxValue="999999999.99m"
                                   DisplayFormat="C2" />
                    </div>
                </div>
            </div>
        </div>

        <!-- Sección Otros Criterios -->
        <div class="criteria-section">
            <div class="criteria-header">
                <span class="criteria-title">Otros Criterios</span>
                <div class="criteria-actions">
                    <DxButton IconCssClass="fi fi-rr-settings" 
                             CssClass="icon-btn secondary-btn" 
                             Click="@OnSettingsClick" />
                    <DxButton IconCssClass="fi fi-rr-search" 
                             CssClass="icon-btn info-btn" 
                             Click="@OnSearchClick" />
                </div>
            </div>
            
            <div class="criteria-checkboxes">
                <div class="criteria-row">
                    <DxCheckBox @bind-Checked="@OficinaOption">Oficina</DxCheckBox>
                    <DxComboBox Data="@OficinasList" 
                               @bind-Value="@SelectedOficina" 
                               NullText="Seleccionar oficina"
                               TextFieldName="Name" 
                               ValueFieldName="Id"
                               Enabled="@OficinaOption" />
                </div>
                
                <div class="criteria-row">
                    <DxCheckBox @bind-Checked="@UbicacionOption">Ubicación</DxCheckBox>
                    <DxComboBox Data="@UbicacionesList" 
                               @bind-Value="@SelectedUbicacion" 
                               NullText="Seleccionar ubicación"
                               TextFieldName="Name" 
                               ValueFieldName="Id"
                               Enabled="@UbicacionOption" />
                </div>
            </div>
        </div>

        <!-- Sección de Reporte -->
        <div class="report-section">
            <div class="report-header">
                <div class="input-field wide">
                    <label>Reporte</label>
                    <DxComboBox Data="@ReportesList" 
                               @bind-Value="@SelectedReporte" 
                               NullText="Seleccionar reporte"
                               TextFieldName="Name" 
                               ValueFieldName="Id" />
                </div>
                <div class="report-button">
                    <DxButton IconCssClass="fi fi-rr-cross-small" 
                             CssClass="icon-btn error-btn" 
                             Click="@OnClearReportClick" />
                </div>
            </div>
            
            <div class="report-details">
                <div class="report-row">
                    <div class="input-field narrow">
                        <label>Tipo</label>
                        <DxComboBox Data="@TipoReporteList" 
                                   @bind-Value="@SelectedTipoReporte" 
                                   NullText="PDF"
                                   TextFieldName="Name" 
                                   ValueFieldName="Id" />
                    </div>
                    <div class="input-field wide">
                        <label>Nombre</label>
                        <DxTextBox @bind-Text="@NombreReporteValue" />
                    </div>
                    <div class="report-actions">
                        <DxButton IconCssClass="fi fi-rr-check" 
                                 CssClass="icon-btn success-btn" 
                                 Click="@OnValidateReportClick" />
                        <DxButton IconCssClass="fi fi-rr-cross-small" 
                                 CssClass="icon-btn error-btn" 
                                 Click="@OnCancelReportClick" />
                        <DxButton IconCssClass="fi fi-rr-settings" 
                                 CssClass="icon-btn secondary-btn" 
                                 Click="@OnConfigReportClick" />
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* Container principal */
    .form-container {
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    /* Sección superior */
    .top-section {
        border: 1px solid #e0e0e0;
        border-radius: 8px;
        padding: 15px;
    }

    .top-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .checkbox-field {
        display: flex;
        align-items: center;
    }

    .checkbox-field.right {
        margin-left: auto;
    }

    /* Sección principal */
    .main-section {
        display: flex;
        flex-direction: column;
        gap: 15px;
        padding: 20px;
        border: 1px solid #e0e0e0;
        border-radius: 8px;
    }

    /* Form rows */
    .form-row {
        display: flex;
        align-items: flex-end;
    }

    /* Input fields con label arriba */
    .input-field {
        display: flex;
        flex-direction: column;
        gap: 5px;
        flex: 1;
    }

    .input-field label {
        font-weight: normal;
        color: #333;
        font-size: 14px;
    }

    .input-field.narrow {
        flex: 0 0 120px;
    }

    .input-field.wide {
        flex: 2;
    }

    /* Sección total */
    .total-section {
        border: 1px solid #e0e0e0;
        border-radius: 8px;
        padding: 20px;
    }

    .total-row {
        display: flex;
        align-items: center;
        gap: 20px;
    }

    .total-label {
        font-weight: 500;
        color: #333;
        font-size: 14px;
        min-width: 120px;
    }

    .total-inputs {
        display: flex;
        gap: 15px;
        flex: 1;
    }

    /* Sección criterios */
    .criteria-section {
        border: 1px solid #e0e0e0;
        border-radius: 8px;
        padding: 20px;
    }

    .criteria-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
        padding-bottom: 10px;
        border-bottom: 1px solid #e0e0e0;
    }

    .criteria-title {
        font-weight: 500;
        color: #333;
        font-size: 16px;
    }

    .criteria-actions {
        display: flex;
        gap: 8px;
    }

    .criteria-checkboxes {
        display: flex;
        flex-direction: column;
        gap: 15px;
    }

    .criteria-row {
        display: flex;
        align-items: center;
        gap: 15px;
    }

    .criteria-row > .dx-checkbox {
        min-width: 120px;
    }

    .criteria-row > .dx-combobox {
        flex: 1;
    }

    /* Sección de reporte */
    .report-section {
        border: 1px solid #e0e0e0;
        border-radius: 8px;
        padding: 20px;
    }

    .report-header {
        display: flex;
        align-items: flex-end;
        gap: 15px;
        margin-bottom: 20px;
    }

    .report-button {
        flex: 0 0 auto;
    }

    .report-details {
        border-top: 1px solid #e0e0e0;
        padding-top: 15px;
    }

    .report-row {
        display: flex;
        align-items: flex-end;
        gap: 15px;
    }

    .report-actions {
        display: flex;
        gap: 8px;
        flex: 0 0 auto;
    }

    /* Botones de acción */
    .icon-btn {
        width: 32px;
        height: 32px;
        min-width: 32px;
        padding: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 6px;
    }

    .success-btn {
        background-color: #28a745;
        border-color: #28a745;
        color: white;
    }

    .success-btn:hover {
        background-color: #218838;
        border-color: #1e7e34;
    }

    .error-btn {
        background-color: #dc3545;
        border-color: #dc3545;
        color: white;
    }

    .error-btn:hover {
        background-color: #c82333;
        border-color: #bd2130;
    }

    .info-btn {
        background-color: #17a2b8;
        border-color: #17a2b8;
        color: white;
    }

    .info-btn:hover {
        background-color: #138496;
        border-color: #117a8b;
    }

    .secondary-btn {
        background-color: #6c757d;
        border-color: #6c757d;
        color: white;
    }

    .secondary-btn:hover {
        background-color: #5a6268;
        border-color: #545b62;
    }

    /* Estilos para DevExpress Components */
    .dx-textbox,
    .dx-combobox,
    .dx-date-edit,
    .dx-spin-edit {
        border-radius: 6px !important;
    }

    .dx-textbox-container,
    .dx-combobox-container,
    .dx-date-edit-container,
    .dx-spin-edit-container {
        border: 1px solid #ced4da !important;
        border-radius: 6px !important;
    }

    .dx-textbox-container:focus-within,
    .dx-combobox-container:focus-within,
    .dx-date-edit-container:focus-within,
    .dx-spin-edit-container:focus-within {
        border-color: #007bff !important;
        box-shadow: 0 0 0 0.2rem rgba(0, 123, 255, 0.25) !important;
    }

    /* Responsive Design */
    media (max-width: 768px) {

        .top-row {
            flex-direction: column;
            gap: 15px;
            align-items: stretch;
        }

        .checkbox-field.right {
            margin-left: 0;
        }

        .total-row {
            flex-direction: column;
            gap: 15px;
            align-items: stretch;
        }

        .total-label {
            min-width: auto;
        }

        .total-inputs {
            flex-direction: column;
        }

        .criteria-header {
            flex-direction: column;
            gap: 15px;
            align-items: stretch;
        }

        .criteria-row {
            flex-direction: column;
            align-items: stretch;
            gap: 10px;
        }

        .criteria-row > .dx-checkbox {
            min-width: auto;
        }


        .report-header,
        .report-row {
            flex-direction: column;
            gap: 15px;
        }

        .report-actions {
            justify-content: center;
        }
    }

    media (max-width: 480px) {
        .form-container {
            gap: 15px;
        }

        .main-section,
        .top-section,
        .total-section,
        .criteria-section,
        .report-section {
            padding: 15px;
        }

        .icon-btn {
            width: 28px;
            height: 28px;
            min-width: 28px;
        }

        .criteria-actions,
        .report-actions {
            gap: 6px;
        }
    }
</style>

@code {
    // **- private string[] // **- ToolbarOptions = { "add", "save", "remove", "leave" };
    
    // Checkboxes superiores
    private bool TodasNominasProcesoOption { get; set; } = false;
    private bool CrearFormatoOption { get; set; } = true;
    
    // Campos principales
    private int? SelectedNomina { get; set; }
    private int? SelectedFormato { get; set; }
    private int? SelectedVersion { get; set; }
    private DateTime? FechaValue { get; set; }
    
    // Total a enviar
    private int TotalCantidadValue { get; set; } = 0;
    private decimal TotalMontoValue { get; set; } = 0.00m;
    
    // Otros criterios
    private bool OficinaOption { get; set; } = true;
    private bool UbicacionOption { get; set; } = true;
    private int? SelectedOficina { get; set; }
    private int? SelectedUbicacion { get; set; }
    
    // Reporte
    private int? SelectedReporte { get; set; }
    private int? SelectedTipoReporte { get; set; }
    private string NombreReporteValue { get; set; } = "";
    
    // Listas de datos
    private List<GeneralItem> NominasList = new List<GeneralItem>
    {
        new GeneralItem { Id = 1, Name = "NOMINA ADMINISTRATIVA" },
        new GeneralItem { Id = 2, Name = "NOMINA OPERATIVA" },
        new GeneralItem { Id = 3, Name = "NOMINA EJECUTIVA" }
    };

    private List<GeneralItem> FormatosList = new List<GeneralItem>
    {
        new GeneralItem { Id = 1, Name = "FORMATO BANCO ATLANTIDA" },
        new GeneralItem { Id = 2, Name = "FORMATO BANCO FICOHSA" },
        new GeneralItem { Id = 3, Name = "FORMATO BANCO BAC" }
    };

    private List<GeneralItem> VersionesList = new List<GeneralItem>
    {
        new GeneralItem { Id = 1, Name = "VERSION 1.0" },
        new GeneralItem { Id = 2, Name = "VERSION 2.0" },
        new GeneralItem { Id = 3, Name = "VERSION 3.0" }
    };

    private List<GeneralItem> OficinasList = new List<GeneralItem>
    {
        new GeneralItem { Id = 1, Name = "OFICINA CENTRAL" },
        new GeneralItem { Id = 2, Name = "SUCURSAL NORTE" },
        new GeneralItem { Id = 3, Name = "SUCURSAL SUR" }
    };

    private List<GeneralItem> UbicacionesList = new List<GeneralItem>
    {
        new GeneralItem { Id = 1, Name = "TEGUCIGALPA" },
        new GeneralItem { Id = 2, Name = "SAN PEDRO SULA" },
        new GeneralItem { Id = 3, Name = "LA CEIBA" }
    };

    private List<GeneralItem> ReportesList = new List<GeneralItem>
    {
        new GeneralItem { Id = 1, Name = "REPORTE DEPOSITOS BANCARIOS" },
        new GeneralItem { Id = 2, Name = "RESUMEN NOMINA" },
        new GeneralItem { Id = 3, Name = "DETALLE EMPLEADOS" }
    };

    private List<GeneralItem> TipoReporteList = new List<GeneralItem>
    {
        new GeneralItem { Id = 1, Name = "PDF" },
        new GeneralItem { Id = 2, Name = "Excel" },
        new GeneralItem { Id = 3, Name = "Word" }
    };
    
    public class GeneralItem
    {
        public int Id { get; set; }
        public string Name { get; set; } = "";
    }
    
    private void OnDatePickerClick()
    {
        Console.WriteLine("Abriendo selector de fecha");
    }
    
    private void OnSettingsClick()
    {
        Console.WriteLine("Abriendo configuración de criterios");
    }
    
    private void OnSearchClick()
    {
        Console.WriteLine("Buscando criterios");
    }
    
    private void OnClearReportClick()
    {
        Console.WriteLine("Limpiando reporte");
    }
    
    private void OnValidateReportClick()
    {
        Console.WriteLine($"Validando reporte: {NombreReporteValue}");
    }
    
    private void OnCancelReportClick()
    {
        Console.WriteLine("Cancelando reporte");
    }
    
    private void OnConfigReportClick()
    {
        Console.WriteLine("Configurando reporte");
    }
    
    private async Task HandleClose()
    {
        await JSRuntime.InvokeVoidAsync("alert", "¡Archivo de depósito Banco guardado!");
    }
}