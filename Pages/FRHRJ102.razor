@page "/FRHRJ102"

@using EIKON.UI.Components
@using DevExpress.Blazor

@layout MainLayout
@inject NavigationManager nv
@inject IJSRuntime JSRuntime

<div class="page">
    <Breadcrumb Title="Creación de Turnos" BackUrl="/dash" />
    <div class="page-header">
        <div class="page-toolbar">
            <Toolbar formulario="FRHxxx999" OnAdd="HandleAdd" OnSave="HandleSave" OnClose="HandleClose" />
        </div>
    </div>

    <div class="frhrj102-form">
        <div class="top-fields">
            <div class="field-row">
                <div class="input small-field">
                    <label>Código</label>
                    <DxTextBox @bind-Text="@Codigo" NullText="">
                        <Buttons>
                            <DxEditorButton IconCssClass="fi fi-rr-search" Click="@OnSearchCodigo" />
                        </Buttons>
                    </DxTextBox>
                </div>

                <DxCheckBox @bind-Checked="@PagaExtras">
                    Turno Rotativo (...)
                </DxCheckBox>

            </div>

            <div class="field-row">
                <div class="input">
                    <label>Descripción</label>
                    <DxTextBox @bind-Text="@Descripcion" NullText="Turno Rotativo (...)" />
                </div>
                <div class="input">
                    <label>Horas Normal</label>
                    <div class="field-with-checks">
                        <DxSpinEdit @bind-Value="@HorasNormal" MinValue="0" DisplayFormat="N2" />
                        <DxCheckBox @bind-Checked="@Completar" CssClass="inline-check">
                            Completar
                        </DxCheckBox>
                    </div>
                </div>

                <div class="input">
                    <label for="user">Fecha Creación</label>
                    <DxDateEdit @bind-Date="@DateTimeValue"
                                CssClass="cw-320"
                                IconCssClass="fi fi-rr-search"
                                InputId="deOverview" />
                </div>
                <div class="input">
                    <label for="user">Fecha de Jornada</label>
                    <DxDateEdit @bind-Date="@DateTimeValue"
                                CssClass="cw-320"
                                IconCssClass="fi fi-rr-search"
                                InputId="deOverview" />
                </div>
            </div>

            <div class="field-row">
            <DxCheckBox @bind-Checked="@Flexible" CssClass="inline-check">
                Flexible
            </DxCheckBox>
            <DxCheckBox @bind-Checked="@PagaExtras" Text="Paga extras" CssClass="inline-check">
                Paga extras
            </DxCheckBox>
            <DxCheckBox @bind-Checked="@Activo" CssClass="inline-check">
                Activo
            </DxCheckBox>
            </div>
        </div>

        <div class="divider"></div>

        <div class="grids-section">
            <div class="grid-container">
                <div class="grid-header">Selección de Jornadas</div>
                <DxGrid Data="@JornadasData"
                        CssClass="jornadas-grid"
                        PageSize="10"
                        ShowPager="false">
                    <Columns>
                        <DxGridDataColumn FieldName="Chk" Caption="Chk" Width="50px" />
                        <DxGridDataColumn FieldName="Codigo" Caption="Código" Width="80px" />
                        <DxGridDataColumn FieldName="Descripcion" Caption="Descripción Jornada" />
                    </Columns>
                </DxGrid>
            </div>

            <div class="grid-container">
                <div class="grid-header">Detalles Jornada</div>
                <DxGrid Data="@DetallesData"
                        CssClass="detalles-grid"
                        PageSize="10"
                        ShowPager="false">
                    <Columns>
                        <DxGridDataColumn FieldName="Dia" Caption="Día" Width="60px" />
                        <DxGridDataColumn FieldName="Horario" Caption="Horario" />
                        <DxGridDataColumn FieldName="Almuerzo" Caption="Almuerzo" Width="100px" />
                    </Columns>
                </DxGrid>
            </div>
        </div>

        <div class="divider"></div>

        <div class="checkboxes-row">
            <DxCheckBox @bind-Checked="@Extras">Extras</DxCheckBox>
            <DxCheckBox @bind-Checked="@Feriados">Feriados</DxCheckBox>
            <DxCheckBox @bind-Checked="@Libres">Libres</DxCheckBox>
            <DxCheckBox @bind-Checked="@Nocturnas">Nocturnas</DxCheckBox>
            <DxCheckBox @bind-Checked="@Otras">Otras</DxCheckBox>
            <DxCheckBox @bind-Checked="@Novedades">Novedades</DxCheckBox>
            <DxCheckBox @bind-Checked="@Ausencias">Ausencias</DxCheckBox>
        </div>

        <div class="bottom-fields">
            <div class="field-group">
                <div class="input">
                    <label>Minutos Holgura Entrada</label>
                    <DxSpinEdit @bind-Value="@MinutosHolguraEntrada" MinValue="0" DisplayFormat="N2" />
                </div>
                <div class="input">
                    <label>Inicio Horas Extras</label>
                    <DxSpinEdit @bind-Value="@InicioHorasExtras" MinValue="0" DisplayFormat="N2" />
                </div>
            </div>

            <div class="field-group">
                <div class="input">
                    <label>Minutos Holgura Salida</label>
                    <DxSpinEdit @bind-Value="@MinutosHolguraSalida" MinValue="0" DisplayFormat="N2" />
                </div>
                <div class="input">
                    <label>Inicio Extraordinarias</label>
                    <DxSpinEdit @bind-Value="@InicioExtraordinarias" MinValue="0" DisplayFormat="N2" />
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    // **- private string[] // **- ToolbarOptions = { "add", "save", "close" };
    private DateTime DateTimeValue { get; set; } = DateTime.Now;

    // Top fields
    private string Codigo { get; set; } = string.Empty;
    private string Descripcion { get; set; } = string.Empty;
    private double HorasNormal { get; set; } = 0.00;
    private string FechaCreacion { get; set; } = string.Empty;
    private string FechaJornada { get; set; } = string.Empty;

    // Checkboxes
    private bool Completar { get; set; } = false;
    private bool Flexible { get; set; } = false;
    private bool PagaExtras { get; set; } = false;
    private bool Activo { get; set; } = false;
    private bool AlAlterno { get; set; } = false;
    private bool Extras { get; set; } = false;
    private bool Feriados { get; set; } = false;
    private bool Libres { get; set; } = false;
    private bool Nocturnas { get; set; } = false;
    private bool Otras { get; set; } = false;
    private bool Novedades { get; set; } = false;
    private bool Ausencias { get; set; } = false;

    // Bottom fields
    private double MinutosHolguraEntrada { get; set; } = 0.00;
    private double MinutosHolguraSalida { get; set; } = 0.00;
    private double InicioHorasExtras { get; set; } = 0.00;
    private double InicioExtraordinarias { get; set; } = 0.00;

    // Grid data
    private List<JornadaItem> JornadasData { get; set; } = new();
    private List<DetalleItem> DetallesData { get; set; } = new();

    public class JornadaItem
    {
        public bool Chk { get; set; }
        public string Codigo { get; set; } = string.Empty;
        public string Descripcion { get; set; } = string.Empty;
    }

    public class DetalleItem
    {
        public string Dia { get; set; } = string.Empty;
        public string Horario { get; set; } = string.Empty;
        public string Almuerzo { get; set; } = string.Empty;
    }

    private void OnSearchCodigo() { }
    private void HandleAdd() { }
    private void HandleSave() { }
    private void HandleClose() { nv.NavigateTo("/dash"); }
}
