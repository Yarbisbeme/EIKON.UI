            <DxGridDataColumn Caption="Nombre" FieldName="Pasnomb" Width="300px" />
           
            <DxGridDataColumn FieldName="Maenume" Caption="Empleado"/>
            <DxGridDataColumn Caption="Expira" FieldName="PasExpira" />
            <DxGridDataColumn FieldName="PasEsEmp" Caption="Empleado" />
            <DxDataGridColumn FieldName="IdentityColumn" Width="150px" Caption="#">
                
