        new TablaReferenciaItem { Nombre = "TRHCI000", Descripcion = "ESTADOS CIVIL" },
        new TablaReferenciaItem { Nombre = "TRHCJ000", Descripcion = "TABLA TB TRHCJ000" },
        new TablaReferenciaItem { Nombre = "TRHCO000", Descripcion = "TABLA TB TRHCO000" },
        new TablaReferenciaItem { Nombre = "TRHCP000", Descripcion = "CONCEPTOS DE PRODUCCIÓN" },
        new TablaReferenciaItem { Nombre = "TRHCP010", Descripcion = "TABLA TB TRHCP010" }
