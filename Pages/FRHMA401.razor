@layout MainLayout
@page "/FRHMA401REF"
@page "/TBREFERENCIA"
@using EIKON.UI.Components
@using DevExpress.Blazor
@using DevExpress.Blazor.Base
@using System.Net.Http.Json
@using System.Net.Http.Headers
@using EIKON.UI.Interfaces
@using DevExpress.AspNetCore.Reporting
@using DevExpress.XtraReports.UI
@using System.ComponentModel.DataAnnotations

@inject NavigationManager nv
@inject IJSRuntime JSRuntime

<div class="page">
    <Breadcrumb Title="FRHMA401 - Tablas de referencia" BackUrl="/dash" />
    <div class="page-header">
        <div class="page-toolbar">
            <Toolbar formulario="FRHxxx999" OnAdd="HandleAdd" OnSave="HandleSave" OnClose="HandleClose" />
        </div>
    </div>
    <div class="frhma401-form">

        <!-- Sección Buscar por -->
        <div class="search-section">
            <div class="search-header">Buscar por:</div>

            <div class="search-options">
                <div class="search-row">
                    <div class="radio-options-search">
                        <div class="radio-item">
                            <DxRadio GroupName="searchType"
                                     @bind-GroupValue="SearchType"
                                     Value="@("nombre")">
                                Nombre
                            </DxRadio>
                        </div>
                        <div class="radio-item">
                            <DxRadio GroupName="searchType"
                                     @bind-GroupValue="SearchType"
                                     Value="@("descripcion")">
                                Descripción
                            </DxRadio>
                        </div>
                    </div>

                    <div class="search-inputs">
                        <DxTextBox @bind-Text="@SearchNombre"
                                   NullText="Buscar por nombre"
                                   Enabled="@(SearchType == "nombre")" />

                        <DxTextBox @bind-Text="@SearchDescripcion"
                                   NullText="Buscar por descripción"
                                   Enabled="@(SearchType == "descripcion")" />
                    </div>

                </div>
            </div>
        </div>

        <!-- Grid de resultados -->
        <div class="grid-section">
            <DxGrid Data="@TablasReferencia"
                    CssClass="tablas-grid"
                    PageSize="20"
                    ShowAllRows="false">
                <Columns>
                    <DxGridDataColumn FieldName="Nombre" Caption="Nombre" Width="150px" />
                    <DxGridDataColumn FieldName="Descripcion" Caption="Descripción" />
                    <DxGridCommandColumn Width="80px">
                        <HeaderTemplate>
                            <span></span>
                        </HeaderTemplate>
                        <CellDisplayTemplate>
                            @{
                                var tabla = (TablaReferenciaItem)context.DataItem;
                            }
                            <DxButton IconCssClass="fi fi-rr-search" @onclick="() => ViewItem(tabla)" />
       
                        </CellDisplayTemplate>
                    </DxGridCommandColumn>
                </Columns>
            </DxGrid>
        </div>

    </div>
</div>

