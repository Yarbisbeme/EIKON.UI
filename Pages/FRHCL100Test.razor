                        </CellDisplayTemplate>
                    </DxGridCommandColumn>
           
             <!-- Columna para el botón -->
        



        </Columns>
    </DxGrid>
    </div>
</div>

    void DrawDonutChart<T>(IEnumerable<T> data, string titleText)
    {
        <div class="chart-item">
            <DxPieChart Data="data"
                        Width="50%"
                        InnerDiameter="0.5">
                <DxChartTitle Text="@titleText" />
                <DxPieChartSeries T="DonutDataItem"
                                  TArgument="string"
                                  TValue="int"
                                  ArgumentField="s => s.Estatus"
                                  ValueField="s => s.Amount"
                                  SummaryMethod="Enumerable.Sum">
                    <DxChartSeriesLabel Visible="true"
                                        Position="RelativePosition.Inside"
                                        ValueFormat='ChartElementFormat.FromLdmlString("#")' />
                </DxPieChartSeries>
                <DxChartLegend VerticalAlignment="VerticalEdge.Bottom"
                               Position="RelativePosition.Outside" />
                <DxChartTooltip Enabled="true" Position="RelativePosition.Outside">
                    
                </DxChartTooltip>
            </DxPieChart>
        </div>
        <DxPopup @bind-Visible="IsModalRolVisible"
                 ShowCloseButton="true" Width="800px" Height="600px"
                 HeaderText="@Nombre">
            @if (rolSeleccionado != null)
            {

                <div class="p-3">
                    <DxGrid AllowColumnReorder="true"
                            AllowColumnResize="true"
                            Data="@opcionesRol"
                            ShowFilterRow="true"
                            FilterRowCondition="GridFilterRowCondition.Contains">
                        <Columns>
                            <DxGridDataColumn Caption="Opciones" FieldName="IsCodigo" Width="360px" VisibleIndex="3">
                                <EditSettings>
                                    <DxComboBoxSettings Data="opcionesMenu"
                                                        ValueFieldName="IsCodigo"
                                                        TextFieldName="IsDescri"
                                                        FilteringMode="DataGridFilteringMode.Contains"
                                                        ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                                                        EditFormat="{1} {2}">
                                        <Columns>
                                            <DxListEditorColumn FieldName="IsCodigo" Caption="Código" />
                                            <DxListEditorColumn FieldName="IsDescri" Caption="Descripción" />
                                            <DxListEditorColumn FieldName="NzCodigo" Caption="Módulo" Width="50px" />
                                        </Columns>
                                    </DxComboBoxSettings>
                                </EditSettings>
                            </DxGridDataColumn>
                            <DxGridDataColumn FieldName="MpAddFor" Caption="C" VisibleIndex="6" Width="40px" >
                                <CellDisplayTemplate>
                                    <DxCheckBox Checked="@((context.DataItem as Trhfm000Dto)?.MpAddFor)" Enabled="false" />
                                </CellDisplayTemplate>
                            </DxGridDataColumn>

                            <DxGridDataColumn Caption="R" FieldName="MpReadFo" VisibleIndex="7" Width="40px" >
                                <CellDisplayTemplate>
                                    <DxCheckBox Checked="@((context.DataItem as Trhfm000Dto)?.MpReadFo)" Enabled="false" />
                                </CellDisplayTemplate>
                            </DxGridDataColumn>
                            <DxGridDataColumn Caption="U" FieldName="MpUpdate" VisibleIndex="8" Width="40px" >
                                <CellDisplayTemplate>
                                    <DxCheckBox Checked="@((context.DataItem as Trhfm000Dto)?.MpUpdate)" Enabled="false" />
                                </CellDisplayTemplate>
                            </DxGridDataColumn>
                            <DxGridDataColumn Caption="D" FieldName="MpDelete" VisibleIndex="9" Width="40px" >
                                <CellDisplayTemplate>
                                    <DxCheckBox Checked="@((context.DataItem as Trhfm000Dto)?.MpDelete)" Enabled="false" />
                                </CellDisplayTemplate>
                            </DxGridDataColumn>
                        </Columns>
                    </DxGrid>
                </div>
            }
        </DxPopup>

    }


 

}

