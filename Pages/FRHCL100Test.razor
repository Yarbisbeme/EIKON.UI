 <div class="w-100 overview-chart">
    <div class="row">
        <div class="col-4">
            <div class="overview-chart-item">
                <div class="text-bg-info">Usuarios Totales</div>
                    <div class="text-center">@usuarios.Count()</div>
                </div>
        </div>
            <div class="col-4">
                <div class="overview-chart-item">
                    <div class="text-bg-primary">Usuarios Activos</div>
                    <div class="text-center">@usuarios.Count(es=>es.PasUserE=="A")</div>
                </div>
            </div>
            <div class="col-4">
                <div class="text-bg-danger">Usuarios Inactivos</div>
                <div class="text-center">@usuarios.Count(es => es.PasUserE != "A")</div>
            </div>
    </div>
    <hr />
