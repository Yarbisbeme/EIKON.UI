@layout MainLayout
@page "/FRHMA539A"
@using EIKON.UI.Components
@using DevExpress.Blazor
@using DevExpress.Blazor.Base
@using System.Net.Http.Json
@using System.Net.Http.Headers
@using EIKON.UI.Interfaces
@using DevExpress.AspNetCore.Reporting
@using DevExpress.XtraReports.UI
@using System.ComponentModel.DataAnnotations

@inject NavigationManager nv
@inject IJSRuntime JSRuntime

<div class="page">
    <Breadcrumb Title="FRHMA539A - Aprobadores Web" BackUrl="/dash" />
    <div class="page-header">
        <div class="page-toolbar">
            <Toolbar formulario="FRHxxx999" OnSave="HandleSave" OnClose="HandleClose" />
        </div>
    </div>
    <div class="frhma539a-form">

        <!-- Código + Nombre Row -->
        <div class="codigo-nombre-row">
            <div class="input codigo-field">
                <label>Código</label>
                <DxTextBox @bind-Text="@Codigo">
                    <Buttons>
                        <DxEditorButton IconCssClass="fi fi-rr-search" Click="@OnSearchCodigo" />
                    </Buttons>
                </DxTextBox>
            </div>
            <div class="input nombre-field">
                <label>Nombre</label>
                <DxTextBox @bind-Text="@Nombre">
                    <Buttons>
                        <DxEditorButton IconCssClass="fi fi-rr-search" Click="@OnSearchNombre" />
                    </Buttons>
                </DxTextBox>
            </div>
        </div>

        <!-- Email -->
        <div style="display:flex; gap:10px">
            <div class="input">
                <label>Email</label>
                <DxTextBox @bind-Text="@Email" NullText="Email" />
            </div>

            <!-- Jerarquía -->
            <div class="input jerarquia-field">
                <label>Jerarquía</label>
                <DxSpinEdit @bind-Value="@Jerarquia"
                            MinValue="0"
                            DisplayFormat="N0"
                            NullText="0" />
            </div>
        </div>

        <!-- Clave -->
        <div class="input">
            <label>Clave</label>
            <div class="search-field">
                <DxTextBox @bind-Text="@Clave"
                           NullText="Clave"
                           ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Never">
                    <Buttons>
                        <DxEditorButton IconCssClass="fi fi-rr-search" />
                    </Buttons>
                </DxTextBox>
                <DxTextBox NullText="ID requisicion" />
            </div>
        </div>

        <!-- Dual Section: Empresa + Ubicación -->
        <div class="dual-section">
            <div class="bordered-area">
                <label class="area-label">Empresa</label>
                <div class="area-content">
                    <!-- Contenido futuro de Empresa -->
                </div>
            </div>
            <div class="bordered-area">
                <label class="area-label">Ubicación</label>
                <div class="area-content">
                    <!-- Contenido futuro de Ubicación -->
                </div>
            </div>
        </div>

        <!-- Procesos Section -->
        <div class="procesos-section">
            <div class="input">
                <label>Proceso</label>
                <DxMemo @bind-Text="@Proceso"
                        Rows="8"
                        NullText="Proceso"
                        CssClass="proceso-memo" />
            </div>
        </div>

    </div>
</div>

@code {
    // **- private string[] // **- ToolbarOptions = { "save", "close" };

    // Fields
    private string Codigo { get; set; } = string.Empty;
    private string Nombre { get; set; } = string.Empty;
    private string Email { get; set; } = string.Empty;
    private int Jerarquia { get; set; } = 0;
    private string Clave { get; set; } = string.Empty;
    private string Proceso { get; set; } = string.Empty;

    private void OnSearchCodigo() { }
    private void OnSearchNombre() { }
    private void HandleSave() { }

    private void HandleClose()
    {
        nv.NavigateTo("/dash");
    }
}
