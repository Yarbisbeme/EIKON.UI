    void CambiarIdioma(string cultura)
    {
        // Atrapamos la URL actual para saber a dónde regresar
        var uri = new Uri(nv.Uri).GetComponents(UriComponents.PathAndQuery, UriFormat.Unescaped);
        
        // Armamos la URL hacia nuestro Mini-API con el idioma deseado
        var query = $"?culture={Uri.EscapeDataString(cultura)}&redirectUri={Uri.EscapeDataString(uri)}";
        
        // Viajamos forzando la recarga para que los textos cambien
        nv.NavigateTo("/Culture/Set" + query, forceLoad: true);
    }
    
