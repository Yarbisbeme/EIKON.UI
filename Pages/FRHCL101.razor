    protected async Task Save()
        {
            // Obligamos al contexto a revisar todo
            bool formularioValido = contextoValidacion.Validate();
            StateHasChanged();

            if (!formularioValido) 
            {
                // Tomamos TODOS los mensajes de error que existan, sin importar a qué campo pertenezcan
                var todosLosErrores = contextoValidacion.GetValidationMessages();
                string culpables = string.Join(" | ", todosLosErrores);

                // Imprimimos la lista cruda
                alertInfo.Show($"Faltan: {culpables}", "warning");
                
                return; // Cortamos el guardado
            }

            var dataItem = SelectedItem;

        // dataItem.Puevaca = Estatus;
        try {
            if (SelectedItem.IdentityColumn==0)
            {
                var ret0 = await api.InsertFrhpu010Dto(dataItem);
                //dataue = new List<Frhue000Dto>();
                clase = "";
            }
            else
            {
                var ret = await api.UpdateFrhpu010Dto(dataItem);
                //   nv.NavigateTo("/FRHCL101");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine("Error al guardar: " + ex.Message);
        }   

        alertInfo.Show("Cargo Actualizado!!!", "success");

        ActiveTabIndex = 1;
        id = SelectedItem.IdentityColumn;
        await CargaRegistro();
        //StateHasChanged();
        contextoValidacion = new EditContext(dataItem); // Nueva linea para hacer las validaciones, ya que el toolbar son divs y no btn
    }

