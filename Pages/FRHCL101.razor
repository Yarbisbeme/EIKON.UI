        alertInfo.Show("Editar Cargo!!!");
    }
    protected void Editar2(Frhrq010Dto item)
    {
        clase_np = clases.FirstOrDefault();
        SelectedItem = new Frhpu010Dto() ;
        SelectedItem.Puetitu = item.Reqtitu?.Trim();
        SelectedItem.Reqnume = item.Reqnume?.Trim();
        SelectedItem.OfCodigo = item.OfCodigo;
        SelectedItem.EmEmpresa = empresaActual;
        SelectedItem.UbCodigo = item.UbCodigo;
        SelectedItem.JoNumber = item.JoNumber;
        SelectedItem.ChangedOn = DateTime.Today;
        SelectedItem.ChangedBy = usuarioActual; 
        SelectedItem.NpCodigo =clase_np.CtCodigo;
        SelectedItem.Puenume = "000000"; 

        categoria_np = categorias.Where(x => x.CtCodigo == clase_np.CtCodigo).FirstOrDefault();
        SelectedItem.Puevaca = "A";
        Estatus = SelectedItem.Puevaca;

        alertInfo.Show("Crear Cargo a partir de una requisicion!!!");
        ActiveTabIndex = 0;

        contextoValidacion = new EditContext(SelectedItem); 
    }
    protected void Eliminar()
    {
        cShdn = "";
        cUhdn = "hidden";
        cAhdn = "hidden";
        //CantSave= false;
        alertInfo.Show("Eliminar Cargo!!!","warning");
        confirmDialog.Show();
    }
    
    protected void Agregar()
    {
        clase = "hidden";
        cShdn = "";
        cUhdn = "hidden";
        cAhdn = "hidden";
        
        // 1. ¡LA LÍNEA MÁGICA! Nace un cargo 100% limpio y vacío
        SelectedItem = new Frhpu010Dto(); 
        
        SelectedItem.IdentityColumn = 0;
        alertInfo.Show("Crear Nuevo Cargo!!!");
        
        SelectedItem.EmEmpresa = empresaActual;
        SelectedItem.CreatedBy = usuarioActual; 
        SelectedItem.CreatedOn = DateTime.Today;
        SelectedItem.ChangedOn = DateTime.Today;
        SelectedItem.ChangedBy = usuarioActual; 
        
        // 2. Le pasamos el objeto limpio al inspector
        contextoValidacion = new EditContext(SelectedItem); 
        CantSave = false;
        
        // 3. Forzamos a la pantalla a limpiarse
        StateHasChanged(); 
    }
