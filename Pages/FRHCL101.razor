    async Task CargaRegistro()
    {
        data = await api.Frhpu010DtoGetAll(Token);   

        if (id==0)
        {
            SelectedItem = data.FirstOrDefault();

        }
        else
        {
            SelectedItem = data.FirstOrDefault(pt => pt.IdentityColumn == id);


        }

        if (SelectedItem != null)
        {
            // 1. Destruir TODOS los espacios (Para IDs y Códigos)
            SelectedItem.Puenume = SelectedItem.Puenume?.Replace(" ", "");
            SelectedItem.Reqnume = SelectedItem.Reqnume?.Replace(" ", "");
            SelectedItem.OfCodigo = SelectedItem.OfCodigo?.Replace(" ", "");
            SelectedItem.UbCodigo = SelectedItem.UbCodigo?.Replace(" ", "");
            SelectedItem.JoNumber = SelectedItem.JoNumber?.Replace(" ", "");
            SelectedItem.NpCodigo = SelectedItem.NpCodigo?.Replace(" ", "");

            // 2. Destruir solo espacios de los bordes (Para Títulos y Nombres)
            SelectedItem.Puetitu = SelectedItem.Puetitu?.Trim();
        }

        clase_np = clases.FirstOrDefault(pt => pt.NpCodigo == SelectedItem.NpCodigo);
        if(clase_np == null)
        {
            clase_np = new Trhnp010Dto();
            clase_np.NpPeriodo = 3;
        }   
        //clase_np.NpPeriodo = id;
        categoria_np = categorias.FirstOrDefault(pt => pt.CtCodigo == clase_np.CtCodigo);
        if (categoria_np == null)
        {
            categoria_np = new Trhct010Dto();
            categoria_np.Ptomedio = 0;
            categoria_np.Minent = 0;
            categoria_np.CtCodigo = clase_np.CtCodigo;
        }
        //data = new List<Frhpu010Dto>();
        data.Add(SelectedItem);
        
        sPrueba = clase_np.NpPeriodo.ToString("N0");
        FechaCrea = SelectedItem.ChangedOn.ToString("yyyy-MM-dd");
        Estatus = SelectedItem.Puevaca;
        Presupuesto = categoria_np.Ptomedio.ToString("N2");
        SueldoEntrada = categoria_np.Minent.ToString("N2");
        // EsEmpl = SelectedItem.PasEsEmp == "S" ? true : false;
        // EnabledEmp = EsEmpl;
        Vacante = SelectedItem.Puevaca == "S" ? true : false;
        // EnabledExp = Expira;
        //  dataue = await api.GetFrhue000DtosByPasUserId(SelectedItem.PasUserid);
        contextoValidacion = new EditContext(SelectedItem); // Nueva linea para hacer las validaciones, ya que el toolbar son divs y no btn
        await InvokeAsync(StateHasChanged);
    }

