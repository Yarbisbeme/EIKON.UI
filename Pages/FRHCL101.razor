    @* 1. Mensajes ocultos (no afectan la vista inicial) *@
    <ConfirmDialog @ref="confirmDialog" Title="Eliminar Usuario" Message="¿Estás seguro que deseas eliminar este Usuario?" OnConfirm="OnConfirmDelete" />
    <AlertDialog @ref="alertDialog" Title="Eikon Alerta" Message="Existe(n) perfil(es) asociados a este empleado, favor eliminar los perfiles" />
    <Alert2 @ref="alertInfo" TypeAlert="info" Message="@Traductor["Titulo_CreacionCargos"]" />

    @* 2. HEADER: Carga instantáneamente sin importar el esqueleto *@
    <div class="header border-bottom pb-2 mb-4 d-flex justify-content-between align-items-center">
        <p class="eikon-primary-text mb-0" style="font-size:18px; font-weight:300;">SIRH - @Traductor["Titulo_CreacionCargos"]</p>
        <Toolbar OnAdd="Agregar" OnSave="Save" OnRemove="Eliminar" formulario="FRHCL101" />
        
        <div>
            <button class="btn btn-primary btn-sm me-1" @onclick="@(() => CambiarIdioma("es"))">ES</button>
            <button class="btn btn-secondary btn-sm" @onclick="@(() => CambiarIdioma("en"))">EN</button>
        </div>
    </div>

    <div class="container">
        @if (cargando)
        {
            <div class="placeholder-glow">
