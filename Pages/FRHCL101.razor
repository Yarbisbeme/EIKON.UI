    protected override async Task OnInitializedAsync()
    {
        // cambiamos la forma de la carga del formulario para que sea afterRender()
    }
    
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try 
            {
                // 1. LEER EL TOKEN
                if (string.IsNullOrEmpty(Token))
                {
                    Token = await auth.GetTokenAsync();
                    Token = auth.tkn;
                    
                    if (string.IsNullOrEmpty(Token)) return; 
                    
                    api.SetToken(Token);
                    auth.SetToken(Token);
                }

                // 2. DATOS DE SESIÓN
                empresaActual = api.GetEmpresa();
                usuarioActual = api.GetUser();

                // 3. DESCARGAR LISTAS
                data = await api.Frhpu010DtoGetAll(Token); 
                datarq = await api.Frhrq010DtoGetAll(Token);
                puestos = await api.Frhjo010DtoGetAll(Token);
                ubicaciones = await api.Trhub010DtoGetByEmpresa(empresaActual, Token);
                oficinas = await api.Trhof010DtoGetByEmpresa(empresaActual, Token); 
                clases = await api.Trhnp010DtoGetByEmpresa(empresaActual, Token);
                categorias = await api.ctGetByEmCodigo(empresaActual, Token);
                motivos = await api.mtGetByEmCodigo(empresaActual, Token);

                // 4. PREPARAR EL FORMULARIO
                await CargaRegistro();
            }
            catch (Exception ex)
            {
                // ¡AQUÍ ATRAPAMOS AL CULPABLE!
                Console.WriteLine("🚨 ERROR FATAL AL CARGAR: " + ex.Message);
                Console.WriteLine(ex.StackTrace);
                
                // Opcional: Mostrarle la alerta al usuario para que sepa que algo falló
                alertInfo.Show("Error de conexión al cargar los datos.", "danger");
            }
            finally 
            {
                // 5. EL FINALLY GARANTIZA QUE EL ESQUELETO SE QUITE SÍ O SÍ
                cargando = false;
                StateHasChanged(); 
            }
        }
    }
    
