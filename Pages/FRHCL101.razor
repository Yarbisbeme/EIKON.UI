                    <span class="placeholder col-3" style="height: 40px; border-radius: 4px;"></span>
                    <span class="placeholder col-3" style="height: 40px; border-radius: 4px;"></span>
                    <span class="placeholder col-3" style="height: 40px; border-radius: 4px;"></span>
                </div>

                @for (int i = 0; i < 4; i++) 
                {
                    <div class="row mb-3">
                        <div class="col-md-4">
                            <span class="placeholder col-4 mb-2" style="height: 15px; border-radius: 3px;"></span> 
                            <span class="placeholder col-12" style="height: 34px; border-radius: 4px;"></span> 
                        </div>
                        <div class="col-md-4">
                            <span class="placeholder col-4 mb-2" style="height: 15px; border-radius: 3px;"></span>
                            <span class="placeholder col-12" style="height: 34px; border-radius: 4px;"></span>
                        </div>
                        <div class="col-md-4">
                            <span class="placeholder col-4 mb-2" style="height: 15px; border-radius: 3px;"></span>
                            <span class="placeholder col-12" style="height: 34px; border-radius: 4px;"></span>
                        </div>
                    </div>
                }
                
                <hr class="mb-2" style="border-top: 2px solid #dee2e6; opacity: 1;" />
                <div class="col">
                    <span class="placeholder col-4 mb-2" style="height: 15px; border-radius: 3px; width: 10px;"></span>
                    <span class="placeholder col-6" style="height: 34px; border-radius: 4px;"></span>
                </div>
            </div>
        }
        else
        {
            <DxTabs ActiveTabIndex="@ActiveTabIndex" ActiveTabIndexChanged="@OnActiveTabIndexChanged" @key="contextoValidacion">

                <DxTabPage CssClass="dxbl-tabs" Text="Mantenimiento del Puesto">
            
                    <EditForm class="eikon-tab-animada" EditContext="@contextoValidacion">
                        <DataAnnotationsValidator />
                        <div class="row">
                            <div class="form-group col-md-4 mb-3">
                                <label class="mb-1" style="font-weight: 500; color: #2e2e2e;" for="puenume">@Traductor["lbl_Cargo"]</label>
                                <DxTextBox CssClass="eikon-input eikon-readonly" id="puenume" @bind-Text="@SelectedItem.Puenume" ReadOnly="true" onin />
                            </div>
                            <div class="form-group col-md-4 mb-3">
                                <label class="mb-1" style="font-weight: 500; color: #2e2e2e;" for="puetitu">Título</label>
                                <DxTextBox CssClass="eikon-input" id="puetitu" @bind-Text="@SelectedItem.Puetitu" BindValueMode="BindValueMode.OnInput"/>
                            </div>
                            <div class="form-group col-md-4 mb-3">
                                <label class="mb-1" style="font-weight: 500; color: #2e2e2e;" for="reqnume">Requisición</label>
                                    
                                <div class="form-group d-flex gap-2">
                                    <DxTextBox CssClass="eikon-input" id="reqnume" @bind-Text="@SelectedItem.Reqnume" BindValueMode="BindValueMode.OnInput"/>
                                    <DxButton Id="btnBuscar" Click="BuscarReq" Text="Buscar" class="btn btn-info"/>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="form-group mb-3 col-md-4">
                                <label class="mb-1" style="font-weight: 500; color: #2e2e2e;" for="Oficina">Oficina</label>
                                <DxComboBox CssClass="eikon-input" id="Oficina" Data="@oficinas" ValueFieldName="OfCodigo" TextFieldName="OfDescri" @bind-Value="SelectedItem.OfCodigo"  />
                            </div>
                            <div class="form-group mb-3 col-md-4">
                                <label class="mb-1" style="font-weight: 500; color: #2e2e2e;" for="Ubicacion">Departamento</label>
                                <DxComboBox CssClass="eikon-input" id="Ubicacion" Data="@ubicaciones" ValueFieldName="UbCodigo" TextFieldName="UbDescri" @bind-Value="SelectedItem.UbCodigo" />
                            </div>
                            <div class="form-group mb-3 col-md-4">
                                <label class="mb-1" style="font-weight: 500; color: #2e2e2e;" for="Puesto">Puesto</label>
                                <DxComboBox CssClass="eikon-input" id="Puesto" Data="@puestos" ValueFieldName="JoNumber" TextFieldName="JoTitulo" @bind-Value="SelectedItem.JoNumber" />
                            </div>
                        </div>

                        <div class="row">
                            <div class="form-group mb-3 col-md-4">
                                <label class="mb-1" style="font-weight: 500; color: #2e2e2e;" for="Clase">Clase</label>
                                <DxComboBox CssClass="eikon-input" id="Clase" Data="@clases" ValueFieldName="NpCodigo" TextFieldName="NpDescri" @bind-Value="SelectedItem.NpCodigo" />
                            </div>

                            <div class="form-group mb-3 col-md-4">
                                <label class="mb-1" style="font-weight: 500; color: #2e2e2e;" for="Categoria">Categoria</label>
                                <DxComboBox CssClass="eikon-input eikon-readonly" id="Categoria" Data="@categorias" ValueFieldName="CtCodigo" TextFieldName="CtDescri" @bind-Value="clase_np.CtCodigo" Readonly />
                            </div>
                            <div class="form-group mb-3 col-md-4">
                                <label class="mb-1" style="font-weight: 500; color: #2e2e2e;" for="create">Fecha Creacion</label>
                                <DxDateEdit CssClass="eikon-input" id="create" @bind-Date="@SelectedItem.ChangedOn" />
                            </div>
                        </div>

                        <div class="row">
                            <div class="form-group mb-3 col-md-4">
                                <label class="mb-1" style="font-weight: 500; color: #2e2e2e;" for="sEntrada">Sueldo Entrada</label>
                                <DxSpinEdit CssClass="eikon-input eikon-readonly" id="sEntrada" @bind-Value="@categoria_np.Minent" Mask="n2" ReadOnly /> @* Solo permite numeros y es para seleccionar *@
                            </div>
                            <div class="form-group mb-3 col-md-4">
                                <label class="mb-1" style="font-weight: 500; color: #2e2e2e;" for="pPrueba">Perido de Prueba en Meses</label>
                                <DxSpinEdit CssClass="eikon-input" id="pPrueba" @bind-Value="@SelectedItem.Pueperi" Mask="@NumericMask.WholeNumber" />
                            </div>
                            <div class="form-group mb-2 col-md-4">
                                <label class="mb-1" style="font-weight: 500; color: #2e2e2e;" for="presupuesto">Presupuesto</label>
                                <DxSpinEdit CssClass="eikon-input" id="presupuesto" @bind-Value="@categoria_np.Ptomedio" Mask="n2" />
                            </div>
                        </div>

                        <hr class="mb-2" style="border-top: 2px solid #dee2e6; opacity: 1;" />
                        
                        <EikonStatusGroup 
                        Label="Estatus" 
                        Items="@estatus" 
                        @bind-Value="@SelectedItem.Puevaca" 
                        />

                    </EditForm>


                </DxTabPage>
                <DxTabPage CssClass="dxbl-tabs"  Text="Consulta de Puestos">
                    <div class="eikon-tab-animada">
                        <h3>Consulta de Puestos</h3>
                        <DxGrid Data="@data" @ref="MyGrid"
                                PageSize="15"
                                CssClass="mw-1100"
                                KeyFieldName="Puenume"
                                ShowFilterRow="true" 
                                FilterRowCondition="GridFilterRowCondition.Contains">
                            <Columns>
                                <DxGridCommandColumn MinWidth="60" VisibleIndex="2">
                                    <HeaderTemplate>
                                        <a class="text-primary" @onclick="@(() => MyGrid.StartEditNewRowAsync())" style="text-decoration: none;" href="javascript:void(0);"><i class="fi fi-rr-plus"></i></a>
                                    </HeaderTemplate>
                                    <CellDisplayTemplate>
                                        <a class="" @onclick="@(() => Editar((Frhpu010Dto)context.DataItem))" style="text-decoration: none;" href="javascript:void(0);"><i class="fi fi-rr-edit"></i></a>
                                    @*  <a class="text-primary" @onclick="@(() => MyGrid.SelectDataItem(context.DataItem))" style="text-decoration: none;" href="javascript:void(0);"><i class="fi fi-rr-edit"></i></a> *@
                                    </CellDisplayTemplate>
                                </DxGridCommandColumn>
                                <DxGridDataColumn Caption="Id" FieldName="Puenume" MinWidth="100" VisibleIndex="3" />
                                <DxGridDataColumn Caption="Descripción" FieldName="Puetitu" MinWidth="300" VisibleIndex="4" />
                            
                                @* <DxGridDataColumn FieldName="OfCodigo" Caption="ID Oficina"/> *@
                                <DxGridDataColumn Caption="Oficina" FieldName="OfCodigo" MinWidth="160" VisibleIndex="5">
                                    <EditSettings>
                                        <DxComboBoxSettings Data="oficinas"
                                                            ValueFieldName="OfCodigo"
                                                            TextFieldName="OfDescri"
                                                            FilteringMode="DataGridFilteringMode.Contains"
                                                            ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                                                            EditFormat="{1} {2}">
                                            <Columns>
                                                <DxListEditorColumn FieldName="OfCodigo" Caption="Código" />
                                                <DxListEditorColumn FieldName="OfDescri" Caption="Descripción" />
                                                <DxListEditorColumn FieldName="EmEmpresa" Caption="Empresa" Width="60px" />
                                            </Columns>
                                        </DxComboBoxSettings>
                                    </EditSettings>
                                </DxGridDataColumn>
                                @* <DxGridDataColumn FieldName="UbCodigo" Caption="ID Ubicac" /> *@
                                <DxGridDataColumn Caption="Departamento" FieldName="UbCodigo" MinWidth="260" VisibleIndex="6">
                                    <EditSettings>
                                        <DxComboBoxSettings Data="ubicaciones"
                                                            ValueFieldName="UbCodigo"
                                                            TextFieldName="UbDescri"
                                                            FilteringMode="DataGridFilteringMode.Contains"
                                                            ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                                                            EditFormat="{1} {2}">
                                            <Columns>
                                                <DxListEditorColumn FieldName="UbCodigo" Caption="Código" />
                                                <DxListEditorColumn FieldName="UbDescri" Caption="Descripción" />
                                                <DxListEditorColumn FieldName="EmEmpresa" Caption="Empresa" Width="60px" />
                                            </Columns>
                                        </DxComboBoxSettings>
                                    </EditSettings>
                                </DxGridDataColumn>
                    @*             <DxGridDataColumn FieldName="JoNumber" Caption="Id Puesto" /> *@ 
                                <DxGridDataColumn Caption="Puesto" FieldName="JoNumber" MinWidth="260" VisibleIndex="7">
                                    <EditSettings>
                                        <DxComboBoxSettings Data="puestos"
                                                            ValueFieldName="JoNumber"
                                                            TextFieldName="JoTitulo"
                                                            ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                                                            EditFormat="{1} {2}">
                                            <Columns>
                                                <DxListEditorColumn FieldName="JoNumber" Caption="Código" />
                                                <DxListEditorColumn FieldName="JoTitulo" Caption="Descripción" />
                                                <DxListEditorColumn FieldName="EmEmpresa" Caption="Empresa" Width="60px" />
                                            </Columns>
                                        </DxComboBoxSettings>
                                    </EditSettings>
                                </DxGridDataColumn>
                                <DxGridDataColumn FieldName="IdentityColumn" MinWidth="150" Caption="#" Visible="false">
                                    
                                </DxGridDataColumn>
                                <!-- Columna para el botón -->
                            



                            </Columns>
                        </DxGrid>
                    </div>
                </DxTabPage>
                <DxTabPage CssClass="dxbl-tabs"  Text="Consulta de Requisiciones">
                    <div class="eikon-tab-animada">
                        <h3>Consulta de Requisiciones</h3>
                        <DxGrid Data="@datarq" @ref="MyGrid2"
                                CssClass="mw-1100"
                                KeyFieldName="Reqnume"
                                ShowFilterRow="true" 
                                FilterRowCondition="GridFilterRowCondition.Contains">
                            <Columns>
                                <DxGridCommandColumn MinWidth="160" VisibleIndex="1">
                                    <HeaderTemplate>
                                    </HeaderTemplate>
                                    <CellDisplayTemplate>
                                        <a class="" @onclick="@(() => Editar2((Frhrq010Dto)context.DataItem))" style="text-decoration: none;" href="javascript:void(0);"><i class="fi fi-rr-edit"></i></a>

                                    </CellDisplayTemplate>
                                    </DxGridCommandColumn>
                                <DxGridDataColumn Caption="Req #" FieldName="Reqnume" MinWidth="80" VisibleIndex="3" 
                                    FilterRowValue="@filtroReq" 
                                    FilterRowValueChanged="@((object v) => filtroReq = v?.ToString())">
                                </DxGridDataColumn>
                                <DxGridDataColumn Caption="Descripción" FieldName="Reqtitu" MinWidth="300" VisibleIndex="4">

                                </DxGridDataColumn>
                                <DxGridDataColumn Caption="Oficina" FieldName="OfCodigo" MinWidth="160" VisibleIndex="5">
                                    <EditSettings>
                                        <DxComboBoxSettings Data="oficinas"
                                                            ValueFieldName="OfCodigo"
                                                            TextFieldName="OfDescri"
                                                            ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                                                            EditFormat="{1} {2}">
                                            <Columns>
                                                <DxListEditorColumn FieldName="OfCodigo" Caption="Código" />
                                                <DxListEditorColumn FieldName="OfDescri" Caption="Descripción" />
                                            </Columns>
                                        </DxComboBoxSettings>
                                    </EditSettings>
                                </DxGridDataColumn>
                                <DxGridDataColumn Caption="Fecha" FieldName="Reqfech" MinWidth="80" VisibleIndex="5"></DxGridDataColumn>
                                <DxGridDataColumn Caption="Cantidad" FieldName="Reqqty" MinWidth="80" VisibleIndex="6"></DxGridDataColumn>

                                <DxGridDataColumn Caption="Motivo" FieldName="MtCodigo" VisibleIndex="8" MinWidth="130">
                                    <EditSettings>
                                        <DxComboBoxSettings Data="motivos"
                                                            ValueFieldName="MtCodigo"
                                                            TextFieldName="MtDescri"
                                                            ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                                                            EditFormat="{1} {2}"
                                                            SearchMode="@ListSearchMode.AutoSearch"
                                                            SearchFilterCondition="@ListSearchFilterCondition.Contains">
                                            <Columns>
                                                <DxListEditorColumn FieldName="MtCodigo" Caption="Código" />
                                                <DxListEditorColumn FieldName="MtDescri" Caption="Descripción" />
                                            </Columns>
                                        </DxComboBoxSettings>
                                    </EditSettings>
                                </DxGridDataColumn>

                                <DxGridDataColumn Caption="Estatus" FieldName="Reqesta" VisibleIndex="9" MinWidth="130">
                                    <EditSettings>
                                        <DxComboBoxSettings Data="estatus"
                                                            ValueFieldName="Value"
                                                            TextFieldName="Text"
                                                            ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                                                            EditFormat="{1} {2}"
                                                            SearchMode="@ListSearchMode.AutoSearch"
                                                            SearchFilterCondition="@ListSearchFilterCondition.Contains">
                                            <Columns>
                                                <DxListEditorColumn FieldName="Value" Caption="Código" />
                                                <DxListEditorColumn FieldName="Text" Caption="Descripción" />

                                            </Columns>
                                        </DxComboBoxSettings>
                                    </EditSettings>
                                </DxGridDataColumn>

                            </Columns>
                        </DxGrid>
                    </div>
                </DxTabPage>
            </DxTabs>
        }
    </div>

