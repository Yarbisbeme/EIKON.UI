@page "/FRHMA102A"
@using DevExpress.Blazor
@using System.Net.Http.Json
@using System.Net.Http.Headers
@using EIKON.UI.Interfaces
@using DevExpress.AspNetCore.Reporting
@using DevExpress.XtraReports.UI
@using EIKON.UI.Components

@inject HttpClient HttpClient
@inject EIKON.UI.Services.EikonDataServices api
@inject EIKON.UI.Services.AuthenticationService auth

@inject NavigationManager nv
@inject IJSRuntime JS

<div class="page">
    <Breadcrumb Title="FRHMA102A" BackUrl="/dash" />
    <div class="page-header">

        <div class="page-search">
            <div class="input-search">
                <label for="user">Usuario</label>
                <DxTextBox @bind-Text="@searchText"
                NullText="Jose Segura Eikon"
                ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Never">
                    <Buttons>
                        <DxEditorButton IconCssClass="fi fi-rr-search"
                        Click="@OnSearchClick" />
                    </Buttons>
                </DxTextBox>
            </div>
        </div>
        <div class="page-toolbar">
            <Toolbar formulario="FRHxxx999" OnClose="HandleClose" />
        </div>
    </div>

    <div class="form-container">
        <!-- Usuario -->
        <div class="form-row">
            <div class="input-field full-width">
                <label>Nombre</label>
                <DxTextBox NullText="Jose Segura Eikon" @bind-Text="@TextValue" />
            </div>
        </div>

        <!-- Sección principal con dos columnas -->
        <div class="main-section">
            <!-- Columna izquierda: Información de Seguridad -->
            <div class="left-column">
                <div class="section-title">Información de Seguridad</div>
                <div class="security-content">
                    <div class="input-field">
                        <label>Contraseña</label>
                        <DxTextBox NullText="Jose Segura Eikon" @bind-Text="@PasswordValue" InputType="DataEditorInputType.Password" />
                    </div>
                    
                    <div class="input-field">
                        <label>Confirmar</label>
                        <DxTextBox NullText="Jose Segura Eikon" @bind-Text="@ConfirmPasswordValue" InputType="DataEditorInputType.Password" />
                    </div>
                    
                    <div class="form-row">
                        <div class="input-field wide">
                            <label>Fecha Expiración</label>
                            <DxDateEdit @bind-Date="@DateTimeValue" />
                        </div>
                        <div class="input-field narrow">
                            <label>¿Expira?</label>
                            <div class="radio-options">
                                <DxRadio GroupName="expires-group" @bind-GroupValue="@ExpiresAnswer" Value="@siValue">Si</DxRadio>
                                <DxRadio GroupName="expires-group" @bind-GroupValue="@ExpiresAnswer" Value="@noValue">No</DxRadio>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Columna derecha: Estado del Sistema -->
            <div class="right-column">
                <div class="section-title">Estado del Sistema</div>
                <div class="system-content">
                    <div class="input-field">
                        <label>Estatus de la Red</label>
                        <div class="radio-options">
                            <DxRadio GroupName="network-status-group" @bind-GroupValue="@NetworkStatusAnswer" Value="@siValue">Si</DxRadio>
                            <DxRadio GroupName="network-status-group" @bind-GroupValue="@NetworkStatusAnswer" Value="@noValue">No</DxRadio>
                        </div>
                    </div>
                    
                    <div class="input-field">
                        <label>Estado</label>
                        <div class="radio-options">
                            <DxRadio GroupName="state-group" @bind-GroupValue="@StateAnswer" Value="@siValue">Si</DxRadio>
                            <DxRadio GroupName="state-group" @bind-GroupValue="@StateAnswer" Value="@noValue">No</DxRadio>
                        </div>
                    </div>
                    
                    <div class="input-field">
                        <label>Extension</label>
                        <DxTextBox NullText="Jose Segura Eikon" @bind-Text="@ExtensionValue" />
                    </div>
                </div>
            </div>
        </div>
    </div>

</div>

<style>
    /* Container principal */
    .form-container {
        display: flex;
        flex-direction: column;
        gap: 20px;
        margin-top: 10px;
    }

    /* Form rows */
    .form-row {
        display: flex;
        gap: 15px;
        align-items: flex-end;
    }

    /* Input fields con label arriba */
    .input-field {
        display: flex;
        flex-direction: column;
        gap: 5px;
    }

    .input-field label {
        font-weight: normal;
        color: #333;
        font-size: 14px;
    }

    /* Tamaños de campos */
    .input-field.full-width {
        flex: 1;
    }

    .input-field.wide {
        flex: 2;
    }

    .input-field.narrow {
        flex: 1;
    }

    /* Sección principal con dos columnas */
    .main-section {
        display: flex;
        gap: 20px;
        margin-top: 20px;
        min-height: 400px;
    }

    .left-column,
    .right-column {
        flex: 1;
        display: flex;
        flex-direction: column;
        border: 1px solid #e0e0e0;
        border-radius: 4px;
        overflow: hidden;
    }

    /* Títulos de sección */
    .section-title {
        background-color: #f5f5f5;
        padding: 12px 15px;
        font-weight: 600;
        border-bottom: 1px solid #e0e0e0;
        text-align: left;
        font-size: 14px;
        color: #333;
    }

    /* Contenido de las secciones */
    .security-content,
    .system-content {
        padding: 15px;
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    /* Radio buttons */
    .radio-options {
        display: flex;
        gap: 15px;
        align-items: center;
        margin-top: 5px;
    }

    /* Responsive Design */
    media (max-width: 768px) {
        .form-row {
            flex-direction: column;
            gap: 10px;
        }

        .input-field.wide,
        .input-field.narrow {
            flex: 1;
        }

        .main-section {
            flex-direction: column;
            gap: 15px;
        }
    }

    media (max-width: 480px) {
        .security-content,
        .system-content {
            padding: 10px;
            gap: 15px;
        }

        .radio-options {
            flex-direction: column;
            align-items: flex-start;
            gap: 8px;
        }
    }
</style>

@code {
    private DateTime DateTimeValue { get; set; } = new DateTime(2025, 9, 3);
    // **- private string[] // **- ToolbarOptions = { "add", "save", "remove", "leave" };
    private string searchText { get; set; } = "";
    private string TextValue { get; set; } = "";
    private string PasswordValue { get; set; } = "";
    private string ConfirmPasswordValue { get; set; } = "";
    private string ExtensionValue { get; set; } = "";
    private string ExpiresAnswer { get; set; } = "si";
    private string NetworkStatusAnswer { get; set; } = "si";
    private string StateAnswer { get; set; } = "si";
    
    private string siValue = "si";
    private string noValue = "no";

    private void OnSearchClick()
    {
        // Aquí puedes manejar la lógica de búsqueda
        Console.WriteLine($"Buscando requisición con ID: {searchText}");
    }

    private async Task HandleClose()
    {
        // Lógica para agregar
        await JS.InvokeVoidAsync("alert", "¡Hola desde Blazor!");

    }
}
