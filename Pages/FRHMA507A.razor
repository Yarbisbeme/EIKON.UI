@page "/FRHMA507A"
@using DevExpress.Blazor
@using System.Net.Http.Json
@using System.Net.Http.Headers
@using EIKON.UI.Interfaces
@using DevExpress.AspNetCore.Reporting
@using DevExpress.XtraReports.UI
@using EIKON.UI.Components

@inject HttpClient HttpClient
@inject EIKON.UI.Services.EikonDataServices api
@inject EIKON.UI.Services.AuthenticationService auth

@inject NavigationManager nv
@inject IJSRuntime JS

<div class="page">
    <Breadcrumb Title="FRHMA507A - Transacciones básicas" BackUrl="/dash" />
    
    <div class="page-header">
        <div class="page-toolbar">
            <Toolbar formulario="FRHxxx999" OnClose="HandleClose" />
        </div>
    </div>

    <div class="form-container">
        <!-- Sistema de Tabs con DevExpress -->
        <DxTabs @bind-ActiveTabIndex="@ActiveTabIndex" 
                CssClass="custom-tabs">
            <DxTabPage Text="Nómina">
                    <!-- Sección de Conceptos -->
                        <div class="concepts-section">
                            <div class="concepts-left">
                                <div class="input-field">
                                    <label>Sueldo</label>
                                    <DxComboBox Data="@ConceptList" 
                                               @bind-Value="@SueldoValue" 
                                               NullText="SALARIO ORDINARIO" 
                                               TextFieldName="Name" 
                                               ValueFieldName="Id" />
                                </div>
                                
                                <div class="input-field">
                                    <label>Retroactivo</label>
                                    <DxComboBox Data="@ConceptList" 
                                               @bind-Value="@RetroactivoValue" 
                                               NullText="RETROACTIVO" 
                                               TextFieldName="Name" 
                                               ValueFieldName="Id" />
                                </div>
                                
                                <div class="input-field">
                                    <label>Completivo</label>
                                    <DxComboBox Data="@ConceptList" 
                                               @bind-Value="@CompletivoValue" 
                                               NullText="COMPLETIVO" 
                                               TextFieldName="Name" 
                                               ValueFieldName="Id" />
                                </div>
                                
                                <div class="input-field">
                                    <label>Saldo a favor ISR</label>
                                    <DxComboBox Data="@ConceptList" 
                                               @bind-Value="@SaldoFavorValue" 
                                               NullText="Seleccionar concepto" 
                                               TextFieldName="Name" 
                                               ValueFieldName="Id" />
                                </div>
                                
                                <div class="input-field">
                                    <label>Descuento vacaciones</label>
                                    <DxComboBox Data="@ConceptList" 
                                               @bind-Value="@DescuentoVacacionesValue" 
                                               NullText="Seleccionar concepto" 
                                               TextFieldName="Name" 
                                               ValueFieldName="Id" />
                                </div>
                                
                                <div class="input-field">
                                    <label>Avance vacaciones</label>
                                    <DxComboBox Data="@ConceptList" 
                                               @bind-Value="@AvanceVacacionesValue" 
                                               NullText="Seleccionar concepto" 
                                               TextFieldName="Name" 
                                               ValueFieldName="Id" />
                                </div>
                            </div>

                            <div class="concepts-right">
                                <div class="input-field">
                                    <label>Bono Vacaciones</label>
                                    <DxComboBox Data="@ConceptList" 
                                               @bind-Value="@BonoVacacionesValue" 
                                               NullText="Seleccionar concepto" 
                                               TextFieldName="Name" 
                                               ValueFieldName="Id" />
                                </div>
                                
                                <div class="input-field">
                                    <label>Diferencial Vacaciones</label>
                                    <DxComboBox Data="@ConceptList" 
                                               @bind-Value="@DiferencialVacacionesValue" 
                                               NullText="Seleccionar concepto" 
                                               TextFieldName="Name" 
                                               ValueFieldName="Id" />
                                </div>
                                
                                <div class="input-field">
                                    <label>Fracción Vacaciones</label>
                                    <DxComboBox Data="@ConceptList" 
                                               @bind-Value="@FraccionVacacionesValue" 
                                               NullText="Seleccionar concepto" 
                                               TextFieldName="Name" 
                                               ValueFieldName="Id" />
                                </div>
                                
                                <div class="input-field">
                                    <label>Redondeo Positivo</label>
                                    <DxComboBox Data="@ConceptList" 
                                               @bind-Value="@RedondeoPositivoValue" 
                                               NullText="Seleccionar concepto" 
                                               TextFieldName="Name" 
                                               ValueFieldName="Id" />
                                </div>
                                
                                <div class="input-field">
                                    <label>Rendondeo Negativo</label>
                                    <DxComboBox Data="@ConceptList" 
                                               @bind-Value="@RedondeoNegativoValue" 
                                               NullText="Seleccionar concepto" 
                                               TextFieldName="Name" 
                                               ValueFieldName="Id" />
                                </div>
                                
                                <div class="input-field">
                                    <label>IDSS</label>
                                    <DxComboBox Data="@ConceptList" 
                                               @bind-Value="@IdssValue" 
                                               NullText="IHSS LABORAL" 
                                               TextFieldName="Name" 
                                               ValueFieldName="Id" />
                                </div>
                            </div>
                        </div>

                        <!-- Sección de Configuraciones -->
                        <div class="config-section">
                            <div class="config-left">
                                <div class="config-group">
                                    <div class="group-title">Base Calculo ISR</div>
                                    <div class="radio-group">
                                        <DxRadio GroupName="base-calculo" @bind-GroupValue="@BaseCalculoIsr" Value="@mensualValue">Mensual</DxRadio>
                                        <DxRadio GroupName="base-calculo" @bind-GroupValue="@BaseCalculoIsr" Value="@anualValue">Anual</DxRadio>
                                    </div>
                                </div>
                            </div>

                            <div class="config-center">
                                <div class="config-group">
                                    <div class="group-title">Sueldo</div>
                                    <div class="radio-group">
                                        <DxRadio GroupName="sueldo-group" @bind-GroupValue="@SueldoGroupValue" Value="@sueldoValue">Sueldo</DxRadio>
                                        <DxRadio GroupName="sueldo-group" @bind-GroupValue="@SueldoGroupValue" Value="@sueldoOtrosBeneficiosValue">Sueldo y Otros Beneficios</DxRadio>
                                        <DxRadio GroupName="sueldo-group" @bind-GroupValue="@SueldoGroupValue" Value="@ingresoBaseCategoriaValue">Ingreso Base y % Categoría</DxRadio>
                                        <DxRadio GroupName="sueldo-group" @bind-GroupValue="@SueldoGroupValue" Value="@ingresoBaseEfectoValue">Ingreso Base y Efecto</DxRadio>
                                    </div>
                                </div>
                            </div>

                            <div class="config-right">
                                <div class="config-group">
                                    <div class="group-title">Calculo del IDSS & Semanal</div>
                                    <div class="radio-group">
                                        <DxRadio GroupName="calculo-idss" @bind-GroupValue="@CalculoIdss" Value="@semana25Value">2.5 y 2.5 Semanas</DxRadio>
                                        <DxRadio GroupName="calculo-idss" @bind-GroupValue="@CalculoIdss" Value="@semana30Value">3.0 y 2.0 semanas</DxRadio>
                                        <DxRadio GroupName="calculo-idss" @bind-GroupValue="@CalculoIdss" Value="@semana20Value">2.0 y 3.0 semanas</DxRadio>
                                    </div>
                                </div>
                            </div>
                        </div>


                        <!-- Sección de Opciones Adicionales -->
                        <div class="options-section">
                            <div class="checkbox-group">
                                <DxCheckBox @bind-Checked="@MostrarInvisible">Mostrar Invisible</DxCheckBox>
                                <DxCheckBox @bind-Checked="@AplicaRedondeo">Aplica Redondeo</DxCheckBox>
                                <DxCheckBox @bind-Checked="@IngresosCorporativos">Ingresos Corporativos</DxCheckBox>
                                <DxCheckBox @bind-Checked="@VenceContrato">Vence Contrato</DxCheckBox>
                            </div>
                        </div>
            </DxTabPage>
            
            <DxTabPage Text="Beneficios">
                <!-- Sección de Beneficios -->
                <div class="beneficios-section">
                    <div class="beneficios-left">
                        <div class="input-field">
                            <label>Seguro Médico</label>
                            <DxComboBox Data="@ConceptList" 
                                       @bind-Value="@SeguroMedicoValue" 
                                       NullText="Seleccionar concepto" 
                                       TextFieldName="Name" 
                                       ValueFieldName="Id" />
                        </div>
                        
                        <div class="input-field">
                            <label>Vacaciones</label>
                            <DxComboBox Data="@ConceptList" 
                                       @bind-Value="@VacacionesValue" 
                                       NullText="Seleccionar concepto" 
                                       TextFieldName="Name" 
                                       ValueFieldName="Id" />
                        </div>
                        
                        <div class="input-field">
                            <label>Incentivo</label>
                            <DxComboBox Data="@ConceptList" 
                                       @bind-Value="@IncentivoValue" 
                                       NullText="Seleccionar concepto" 
                                       TextFieldName="Name" 
                                       ValueFieldName="Id" />
                        </div>
                        
                        <div class="input-field">
                            <label>Educación</label>
                            <DxComboBox Data="@ConceptList" 
                                       @bind-Value="@EducacionValue" 
                                       NullText="Seleccionar concepto" 
                                       TextFieldName="Name" 
                                       ValueFieldName="Id" />
                        </div>
                        
                        <div class="input-field">
                            <label>Costo Selección</label>
                            <DxComboBox Data="@ConceptList" 
                                       @bind-Value="@CostoSeleccionValue" 
                                       NullText="COSTOS PROCESO DE SELECCIÓN" 
                                       TextFieldName="Name" 
                                       ValueFieldName="Id" />
                        </div>
                        
                        <div class="input-field">
                            <label>Otros Ingresos</label>
                            <DxComboBox Data="@ConceptList" 
                                       @bind-Value="@OtrosIngresosValue" 
                                       NullText="Seleccionar concepto" 
                                       TextFieldName="Name" 
                                       ValueFieldName="Id" />
                        </div>
                        
                        <div class="input-field">
                            <label>Abono Prestamos</label>
                            <DxComboBox Data="@ConceptList" 
                                       @bind-Value="@AbonoPrestamosValue" 
                                       NullText="Seleccionar concepto" 
                                       TextFieldName="Name" 
                                       ValueFieldName="Id" />
                        </div>
                    </div>
                </div>

                <!-- Sección de Configuraciones de Beneficios -->
                <div class="config-section">
                    <div class="config-left">
                        <div class="config-group">
                            <div class="group-title">Presención Beneficios</div>
                            <div class="radio-group">
                                <DxRadio GroupName="presencia-beneficios" @bind-GroupValue="@PresenciaBeneficios" Value="@anualBeneficiosValue">Anual</DxRadio>
                                <DxRadio GroupName="presencia-beneficios" @bind-GroupValue="@PresenciaBeneficios" Value="@mensualBeneficiosValue">Mensual</DxRadio>
                            </div>
                        </div>
                    </div>

                    <div class="config-right">
                        <div class="config-group">
                            <div class="group-title">Esquemas de Costos</div>
                            <div class="radio-group">
                                <DxRadio GroupName="esquemas-costos" @bind-GroupValue="@EsquemasCostos" Value="@areaValue">Área</DxRadio>
                                <DxRadio GroupName="esquemas-costos" @bind-GroupValue="@EsquemasCostos" Value="@empleadoValue">Empleado</DxRadio>
                                <DxRadio GroupName="esquemas-costos" @bind-GroupValue="@EsquemasCostos" Value="@cargoPuestoValue">Cargo/Puesto</DxRadio>
                            </div>
                        </div>
                    </div>
                </div>
            </DxTabPage>
            
            <DxTabPage Text="Fórmulas vacaciones">
                <!-- Sección de Fórmulas Superior -->
                <div class="formulas-section">
                    <div class="formulas-left">
                        <div class="input-field">
                            <label>Días según Ley</label>
                            <DxComboBox Data="@FormulasList" 
                                       @bind-Value="@DiasSegunLeyValue" 
                                       NullText="VACACION_LEY" 
                                       TextFieldName="Name" 
                                       ValueFieldName="Id" />
                        </div>
                        
                        <div class="input-field">
                            <label>Días según Empresa</label>
                            <DxComboBox Data="@FormulasList" 
                                       @bind-Value="@DiasSegunEmpresaValue" 
                                       NullText="VACACION_LEY" 
                                       TextFieldName="Name" 
                                       ValueFieldName="Id" />
                        </div>
                        
                        <div class="input-field">
                            <label>Días adicionales a ley</label>
                            <DxComboBox Data="@FormulasList" 
                                       @bind-Value="@DiasAdicionalesLeyValue" 
                                       NullText="Seleccionar concepto" 
                                       TextFieldName="Name" 
                                       ValueFieldName="Id" />
                        </div>
                        
                        <div class="input-field">
                            <label>Fórmula Bono</label>
                            <DxComboBox Data="@FormulasList" 
                                       @bind-Value="@FormulaBonoValue" 
                                       NullText="Seleccionar concepto" 
                                       TextFieldName="Name" 
                                       ValueFieldName="Id" />
                        </div>
                        
                        <div class="input-field">
                            <label>Fórmula avance</label>
                            <DxComboBox Data="@FormulasList" 
                                       @bind-Value="@FormulaAvanceValue" 
                                       NullText="Seleccionar concepto" 
                                       TextFieldName="Name" 
                                       ValueFieldName="Id" />
                        </div>
                    </div>

                    <div class="formulas-right">
                        <div class="input-field">
                            <label>Fórmula Diferencial</label>
                            <DxComboBox Data="@FormulasList" 
                                       @bind-Value="@FormulaDiferencialValue" 
                                       NullText="Seleccionar concepto" 
                                       TextFieldName="Name" 
                                       ValueFieldName="Id" />
                        </div>
                        
                        <div class="input-field">
                            <label>Fórmula Fracción</label>
                            <DxComboBox Data="@FormulasList" 
                                       @bind-Value="@FormulaFraccionValue" 
                                       NullText="Seleccionar concepto" 
                                       TextFieldName="Name" 
                                       ValueFieldName="Id" />
                        </div>
                        
                        <div class="input-field">
                            <label>Plantilla de Carta</label>
                            <DxComboBox Data="@PlantillasList" 
                                       @bind-Value="@PlantillaCartaValue" 
                                       NullText="Carta de Vacaciones" 
                                       TextFieldName="Name" 
                                       ValueFieldName="Id" />
                        </div>
                        
                        <div class="input-field">
                            <label>Acción vacaciones</label>
                            <DxComboBox Data="@AccionesList" 
                                       @bind-Value="@AccionVacacionesValue" 
                                       NullText="Vacaciones" 
                                       TextFieldName="Name" 
                                       ValueFieldName="Id" />
                        </div>
                        
                        <div class="input-field">
                            <label>Fórmula Días Pendientes</label>
                            <DxComboBox Data="@FormulasList" 
                                       @bind-Value="@FormulaDiasPendientesValue" 
                                       NullText="Seleccionar concepto" 
                                       TextFieldName="Name" 
                                       ValueFieldName="Id" />
                        </div>
                        
                        <div class="input-field">
                            <label>Fórmula Antigüedad</label>
                            <DxComboBox Data="@FormulasList" 
                                       @bind-Value="@FormulaAntiguedadValue" 
                                       NullText="Seleccionar concepto" 
                                       TextFieldName="Name" 
                                       ValueFieldName="Id" />
                        </div>
                    </div>
                </div>

                <!-- Sección de Opciones de Vacaciones con Campos Numéricos -->
                <div class="vacaciones-options-section">
                    <!-- Campos Numéricos en la parte superior -->
                    <div class="numeric-fields">
                        <div class="input-field">
                            <label>Mes Inicio</label>
                            <DxSpinEdit @bind-Value="@MesInicioValue" 
                                       MinValue="1" 
                                       MaxValue="12"
                                       DisplayFormat="N0" />
                        </div>
                        <div class="input-field">
                            <label>Años Acumular</label>
                            <DxSpinEdit @bind-Value="@AnosAcumularValue" 
                                       MinValue="0" 
                                       MaxValue="50"
                                       DisplayFormat="N0" />
                        </div>
                    </div>

                    <!-- Grid de Checkboxes -->
                    <div class="checkbox-grid">
                        <div class="checkbox-column">
                            <DxCheckBox @bind-Checked="@DgtBaseIngresoTomados">DGT Base Ingreso/Tomados</DxCheckBox>
                            <DxCheckBox @bind-Checked="@AntiguedadAcumulada">Antigüedad acumulada</DxCheckBox>
                            <DxCheckBox @bind-Checked="@MesesAcumulados">Meses Acumulados</DxCheckBox>
                            <DxCheckBox @bind-Checked="@DigitarPendientes">Digitar las Pendientes</DxCheckBox>
                        </div>
                        <div class="checkbox-column">
                            <DxCheckBox @bind-Checked="@CalcularPendientes">Calcular las Pendientes</DxCheckBox>
                            <DxCheckBox @bind-Checked="@VerSoloAnoActual">Ver Solo Año Actual</DxCheckBox>
                            <DxCheckBox @bind-Checked="@RegistrarAusencias">Registrar en Ausencias, Permisos y Tardanzas</DxCheckBox>
                            <DxCheckBox @bind-Checked="@RegistrarAccionCambio">Registrar desde Acción de Cambio</DxCheckBox>
                        </div>
                    </div>
                </div>
            </DxTabPage>
            
            <DxTabPage Text="Elementos básicos">
                <!-- Sección de Configuración de Días y Horas -->
                <div class="elementos-section">
                    <div class="elementos-left">
                        <div class="input-field">
                            <label>Días a la semana</label>
                            <DxSpinEdit @bind-Value="@DiasSemanaMVal" 
                                       MinValue="1" 
                                       MaxValue="7" />
                        </div>
                        
                        <div class="input-field">
                            <label>Horas por día</label>
                            <DxSpinEdit @bind-Value="@HorasDiaValue" 
                                       MinValue="1" 
                                       MaxValue="24" />
                        </div>
                        
                        <div class="input-field">
                            <label>Turno Estándar</label>
                            <DxComboBox Data="@TurnosList" 
                                       @bind-Value="@TurnoEstandarValue" 
                                       NullText="Turno Administrativos" 
                                       TextFieldName="Name" 
                                       ValueFieldName="Id" />
                        </div>
                        
                        <div class="input-field">
                            <label>Horario Estándar</label>
                            <DxComboBox Data="@HorariosList" 
                                       @bind-Value="@HorarioEstandarValue" 
                                       NullText="08:00 hasta 17:30" 
                                       TextFieldName="Name" 
                                       ValueFieldName="Id" />
                        </div>
                        
                        <div class="input-field">
                            <label>Nómina Estándar</label>
                            <DxComboBox Data="@NominasList" 
                                       @bind-Value="@NominaEstandarValue" 
                                       NullText="NOMINA ADMINISTRATIVA" 
                                       TextFieldName="Name" 
                                       ValueFieldName="Id" />
                        </div>
                        
                        <div class="input-field">
                            <label>Base pago Estándar</label>
                            <DxComboBox Data="@BasePagosList" 
                                       @bind-Value="@BasePagoEstandarValue" 
                                       NullText="Mensual" 
                                       TextFieldName="Name" 
                                       ValueFieldName="Id" />
                        </div>
                        
                        <div class="input-field">
                            <label>Base Cálculo Estándar</label>
                            <DxComboBox Data="@BaseCalculosList" 
                                       @bind-Value="@BaseCalculoEstandarValue" 
                                       NullText="Mensual" 
                                       TextFieldName="Name" 
                                       ValueFieldName="Id" />
                        </div>
                        
                        <div class="input-field">
                            <label>Moneda Base Estándar</label>
                            <DxComboBox Data="@MonedasList" 
                                       @bind-Value="@MonedaBaseEstandarValue" 
                                       NullText="C$ - Córdobas" 
                                       TextFieldName="Name" 
                                       ValueFieldName="Id" />
                        </div>
                        
                        <div class="input-field">
                            <label>Provincia Principal</label>
                            <DxComboBox Data="@ProvinciasList" 
                                       @bind-Value="@ProvinciaPrincipalValue" 
                                       NullText="01 - MANAGUA" 
                                       TextFieldName="Name" 
                                       ValueFieldName="Id" />
                        </div>
                    </div>

                    <div class="elementos-right">
                        <div class="input-field">
                            <label>Inicio Horas Extra</label>
                            <DxSpinEdit @bind-Value="@InicioHorasExtraValue" 
                                       MinValue="0m" 
                                       MaxValue="99.99m" />
                        </div>
                        
                        <div class="input-field">
                            <label>Inicio Extraordinarias</label>
                            <DxSpinEdit @bind-Value="@InicioExtraordinariasValue" 
                                       MinValue="0m" 
                                       MaxValue="99.99m" />
                        </div>
                        
                        <div class="input-field">
                            <label>Hora Inicio Nocturna</label>
                            <DxTextBox @bind-Text="@HoraInicioNocturnaValue" 
                                      NullText=":" />
                        </div>
                        
                        <div class="input-field">
                            <label>Hora Termino Nocturna</label>
                            <DxTextBox @bind-Text="@HoraTerminoNocturnaValue" 
                                      NullText=":" />
                        </div>
                        
                        <div class="input-field">
                            <label>Turnos > horas Ley</label>
                            <div class="empty-space"></div>
                        </div>
                        
                        <div class="input-field">
                            <label>Minutos Extra</label>
                            <DxSpinEdit @bind-Value="@MinutosExtraValue" 
                                       MinValue="0" 
                                       MaxValue="999" />
                        </div>
                        
                        <div class="input-field">
                            <label>Días Alerta</label>
                            <DxSpinEdit @bind-Value="@DiasAlertaValue" 
                                       MinValue="0" 
                                       MaxValue="999" />
                        </div>
                        
                        <div class="input-field">
                            <label>Minutos Entradas</label>
                            <DxSpinEdit @bind-Value="@MinutosEntradasValue" 
                                       MinValue="0" 
                                       MaxValue="999" />
                        </div>
                        
                        <div class="input-field">
                            <label>Minutos Salidas</label>
                            <DxSpinEdit @bind-Value="@MinutosSalidasValue" 
                                       MinValue="0" 
                                       MaxValue="999" />
                        </div>
                    </div>
                </div>

                <!-- Sección de Excepciones - Ancho Completo -->
                <div class="excepciones-section">
                    <div class="input-field">
                        <label>Excepciones Ausencias</label>
                        <div class="empty-space"></div>
                    </div>
                    
                    <div class="input-field">
                        <label>Excepciones Nocturnidad</label>
                        <div class="empty-space"></div>
                    </div>
                    
                    <div class="input-field">
                        <label>Excepciones Horas Trab</label>
                        <div class="empty-space"></div>
                    </div>
                </div>

                <!-- Sección de Opciones de Configuración -->
                <div class="config-section">
                    <div class="config-left">
                        <div class="config-group">
                            <div class="group-title">Categoría</div>
                            <div class="radio-group">
                                <DxRadio GroupName="categoria" @bind-GroupValue="@CategoriaValue" Value="@validarRangosValue">Validar Rangos</DxRadio>
                                <DxRadio GroupName="categoria" @bind-GroupValue="@CategoriaValue" Value="@bandaFijaValue">Banda Fija</DxRadio>
                                <DxRadio GroupName="categoria" @bind-GroupValue="@CategoriaValue" Value="@flexibleValue">Flexible</DxRadio>
                            </div>
                        </div>
                    </div>

                    <div class="config-right">
                        <div class="config-group">
                            <div class="group-title">Fuente acumulado</div>
                            <div class="radio-group">
                                <DxRadio GroupName="fuente-acumulado" @bind-GroupValue="@FuenteAcumuladoValue" Value="@historicoAdmvoValue">Histórico admvo</DxRadio>
                                <DxRadio GroupName="fuente-acumulado" @bind-GroupValue="@FuenteAcumuladoValue" Value="@nominaValue">Nómina</DxRadio>
                                <DxRadio GroupName="fuente-acumulado" @bind-GroupValue="@FuenteAcumuladoValue" Value="@ultimoSueldoValue">Último Sueldo</DxRadio>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Sección de Opciones de Elementos -->
                <div class="elementos-options-section">
                    <div class="checkbox-grid">
                        <div class="checkbox-column">
                            <DxCheckBox @bind-Checked="@PagaExtrasDiario">Paga Extras Diario</DxCheckBox>
                            <DxCheckBox @bind-Checked="@PagaExtrasAutosDias">Paga Extras Autos/Días</DxCheckBox>
                            <DxCheckBox @bind-Checked="@DescuentaHoras">Descuenta Horas</DxCheckBox>
                            <DxCheckBox @bind-Checked="@PonchaAlmuerzo">Poncha Almuerzo</DxCheckBox>
                        </div>
                        <div class="checkbox-column">
                            <DxCheckBox @bind-Checked="@RelojIdentificaES">Reloj Identifica E/S</DxCheckBox>
                            <DxCheckBox @bind-Checked="@QuitarMinutosExcedidos">Quitar Minutos Excedidos</DxCheckBox>
                            <DxCheckBox @bind-Checked="@PonchaManual">Poncha Manual</DxCheckBox>
                        </div>
                    </div>
                </div>
            </DxTabPage>
            
            <DxTabPage Text="Aportes legales">
                <!-- Sección de Aportes y Configuraciones -->
                <div class="aportes-section">
                    <div class="aportes-left">
                        <div class="input-field">
                            <label>Aporte Inotep</label>
                            <DxComboBox Data="@AportesInotepList" 
                                       @bind-Value="@AporteInotepValue" 
                                       NullText="INATEC" 
                                       TextFieldName="Name" 
                                       ValueFieldName="Id" />
                        </div>
                        
                        <div class="input-field">
