                                       NullText="Seleccionar aporte" 
                                       TextFieldName="Name" 
                                       ValueFieldName="Id" />
                        </div>
                        
                        <div class="input-field">
                            <label>% Accs. Trabajo</label>
                            <DxSpinEdit @bind-Value="@PorcentajeAccsTrabajoValue" 
                                       MinValue="0m" 
                                       MaxValue="100m" />
                        </div>
                        
                        <div class="input-field">
                            <label>Tope Contribución Acc</label>
                            <DxSpinEdit @bind-Value="@TopeContribucionAccValue" 
                                       MinValue="0m" 
                                       MaxValue="999999.99m" />
                        </div>
                    </div>

                    <div class="aportes-right">
                        <div class="input-field">
                            <label>Salario Mínimo</label>
                            <DxSpinEdit @bind-Value="@SalarioMinimoValue" 
                                       MinValue="0m" 
                                       MaxValue="999999.99m" />
                        </div>
                        
                        <div class="input-field">
                            <label>Tope AFP ISR</label>
                            <DxSpinEdit @bind-Value="@TopeAfpIsrValue" 
                                       MinValue="0m" 
                                       MaxValue="999999.99m" />
                        </div>
                        
                        <div class="input-field">
                            <label>% neto mínimo en nómina</label>
                            <DxSpinEdit @bind-Value="@PorcentajeNetoMinimoValue" 
                                       MinValue="0m" 
                                       MaxValue="100m" />
                        </div>
                        
                        <div class="input-field">
                            <label>Retribución Complementaria</label>
                            <DxSpinEdit @bind-Value="@RetribucionComplementariaValue" 
                                       MinValue="0m" 
                                       MaxValue="999999.99m" />
                        </div>
                        
                        <div class="input-field">
                            <label>Valor de redondeo</label>
                            <DxSpinEdit @bind-Value="@ValorRedondeoValue" 
                                       MinValue="0m" 
                                       MaxValue="999999.99m" />
                        </div>

                        <div class="input-field">
                            <label>Presentación Idss</label>
                            <div class="radio-inline">
                                <DxRadio GroupName="presentacion-idss" @bind-GroupValue="@PresentacionIdss" Value="@mensualAportesValue">Mensual</DxRadio>
                                <DxRadio GroupName="presentacion-idss" @bind-GroupValue="@PresentacionIdss" Value="@semanalAportesValue">Semanal</DxRadio>
                            </div>
                        </div>
                    </div>
                </div>
            </DxTabPage>
            
            <DxTabPage Text="Seguridad">
                <!-- Sección de Configuración de Seguridad -->
                <div class="seguridad-section">
                    <div class="input-field">
                        <label>Correo Seguridad</label>
                        <DxTextBox @bind-Text="@CorreoSeguridadValue" 
                                  NullText="Ingrese correo de seguridad" />
