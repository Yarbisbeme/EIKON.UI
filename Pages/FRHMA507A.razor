                    <div class="seguridad-row">
                        <div class="input-field">
                            <label>Dominio</label>
                            <DxTextBox @bind-Text="@DominioValue" 
                                      NullText="Ingrese dominio" />
                        </div>
                        
                        <div class="checkbox-field">
                            <DxCheckBox @bind-Checked="@EnviarCorreoSeguridad">Enviar Correo Seguridad</DxCheckBox>
                        </div>
                    </div>
                </div>
            </DxTabPage>
        </DxTabs>
    </div>
