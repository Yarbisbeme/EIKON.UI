@page "/FRHUT133"

@using EIKON.UI.Components
@using DevExpress.Blazor
@using System.Net.Http.Json
@using System.Net.Http.Headers
@using EIKON.UI.Interfaces
@using DevExpress.AspNetCore.Reporting
@using DevExpress.XtraReports.UI
@using System.ComponentModel.DataAnnotations

@layout MainLayout
@inject HttpClient HttpClient
@inject EIKON.UI.Services.EikonDataServices api
@inject EIKON.UI.Services.AuthenticationService auth
@inject NavigationManager nv
@inject IJSRuntime JS

<div class="page">
    <Breadcrumb Title="FRHUT133 - Sirh - Configuración de Reportes Columnares" BackUrl="/dash" />
    
    <div class="page-header">
        <div class="page-toolbar">
            <Toolbar formulario="FRHxxx999" OnClose="HandleClose" />
        </div>
    </div>

    <div class="form-container">
        <!-- Primera Fila - Reporte y Transacción -->
        <div class="form-row">
            <div class="input-field">
                <label>Reporte</label>
                <DxComboBox Data="@ReportesList" 
                           @bind-Value="@SelectedReporte" 
                           NullText="Seleccionar reporte"
                           TextFieldName="Name" 
                           ValueFieldName="Id" />
            </div>
            <div class="input-field">
                <label>Transacción</label>
                <DxComboBox Data="@TransaccionsList" 
                           @bind-Value="@SelectedTransaccion" 
                           NullText="Seleccionar transacción"
                           TextFieldName="Name" 
                           ValueFieldName="Id" />
            </div>
        </div>

        <!-- Sección Principal - Área Central -->
        <div class="main-content-section">
            <div class="content-workspace">
                <div class="workspace-placeholder">
                    <i class="fi fi-rr-document" style="font-size: 48px; color: #ccc; margin-bottom: 15px;"></i>
                    <p>Área de configuración de reportes columnares</p>
                    <small>Utilice el toolbar superior para configurar las columnas del reporte</small>
                </div>
            </div>
        </div>

        <!-- Tercera Fila - Columna -->
        <div class="form-row">
            <div class="input-field full-width">
                <label>Columna</label>
                <DxComboBox Data="@ColumnasList" 
                           @bind-Value="@SelectedColumna" 
                           NullText="Seleccionar columna"
                           TextFieldName="Name" 
                           ValueFieldName="Id" />
            </div>
        </div>
    </div>
</div>

<style>
    /* Container principal */
    .form-container {
        display: flex;
        flex-direction: column;
        gap: 25px;
        padding: 20px 0;
    }

    /* Form rows */
    .form-row {
        display: flex;
        gap: 20px;
        align-items: flex-end;
        min-height: 60px;
    }

    /* Input fields */
    .input-field {
        display: flex;
        flex-direction: column;
        gap: 6px;
        flex: 1;
        min-width: 150px;
    }

    .input-field.full-width {
        flex: 1;
        width: 100%;
    }

    .input-field label {
        font-weight: 500;
        color: #333;
        font-size: 13px;
        margin-bottom: 5px;
    }

    /* Sección principal - Área central */
    .main-content-section {
        min-height: 400px;
        border: 1px solid #e0e0e0;
        border-radius: 8px;
        overflow: hidden;
        background-color: white;
    }

    .content-workspace {
        padding: 30px;
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 350px;
    }

    .workspace-placeholder {
        text-align: center;
        color: #6c757d;
    }

    .workspace-placeholder p {
        font-size: 16px;
        font-weight: 500;
        margin-bottom: 8px;
        color: #495057;
    }

    .workspace-placeholder small {
        font-size: 13px;
        color: #6c757d;
    }


    /* DevExpress Components */
    .dx-combobox {
        border-radius: 6px !important;
    }

    .dx-combobox-container {
        border: 1px solid #ced4da !important;
        border-radius: 6px !important;
        transition: all 0.3s ease !important;
    }

    .dx-combobox-container:focus-within {
        border-color: #dc3545 !important;
        box-shadow: 0 0 0 0.2rem rgba(220, 53, 69, 0.25) !important;
    }

    /* Responsive Design */
    media (max-width: 1024px) {
        .form-container {
            padding: 15px;
            gap: 20px;
        }

        .form-row {
            flex-wrap: wrap;
            gap: 15px;
        }

        .main-content-section {
            min-height: 350px;
        }

        .content-workspace {
            padding: 20px;
            min-height: 300px;
        }
    }

    media (max-width: 768px) {
        .form-container {
            padding: 15px;
            gap: 15px;
        }

        .form-row {
            flex-direction: column;
            gap: 15px;
            align-items: stretch;
            min-height: auto;
        }

        .input-field {
            min-width: auto;
        }

        .main-content-section {
            min-height: 300px;
        }

        .content-workspace {
            padding: 20px;
            min-height: 200px;
        }

        .workspace-placeholder {
            text-align: center;
        }

        .workspace-placeholder i {
            font-size: 36px !important;
        }

        .workspace-placeholder p {
            font-size: 14px;
        }

        .workspace-placeholder small {
            font-size: 12px;
        }
    }

    media (max-width: 480px) {
        .form-container {
            gap: 12px;
            padding: 12px;
        }

        .form-row {
            gap: 12px;
        }

        .main-content-section {
            min-height: 250px;
        }

        .content-workspace {
            padding: 15px;
            min-height: 150px;
        }


        .input-field label {
            font-size: 12px;
        }

        .workspace-placeholder i {
            font-size: 30px !important;
        }

        .workspace-placeholder p {
            font-size: 13px;
        }
    }
</style>

@code {
    // **- private string[] // **- ToolbarOptions = { "add", "save", "remove", "leave" };
    
    // Campos del formulario
    private int? SelectedReporte { get; set; }
    private int? SelectedTransaccion { get; set; }
    private int? SelectedColumna { get; set; }
    
    // Listas de datos
    private List<OptionItem> ReportesList = new List<OptionItem>
    {
        new OptionItem { Id = 1, Name = "Reporte de Nómina" },
        new OptionItem { Id = 2, Name = "Reporte de Empleados" },
        new OptionItem { Id = 3, Name = "Reporte de Departamentos" },
        new OptionItem { Id = 4, Name = "Reporte de Asistencia" },
        new OptionItem { Id = 5, Name = "Reporte Financiero" }
    };

    private List<OptionItem> TransaccionsList = new List<OptionItem>
    {
        new OptionItem { Id = 1, Name = "Consulta General" },
        new OptionItem { Id = 2, Name = "Inserción de Datos" },
        new OptionItem { Id = 3, Name = "Actualización" },
        new OptionItem { Id = 4, Name = "Eliminación" },
        new OptionItem { Id = 5, Name = "Proceso Batch" }
    };

    private List<OptionItem> ColumnasList = new List<OptionItem>
    {
        new OptionItem { Id = 1, Name = "ID Empleado" },
        new OptionItem { Id = 2, Name = "Nombre Completo" },
        new OptionItem { Id = 3, Name = "Departamento" },
        new OptionItem { Id = 4, Name = "Puesto" },
        new OptionItem { Id = 5, Name = "Salario Base" },
        new OptionItem { Id = 6, Name = "Fecha Ingreso" },
        new OptionItem { Id = 7, Name = "Estado" },
        new OptionItem { Id = 8, Name = "Supervisor" }
    };

    public class OptionItem
    {
        public int Id { get; set; }
        public string Name { get; set; } = "";
    }
    
    
    private async Task HandleClose()
    {
        await JS.InvokeVoidAsync("alert", "¡Configuración de reportes guardada exitosamente!");
    }
}