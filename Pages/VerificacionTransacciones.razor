@page "/verificacion-transacciones"
@using EIKON.UI.Components
@* @rendermode InteractiveServer *@

<div class="verificacion-transacciones">
    <Breadcrumb Title="Verificación de Transacciones" BackUrl="/dash" />
    <div class="header">
        <div class="requisicion-search">
            <div class="input-search">
                <label for="user">Empleado</label>
                <DxTextBox @bind-Text="@searchText"
                           NullText="ID Empleado"
                           ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Never">
                    <Buttons>
                        <DxEditorButton IconCssClass="fi fi-rr-search" />
                    </Buttons>
                </DxTextBox>
            </div>
        </div>
        <div class="requisicion-toolbar">
            <Toolbar formulario="FRHxxx999" />
        </div>
    </div>

    <div style="display:flex;width:100%;align-items:center;gap:20px; height:180px;">
        <div style="width:100%;display:flex;gap:10px;flex-direction:column;">
            <div class="input">
                <label for="user">Nombre</label>
                <DxTextBox NullText="Nombre empleado" @bind-Text="@TextValue" />
            </div>
            <div class="input">
                <label for="user">Cargo</label>
                <DxTextBox NullText="Cargo empleado" @bind-Text="@TextValue" />
            </div>
        </div>

        <div style="width:200px;height:100%;padding:10px;border:1px solid #E5E5EA;display:flex; align-items:center; justify-content:center;flex-direction:column;position:relative;border-radius:4px;">
            <p id="radio-group-overview-label" class="" style="position:absolute;left:10px;top:-10px;background-color:#FBF9F9;">Tipo de Transacción</p>
            <DxRadioGroup aria-labelledby="radio-group-overview-label"
                          Items="@Languages"
                          @bind-Value="@PreferredLanguage"
                          CssClass="dx-demo-radio-group" />
        </div>
    </div>


    <div class="input">
        <label for="user">Área</label>
        <DxTextBox NullText="Cargo empleado" @bind-Text="@TextValue" />
    </div>
    <div class="input">
        <label for="user">Nómina</label>
        <DxTextBox NullText="Cargo empleado" @bind-Text="@TextValue" />
    </div>

    <div style="display:flex;width:100%;align-items:center;gap:20px; height:250px;">
        <div style="display:flex;flex-direction:column; width:100%;gap:20px;">
            <div class="input">
                <label for="user">Transacción</label>
                <div class="search-field" style="display:flex; gap:20px;">
                    <DxTextBox @bind-Text="@searchText"
                               NullText="ID requisición"
                               ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Never">
                        <Buttons>
                            <DxEditorButton IconCssClass="fi fi-rr-search" />
                        </Buttons>
                    </DxTextBox>
                    <DxTextBox NullText="ID requisicion" />
                </div>
            </div>

        <div style="display:flex; gap:10px;">

            <div class="input">
                <label for="user">Cantidad</label>
                <DxSpinEdit @bind-Value="@DecimalValue"
                            CssClass="cw-320"
                            InputId="seOverview" />
            </div>

            <div class="input">
                <label for="user">Monto</label>
                <DxSpinEdit @bind-Value="@DecimalValue"
                            CssClass="cw-320"
                            InputId="seOverview" />
            </div>

            <div class="input">
                <label for="user">Aplicar</label>
                <DxSpinEdit @bind-Value="@DecimalValue"
                            CssClass="cw-320"
                            InputId="seOverview" />
            </div>
        </div>


        <div style="display:flex; gap:10px;">

            <div class="input">
                <label for="user">Pago neto</label>
                <DxSpinEdit @bind-Value="@DecimalValue"
                            CssClass="cw-320"
                            InputId="seOverview" />
            </div>

            <div class="input">
                <label for="user">Periodo</label>
                <DxSpinEdit @bind-Value="@DecimalValue"
                            CssClass="cw-320"
                            InputId="seOverview" />
            </div>
        </div>
        </div>


        <div style="width:200px;height:100%;padding:10px;border:1px solid #E5E5EA;display:flex; align-items:center; justify-content:center;flex-direction:column;position:relative;border-radius:4px;">
            <p id="radio-group-overview-label" class="" style="position:absolute;left:10px;top:-10px;background-color:#FBF9F9;">Aplicación</p>
            <DxRadioGroup aria-labelledby="radio-group-overview-label"
                          Items="@PeriodOptions"
                          @bind-Value="@PreferredOption"
                          CssClass="dx-demo-radio-group" />
        </div>
    </div>

    <div class="input">
        <label for="user">Nómina</label>
        <DxMemo NullText="Ingrese observaciones adicionales..."
                @bind-Text="@Observations"
                Rows="6"
                ResizeMode="MemoResizeMode.Vertical"
                MaxLength="1000" />
    </div>


    <DxGrid Data="@TransactionData"
            PageSize="10"
            ColumnResizeMode="GridColumnResizeMode.NextColumn"
            TextWrapEnabled="false"
            CssClass="custom-grid"
            PagerVisible="true">
        <Columns>
            <DxGridDataColumn FieldName="Codigo" Caption="Código" Width="100%" />
            <DxGridDataColumn FieldName="Transaccion" Caption="Transacción" Width="100%" />
            <DxGridDataColumn FieldName="Cantidad" Caption="Cantidad" Width="100%" DisplayFormat="N2" />
            <DxGridDataColumn FieldName="Monto" Caption="Monto" Width="100%" DisplayFormat="C2" />
            <DxGridCommandColumn Width="100px">
                <HeaderTemplate>
                    <span>Acciones</span>
                </HeaderTemplate>
                <CellDisplayTemplate>
                    <DxButton Text="⋮"
                              RenderStyle="ButtonRenderStyle.None"
                              Click="@(() => PopupVisible = true)"
                              CssClass="action-menu-btn" />
                </CellDisplayTemplate>
            </DxGridCommandColumn>
        </Columns>
    </DxGrid>

<DxPopup @bind-Visible="@PopupVisible"
        ShowFooter="true"
        HeaderText="Planes de Pago"
        Width="720"
        Height="auto">
    <BodyContentTemplate>
        <div style="display:flex;flex-direction:column;gap: 20px;">
            <div style="width:100%; display:flex; justify-content:flex-end">

                <Toolbar formulario="FRHxxx999" />
            </div>

                <div style="display:flex;gap:10px;">
                    <div class="select">
                        <label for="company">Planes de Pago</label>
                        <DxComboBox Data="@empresas"
                                    @bind-Value="@empresaSeleccionada"
                                    TextFieldName="@nameof(Empresa.Nombre)"
                                    ValueFieldName="@nameof(Empresa.Id)"
                                    CssClass="mi-combobox"
                                    NullText="Seleccionar Motivo"
                                    ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Never" />
                    </div>

                    <div class="input">
                        <label for="user">Cantidad</label>
                        <DxSpinEdit @bind-Value="@DecimalValue"
                                    CssClass="cw-320"
                                    InputId="seOverview" />
                    </div>
                </div>

                <DxGrid Data="@Data"
                        PageSize="10"
                        ColumnResizeMode="GridColumnResizeMode.NextColumn"
                        TextWrapEnabled="false"
                        CssClass="custom-grid"
                        FilterRowCondition="GridFilterRowCondition.Equals"
                        PagerVisible="true"
                        PagerNavigationMode="PagerNavigationMode.InputBox"
                        PagerSwitchToInputBoxButtonCount="5">
                    <Columns>
                        <DxGridDataColumn FieldName="Codigo" Caption="Código" Width="100%" />
                        <DxGridDataColumn FieldName="Prestamo" Caption="Prestamo" Width="100%" />
                        <DxGridDataColumn FieldName="Monto" Caption="Monto" Width="100%" DisplayFormat="F4" TextAlignment="GridTextAlignment.Right" />
                    </Columns>
                </DxGrid>

            </div>
    </BodyContentTemplate>
    <FooterContentTemplate>
        <div style="text-align: right; padding: 10px;">
            <DxButton Text="Cerrar" 
                     Click="@(() => PopupVisible = false)"
                     CssClass="mr-1" />
        </div>
    </FooterContentTemplate>
</DxPopup>

</div>


