            trhtp010 = (List<Trhtp010Dto>)await api.GetTrhtp010Dtos();
            trhca010 = (List<Trhca010Dto>)await api.GetTrhca010Dtos();
            trhta010 = (List<Trhta010Dto>)await api.GetTrhta010Dtos();
            trhwy010 = (List<Trhwy010Dto>)await api.GetTrhwy010Dtos();
            // data = (List<Trhgr010Dto>)await api.Trhgr010DtoGetAll(Token);
            editModel = trhwc010.FirstOrDefault() ?? new Trhwc010Dto();
            imptoItems = trhwc010.Where(t=>t.WcTipoTr=="D").Select(i => new ImpuestoItem(i.WcCodigo, i.WcDescri)).ToList();
            await CargarPartidas();
            await InvokeAsync(StateHasChanged);
        }

