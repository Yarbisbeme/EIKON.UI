                width: 95%;
                margin: 0 auto;
                background-color: #e9e9e9;
                padding: 10px;
                border-radius: 8px;
                box-shadow: 0px 0px 10px rgba(0, 0, 0, 0.1);
            }

            h1 {
                font-size: 18px;
                color: #333;
                text-align: center;
                margin-bottom: 5px;
            }

            .form-group {
                margin-bottom: 4px;
            }

                .form-group label {
                    display: block;
                    font-weight: bold;
                    margin-bottom: 4px;
                }

                .form-group input, .form-group select {
                    width: 80%;
                    padding: 4px;
                    box-sizing: border-box;
                }

                    .form-group input[type="checkbox"] {
                        width: 50%;
                    }

            .form-row {
                display: flex;
                justify-content: space-between;
            }

                .form-row .form-group {
                    width: 48%;
                }

            .actions {
                text-align: right;
               
                margin-top: 10px;
            }

                .actions button {
                    padding: 10px 15px;
                    margin: 0 5px;
                    cursor: pointer;
                }

            .checkitem > label {
                display: inline-block;
                width: calc(100% - 20px);
                vertical-align: middle;
            }

            .checkitem > input[type=checkbox] {
                display: inline-block;
                width: 15px;
                height: 25%;
                vertical-align: middle;
            }

            .checkitem > input[type=radio] {
                display: inline-block;
                width: 15px;
                height: 25%;
                vertical-align: middle;

            }

            table {
                width: 100%;
                margin-top: 15px;
                border-collapse: collapse;
            }

            table, th, td {
                border: 1px solid #ccc;
            }

            th, td {
                padding: 8px;
                text-align: left;
            }

