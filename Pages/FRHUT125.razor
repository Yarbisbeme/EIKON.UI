@page "/FRHUT125"

@using EIKON.UI.Components
@using DevExpress.Blazor
@using System.Net.Http.Json
@using System.Net.Http.Headers
@using EIKON.UI.Interfaces
@using DevExpress.AspNetCore.Reporting
@using DevExpress.XtraReports.UI
@using System.ComponentModel.DataAnnotations

@layout MainLayout
@inject HttpClient HttpClient
@inject EIKON.UI.Services.EikonDataServices api
@inject EIKON.UI.Services.AuthenticationService auth
@inject NavigationManager nv
@inject IJSRuntime JS

<div class="page">
    <Breadcrumb Title="FRHUT125 - Mantenimiento Bancos" BackUrl="/dash" />
    
    <div class="page-header">
        <div class="page-toolbar">
            <Toolbar formulario="FRHxxx999" OnClose="HandleClose" />
        </div>
    </div>

    <div class="form-container">
        <!-- Primera Fila - Código y Descripción -->
        <div class="form-row">
            <div class="input-field">
                <label>Código</label>
                <DxTextBox @bind-Text="@CodigoValue"
                           ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Never">
                    <Buttons>
                        <DxEditorButton IconCssClass="fi fi-rr-search" 
                                       Click="@OnSearchCodigoClick" />
                    </Buttons>
                </DxTextBox>
            </div>
            <div class="input-field wide">
                <label>Descripción</label>
                <DxTextBox @bind-Text="@DescripcionValue" />
            </div>
        </div>

        <!-- Segunda Fila - Contacto -->
        <div class="form-row">
            <div class="input-field wide">
                <label>Contacto</label>
                <DxTextBox @bind-Text="@ContactoValue" />
            </div>
        </div>

        <!-- Tercera Fila - Email -->
        <div class="form-row">
            <div class="input-field wide">
                <label>Email</label>
                <DxTextBox @bind-Text="@EmailValue" />
            </div>
        </div>

        <!-- Cuarta Fila - Cuenta -->
        <div class="form-row">
            <div class="input-field wide">
                <label>Cuenta</label>
                <DxTextBox @bind-Text="@CuentaValue" />
            </div>
        </div>

        <!-- Quinta Fila - Activo y Formato Depósito -->
        <div class="form-row bottom-section">
            <div class="checkbox-container">
                <DxCheckBox @bind-Checked="@ActivoOption">Activo</DxCheckBox>
            </div>
            <div class="formato-deposito">
                <label class="formato-label">Formato Depósito</label>
            </div>
        </div>
    </div>
</div>

<style>
    /* Container principal */
    .form-container {
        display: flex;
        flex-direction: column;
        gap: 20px;
        padding: 20px 0;
        width: 100%;
    }

    /* Form rows */
    .form-row {
        display: flex;
        gap: 20px;
        align-items: flex-end;
        min-height: 60px;
    }

    .form-row.bottom-section {
        align-items: center;
        margin-top: 15px;
        padding-top: 20px;
        border-top: 1px solid #e0e0e0;
    }

    /* Input fields */
    .input-field {
        display: flex;
        flex-direction: column;
        gap: 6px;
        flex: 1;
        min-width: 150px;
    }

    .input-field.wide {
        flex: 3;
    }

    .input-field label {
        font-weight: 500;
        color: #333;
        font-size: 13px;
        margin-bottom: 5px;
    }

    /* Checkbox container */
    .checkbox-container {
        display: flex;
        align-items: center;
        flex: 0 0 auto;
        margin-right: 40px;
    }

    /* Formato depósito */
    .formato-deposito {
        flex: 1;
        display: flex;
        align-items: center;
    }

    .formato-label {
        font-weight: 500;
        color: #6c757d;
        font-size: 14px;
        font-style: italic;
    }

    /* DevExpress Components */
    .dx-textbox {
        border-radius: 6px !important;
    }

    .dx-textbox-container {
        border: 1px solid #ced4da !important;
        border-radius: 6px !important;
        transition: all 0.3s ease !important;
    }

    .dx-textbox-container:focus-within {
        border-color: #dc3545 !important;
        box-shadow: 0 0 0 0.2rem rgba(220, 53, 69, 0.25) !important;
    }

    /* Checkboxes */
    .dx-checkbox {
        font-size: 14px;
        font-weight: 500;
    }

    .dx-checkbox-checked .dx-checkbox-icon {
        background-color: #dc3545 !important;
        border-color: #dc3545 !important;
    }

    .dx-checkbox:hover .dx-checkbox-icon {
        border-color: #dc3545 !important;
    }

    /* Search button styling */
    .dx-editor-button {
        background-color: #6c757d !important;
        border-color: #6c757d !important;
        color: white !important;
        border-radius: 4px !important;
    }

    .dx-editor-button:hover {
        background-color: #5a6268 !important;
        border-color: #545b62 !important;
    }

    /* Responsive Design */
    media (max-width: 1024px) {
        .form-container {
            width: 100%;
            padding: 15px;
            gap: 18px;
        }

        .form-row {
            flex-wrap: wrap;
            gap: 15px;
        }

        .formato-deposito {
            margin-top: 10px;
        }
    }

    media (max-width: 768px) {
        .form-container {
            padding: 15px;
            gap: 15px;
        }

        .form-row {
            flex-direction: column;
            gap: 15px;
            align-items: stretch;
            min-height: auto;
        }

        .form-row.bottom-section {
            flex-direction: column;
            align-items: stretch;
            gap: 15px;
        }

        .input-field {
            min-width: auto;
        }

        .input-field.wide {
            flex: 1;
        }

        .checkbox-container {
            margin-right: 0;
            justify-content: flex-start;
        }

        .formato-deposito {
            margin-top: 0;
            justify-content: flex-start;
        }
    }

    media (max-width: 480px) {
        .form-container {
            gap: 12px;
            padding: 12px;
        }

        .form-row {
            gap: 12px;
        }

        .form-row.bottom-section {
            padding-top: 15px;
            gap: 12px;
        }

        .input-field label,
        .formato-label {
            font-size: 12px;
        }
    }
</style>

@code {
    // **- private string[] // **- ToolbarOptions = { "add", "save", "remove", "leave" };
    
    // Campos del formulario
    private string CodigoValue { get; set; } = "";
    private string DescripcionValue { get; set; } = "";
    private string ContactoValue { get; set; } = "";
    private string EmailValue { get; set; } = "";
    private string CuentaValue { get; set; } = "";
    
    // Opciones de checkbox
    private bool ActivoOption { get; set; } = true;
    
    // Event handlers
    private void OnSearchCodigoClick() => Console.WriteLine("Buscar código");
    
    private async Task HandleClose()
    {
        await JS.InvokeVoidAsync("alert", "¡Banco guardado exitosamente!");
    }
}