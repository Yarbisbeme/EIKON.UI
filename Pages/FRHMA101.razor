    public Task LimpiarSeleccion()
    {
        // Recorre toda la lista de elementos para desmarcar.
        // Se utiliza una función recursiva para manejar los nodos anidados (hijos).
        DesmarcarNodosRecursivo(ModuloItemsSelect);

        // Llama a StateHasChanged para forzar a Blazor a re-renderizar
        // el TreeView con el estado de datos modificado.
        StateHasChanged();

        return Task.CompletedTask;
    }

    private void DesmarcarNodosRecursivo(IEnumerable<ModuloItemDto> items)
    {
        if (items == null) return;

        foreach (var item in items)
        {
            // 1. Desmarca el nodo actual
            item.Checked = false;

            // 2. Si tiene hijos, llama a sí misma para desmarcarlos también
            if (item.Children != null && item.Children.Any())
            {
                DesmarcarNodosRecursivo(item.Children);
            }
        }
    }

