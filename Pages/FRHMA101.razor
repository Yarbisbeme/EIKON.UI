    private void OnSearchClick()
    {
        Console.WriteLine($"Buscando perfil: {PerfilValue}");
    }
    async Task OnSelectedPerfilChanged(SelectedDataItemChangedEventArgs<Trhpa000Dto> args)
    {
        trhpa000DtoSelected = args.DataItem;
        if (treeview != null)
        {
            treeview.ClearSelection(); // ✅ limpiar todos los checks
        }
        if(trhpa000DtoSelected != null){
            trhfm000Dtos = await api.Trhfm000DtoGetPorPaCodigo(Token,trhpa000DtoSelected.PaCodigo);
            trhmp000Dtos = await api.Trhmp000DtoGetPorPaCodigo(Token, trhpa000DtoSelected.PaCodigo);
            MenuRoles = await api.GetMenuRoles(trhpa000DtoSelected.PaCodigo);
            ModuloItems = ModuloMapper.MapList(MenuItems);
            await LimpiarSeleccion();
            ModuloItemsSelect = ModuloMapper.SeleccionarNodosPorCodigo(ModuloItems, MenuRoles);
            trhfm000DtoSelected = trhfm000Dtos.FirstOrDefault();
            if (trhmp000Dtos != null && trhmp000Dtos.Count>0)
            {
                trhmp000DtoSelected = trhmp000Dtos.FirstOrDefault();
                mpNivel = trhmp000DtoSelected.MpNivel;
            }
            // treeview2.ExpandAll();
        }
        StateHasChanged();
        try
        {
            treeview2.ExpandAll();
        }
        catch (Exception)
        {

            await treeview.NodeClick.InvokeAsync();
        }

        // if (args.ChangeSource == SelectionChangeSource.ParameterChange)
        //     msg = "Selection changed in code. The selected item: " + args.DataItem.CityName;
        // else
        //     msg = "Selection changed by a user action. The selected item: " + args.DataItem.CityName;
    }
    private async Task HandleClose()
    {
        await JS.InvokeVoidAsync("alert", "¡Perfil guardado!");
    }
    async void CheckedChangedAct(bool value)
    {
        //StateHasChanged();
        ActualizarFormulario=value;
        await ActualizarTrhfm000();
    }
    async void CheckedChangedBor(bool value)
    {
        //StateHasChanged();
        BorrarFormulario = value;
        await ActualizarTrhfm000();
    }
    void HabilitarCkBox(bool value)
    {
        habilitarCkBox = value; 
        habilitarRadioBot = !value;
    }
    async void CheckedChangedAdd(bool value)
    {
        //StateHasChanged();
        AnadirFormulario = value;
        await ActualizarTrhfm000();
    }
    async void CheckedChangedAud(bool value)
    {
        //StateHasChanged();
        AuditoriaMiscelaneos = value;
        await ActualizarTrhfm000();
    }
    async void ActualizarMp(string valor)
    {
