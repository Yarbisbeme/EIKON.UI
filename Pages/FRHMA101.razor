    private bool habilitarRadioBot { get; set; } = false;

    private bool ActualizarFormulario { get; set; } = false;
    private bool BorrarFormulario { get; set; } = false;
    private bool AnadirFormulario { get; set; } = false;
    private bool ImprimirMiscelaneos { get; set; } = false;
    private bool EmailMiscelaneos { get; set; } = false;
    private bool AuditoriaMiscelaneos { get; set; } = false;

    // Constants for radio buttons
    private string grupoValue = "grupo";
    private string dbaValue = "dba";
    private string webValue = "web";
    private string consultaValue = "consulta";
    private string restringidoValue = "restringido";
    private string actualizarValue = "actualizar";
