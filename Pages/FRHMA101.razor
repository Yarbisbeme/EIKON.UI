        await ActualizarTrhmp000(valor);
    }
    async void CheckedChangedMail(bool value)
    {
        //StateHasChanged();
        EmailMiscelaneos = value;
        await ActualizarTrhfm000();
    }
    async void CheckedChangedImp(bool value)
    {
        //StateHasChanged();
        ImprimirMiscelaneos = value;
        await ActualizarTrhfm000();
    }
    void SelectionChanged(TreeViewNodeEventArgs e)
    {
        ActualizarFormulario = false;
        BorrarFormulario = false;
        AnadirFormulario = false;

        ImprimirMiscelaneos = false;
        EmailMiscelaneos = false;
        AuditoriaMiscelaneos = false;
        var x = e.NodeInfo?.Text;
        var y = e.NodeInfo?.Name;
        // var c = e.NodeInfo?.Url;
        var nivel = e.NodeInfo?.Level;
        if (y != null)
        {
            //trhfm000Dtos =  api.Trhfm000DtoGetPorPaCodigo(Token, trhpa000DtoSelected.PaCodigo).Result;
            HabilitarCkBox(false);
            trhfm000DtoSelected = trhfm000Dtos.FirstOrDefault(fm => fm.IsCodigo.Contains(y.Trim()));
            if (nivel == 1 && trhfm000DtoSelected != null)
            {
                {
                    HabilitarCkBox(true);
                    ActualizarFormulario = trhfm000DtoSelected.MpUpdate ? true : false;
                    BorrarFormulario = trhfm000DtoSelected.MpDelete ? true : false;
                    AnadirFormulario = trhfm000DtoSelected.MpAddFor ? true : false;

                    ImprimirMiscelaneos = trhfm000DtoSelected.MpPrint ? true : false;
                    EmailMiscelaneos = trhfm000DtoSelected.MpMail ? true : false;
                    AuditoriaMiscelaneos = trhfm000DtoSelected.MpAudit ? true : false;
                }
                trhmp000DtoSelected = trhmp000Dtos.FirstOrDefault(mp => mp.IsCodigo.Contains(y.Trim()));
                if (trhmp000DtoSelected == null)
                {
                    mpNivel = "R";
                    trhmp000DtoSelected = new Trhmp000Dto();
                    trhmp000DtoSelected.PaCodigo = trhpa000DtoSelected.PaCodigo;
                    trhmp000DtoSelected.IsCodigo = y.Trim();
                    trhmp000DtoSelected.MpNivel = "R";
                    trhmp000DtoSelected.IdentityColumn = 0;
                }
                if (nivel == 2 && trhmp000DtoSelected != null)
                {

                    mpNivel = trhmp000DtoSelected.MpNivel;

                }

            }
        }
    }
