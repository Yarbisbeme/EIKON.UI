    // Form fields
    private string NumeroValue { get; set; } = "";
    private string PerfilValue { get; set; } = "";
    private bool IgualPerfilExistente { get; set; } = false;
    private bool AllowCheck { get; set; } = false;
    private string PerfilBaseValue { get; set; } = "";
    private string DescripcionValue { get; set; } = "";

    // Radio button values
    private string TipoAnswer { get; set; } = "grupo";
    private string ControlesAnswer { get; set; } = "consulta";
    private string mpNivel { get; set; } = "C";
    public class Estatus
    {
        public string Value { get; set; }
        public string Text { get; set; }

        public Estatus(string value, string text)
        {
            Value = value;
            Text = text;
        }
    }
    private List<Estatus> estatus = new()
    {
        new Estatus("G", "Grupo"),
        new Estatus("D", "DBA"),
        new Estatus("W", "Web"),
            };

    public class Controles
    {
        public string Value { get; set; }
        public string Text { get; set; }

        public Controles(string value, string text)
        {
            Value = value;
            Text = text;
        }
    }
