    async Task CheckingChanged(TreeViewCheckedChangedEventArgs e)
    {
        if (e.CheckedItems != null)
            checkedOptions = e.CheckedItems;

        if (e.CheckedItems != null && checkedOptions.Count>0)
        {
            MenuItemSelected = new List<ModuloItemDto>();
            foreach (var item in checkedOptions)
            {  if( item.Checked==true)
                    MenuItemSelected.Add((ModuloItemDto)item.DataItem);
            }
            foreach (var item in MenuItemSelected)
            {
                var pacodigo = "";
                var iscodigo=item.Url.Trim().ToLower();
                try
                {
                    pacodigo = trhfm000Dtos.Where(fm => fm.IsCodigo.Trim().ToLower() == iscodigo).FirstOrDefault().PaCodigo;
                }
                catch (Exception)
                {
                    pacodigo=null;
                }

                if ( pacodigo == trhpa000DtoSelected.PaCodigo)
                    continue;
                Trhfm000Dto fm = new Trhfm000Dto();
                fm.PaCodigo = trhpa000DtoSelected.PaCodigo;
                fm.IsCodigo = iscodigo.ToUpper();
                fm.MpReadFo = true;
                fm.MpMail = false;
                fm.MpUpdate = true;
                fm.MpDelete= false;
                fm.MpAddFor = false;
                fm.MpAudit = true;
                fm.IdentityColumn = 0;
                fm.CreatedOn = DateTime.Now;
                fm.CreatedBy = "EikonArkhe";
                fm.ChangedBy = "EikonArkhe";
                fm.ChangedOn = DateTime.Now;
                await api.InsertTrhfm000Dto(fm);
                MenuRoles = await api.GetMenuRoles(trhpa000DtoSelected.PaCodigo);
                trhfm000Dtos = await api.Trhfm000DtoGetPorPaCodigo(Token, trhpa000DtoSelected.PaCodigo);
                // StateHasChanged();
                // treeview2.ExpandAll();
                //StateHasChanged;
                //Task.CompletedTask;
            }

            foreach (var item in trhfm000Dtos)
            {
                var pacodigo = "";
                var iscodigo = item.IsCodigo.Trim().ToLower();
                var id = item.IdentityColumn;
                try
                {
                    pacodigo = MenuItemSelected.Where(fm => fm.Url.Trim().ToLower() == iscodigo).FirstOrDefault().Url.Trim().ToLower();
                }
                catch (Exception)
                {
                    pacodigo = null;
                }

                if (pacodigo == iscodigo)
                    continue;

                await api.DeleteTrhfm000Dto(id);
                MenuRoles = await api.GetMenuRoles(trhpa000DtoSelected.PaCodigo);
                trhfm000Dtos = await api.Trhfm000DtoGetPorPaCodigo(Token, trhpa000DtoSelected.PaCodigo);

                //StateHasChanged;
                //Task.CompletedTask;
            }
            //StateHasChanged();
            treeview2.ExpandAll();
        }


    }
