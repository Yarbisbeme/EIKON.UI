@page "/FRHMA101"
@using DevExpress.Blazor
@using System.Net.Http.Json
@using System.Net.Http.Headers
@using DevExpress.DataAccess
@using EIKON.UI.Interfaces
@using DevExpress.AspNetCore.Reporting
@using DevExpress.XtraReports.UI

@using EIKON.UI.Components

@inject HttpClient HttpClient
@inject EIKON.UI.Services.EikonDataServices api
@inject EIKON.UI.Services.AuthenticationService auth

@inject NavigationManager nv
@inject IJSRuntime JS

<div class="page">
    <Breadcrumb Title="FRHMA101 - Perfiles de Seguridad" BackUrl="/dash" />
    @if (trhpa000Dtos == null)
        {
            <p><em>Loading...</em></p>
        }
        else
        {
    <div class="page-header">
        <div class="header-controls">
            <div class="checkbox-group">
                <DxCheckBox @bind-Checked="@IgualPerfilExistente">Igual a Perfil Existente</DxCheckBox>
                <DxComboBox Id="ofcodigo" Data="@trhpa000Dtos"
                            ValueFieldName="PaCodigo"
                            TextFieldName="PaDescri"
                            @bind-Value="@trhpa000DtoSelected.PaCodigo"
                                SelectedDataItemChanged="(SelectedDataItemChangedEventArgs<Trhpa000Dto> args) =>
                                                                     OnSelectedPerfilChanged(args)"
                            ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                            EditFormat="{1} {2}"
                            SearchMode="@ListSearchMode.AutoSearch"
                            SearchFilterCondition="@ListSearchFilterCondition.Contains">
                    <Columns>
                        <DxListEditorColumn FieldName="PaCodigo" Caption="Código" />
                        <DxListEditorColumn FieldName="PaDescri" Caption="Descripción" />
                    </Columns>
                </DxComboBox>
            </div>
            <div class="page-toolbar">
                <Toolbar formulario="FRHxxx999" OnClose="HandleClose" OnSave="ActualizarTrhpa000" OnAdd="AgregarTrhpa000"/>
            </div>
        </div>
    </div>

    <div class="form-container">
        <!-- Primera fila: Número y Perfil -->
        <div class="form-row">
            <div class="input-field narrow">
                <label>Perfil Id</label>
                    <DxTextBox NullText="0000" @bind-Text="@trhpa000DtoSelected.PaCodigo" ReadOnly="true" @bind-Text:after="@MetodoAejecutar" />
            </div>
            <div class="input-field wide">
                <label>Perfil</label>
                <DxTextBox @bind-Text="@trhpa000DtoSelected.PaDescri"
                           NullText="0000" 
                           ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Never">
                    
                </DxTextBox>
            </div>
        </div>

        <!-- Segunda fila: Descripción -->
        <div class="form-row">
            <div class="input-field full-width">
                <label>Descripción</label>
                <DxMemo NullText="Perfil de administrador con acceso completo al sistema..."
                        @bind-Text="@trhpa000DtoSelected.PaComent"
                        Rows="4"
                        ResizeMode="MemoResizeMode.Vertical"
                        MaxLength="500" />
            </div>
        </div>

        <!-- Sección principal con dos columnas -->
        <div class="main-section">
            <!-- Columna izquierda: Definición de Perfil -->
            <div class="left-column">
                <div class="section-title">Definición de Perfil</div>
                <div class="selector-container">
                        <div class="treeview-scroll-container">
                      
                        <DxTreeView Data="@ModuloItemsSelect"
                                    CheckMode="TreeViewCheckMode.Multiple"
                                    CheckedChanged="CheckingChanged"
                                    AnimationType="LayoutAnimationType.Slide"
                                    CssClass="h-300"
                                    @ref="treeview">
                            <DataMappings>
                                <DxTreeViewDataMapping Children="Children"
                                                       AllowCheck="AllowCheck"
                                                       Text="Title" />
                                <DxTreeViewDataMapping Text="Title"
                                                       Level="1"
                                                       Children="Children"
                                                       Checked="Checked" />
                                    <DxTreeViewDataMapping Text="Url"
                                                           Level="2"
                                                           Name="Url"
                                                           Checked="Checked" />
                                   
                            </DataMappings>
                        </DxTreeView>
                        
                    </div>
                    
                    @* <div class="tree-controls">
                        <DxButton Text=">" CssClass="tree-btn" />
                        <DxButton Text=">>" CssClass="tree-btn" />
                        <DxButton Text="<" CssClass="tree-btn" />
                        <DxButton Text="<<" CssClass="tree-btn" />
                    </div> *@
                    
                    <div class="selected-items">
                            <div class="treeview-scroll-container">
                            <div class="cw-320">
                                    <DxTreeView Data="@MenuRoles"
                                                AllowSelectNodes="true"
                                                SelectionChanged="@SelectionChanged"
                                                AnimationType="LayoutAnimationType.Slide"
                                                CssClass="h-300"
                                                @ref="treeview2">
                                        <DataMappings>
                                            <DxTreeViewDataMapping Children="Children"
                                                                   AllowCheck="AllowCheck"
                                                                   Text="Title" />
                                            <DxTreeViewDataMapping Text="Title"
                                                                   Level="1"
                                                                   Name="Url"
                                                                   Children="Children"
                                                                   Checked="Checked" />
                                            <DxTreeViewDataMapping Text="Url"
                                                                   Level="2"
                                                                   Name="Url"
                                                                   Checked="Checked" />
                                        </DataMappings>
                                    </DxTreeView>

                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Columna derecha: Configuración de Permisos -->
            <div class="right-column">
                <div class="section-title">Configuración de Permisos</div>
                
                <div class="permissions-content">
                    <div class="input-field">
                        <label>Tipo</label>
                        <div class="radio-options">
                                <DxRadioGroup Id="patipo" 
                                              Items="@estatus"
                                              TextFieldName="Text"
                                              ValueFieldName="Value"
                                              @bind-Value="@trhpa000DtoSelected.PaTipo"
                                              Layout="RadioGroupLayout.Horizontal">
                                </DxRadioGroup>
                            @* <DxRadio GroupName="tipo-group" @bind-GroupValue="@TipoAnswer" Value="@grupoValue">Grupo</DxRadio>
                            <DxRadio GroupName="tipo-group" @bind-GroupValue="@TipoAnswer" Value="@dbaValue">DBA</DxRadio>
                            <DxRadio GroupName="tipo-group" @bind-GroupValue="@TipoAnswer" Value="@webValue">Web</DxRadio> *@
                        </div>
                    </div>

                    <div class="input-field">
                            <label>Formulario</label>
                        <div class="checkbox-options">
                                <DxCheckBox Checked="@ActualizarFormulario" Enabled="habilitarCkBox" CheckedChanged="@((bool t) => CheckedChangedAct(t))">Actualizar</DxCheckBox>
                                <DxCheckBox Checked="@BorrarFormulario" Enabled="habilitarCkBox" CheckedChanged="@((bool t) => CheckedChangedBor(t))">Borrar</DxCheckBox>
                                <DxCheckBox Checked="@AnadirFormulario" Enabled="habilitarCkBox" CheckedChanged="@((bool t) => CheckedChangedAdd(t))">Añadir</DxCheckBox>
                        </div>
                    </div>

                    <div class="input-field">
                        <label>Misceláneos</label>
                        <div class="checkbox-options">
                          
                                <DxCheckBox Checked="@ImprimirMiscelaneos" Enabled="habilitarCkBox" CheckedChanged="@((bool t) => CheckedChangedImp(t))">Imprimir</DxCheckBox>
                                <DxCheckBox Checked="@EmailMiscelaneos" Enabled="habilitarCkBox" CheckedChanged="@((bool t) => CheckedChangedMail(t))">Email</DxCheckBox>
                                <DxCheckBox Checked="@AuditoriaMiscelaneos" Enabled="habilitarCkBox" CheckedChanged="@((bool t) => CheckedChangedAud(t))">Auditoría</DxCheckBox>
                        </div>
                    </div>

                    <div class="input-field">
                        <label>Controles</label>
                        <div class="radio-options">
                                <DxRadioGroup Id="patipo"
                                              Items="@controles"
                                              TextFieldName="Text"
                                              ValueFieldName="Value"
                                              Enabled="habilitarRadioBot"
                                              ValueChanged="@((string newValue) => ActualizarMp(newValue))"
                                              value="@mpNivel"
                                              Layout="RadioGroupLayout.Vertical">
                                </DxRadioGroup>
                            @* <DxRadio GroupName="controles-group" @bind-GroupValue="@ControlesAnswer"    Value="@consultaValue">Consulta   </DxRadio>
                            <DxRadio GroupName="controles-group" @bind-GroupValue="@ControlesAnswer" Value="@restringidoValue">Restringido</DxRadio>
                            <DxRadio GroupName="controles-group" @bind-GroupValue="@ControlesAnswer"  Value="@actualizarValue">Actualizar  </DxRadio> *@
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>


}
</div>
<style>
    /* Container principal */
    .form-container {
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    /* Header controls */
    .header-controls {
        display: flex;
        justify-content: space-between;
        align-items: center;
        width: 100%;
    }

    .checkbox-group {
        display: flex;
        align-items: center;
        gap: 15px;
        min-width: 350px;
        white-space: nowrap;
    }

    .checkbox-group > * {
        white-space: nowrap;
    }

    .perfil-base-input {
        min-width: 200px;
    }

    /* Form rows */
    .form-row {
        display: flex;
        gap: 15px;
        align-items: flex-end;
    }

    /* Input fields con label arriba */
    .input-field {
        display: flex;
        flex-direction: column;
        gap: 5px;
    }

    .input-field label {
        font-weight: normal;
        color: #333;
        font-size: 14px;
    }

    /* Tamaños de campos */
    .input-field.full-width {
        flex: 1;
    }

    .input-field.narrow {
        flex: 0 0 200px;
    }

    .input-field.wide {
        flex: 1;
    }

    /* Sección principal con dos columnas */
    .main-section {
        display: flex;
        gap: 20px;
        margin-top: 20px;
        min-height: 500px;
    }

    .left-column {
        flex: 2;
        display: flex;
        flex-direction: column;
        border: 1px solid #e0e0e0;
        border-radius: 8px;
        overflow: hidden;
    }

    .right-column {
        flex: 1;
        display: flex;
        flex-direction: column;
        border: 1px solid #e0e0e0;
        border-radius: 8px;
        overflow: hidden;
        min-width: 320px;
        max-width: 400px;
    }

    /* Títulos de sección */
    .section-title {
        background-color: #f5f5f5;
        padding: 12px 15px;
        font-weight: 600;
        border-bottom: 1px solid #e0e0e0;
        text-align: center;
        font-size: 14px;
        color: #333;
    }

    /* Selector container para TreeView */
    .selector-container {
        display: flex;
        flex: 1;
        gap: 0;
        height: 420px;
    }

    .available-items,
    .selected-items {
        flex: 1;
        padding: 10px;
        overflow-y: auto;
        height: 100%;
        border-right: 1px solid #e0e0e0;
        display: flex;
        flex-direction: column;
    }

    .selected-items {
        border-right: none;
        border-left: 1px solid #e0e0e0;
    }

    .selected-tree-container {
        flex: 1;
        display: flex;
/*         align-items: center; */       
      justify-content: center;
    }

    .profile-tree {
        width: 100%;
        height: 100%;
    }

    .no-data {
        color: #666;
        font-style: italic;
        text-align: center;
    }

    .tree-node {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 2px 0;
    }

    .tree-node i {
        color: #666;
        font-size: 14px;
    }

    .tree-controls {
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        gap: 10px;
        padding: 10px;
        min-width: 80px;
        height: 100%;
        background-color: #fafafa;
        border-left: 1px solid #e0e0e0;
        border-right: 1px solid #e0e0e0;
    }

    .tree-btn {
        min-width: 40px;
        height: 30px;
    }

    /* Contenido de permisos */
    .permissions-content {
        padding: 15px;
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    .treeview-scroll-container {
        /* Establece la altura máxima deseada */
        max-height: 400px;
        /* Habilita la barra de desplazamiento vertical si el contenido excede el max-height */
        overflow-y: auto;
        /* (Opcional) Habilita la barra de desplazamiento horizontal si el contenido es muy ancho */
        overflow-x: hidden;
    }
    .radio-options,
    .checkbox-options {
        display: flex;
        flex-direction: column;
        gap: 8px;
        margin-top: 5px;
    }

    /* Responsive Design */
    media (max-width: 768px) {
        .header-controls {
            flex-direction: column;
            gap: 15px;
            align-items: stretch;
        }

        .checkbox-group {
            flex-direction: column;
            gap: 10px;
        }

        .form-row {
            flex-direction: column;
            gap: 10px;
        }

        .input-field.narrow,
        .input-field.wide {
            flex: 1;
        }

        .main-section {
            flex-direction: column;
            gap: 15px;
        }

        .selector-container {
            height: 300px;
        }
    }

    media (max-width: 480px) {
        .permissions-content {
            padding: 10px;
            gap: 15px;
        }

        .tree-controls {
            flex-direction: row;
            flex-wrap: wrap;
            min-width: auto;
            height: auto;
            padding: 5px;
        }

        .tree-btn {
            min-width: 35px;
            height: 28px;
        }
    }
</style>

@code {
