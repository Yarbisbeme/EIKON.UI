@page "/FRHNO207C"
@layout MainLayout
@inject IJSRuntime JSRuntime

<div class="page">
    <Breadcrumb Title="FRHNO207C - Cuadre visual de nómina" BackUrl="/dash" />
    
    <div class="page-header">
        <div class="page-toolbar">
            <Toolbar formulario="FRHxxx999" OnClose="HandleClose" />
        </div>
    </div>

    <div class="form-container">
        <!-- Sección de Criterios y Controles -->
        <div class="controls-section">
            <DxTabs @bind-ActiveTabIndex="@ActiveTabIndex" CssClass="criteria-tabs">
                <DxTabPage Text="Criterios">
                    <div class="controls-content">
                <!-- Fila de campos principales -->
                <div class="main-fields-row">
                    <div class="input-field">
                        <label>Nómina validar</label>
                        <DxComboBox Data="@NominasList" 
                                   @bind-Value="@SelectedNomina" 
                                   NullText="Seleccionar nómina"
                                   TextFieldName="Name" 
                                   ValueFieldName="Id" />
                    </div>
                    
                    <div class="input-field">
                        <label>Comparada</label>
                        <DxTextBox @bind-Text="@ComparadaValue" />
                    </div>
                    
                    <div class="input-field">
                        <label>Reporte</label>
                        <DxTextBox @bind-Text="@ReporteValue"
                                   ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Never">
                            <Buttons>
                                <DxEditorButton IconCssClass="fi fi-rr-search" 
                                               Click="@OnSearchReporteClick" />
                            </Buttons>
                        </DxTextBox>
                    </div>
                </div>
                
                <!-- Fila de controles adicionales -->
                <div class="additional-controls-row">
                    <div class="checkbox-options">
                        <DxCheckBox @bind-Checked="@TransaccionalesOption">Transaccionales</DxCheckBox>
                    </div>
                </div>
                    </div>
                </DxTabPage>
                <DxTabPage Text="Otros criterios">
                    <div class="controls-content">
                        <div class="otros-criterios-content">
                            <p>Contenido de otros criterios aquí...</p>
                        </div>
                    </div>
                </DxTabPage>
            </DxTabs>
        </div>

        <!-- Sección de Resumen Superior -->
        <div class="summary-section">
            <div class="summary-table">
                <div class="summary-header">
                    <div class="header-cell"></div>
                    <div class="header-cell">Actual</div>
                    <div class="header-cell">Comparada</div>
                    <div class="header-cell">Dif.(+/-)</div>
                </div>
                <div class="summary-row">
                    <div class="summary-cell label">Ingresos</div>
                    <div class="summary-cell amount">$0.00</div>
                    <div class="summary-cell amount">$0.00</div>
                    <div class="summary-cell amount">$0.00</div>
                </div>
                <div class="summary-row">
                    <div class="summary-cell label">Descuentos</div>
                    <div class="summary-cell amount">$0.00</div>
                    <div class="summary-cell amount">$0.00</div>
                    <div class="summary-cell amount">$0.00</div>
                </div>
                <div class="summary-row">
                    <div class="summary-cell label">Total Neto</div>
                    <div class="summary-cell amount">$0.00</div>
                    <div class="summary-cell amount">$0.00</div>
                    <div class="summary-cell amount">$0.00</div>
                </div>
                <div class="summary-row">
                    <div class="summary-cell label">Empleados</div>
                    <div class="summary-cell amount">0.00</div>
                    <div class="summary-cell amount">0.00</div>
                    <div class="summary-cell amount">0.00</div>
                </div>
            </div>
        </div>

        <!-- Sección Principal con Tabs Centrales -->
        <div class="main-content">
            <!-- Tabs Centrales para Indicadores y Resumen -->
            <div class="central-tabs-section">
                <DxTabs @bind-ActiveTabIndex="@CentralTabIndex" CssClass="central-tabs">
                    <DxTabPage Text="Indicadores de cuadre">
                        <div class="tab-content-grid">
                            <DxGrid Data="@IndicadoresData"
                                    PageSize="8"
                                    ColumnResizeMode="GridColumnResizeMode.NextColumn"
                                    TextWrapEnabled="false"
                                    CssClass="indicators-grid"
                                    PagerVisible="true">
                                <Columns>
                                    <DxGridDataColumn FieldName="Descripcion" Caption="Descripción" Width="40%" />
                                    <DxGridDataColumn FieldName="Cantidad" Caption="Cantidad" Width="30%" DisplayFormat="N0" TextAlignment="GridTextAlignment.Right" />
                                    <DxGridDataColumn FieldName="Monto" Caption="Monto" Width="30%" DisplayFormat="C2" TextAlignment="GridTextAlignment.Right" />
                                </Columns>
                            </DxGrid>
                        </div>
                    </DxTabPage>
                    <DxTabPage Text="Resumen de transacciones">
                        <div class="tab-content-chart">
                            <div class="section-header">
                                <div class="chart-actions">
                                    <DxButton Text="Exportar" 
                                             CssClass="btn-sm secondary-btn" 
                                             Click="@OnExportarClick" />
                                    <DxButton Text="Modificar Gráfico" 
                                             CssClass="btn-sm info-btn" 
                                             Click="@OnModificarGraficoClick" />
                                </div>
                            </div>
                            <div class="chart-container">
                                <!-- Placeholder para el gráfico -->
                                <div class="chart-placeholder">
                                    <div class="chart-content">
                                        <div class="chart-lines">
                                            <div class="chart-line line1"></div>
                                            <div class="chart-line line2"></div>
                                        </div>
                                        <div class="chart-text">Gráfico de Resumen</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </DxTabPage>
                </DxTabs>
            </div>

            <!-- Sección Inferior con Empleados y Volante -->
            <div class="bottom-content">
                <!-- Empleados en el pago -->
                <div class="employees-section">
                    <div class="section-title">
                        <DxCheckBox @bind-Checked="@EmpleadosEnPagoOption">Empleados En el pago</DxCheckBox>
                    </div>
                    <DxGrid Data="@EmpleadosData"
                            PageSize="6"
                            ColumnResizeMode="GridColumnResizeMode.NextColumn"
                            TextWrapEnabled="false"
                            CssClass="employees-grid"
                            PagerVisible="true">
                        <Columns>
                            <DxGridDataColumn FieldName="NumeroEmpleado" Caption="No." Width="15%" />
                            <DxGridDataColumn FieldName="Nombre" Caption="Nombre" Width="35%" />
                            <DxGridDataColumn FieldName="Cuenta" Caption="Cuenta" Width="25%" />
                            <DxGridDataColumn FieldName="Neto" Caption="Neto" Width="25%" DisplayFormat="C2" TextAlignment="GridTextAlignment.Right" />
                        </Columns>
                    </DxGrid>
                </div>

                <!-- Volante de empleado -->
                <div class="volante-section">
                    <div class="section-title">Volante de empleado</div>
                    <DxGrid Data="@VolanteData"
                            PageSize="6"
                            ColumnResizeMode="GridColumnResizeMode.NextColumn"
                            TextWrapEnabled="false"
                            CssClass="volante-grid"
                            PagerVisible="false">
                        <Columns>
                            <DxGridDataColumn FieldName="Codigo" Caption="Código" Width="25%" />
                            <DxGridDataColumn FieldName="Descripcion" Caption="Descripción" Width="40%" />
                            <DxGridDataColumn FieldName="Cantidad" Caption="Cantidad" Width="17.5%" DisplayFormat="N2" TextAlignment="GridTextAlignment.Right" />
                            <DxGridDataColumn FieldName="Monto" Caption="Monto" Width="17.5%" DisplayFormat="C2" TextAlignment="GridTextAlignment.Right" />
                        </Columns>
                    </DxGrid>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* Container principal */
    .form-container {
        display: flex;
        flex-direction: column;
        gap: 20px;
        margin-top: 10px;
    }

    /* Sección de controles */
    .controls-section {
        border: 1px solid #e0e0e0;
        border-radius: 8px;
        overflow: hidden;
        width: 100%;
    }

    /* DxTabs styling */
    .criteria-tabs .dx-tabs-nav-item.dx-tabs-nav-item-selected {
        background-color: #dc3545 !important;
        color: white !important;
        border-color: #dc3545 !important;
    }

    .criteria-tabs .dx-tabs-nav-item {
        background-color: #f8f9fa !important;
        color: #666 !important;
        border: 1px solid #e0e0e0 !important;
        padding: 12px 20px !important;
        font-weight: 500 !important;
    }

    .criteria-tabs .dx-tabs-nav-item:hover:not(.dx-tabs-nav-item-selected) {
        background-color: #e9ecef !important;
    }

    .criteria-tabs {
        border: none !important;
    }

    .criteria-tabs .dx-tabs-content {
        padding: 0 !important;
        border: none !important;
    }

    /* Central tabs styling */
    .central-tabs .dx-tabs-nav-item.dx-tabs-nav-item-selected {
        background-color: #dc3545 !important;
        color: white !important;
        border-color: #dc3545 !important;
    }

    .central-tabs .dx-tabs-nav-item {
        background-color: #f8f9fa !important;
        color: #666 !important;
        border: 1px solid #e0e0e0 !important;
        padding: 10px 16px !important;
        font-weight: 500 !important;
    }

    .central-tabs .dx-tabs-nav-item:hover:not(.dx-tabs-nav-item-selected) {
        background-color: #e9ecef !important;
    }

    .central-tabs .dx-tabs-content {
        padding: 15px !important;
        border: none !important;
        height: calc(100% - 45px);
    }

    /* Tab content containers */
    .tab-content-grid,
    .tab-content-chart {
        height: 100%;
        display: flex;
        flex-direction: column;
    }

    .tab-content-chart .section-header {
        margin-bottom: 15px;
        justify-content: flex-end;
    }

    .controls-content {
        display: flex;
        flex-direction: column;
        padding: 20px;
        gap: 20px;
    }

    .main-fields-row {
        display: flex;
        gap: 20px;
        margin-bottom: 20px;
    }
    
    .main-fields-row .input-field {
        flex: 1;
    }
    
    .additional-controls-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 20px;
    }


    .action-buttons {
        display: flex;
        gap: 8px;
    }

    .checkbox-options {
        margin-top: 10px;
    }

    /* Input fields */
    .input-field {
        display: flex;
        flex-direction: column;
        gap: 5px;
        max-width: 300px;
    }

    .input-field label {
        font-weight: normal;
        color: #333;
        font-size: 14px;
    }

    /* Sección de resumen */
    .summary-section {
        border: 1px solid #e0e0e0;
        border-radius: 8px;
        padding: 20px;
        width: 100%;
    }

    .summary-table {
        display: flex;
        flex-direction: column;
        width: 100%;
        margin: 0 auto;
    }

    .summary-header {
        display: flex;
        background-color: #f8f9fa;
        border-bottom: 2px solid #dee2e6;
    }

    .header-cell {
        flex: 1;
        padding: 10px;
        font-weight: 600;
        text-align: center;
        border-right: 1px solid #dee2e6;
    }

    .header-cell:last-child {
        border-right: none;
    }

    .summary-row {
        display: flex;
        border-bottom: 1px solid #dee2e6;
    }

    .summary-row:last-child {
        border-bottom: none;
    }

    .summary-cell {
        flex: 1;
        padding: 8px 10px;
        border-right: 1px solid #dee2e6;
        text-align: center;
    }

    .summary-cell:last-child {
        border-right: none;
    }

    .summary-cell.label {
        font-weight: 500;
        text-align: left;
        color: #333;
    }

    .summary-cell.amount {
        font-family: monospace;
        font-weight: 500;
        text-align: right;
    }

    /* Contenido principal */
    .main-content {
        display: flex;
        flex-direction: column;
        gap: 20px;
        height: 600px;
    }

    /* Sección de tabs centrales */
    .central-tabs-section {
        height: 300px;
        border: 1px solid #e0e0e0;
        border-radius: 8px;
        overflow: hidden;
    }

    /* Sección inferior con empleados y volante */
    .bottom-content {
        display: flex;
        gap: 20px;
        flex: 1;
    }

    /* Secciones de grid */
    .employees-section,
    .volante-section {
        border: 1px solid #e0e0e0;
        border-radius: 8px;
        padding: 15px;
        display: flex;
        flex-direction: column;
        gap: 10px;
        flex: 1;
    }

    .section-title {
        font-weight: 600;
        color: #333;
        font-size: 14px;
        margin-bottom: 5px;
    }

    .section-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 15px;
    }

    .chart-actions {
        display: flex;
        gap: 8px;
    }

    /* Chart placeholder */
    .chart-container {
        flex: 1;
        min-height: 150px;
        max-height: 180px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .chart-placeholder {
        width: 100%;
        height: 150px;
        background-color: #f8f9fa;
        border: 2px dashed #dee2e6;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 6px;
    }

    .chart-content {
        text-align: center;
    }

    .chart-lines {
        display: flex;
        justify-content: center;
        gap: 10px;
        margin-bottom: 10px;
    }

    .chart-line {
        width: 40px;
        height: 3px;
        background-color: #007bff;
        border-radius: 2px;
        transform-origin: left;
    }

    .chart-line.line1 {
        transform: rotate(15deg);
    }

    .chart-line.line2 {
        transform: rotate(-15deg);
        background-color: #28a745;
    }

    .chart-text {
        color: #666;
        font-size: 12px;
        font-weight: 500;
    }

    /* Grids */
    .indicators-grid,
    .employees-grid,
    .volante-grid {
        flex: 1;
        width: 100%;
        min-height: 180px;
    }

    .indicators-grid {
        height: 100%;
    }

    /* Botones */
    .icon-btn {
        width: 32px;
        height: 32px;
        min-width: 32px;
        padding: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 6px;
    }

    .btn-sm {
        padding: 6px 12px;
        font-size: 12px;
        border-radius: 4px;
    }

    .error-btn {
        background-color: #dc3545;
        border-color: #dc3545;
        color: white;
    }

    .error-btn:hover {
        background-color: #c82333;
        border-color: #bd2130;
    }

    .info-btn {
        background-color: #17a2b8;
        border-color: #17a2b8;
        color: white;
    }

    .info-btn:hover {
        background-color: #138496;
        border-color: #117a8b;
    }

    .secondary-btn {
        background-color: #6c757d;
        border-color: #6c757d;
        color: white;
    }

    .secondary-btn:hover {
        background-color: #5a6268;
        border-color: #545b62;
    }

    /* DevExpress Components */
    .dx-textbox,
    .dx-combobox {
        border-radius: 6px !important;
    }

    .dx-textbox-container,
    .dx-combobox-container {
        border: 1px solid #ced4da !important;
        border-radius: 6px !important;
    }

    .dx-textbox-container:focus-within,
    .dx-combobox-container:focus-within {
        border-color: #007bff !important;
        box-shadow: 0 0 0 0.2rem rgba(0, 123, 255, 0.25) !important;
    }

    /* Responsive Design */
    media (max-width: 768px) {
        .controls-content {
            flex-direction: column;
            gap: 20px;
        }

        .right-controls {
            align-items: flex-start;
            min-width: auto;
        }

        .main-content {
            height: auto;
        }

        .central-tabs-section {
            height: 400px;
        }

        .bottom-content {
            flex-direction: column;
        }

        .employees-section,
        .volante-section {
            height: 250px;
            min-height: 250px;
        }

        .section-header {
            flex-direction: column;
            gap: 10px;
            align-items: stretch;
        }

        .chart-actions {
            justify-content: center;
        }
    }

    media (max-width: 768px) {
        .main-fields-row {
            flex-direction: column;
            gap: 15px;
        }
        
        .additional-controls-row {
            flex-direction: column;
            align-items: stretch;
            gap: 15px;
        }
    }

    media (max-width: 480px) {
        .form-container {
            gap: 15px;
        }

        .controls-section,
        .summary-section,
        .indicators-section,
        .employees-section,
        .transactions-section,
        .volante-section {
            padding: 15px;
        }

        .tabs-header {
            flex-direction: column;
        }

        .tab-button {
            border-right: none;
            border-bottom: 1px solid #e0e0e0;
        }

        .input-field {
            max-width: none;
        }

        .central-tabs-section {
            height: 350px;
        }

        .employees-section,
        .volante-section {
            height: 200px;
            min-height: 200px;
        }

        .icon-btn {
            width: 28px;
            height: 28px;
            min-width: 28px;
        }
    }
</style>

@code {
    // **- private string[] // **- ToolbarOptions = { "add", "save", "remove", "leave" };
    
    // Tab controls
    private int ActiveTabIndex { get; set; } = 0;
    private int CentralTabIndex { get; set; } = 0;
    
    // Campos del formulario
    private int? SelectedNomina { get; set; }
    private string ComparadaValue { get; set; } = "";
    private string ReporteValue { get; set; } = "";
    
    // Opciones de checkboxes
    private bool TransaccionalesOption { get; set; } = true;
    private bool EmpleadosEnPagoOption { get; set; } = true;
    
    // Listas de datos
    private List<NominaItem> NominasList = new List<NominaItem>
    {
        new NominaItem { Id = 1, Name = "NOMINA ADMINISTRATIVA" },
        new NominaItem { Id = 2, Name = "NOMINA OPERATIVA" },
        new NominaItem { Id = 3, Name = "NOMINA EJECUTIVA" }
    };

    private List<IndicadorItem> IndicadoresData = new List<IndicadorItem>
    {
        new IndicadorItem { Descripcion = "SALARIO BASE", Cantidad = 150, Monto = 2250000.00m },
        new IndicadorItem { Descripcion = "HORAS EXTRAS", Cantidad = 45, Monto = 135000.00m },
        new IndicadorItem { Descripcion = "BONIFICACIONES", Cantidad = 23, Monto = 575000.00m }
    };

    private List<EmpleadoItem> EmpleadosData = new List<EmpleadoItem>
    {
        new EmpleadoItem { NumeroEmpleado = "001", Nombre = "JUAN PEREZ", Cuenta = "12345678", Neto = 25000.00m },
        new EmpleadoItem { NumeroEmpleado = "002", Nombre = "MARIA RODRIGUEZ", Cuenta = "87654321", Neto = 28000.00m },
        new EmpleadoItem { NumeroEmpleado = "003", Nombre = "CARLOS LOPEZ", Cuenta = "11223344", Neto = 32000.00m },
        new EmpleadoItem { NumeroEmpleado = "004", Nombre = "ANA MARTINEZ", Cuenta = "44332211", Neto = 27500.00m }
    };

    private List<VolanteItem> VolanteData = new List<VolanteItem>
    {
        new VolanteItem { Codigo = "001", Descripcion = "SALARIO BASE", Cantidad = 1.00m, Monto = 25000.00m },
        new VolanteItem { Codigo = "002", Descripcion = "HORAS EXTRAS", Cantidad = 8.00m, Monto = 3000.00m },
        new VolanteItem { Codigo = "101", Descripcion = "IHSS LABORAL", Cantidad = 1.00m, Monto = -840.00m },
        new VolanteItem { Codigo = "102", Descripcion = "IR SOBRE SUELDOS", Cantidad = 1.00m, Monto = -2800.00m }
    };
    
    public class NominaItem
    {
        public int Id { get; set; }
        public string Name { get; set; } = "";
    }
    
    public class IndicadorItem
    {
        public string Descripcion { get; set; } = "";
        public int Cantidad { get; set; }
        public decimal Monto { get; set; }
    }
    
    public class EmpleadoItem
    {
        public string NumeroEmpleado { get; set; } = "";
        public string Nombre { get; set; } = "";
        public string Cuenta { get; set; } = "";
        public decimal Neto { get; set; }
    }
    
    public class VolanteItem
    {
        public string Codigo { get; set; } = "";
        public string Descripcion { get; set; } = "";
        public decimal Cantidad { get; set; }
        public decimal Monto { get; set; }
    }
    
    private void OnSearchReporteClick()
    {
        Console.WriteLine($"Buscando reporte: {ReporteValue}");
    }
    
    private void OnClearClick()
    {
        Console.WriteLine("Limpiando datos");
    }
    
    private void OnSettingsClick()
    {
        Console.WriteLine("Abriendo configuración");
    }
    
    private void OnExportarClick()
    {
        Console.WriteLine("Exportando gráfico");
    }
    
    private void OnModificarGraficoClick()
    {
        Console.WriteLine("Modificando gráfico");
    }
    
    private async Task HandleClose()
    {
        await JSRuntime.InvokeVoidAsync("alert", "¡Cuadre visual de nómina guardado!");
    }
}