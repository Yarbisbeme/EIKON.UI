@page "/FRHNO204New"

@using EIKON.UI.Components
@using DevExpress.Blazor
@using System.Net.Http.Json
@using System.Net.Http.Headers
@using EIKON.UI.Interfaces
@using DevExpress.AspNetCore.Reporting
@using DevExpress.XtraReports.UI
@using System.ComponentModel.DataAnnotations

@layout MainLayout
@inject HttpClient HttpClient
@inject EIKON.UI.Services.EikonDataServices api
@inject EIKON.UI.Services.AuthenticationService auth
@inject NavigationManager nv
@inject IJSRuntime JS

<div class="page">
    <Breadcrumb Title="FRHNO204 - Verificación de Partidas" BackUrl="/dash" />
    
    <div class="page-header">
        <div class="page-toolbar">
            <Toolbar formulario="FRHxxx999" OnClose="HandleClose" />
        </div>
    </div>

    <div class="form-container">
        <!-- Sección Superior de Campos -->
        <div class="top-section">
            <!-- Primera Fila -->
            <div class="form-row">
                <div class="input-field">
                    <label>Nómina a verificar</label>
                    <DxComboBox Data="@NominasList" 
                               @bind-Value="@SelectedNomina" 
                               NullText="Seleccionar nómina"
                               TextFieldName="Name" 
                               ValueFieldName="Id" />
                </div>
            </div>

            <!-- Segunda Fila -->
            <div class="form-row">
                <div class="input-field">
                    <label>Año Fiscal</label>
                    <DxSpinEdit @bind-Value="@AnoFiscalValue" 
                               MinValue="2000" 
                               MaxValue="2099" />
                </div>
            </div>

            <!-- Tercera Fila - Campos en tres columnas -->
            <div class="form-row three-columns">
                <div class="input-field">
                    <label>Efectividad</label>
                    <DxDateEdit @bind-Date="@EfectividadValue" 
                               NullText="dd/mm/yyyy" />
                </div>
                <div class="input-field">
                    <label>Al</label>
                    <DxDateEdit @bind-Date="@AlValue" 
                               NullText="dd/mm/yyyy" />
                </div>
                <div class="input-field">
                    <label>Corte</label>
                    <DxDateEdit @bind-Date="@CorteValue" 
                               NullText="dd/mm/yyyy" />
                </div>
            </div>

            <!-- Cuarta Fila - Comentario -->
            <div class="form-row">
                <div class="input-field wide">
                    <label>Comentario</label>
                    <DxTextBox @bind-Text="@ComentarioValue" />
                </div>
            </div>
        </div>

        <!-- Sección Principal del Grid -->
        <div class="grid-section">
            <!-- Toolbar del Grid -->
            <div class="grid-toolbar">
                <div class="toolbar-left">
                    <DxCheckBox @bind-Checked="@SelectAllRows" 
                               CssClass="select-all-checkbox" />
                </div>
                <div class="toolbar-center">
                    <DxButton Text="Buscar" 
                             CssClass="btn-sm primary-btn" 
                             Click="@OnBuscarClick" />
                </div>
                <div class="toolbar-right">
                    <DxButton IconCssClass="fi fi-rr-angle-up" 
                             CssClass="icon-btn secondary-btn" 
                             Click="@OnMoveUpClick" />
                    <DxButton IconCssClass="fi fi-rr-angle-down" 
                             CssClass="icon-btn secondary-btn" 
                             Click="@OnMoveDownClick" />
                </div>
            </div>

            <!-- Grid Principal -->
            <DxGrid Data="@PartidaData"
                    PageSize="10"
                    ColumnResizeMode="GridColumnResizeMode.NextColumn"
                    TextWrapEnabled="false"
                    CssClass="partida-grid"
                    PagerVisible="true"
                    ShowGroupPanel="false"
                    AllowSelectRowByClick="true">
                <Columns>
                    <DxGridSelectionColumn Width="50px" />
                    <DxGridDataColumn FieldName="Codigo" Caption="Código" Width="15%" />
                    <DxGridDataColumn FieldName="Empleado" Caption="Empleado" Width="35%" />
                    <DxGridDataColumn FieldName="Fecha" Caption="Fecha" Width="20%" 
                                     DisplayFormat="dd/MM/yyyy" />
                    <DxGridDataColumn FieldName="Monto" Caption="Monto" Width="30%" 
                                     DisplayFormat="C2" TextAlignment="GridTextAlignment.Right" />
                </Columns>
            </DxGrid>
        </div>

        <!-- Sección Inferior de Opciones y Reporte -->
        <div class="bottom-section">
            <!-- Opciones con Checkboxes -->
            <div class="options-section">
                <div class="checkbox-group">
                    <DxCheckBox @bind-Checked="@InformacionAgrupadaOption">
                        Información Agrupada
                    </DxCheckBox>
                    <DxCheckBox @bind-Checked="@VolantesNegativosOption">
                        Volantes Negativos
                    </DxCheckBox>
                    <DxCheckBox @bind-Checked="@SoloVariacionesOption">
                        Solo Variaciones
                    </DxCheckBox>
                    <DxCheckBox @bind-Checked="@VolantesEnCeroOption">
                        Volantes en cero
                    </DxCheckBox>
                    <DxCheckBox @bind-Checked="@InformablesDeControlOption">
                        Informables de Control
                    </DxCheckBox>
                    <DxCheckBox @bind-Checked="@MostrarInvisiblesOption">
                        Mostrar Invisibles
                    </DxCheckBox>
                </div>

                <!-- Botones de acción -->
                <div class="action-buttons">
                    <DxButton IconCssClass="fi fi-rr-refresh" 
                             CssClass="icon-btn success-btn" 
                             Click="@OnRefreshClick" />
                    <DxButton IconCssClass="fi fi-rr-settings" 
                             CssClass="icon-btn info-btn" 
                             Click="@OnSettingsClick" />
                </div>
            </div>

            <!-- Sección de Reporte -->
            <div class="report-section">
                <div class="input-field wide">
                    <DxTextBox @bind-Text="@ReporteValue" 
                              NullText="Reporte" />
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* Container principal */
    .form-container {
        display: flex;
        flex-direction: column;
        gap: 20px;
        margin-top: 10px;
    }

    /* Sección superior */
    .top-section {
        display: flex;
        flex-direction: column;
        gap: 15px;
        border: 1px solid transparent;
        border-radius: 8px;
    }

    /* Form rows */
    .form-row {
        display: flex;
        gap: 20px;
        align-items: flex-end;
    }

    .form-row.three-columns {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: 20px;
    }

    /* Input fields */
    .input-field {
        display: flex;
        flex-direction: column;
        gap: 5px;
        flex: 1;
    }

    .input-field.wide {
        flex: 2;
    }

    .input-field label {
        font-weight: normal;
        color: #333;
        font-size: 14px;
    }

    /* Sección del grid */
    .grid-section {
        border: 1px solid #e0e0e0;
        border-radius: 8px;
        padding: 0;
        overflow: hidden;
    }

    /* Toolbar del grid */
    .grid-toolbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 15px 20px;
        background-color: #f8f9fa;
        border-bottom: 1px solid #e0e0e0;
    }

    .toolbar-left,
    .toolbar-center,
    .toolbar-right {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .toolbar-center {
        flex: 1;
        justify-content: center;
    }

    .select-all-checkbox {
        margin: 0;
    }

    /* Grid principal */
    .partida-grid {
        border: none;
        border-radius: 0;
    }

    /* Sección inferior */
    .bottom-section {
        display: flex;
        flex-direction: column;
        gap: 15px;
    }

    /* Sección de opciones */
    .options-section {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        padding: 20px;
        border: 1px solid #e0e0e0;
        border-radius: 8px;
        gap: 20px;
    }

    .checkbox-group {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 15px;
        flex: 1;
    }

    .action-buttons {
        display: flex;
        gap: 8px;
        flex: 0 0 auto;
    }

    /* Sección de reporte */
    .report-section {
        padding: 20px;
        border: 1px solid #e0e0e0;
        border-radius: 8px;
    }

    /* Botones */
    .icon-btn {
        width: 32px;
        height: 32px;
        min-width: 32px;
        padding: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 6px;
    }

    .btn-sm {
        padding: 8px 16px;
        font-size: 13px;
        border-radius: 4px;
        font-weight: 500;
    }

    .primary-btn {
        background-color: #dc3545;
        border-color: #dc3545;
        color: white;
    }

    .primary-btn:hover {
        background-color: #c82333;
        border-color: #bd2130;
    }

    .secondary-btn {
        background-color: #6c757d;
        border-color: #6c757d;
        color: white;
    }

    .secondary-btn:hover {
        background-color: #5a6268;
        border-color: #545b62;
    }

    .success-btn {
        background-color: #28a745;
        border-color: #28a745;
        color: white;
    }

    .success-btn:hover {
        background-color: #218838;
        border-color: #1e7e34;
    }

    .info-btn {
        background-color: #17a2b8;
        border-color: #17a2b8;
        color: white;
    }

    .info-btn:hover {
        background-color: #138496;
        border-color: #117a8b;
    }

    /* DevExpress Components */
    .dx-textbox,
    .dx-combobox,
    .dx-date-edit,
    .dx-spin-edit {
        border-radius: 6px !important;
    }

    .dx-textbox-container,
    .dx-combobox-container,
    .dx-date-edit-container,
    .dx-spin-edit-container {
        border: 1px solid #ced4da !important;
        border-radius: 6px !important;
    }

    .dx-textbox-container:focus-within,
    .dx-combobox-container:focus-within,
    .dx-date-edit-container:focus-within,
    .dx-spin-edit-container:focus-within {
        border-color: #007bff !important;
        box-shadow: 0 0 0 0.2rem rgba(0, 123, 255, 0.25) !important;
    }

    /* Responsive Design */
    media (max-width: 768px) {
        .top-section,
        .options-section,
        .report-section {
            padding: 15px;
        }

        .form-row {
            flex-direction: column;
            gap: 15px;
        }

        .form-row.three-columns {
            grid-template-columns: 1fr;
        }

        .grid-toolbar {
            flex-direction: column;
            gap: 15px;
            align-items: stretch;
        }

        .toolbar-left,
        .toolbar-center,
        .toolbar-right {
            justify-content: center;
        }

        .checkbox-group {
            grid-template-columns: 1fr;
            gap: 10px;
        }

        .options-section {
            flex-direction: column;
            align-items: stretch;
        }

        .action-buttons {
            justify-content: center;
        }
    }

   media (max-width: 480px) {
        .form-container {
            gap: 15px;
        }

        .top-section,
        .options-section,
        .report-section {
            padding: 15px;
        }

        .grid-toolbar {
            padding: 10px 15px;
        }

        .icon-btn {
            width: 28px;
            height: 28px;
            min-width: 28px;
        }

        .btn-sm {
            padding: 6px 12px;
            font-size: 12px;
        }
    }
</style>

@code {
    // **- private string[] // **- ToolbarOptions = { "add", "save", "remove", "leave" };
    
    // Campos del formulario
    private int? SelectedNomina { get; set; }
    private int AnoFiscalValue { get; set; } = DateTime.Now.Year;
    private DateTime? EfectividadValue { get; set; }
    private DateTime? AlValue { get; set; }
    private DateTime? CorteValue { get; set; }
    private string ComentarioValue { get; set; } = "";
    private string ReporteValue { get; set; } = "";
    
    // Opciones del grid
    private bool SelectAllRows { get; set; } = false;
    
    // Opciones de checkboxes
    private bool InformacionAgrupadaOption { get; set; } = false;
    private bool VolantesNegativosOption { get; set; } = false;
    private bool SoloVariacionesOption { get; set; } = false;
    private bool VolantesEnCeroOption { get; set; } = false;
    private bool InformablesDeControlOption { get; set; } = false;
    private bool MostrarInvisiblesOption { get; set; } = false;
    
    // Listas de datos
    private List<NominaItem> NominasList = new List<NominaItem>
    {
        new NominaItem { Id = 1, Name = "NOMINA ADMINISTRATIVA" },
        new NominaItem { Id = 2, Name = "NOMINA OPERATIVA" },
        new NominaItem { Id = 3, Name = "NOMINA EJECUTIVA" },
        new NominaItem { Id = 4, Name = "NOMINA ESPECIAL" }
    };

    private List<PartidaItem> PartidaData = new List<PartidaItem>
    {
        new PartidaItem { Codigo = "001", Empleado = "JUAN CARLOS PEREZ MARTINEZ", Fecha = DateTime.Now.AddDays(-5), Monto = 25000.00m },
        new PartidaItem { Codigo = "002", Empleado = "MARIA ELENA RODRIGUEZ LOPEZ", Fecha = DateTime.Now.AddDays(-3), Monto = 28500.00m },
        new PartidaItem { Codigo = "003", Empleado = "CARLOS ALBERTO SANCHEZ RIVERA", Fecha = DateTime.Now.AddDays(-2), Monto = 32000.00m },
        new PartidaItem { Codigo = "004", Empleado = "ANA PATRICIA MARTINEZ GONZALEZ", Fecha = DateTime.Now.AddDays(-1), Monto = 27500.00m },
        new PartidaItem { Codigo = "005", Empleado = "LUIS FERNANDO HERNANDEZ CASTRO", Fecha = DateTime.Now, Monto = 31200.00m },
        new PartidaItem { Codigo = "006", Empleado = "SOFIA ISABEL VARGAS MENDOZA", Fecha = DateTime.Now.AddDays(-4), Monto = 29800.00m },
        new PartidaItem { Codigo = "007", Empleado = "RICARDO MANUEL TORRES JIMENEZ", Fecha = DateTime.Now.AddDays(-6), Monto = 33500.00m },
        new PartidaItem { Codigo = "008", Empleado = "PATRICIA EUGENIA MORALES RUIZ", Fecha = DateTime.Now.AddDays(-7), Monto = 26700.00m }
    };
    
    public class NominaItem
    {
        public int Id { get; set; }
        public string Name { get; set; } = "";
    }
    
    public class PartidaItem
    {
        public string Codigo { get; set; } = "";
        public string Empleado { get; set; } = "";
        public DateTime Fecha { get; set; }
        public decimal Monto { get; set; }
    }
    
    private void OnBuscarClick()
    {
        Console.WriteLine("Buscando partidas");
    }
    
    private void OnMoveUpClick()
    {
        Console.WriteLine("Mover arriba");
    }
    
    private void OnMoveDownClick()
    {
        Console.WriteLine("Mover abajo");
    }
    
    private void OnRefreshClick()
    {
        Console.WriteLine("Actualizando datos");
    }
    
    private void OnSettingsClick()
    {
        Console.WriteLine("Abriendo configuración");
    }
    
    private async Task HandleClose()
    {
        await JS.InvokeVoidAsync("alert", "¡Verificación de Partidas guardada!");
    }
}