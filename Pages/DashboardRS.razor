                <div class="section-title">Embudo de Selección</div>
                <canvas id="chartEmbudoRS"></canvas>
            </div>
        </div>

        <!-- Fuentes de reclutamiento -->
        <div class="col-md-6" style="display:none;">
            <div class="dashboard-card">
                <div class="section-title">Fuentes de Reclutamiento</div>
                <canvas id="chartFuentesRS"></canvas>
            </div>
        </div>

    </div>
