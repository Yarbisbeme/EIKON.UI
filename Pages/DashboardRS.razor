<div class="container-fluid">

    <!-- ===================== KPIs PRINCIPALES ===================== -->
    <div class="row g-3 mb-2">

        <div class="col-6 col-md-2">
            <div class="dashboard-card text-center">
                <div class="header">Requisiciones Activas</div>
                <div class="kpi-number kpi-warning">14</div>
                <div class="small text-muted">En proceso</div>
            </div>
        </div>

        <div class="col-6 col-md-2">
            <div class="dashboard-card text-center">
                <div class="header">Cargos Vacantes</div>
                <div class="kpi-number kpi-danger">37</div>
                <div class="small text-muted">Sin cubrir</div>
            </div>
        </div>

        <div class="col-6 col-md-2">
            <div class="dashboard-card text-center">
                <div class="header">Aplicaciones (mes)</div>
                <div class="kpi-number kpi-success">412</div>
                <div class="small text-muted">Candidatos nuevos</div>
            </div>
        </div>

        <div class="col-6 col-md-2">
            <div class="dashboard-card text-center">
                <div class="header">Tasa de Conversión</div>
                <div class="kpi-number">14%</div>
                <div class="small text-muted">Aplicado → Contratado</div>
            </div>
        </div>

        <div class="col-6 col-md-2">
            <div class="dashboard-card text-center">
                <div class="header">Tiempo Prom. Contratación</div>
                <div class="kpi-number">22 días</div>
                <div class="small text-muted">Desde solicitud</div>
            </div>
        </div>

    </div>

    <!-- ===================== GRÁFICOS ===================== -->
    <div class="row g-3 mb-3" >

        <!-- Embudo de selección -->
        <div class="col-md-6" style="display:none;">
