    <!-- ===================== MODAL RESUMEN R&S ===================== -->
    <div class="modal fade eikon-modal @(showRSResumen ? "show" : "")">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content">

                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title">Resumen Ejecutivo — R&S</h5>
                    <button class="btn-close btn-close-white" @onclick="CloseResumenRS"></button>
                </div>

                <div class="modal-body small">

                    <ul class="mb-2">
                        <li>✔ Requisiciones abiertas: <strong>14</strong>.</li>
                        <li>✔ Candidatos activos en proceso: <strong>126</strong>.</li>
                        <li>✔ Aplicaciones recibidas este mes: <strong>412</strong>.</li>
                        <li>✔ Tiempo promedio de contratación: <strong>22 días</strong>.</li>
                        <li>✔ Conversión promedio: <strong>14%</strong>.</li>
                        <li>✔ Fuente más efectiva: <strong>LinkedIn</strong>.</li>
                    </ul>

                    <p class="text-muted">
                        En producción, este panel será alimentado por Requisiciones,
                        Cargos, Aplicaciones, Tracking de Candidatos y Nómina.
                    </p>

                </div>

                <div class="modal-footer">
                    <button class="btn btn-secondary btn-sm" @onclick="CloseResumenRS">Cerrar</button>
                </div>

            </div>
        </div>

        @if (showRSResumen)
        {
            <div class="modal-backdrop fade show eikon-backdrop"></div>
        }
    </div>

</div>

