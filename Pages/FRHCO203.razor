@layout MainLayout
@page "/FRHCO203"
@using EIKON.UI.Components
@using DevExpress.Blazor
@using DevExpress.Blazor.Base
@using System.Net.Http.Json
@using System.Net.Http.Headers
@using EIKON.UI.Interfaces
@using DevExpress.AspNetCore.Reporting
@using DevExpress.XtraReports.UI
@using System.ComponentModel.DataAnnotations

@inject NavigationManager nv
@inject IJSRuntime JSRuntime

<div class="page">
    <Breadcrumb Title="FRHCO203 - Beneficios individuales" BackUrl="/dash" />
    <div class="page-header">
        <div class="page-toolbar">
            <Toolbar formulario="FRHxxx999" OnSave="HandleSave" OnClose="HandleClose" />
        </div>
    </div>
    <div class="frhco203-form">

        <!-- Número Field -->
        <div class="input" style="width:30%;">
            <label>Número</label>
            <DxTextBox @bind-Text="@Numero" NullText="Número" CssClass="numero-field">
                <Buttons>
                    <DxEditorButton IconCssClass="fi fi-rr-search" Click="@OnSearchNumero" />
                </Buttons>
            </DxTextBox>
        </div>

        <!-- Empleado -->
        <div class="input">
            <label>Empleado</label>
            <DxTextBox @bind-Text="@Empleado" NullText="Empleado" />
        </div>

        <!-- Oficina + Ubicación -->
        <div class="dual-input-row">
            <div class="input">
                <label>Oficina</label>
                <DxTextBox @bind-Text="@Oficina" NullText="Oficina" />
            </div>
            <div class="input">
                <label>Ubicación</label>
                <DxTextBox @bind-Text="@Ubicacion" NullText="Ubicación" />
            </div>
        </div>

        <!-- Cargo -->
        <div class="input">
            <label>Cargo</label>
            <DxTextBox @bind-Text="@Cargo" NullText="Cargo" />
        </div>

        <!-- Categoría Row: Categoría + Fecha Ingreso + Sueldo -->
        <div class="categoria-row">
            <div class="input">
                <label>Categoría</label>
                <DxTextBox @bind-Text="@Categoria" NullText="Categoría" />
            </div>
            <div class="input">
                <label>Fecha Ingreso</label>
                <DxDateEdit @bind-Date="@FechaIngreso" DisplayFormat="dd/MM/yyyy" NullText="dd/mm/yyyy" />
            </div>
            <div class="input">
                <label>Sueldo</label>
                <DxSpinEdit @bind-Value="@Sueldo" MinValue="0" DisplayFormat="N2" NullText="0.00" />
            </div>
        </div>

        <!-- Beneficio -->
        <div class="input">
            <label>Beneficio</label>
            <div class="search-field">
                <DxTextBox @bind-Text="@Beneficio"
                           NullText="ID requisición"
                           ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Never">
                    <Buttons>
                        <DxEditorButton IconCssClass="fi fi-rr-search"
                                        Click="@OnSearchBeneficio" />
                    </Buttons>
                </DxTextBox>
                <DxTextBox NullText="ID requisicion" />
            </div>
        </div>

        <!-- Periodicidad Row: Periodicidad + Base pago + Moneda -->
        <div class="periodicidad-row">
            <div class="input">
                <label>Periodicidad</label>
                <DxTextBox @bind-Text="@Periodicidad" NullText="Periodicidad" />
            </div>
            <div class="input">
                <label>Base pago</label>
                <DxComboBox Data="@BasePagoOpciones" @bind-Value="@BasePago" NullText="Base pago" />
            </div>
            <div class="input">
                <label>Moneda</label>
                <DxComboBox Data="@MonedaOpciones" @bind-Value="@Moneda" NullText="Moneda" />
            </div>
        </div>

        <!-- Dual Section: Left (Amounts) + Right (Dates) -->
        <div class="dual-section">
            <!-- Left Column: Amounts -->
            <div class="amounts-section">
                <div class="input">
                    <label>Cantidad</label>
                    <DxSpinEdit @bind-Value="@Cantidad" MinValue="0" DisplayFormat="N2" NullText="0.00" />
                </div>
                <div class="input">
                    <label>Monto total</label>
                    <DxSpinEdit @bind-Value="@MontoTotal" MinValue="0" DisplayFormat="N2" NullText="0.00" />
                </div>
                <div class="input">
                    <label>Paga Empresa</label>
                    <DxSpinEdit @bind-Value="@PagaEmpresa" MinValue="0" DisplayFormat="N2" NullText="0.00" />
                </div>
                <div class="input">
                    <label>Paga Empleado</label>
                    <DxSpinEdit @bind-Value="@PagaEmpleado" MinValue="0" DisplayFormat="N2" NullText="0.00" />
                </div>
            </div>

            <!-- Right Column: Dates -->
            <div class="dates-section">
                <div class="input">
                    <label>Aplica</label>
                    <div class="date-with-button">
                        <DxDateEdit @bind-Date="@AplicaFecha" DisplayFormat="dd/MM/yyyy" NullText="dd/mm/yyyy" />
                    </div>
                </div>
                <div class="input">
                    <label>Desde</label>
                    <div class="date-with-button">
                        <DxDateEdit @bind-Date="@DesdeFecha" DisplayFormat="dd/MM/yyyy" NullText="dd/mm/yyyy" />
                    </div>
                </div>
                <div class="input">
                    <label>Hasta</label>
                    <div class="date-with-button">
                        <DxDateEdit @bind-Date="@HastaFecha" DisplayFormat="dd/MM/yyyy" NullText="dd/mm/yyyy" />
                    </div>
                </div>
                <div class="checkboxes-row">
                    <DxCheckBox @bind-Checked="@EnviarEmpleado">Enviar a Empleado</DxCheckBox>
                    <DxCheckBox @bind-Checked="@MostrarHistoricos">Mostrar Historicos</DxCheckBox>
                </div>
            </div>
        </div>

        <!-- Grid -->
        <DxGrid Data="@Beneficios" CssClass="beneficios-grid" PageSize="10">
            <Columns>
                <DxGridDataColumn FieldName="Codigo" Caption="Código" Width="15%" />
                <DxGridDataColumn FieldName="Tipo" Caption="Tipo" Width="25%" />
                <DxGridDataColumn FieldName="Mensual" Caption="Mensual" Width="15%" />
                <DxGridDataColumn FieldName="Total" Caption="Total" Width="15%" />
                <DxGridDataColumn FieldName="Inicio" Caption="Inicio" Width="15%" />
                <DxGridDataColumn FieldName="Fin" Caption="Fin" Width="15%" />
            </Columns>
        </DxGrid>

        <!-- Reporte Dropdown -->
        <div class="input reporte-field">
            <label>Reporte</label>
            <DxComboBox Data="@Reportes" @bind-Value="@ReporteSeleccionado" NullText="Seleccione reporte" />
        </div>

    </div>
</div>

@code {
    // **- private string[] // **- ToolbarOptions = { "save", "close" };

    // Basic Fields
    private string Numero { get; set; } = string.Empty;
    private string Empleado { get; set; } = string.Empty;
    private string Oficina { get; set; } = string.Empty;
    private string Ubicacion { get; set; } = string.Empty;
    private string Cargo { get; set; } = string.Empty;

    // Categoría Row
    private string Categoria { get; set; } = string.Empty;
    private DateTime? FechaIngreso { get; set; }
    private decimal Sueldo { get; set; } = 0.00m;

    // Beneficio Section
    private string Beneficio { get; set; } = string.Empty;
    private string Periodicidad { get; set; } = string.Empty;
    private string BasePago { get; set; } = string.Empty;
    private string Moneda { get; set; } = string.Empty;

    // Amounts
    private decimal Cantidad { get; set; } = 0.00m;
    private decimal MontoTotal { get; set; } = 0.00m;
    private decimal PagaEmpresa { get; set; } = 0.00m;
    private decimal PagaEmpleado { get; set; } = 0.00m;

    // Dates
    private DateTime? AplicaFecha { get; set; }
    private DateTime? DesdeFecha { get; set; }
    private DateTime? HastaFecha { get; set; }

    // Checkboxes
    private bool EnviarEmpleado { get; set; } = false;
    private bool MostrarHistoricos { get; set; } = false;

    // Reporte
    private string ReporteSeleccionado { get; set; } = string.Empty;

    // Dropdown Data
    private List<string> BasePagoOpciones = new List<string> { "Salario Base", "Salario Integral", "Promedio" };
    private List<string> MonedaOpciones = new List<string> { "Colones", "Dólares", "Euros" };
    private List<string> Reportes = new List<string> { "Reporte General", "Reporte Detallado", "Reporte Individual" };

    // Grid Data
    private List<BeneficioItem> Beneficios = new List<BeneficioItem>
    {
        new BeneficioItem { Codigo = "B001", Tipo = "Seguro Médico", Mensual = "5000.00", Total = "60000.00", Inicio = "01/01/2024", Fin = "31/12/2024" },
        new BeneficioItem { Codigo = "B002", Tipo = "Bono Alimentación", Mensual = "2000.00", Total = "24000.00", Inicio = "01/01/2024", Fin = "31/12/2024" }
    };

    // Event Handlers
    private void OnSearchNumero() { }
    private void OnSearchBeneficio() { }
    private void OnAplicaCalendar() { }
    private void OnDesdeCalendar() { }
    private void OnHastaCalendar() { }
    private void HandleSave() { }
    private void HandleClose() { nv.NavigateTo("/dash"); }

    public class BeneficioItem
    {
        public string Codigo { get; set; } = string.Empty;
        public string Tipo { get; set; } = string.Empty;
        public string Mensual { get; set; } = string.Empty;
        public string Total { get; set; } = string.Empty;
        public string Inicio { get; set; } = string.Empty;
        public string Fin { get; set; } = string.Empty;
    }
}
