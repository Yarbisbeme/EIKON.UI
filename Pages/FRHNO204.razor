@page "/FRHNO204"

@using EIKON.UI.Components
@using DevExpress.Blazor
@using System.Net.Http.Json
@using System.Net.Http.Headers
@using EIKON.UI.Interfaces
@using DevExpress.AspNetCore.Reporting
@using DevExpress.XtraReports.UI
@using System.ComponentModel.DataAnnotations

@layout MainLayout
@inject HttpClient HttpClient
@inject EIKON.UI.Services.EikonDataServices api
@inject EIKON.UI.Services.AuthenticationService auth
@inject NavigationManager nv
@inject IJSRuntime JS

<div class="page">
    <Breadcrumb Title="Verificación de Partidas" BackUrl="/dash" />
    
    <div class="page-header">
        <div class="page-toolbar">
            <Toolbar formulario="FRHNO204" OnClose="HandleClose" />
        </div>
    </div>

    <div class="form-container">
        <!-- Sección Superior de Campos -->
        <div class="top-section">
            <!-- Primera Fila -->
            <div class="form-row three-columns">
                <div class="input-field">
                    <label>Nómina a verificar</label>
                    <DxComboBox Data="@NominasList"
                                @bind-Value="@NominaSeleccionada"
                                NullText="Seleccionar nómina"
                               TextFieldName="WbDescri" 
                               ValueFieldName="WbCodigo" />
                </div>
                <div class="input-field">
                    <label>Año Fiscal</label>
                    <DxSpinEdit @bind-Value="@AnoFiscalValue"
                                MinValue="2000"
                                MaxValue="2099"
                                ReadOnly/>
                </div>
            </div>

            <!-- Segunda Fila -->
            

            <!-- Tercera Fila - Campos en tres columnas -->
            <div class="form-row three-columns">
                <div class="input-field">
                    <label>Efectividad</label>
                    <DxDateEdit @bind-Date="@EfectividadValue" 
                               NullText="dd/mm/yyyy"
                               ReadOnly/>
                </div>
                <div class="input-field">
                    <label>Al</label>
                    <DxDateEdit @bind-Date="@AlValue" 
                               NullText="dd/mm/yyyy"
                                ReadOnly />
                </div>
                <div class="input-field">
                    <label>Corte</label>
                    <DxDateEdit @bind-Date="@CorteValue" 
                               NullText="dd/mm/yyyy"
                                ReadOnly />
                </div>
            </div>

            <!-- Cuarta Fila - Comentario -->
            <div class="form-row">
                <div class="input-field wide">
                    <label>Comentario</label>
                    <DxTextBox @bind-Text="@ComentarioValue" ReadOnly />
                </div>
            </div>
        </div>

        <!-- Sección Principal del Grid -->
        <div class="grid-section">
            <!-- Toolbar del Grid -->
            <div class="grid-toolbar">
                <div class="toolbar-left">
                    <DxCheckBox @bind-Checked="@SelectAllRows" 
                               CssClass="select-all-checkbox" />
                </div>
                <div class="toolbar-center">
                    <DxButton Text="Buscar" 
                             CssClass="btn-sm primary-btn" 
                             Click="@OnBuscarClick" />
                </div>
                <div class="toolbar-right">
                    <DxButton IconCssClass="fi fi-rr-angle-up" 
                             CssClass="icon-btn secondary-btn" 
                             Click="@OnMoveUpClick" />
                    <DxButton IconCssClass="fi fi-rr-angle-down" 
                             CssClass="icon-btn secondary-btn" 
                             Click="@OnMoveDownClick" />
                </div>
            </div>

            <!-- Grid Principal -->
            <DxGrid @ref="Grid" Data="@Partida"
                    PageSize="10"
                    ColumnResizeMode="GridColumnResizeMode.NextColumn"
                    TextWrapEnabled="false"
                    CssClass="partida-grid"
                    PagerVisible="true"
                    ShowGroupPanel="false"
                    KeyFieldName="Maenume"
                    AllowSelectRowByClick="true"
                    AutoCollapseDetailRow="true">
                <Columns>
                    <DxGridSelectionColumn Width="5%" />
                    <DxGridDataColumn FieldName="Maenume" Caption="Código Empleado" Width="15%" />
                    <DxGridDataColumn Caption="Nombre" FieldName="Maenume" Width="50%">
                        <EditSettings>
                            <DxComboBoxSettings Data="empleados"
                                                ValueFieldName="Maenume"
                                                TextFieldName="Maenomb">
                                
                            </DxComboBoxSettings>
                        </EditSettings>
                    </DxGridDataColumn>
                    <DxGridDataColumn FieldName="FechaTran" Caption="Fecha" Width="15%" 
                                     DisplayFormat="dd/MM/yyyy" />
                    <DxGridDataColumn FieldName="MontoQue" Caption="Monto" Width="15%"
                                      DisplayFormat="C2" TextAlignment="GridTextAlignment.Right" CaptionAlignment="GridTextAlignment.Right" />
                </Columns>
                <DetailRowTemplate >
                    <FRHNO204Det frhwe="(Frhwe010Dto)context.DataItem" />
                   @*  <DxGrid Data="@PartidaDet"
                            PageSize="5"
                            KeyFieldName="Maenume"
                            ShowGroupPanel="false"
                            CssClass="detalle-grid">

                        <Columns>
                            <DxGridDataColumn FieldName="WcCodigo" Caption="Código" Width="20%" />
                            <DxGridDataColumn FieldName="Descripcion" Caption="Transacción" Width="50%" />
                            <DxGridDataColumn FieldName="WvCantida"
                                              Caption="Cantidad"
                                              Width="15%"
                                              TextAlignment="GridTextAlignment.Right" />
                            <DxGridDataColumn FieldName="WpMonto"
                                              Caption="Monto"
                                              Width="15%"
                                              DisplayFormat="C2"
                                              TextAlignment="GridTextAlignment.Right" />
                        </Columns>

                    </DxGrid> *@
                </DetailRowTemplate>
            </DxGrid>
        </div>

        <!-- Sección Inferior de Opciones y Reporte -->
        <div class="bottom-section">
            <!-- Opciones con Checkboxes -->
            <div class="options-section">
                <div class="checkbox-group">
                    <DxCheckBox @bind-Checked="@InformacionAgrupadaOption">
                        Información Agrupada
                    </DxCheckBox>
                    <DxCheckBox @bind-Checked="@VolantesNegativosOption">
                        Volantes Negativos
                    </DxCheckBox>
                    <DxCheckBox @bind-Checked="@SoloVariacionesOption">
                        Solo Variaciones
                    </DxCheckBox>
                    <DxCheckBox @bind-Checked="@VolantesEnCeroOption">
                        Volantes en cero
                    </DxCheckBox>
                    <DxCheckBox @bind-Checked="@InformablesDeControlOption">
                        Informables de Control
                    </DxCheckBox>
                    <DxCheckBox @bind-Checked="@MostrarInvisiblesOption">
                        Mostrar Invisibles
                    </DxCheckBox>
                </div>

                <!-- Botones de acción -->
                <div class="action-buttons">
                    <DxButton IconCssClass="fi fi-rr-refresh" 
                             CssClass="icon-btn success-btn" 
                             Click="@OnRefreshClick" />
                    <DxButton IconCssClass="fi fi-rr-settings" 
                             CssClass="icon-btn info-btn" 
                             Click="@OnSettingsClick" />
                </div>
            </div>

            <!-- Sección de Reporte -->
            <div class="report-section">
                <div class="input-field wide">
                    <DxTextBox @bind-Text="@ReporteValue" 
                              NullText="Reporte" />
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* Container principal */
    .form-container {
        display: flex;
        flex-direction: column;
        gap: 20px;
        margin-top: 10px;
    }

    /* Sección superior */
    .top-section {
        display: flex;
        flex-direction: column;
        gap: 15px;
        border: 1px solid transparent;
        border-radius: 8px;
    }

    /* Form rows */
    .form-row {
        display: flex;
        gap: 20px;
        align-items: flex-end;
    }

    .form-row.three-columns {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: 20px;
    }

    /* Input fields */
    .input-field {
        display: flex;
        flex-direction: column;
        gap: 5px;
        flex: 1;
    }

    .input-field.wide {
        flex: 2;
    }

    .input-field label {
        font-weight: normal;
        color: #333;
        font-size: 14px;
    }

    /* Sección del grid */
    .grid-section {
        border: 1px solid #e0e0e0;
        border-radius: 8px;
        padding: 0;
        overflow: hidden;
    }

    /* Toolbar del grid */
    .grid-toolbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 15px 20px;
        background-color: #f8f9fa;
        border-bottom: 1px solid #e0e0e0;
    }

    .toolbar-left,
    .toolbar-center,
    .toolbar-right {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .toolbar-center {
        flex: 1;
        justify-content: center;
    }

    .select-all-checkbox {
        margin: 0;
    }

    /* Grid principal */
    .partida-grid {
        border: none;
        border-radius: 0;
    }

    /* Sección inferior */
    .bottom-section {
        display: flex;
        flex-direction: column;
        gap: 15px;
    }

    /* Sección de opciones */
    .options-section {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        padding: 20px;
        border: 1px solid #e0e0e0;
        border-radius: 8px;
        gap: 20px;
    }

    .checkbox-group {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 15px;
        flex: 1;
    }

    .action-buttons {
        display: flex;
        gap: 8px;
        flex: 0 0 auto;
    }

    /* Sección de reporte */
    .report-section {
        padding: 20px;
        border: 1px solid #e0e0e0;
        border-radius: 8px;
    }

    /* Botones */
    .icon-btn {
        width: 32px;
        height: 32px;
        min-width: 32px;
        padding: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 6px;
    }

    .btn-sm {
        padding: 8px 16px;
        font-size: 13px;
        border-radius: 4px;
        font-weight: 500;
    }

    .primary-btn {
        background-color: #dc3545;
        border-color: #dc3545;
        color: white;
    }

    .primary-btn:hover {
        background-color: #c82333;
        border-color: #bd2130;
    }

    .secondary-btn {
        background-color: #6c757d;
        border-color: #6c757d;
        color: white;
    }

    .secondary-btn:hover {
        background-color: #5a6268;
        border-color: #545b62;
    }

    .success-btn {
        background-color: #28a745;
        border-color: #28a745;
        color: white;
    }

    .success-btn:hover {
        background-color: #218838;
        border-color: #1e7e34;
    }

    .info-btn {
        background-color: #17a2b8;
        border-color: #17a2b8;
        color: white;
    }

    .info-btn:hover {
        background-color: #138496;
        border-color: #117a8b;
    }

    /* DevExpress Components */
    .dx-textbox,
    .dx-combobox,
    .dx-date-edit,
    .dx-spin-edit {
        border-radius: 6px !important;
    }

    .dx-textbox-container,
    .dx-combobox-container,
    .dx-date-edit-container,
    .dx-spin-edit-container {
        border: 1px solid #ced4da !important;
        border-radius: 6px !important;
    }

    .dx-textbox-container:focus-within,
    .dx-combobox-container:focus-within,
    .dx-date-edit-container:focus-within,
    .dx-spin-edit-container:focus-within {
        border-color: #007bff !important;
        box-shadow: 0 0 0 0.2rem rgba(0, 123, 255, 0.25) !important;
    }

    /* DxGrid */
    /* Fondo general del grid de detalle */
    .detalle-grid {
        background-color: #f5f7fa;
        border-radius: 6px;
        padding: 8px;
    }

        /* Cabecera */
        .detalle-grid .dxbl-grid-header {
            background-color: #e3e7ed;
            font-weight: 600;
        }

        /* Filas */
        .detalle-grid .dxbl-grid-row {
            background-color: #f5f7fa;
        }

            /* Hover */
            .detalle-grid .dxbl-grid-row:hover {
                background-color: #eaf0ff;
            }

    /* Responsive Design */
    media (max-width: 768px) {
        .top-section,
        .options-section,
        .report-section {
            padding: 15px;
        }

        .form-row {
            flex-direction: column;
            gap: 15px;
        }

        .form-row.three-columns {
            grid-template-columns: 1fr;
        }

        .grid-toolbar {
            flex-direction: column;
            gap: 15px;
            align-items: stretch;
        }

        .toolbar-left,
        .toolbar-center,
        .toolbar-right {
            justify-content: center;
        }

        .checkbox-group {
            grid-template-columns: 1fr;
            gap: 10px;
        }

        .options-section {
            flex-direction: column;
            align-items: stretch;
        }

        .action-buttons {
            justify-content: center;
        }
    }

   media (max-width: 480px) {
        .form-container {
            gap: 15px;
        }

        .top-section,
        .options-section,
        .report-section {
            padding: 15px;
        }

        .grid-toolbar {
            padding: 10px 15px;
        }

        .icon-btn {
            width: 28px;
            height: 28px;
            min-width: 28px;
        }

        .btn-sm {
            padding: 6px 12px;
            font-size: 12px;
        }
    }
</style>

