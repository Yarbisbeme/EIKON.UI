    private async Task CargarPeriodos()
    {
        if (Token != null)
        {

            ApiBaseUrl = api.GetApiBaseUrl();
            HttpClient.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", Token);
            if (NominaSeleccionada != null)
            {
                Partida = await api.Frhwe010DtoGetByEmpresaNomina(NominaSeleccionada.EmEmpresa, NominaSeleccionada.WbCodigo, Token);
                var ano = (int)Partida.First().WgAnoRef;
                var sec = (int)Partida.First().WgSecuen;
                //periodos = await api.Trhwg010DtoGetByEmpresa(NominaSeleccionada.EmEmpresa,  Token);
                //PartidaDet = await api.Frhwd010DtoGetByEmpresaNomina(NominaSeleccionada.EmEmpresa, NominaSeleccionada.WbCodigo, Token);

                periodos = await api.Trhwg010PorEmpresa(NominaSeleccionada.EmEmpresa, NominaSeleccionada.WbCodigo, ano, Token); //.Where(p => p.WsEstatus.StartsWith("E") || p.WsEstatus.StartsWith("P"));
                periodos = periodos.Where(p => p.WgSecuen==sec).ToList();
                empleados = await api.Frhma010DtoGetByEmpresa(NominaSeleccionada.EmEmpresa, Token);
                AnoFiscalValue = ano;
                EfectividadValue = periodos.Min(p => p.WgInicial).DateTime;
                AlValue = periodos.Max(p => p.WgFinalF).DateTime;
                CorteValue = periodos.Max(p => p.WgFechaC).DateTime;

            }
            
            
            StateHasChanged();
            
        }

    }
    void AutoCollapseDetailRow_Changed(bool newValue)
    {
       
        if (newValue)
        {
            Grid.BeginUpdate();
            Grid.CollapseAllDetailRows();
            Grid.ExpandDetailRow(0);
            Grid.EndUpdate();
        }
    }
