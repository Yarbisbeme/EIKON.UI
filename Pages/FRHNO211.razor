@page "/FRHNO211"

@using EIKON.UI.Components
@using DevExpress.Blazor
@using System.Net.Http.Json
@using System.Net.Http.Headers
@using EIKON.UI.Interfaces
@using DevExpress.AspNetCore.Reporting
@using DevExpress.XtraReports.UI
@using System.ComponentModel.DataAnnotations

@layout MainLayout
@inject HttpClient HttpClient
@inject EIKON.UI.Services.EikonDataServices api
@inject EIKON.UI.Services.AuthenticationService auth
@inject NavigationManager nv
@inject IJSRuntime JS

<div class="page">
    <Breadcrumb Title="FRHNO211 - Publicar Mensajes en Volantes" BackUrl="/dash" />
    
    <div class="page-header">
        <div class="page-toolbar">
            <Toolbar formulario="FRHxxx999" OnClose="HandleClose" />
        </div>
    </div>

    <div class="form-container">
        <!-- Primera Fila -->
        <div class="form-row">
            <div class="input-field">
                <label>Número</label>
                <DxTextBox @bind-Text="@NumeroValue"
                           ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Never">
                    <Buttons>
                        <DxEditorButton IconCssClass="fi fi-rr-search" 
                                       Click="@OnSearchNumeroClick" />
                    </Buttons>
                </DxTextBox>
            </div>
        </div>

        <!-- Segunda Fila -->
        <div class="form-row">
            <div class="input-field wide">
                <label>Empleado</label>
                <DxComboBox Data="@EmpleadosList" 
                           @bind-Value="@SelectedEmpleado" 
                           NullText="Seleccionar empleado"
                           TextFieldName="Name" 
                           ValueFieldName="Id" />
            </div>
        </div>

        <!-- Tercera Fila -->
        <div class="form-row">
            <div class="input-field wide">
                <label>Nómina</label>
                <DxComboBox Data="@NominasList" 
                           @bind-Value="@SelectedNomina" 
                           NullText="Seleccionar nómina"
                           TextFieldName="Name" 
                           ValueFieldName="Id" />
            </div>
        </div>

        <!-- Cuarta Fila -->
        <div class="form-row">
            <div class="input-field">
                <label>No Mensaje</label>
                <DxSpinEdit @bind-Value="@NoMensajeValue" 
                           MinValue="0" 
                           MaxValue="9999" />
            </div>
            <div class="input-field">
                <label>Períodos</label>
                <DxSpinEdit @bind-Value="@PeriodosValue" 
                           MinValue="0" 
                           MaxValue="999" />
            </div>
            <div class="input-field">
                <label>Año</label>
                <DxSpinEdit @bind-Value="@AnoValue" 
                           MinValue="2020" 
                           MaxValue="2030" />
            </div>
        </div>

        <!-- Quinta Fila - Mensaje -->
        <div class="form-row">
            <div class="input-field message-field">
                <label>Mensaje a publicar en volante</label>
                <DxMemo @bind-Value="@MensajeValue" 
                       Rows="6" 
                       NullText="Escriba su mensaje aquí..." />
            </div>
        </div>

        <!-- Grid Section -->
        <div class="grid-section">
            <DxGrid Data="@MensajesData" CssClass="custom-grid">
                <Columns>
                    <DxGridDataColumn FieldName="Codigo" Caption="Código" Width="100%" />
                    <DxGridDataColumn FieldName="Ano" Caption="Año" Width="100%" />
                    <DxGridDataColumn FieldName="Nomina" Caption="Nómina" Width="100%" />
                    <DxGridDataColumn FieldName="Periodos" Caption="Períodos" Width="100%" />
                </Columns>
            </DxGrid>
        </div>
    </div>
</div>

@code {
    // **- private string[] // **- ToolbarOptions = { "add", "save", "remove", "leave" };
    
    // Campos del formulario
    private string NumeroValue { get; set; } = "";
    private int? SelectedEmpleado { get; set; }
    private int? SelectedNomina { get; set; }
    private int NoMensajeValue { get; set; } = 0;
    private int PeriodosValue { get; set; } = 0;
    private int AnoValue { get; set; } = DateTime.Now.Year;
    private string MensajeValue { get; set; } = "";

    // Listas de datos
    private List<OptionItem> EmpleadosList = new List<OptionItem>
    {
        new OptionItem { Id = 1, Name = "Todos los empleados" },
        new OptionItem { Id = 2, Name = "Juan Pérez" },
        new OptionItem { Id = 3, Name = "María González" },
        new OptionItem { Id = 4, Name = "Carlos Rodríguez" }
    };

    private List<OptionItem> NominasList = new List<OptionItem>
    {
        new OptionItem { Id = 1, Name = "Nómina General" },
        new OptionItem { Id = 2, Name = "Nómina Especial" },
        new OptionItem { Id = 3, Name = "Nómina Quincenal" }
    };

    private List<MensajeItem> MensajesData = new List<MensajeItem>
    {
        new MensajeItem { Codigo = "MSG001", Ano = 2024, Nomina = "Nómina General", Periodos = "12" },
        new MensajeItem { Codigo = "MSG002", Ano = 2024, Nomina = "Nómina Especial", Periodos = "6" },
        new MensajeItem { Codigo = "MSG003", Ano = 2023, Nomina = "Nómina Quincenal", Periodos = "24" }
    };

    public class OptionItem
    {
        public int Id { get; set; }
        public string Name { get; set; } = "";
    }

    public class MensajeItem
    {
        public string Codigo { get; set; } = "";
        public int Ano { get; set; }
        public string Nomina { get; set; } = "";
        public string Periodos { get; set; } = "";
    }
    
    // Event handlers
    private void OnSearchNumeroClick() => Console.WriteLine("Buscar número");
    
    private async Task HandleClose()
    {
        await JS.InvokeVoidAsync("alert", "¡Mensaje en volante guardado!");
    }
}

<style>
    /* Container principal */
    .form-container {
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    /* Form rows */
    .form-row {
        display: flex;
        gap: 20px;
        align-items: flex-end;
        min-height: 60px;
    }

    /* Input fields */
    .input-field {
        display: flex;
        flex-direction: column;
        gap: 6px;
        flex: 1;
        min-width: 150px;
    }

    .input-field.wide {
        flex: 3;
    }

    .input-field.message-field {
        flex: 1;
        min-height: auto;
    }

    .input-field label {
        font-weight: 500;
        color: #333;
        font-size: 13px;
        margin-bottom: 5px;
    }

    /* Grid section */
    .grid-section {
        margin-top: 20px;
        border: 1px solid #dee2e6;
        border-radius: 8px;
        overflow: hidden;
    }

    .custom-grid {
        border: none;
        border-radius: 0;
    }

    /* DevExpress Components */
    .dx-textbox,
    .dx-combobox,
    .dx-spin-edit,
    .dx-memo {
        border-radius: 6px !important;
    }

    .dx-textbox-container,
    .dx-combobox-container,
    .dx-spin-edit-container,
    .dx-memo-container {
        border: 1px solid #ced4da !important;
        border-radius: 6px !important;
        transition: all 0.3s ease !important;
    }

    .dx-textbox-container:focus-within,
    .dx-combobox-container:focus-within,
    .dx-spin-edit-container:focus-within,
    .dx-memo-container:focus-within {
        border-color: #dc3545 !important;
        box-shadow: 0 0 0 0.2rem rgba(220, 53, 69, 0.25) !important;
    }

    /* Memo específico */
    .dx-memo-container {
        min-height: 150px !important;
    }

    /* Grid específico */
    .dx-grid-header-content {
        background-color: #f8f9fa !important;
        font-weight: 600 !important;
        color: #333 !important;
    }

    .dx-grid-data-row:nth-child(even) {
        background-color: #f8f9fa !important;
    }

    .dx-grid-data-row:hover {
        background-color: rgba(220, 53, 69, 0.05) !important;
    }

    /* Responsive Design */
    media (max-width: 1024px) {
        .form-row {
            flex-wrap: wrap;
            gap: 15px;
        }
    }

    media (max-width: 768px) {
        .form-container {
            padding: 15px;
        }

        .form-row {
            flex-direction: column;
            gap: 15px;
            align-items: stretch;
            min-height: auto;
        }

        .input-field {
            min-width: auto;
        }

        .input-field.wide {
            flex: 1;
        }
    }

    media (max-width: 480px) {
        .form-container {
            gap: 15px;
            padding: 15px;
        }

        .form-row {
            gap: 12px;
        }
    }
</style>