@layout MainLayout
@page "/FRHMA524"
@using EIKON.UI.Components
@using DevExpress.Blazor
@using DevExpress.Blazor.Base
@using System.Net.Http.Json
@using System.Net.Http.Headers
@using EIKON.UI.Interfaces
@using DevExpress.AspNetCore.Reporting
@using DevExpress.XtraReports.UI
@using System.ComponentModel.DataAnnotations

@inject NavigationManager nv
@inject IJSRuntime JSRuntime

<div class="page">
    <Breadcrumb Title="FRHMA524 - Días feriados y Recordatorios" BackUrl="/dash" />
    <div class="page-header">
        <div class="page-toolbar">
            <Toolbar formulario="FRHxxx999" OnSave="HandleSave" OnClose="HandleClose" />
        </div>
    </div>
    <div class="frhma524-form">

        <!-- Código -->
        <div class="input codigo-field">
            <label>Código</label>
            <DxTextBox @bind-Text="@Codigo">
                <Buttons>
                    <DxEditorButton IconCssClass="fi fi-rr-search" Click="@OnSearchCodigo" />
                </Buttons>
            </DxTextBox>
        </div>

        <!-- Descripción -->
        <div class="input">
            <label>Descripción</label>
            <DxTextBox @bind-Text="@Descripcion" NullText="Descripción" />
        </div>

        <!-- Fila: Fecha + Checkboxes -->
        <div class="fecha-row">
            <div class="input fecha-field">
                <label>Fecha</label>
                <DxDateEdit @bind-Date="@Fecha" DisplayFormat="dd/MM/yyyy" NullText="dd/MM/yyyy" />
            </div>

            <div class="checkboxes-group">
                <DxCheckBox @bind-Checked="@Feriado">Feriado</DxCheckBox>
                <DxCheckBox @bind-Checked="@Recordatorio">Recordatorio</DxCheckBox>
                <DxCheckBox @bind-Checked="@Recurrente">Recurrente</DxCheckBox>
            </div>
        </div>

        <!-- Comentario -->
        <div class="input">
            <label>Comentario</label>
            <DxMemo @bind-Text="@Comentario" Rows="6" NullText="Comentario" />
        </div>

    </div>
</div>

@code {
    // **- private string[] // **- ToolbarOptions = { "save", "close" };

    // Fields
    private string Codigo { get; set; } = string.Empty;
    private string Descripcion { get; set; } = string.Empty;
    private DateTime? Fecha { get; set; } = null;
    private bool Feriado { get; set; } = false;
    private bool Recordatorio { get; set; } = false;
    private bool Recurrente { get; set; } = false;
    private string Comentario { get; set; } = string.Empty;

    private void OnSearchCodigo()
    {
        // Implementar búsqueda de código
    }

    private void HandleSave()
    {
        // Implementar guardado
    }

    private void HandleClose()
    {
        nv.NavigateTo("/dash");
    }
}
