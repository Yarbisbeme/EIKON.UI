@page "/wfrhue000"

@using DevExpress.Blazor
@using System.Net.Http.Json
@using System.Net.Http.Headers
@using EIKON.UI.Interfaces

@inject HttpClient HttpClient
@inject EIKON.UI.Services.EikonDataServices api

<PageTitle>Opciones Menu</PageTitle>
<h1>Mantenimiento frhue000...</h1>

@if (data == null)
{
    <p><em>Loading...</em></p>
}
else
{
    <DxGrid Data="@data" @ref="MyGrid" 
            CssClass="mw-1100"
            EditModelSaving="OnEditModelSaving"
                EditMode="GridEditMode.EditRow"
            DataItemDeleting="OnDataItemDeleting"
            ShowFilterRow="true" FilterRowCondition="GridFilterRowCondition.Equals"
            >
        <Columns>
            <DxGridCommandColumn Width="160px" VisibleIndex="1">
                <HeaderTemplate>
                    <a class="text-primary" @onclick="@(() => MyGrid.StartEditNewRowAsync())" style="text-decoration: none;" href="javascript:void(0);"><i class="fi fi-rr-plus"></i></a>
                </HeaderTemplate>
                <CellDisplayTemplate>
                    <a class="text-primary" @onclick="@(() => MyGrid.StartEditRowAsync(context.VisibleIndex))" style="text-decoration: none;" href="javascript:void(0);"><i class="fi fi-rr-edit"></i></a>
                    <a class="text-primary" @onclick="@(() => MyGrid.ShowDataItemDeleteConfirmation(context.DataItem))" style="text-decoration: none;" href="javascript:void(0);"><i class="fi fi-rr-trash"></i></a>
                </CellDisplayTemplate>
               </DxGridCommandColumn>

            <DxGridDataColumn Caption="Usuarios" FieldName="PasUserid" Width="260px" VisibleIndex="2">
                <EditSettings>
                    <DxComboBoxSettings Data="usuarios"
                                        ValueFieldName="PasUserid"
                                        TextFieldName="Pasnomb"
                                        FilteringMode="DataGridFilteringMode.Contains"
                                        ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                                        EditFormat="{1} {2}">
                        <Columns>
                            <DxListEditorColumn FieldName="PasUserid" Caption="Código" />
                            <DxListEditorColumn FieldName="Pasnomb" Caption="Descripción" />
                            <DxListEditorColumn FieldName="Maenume" Caption="EikonId" Width="60px" />
                        </Columns>
                    </DxComboBoxSettings>
                </EditSettings>
            </DxGridDataColumn>

            <DxGridDataColumn Caption="Empresa" FieldName="EmCodigo" Width="260px" VisibleIndex="2" >
            <EditSettings>
                    <DxComboBoxSettings Data="empresas"
                                        ValueFieldName="EmCodigo"
                                        TextFieldName="EmDescri"
                                        FilteringMode="DataGridFilteringMode.Contains"
                                        ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                                        EditFormat="{1} {2}">
                                        <Columns>
                            <DxListEditorColumn FieldName="EmCodigo" Caption="Código" />
                        <DxListEditorColumn FieldName="EmDescri" Caption="Descripción" />
                            <DxListEditorColumn FieldName="Status" Caption="Estatus" Width="60px"  />
                    </Columns>
                    </DxComboBoxSettings>
                </EditSettings>
            </DxGridDataColumn>
            <DxGridDataColumn FieldName="PaCodigo" Caption="Perfiles" Width="300px" VisibleIndex="3"  >
                <EditSettings>
                    <DxComboBoxSettings Data="perfiles"
                                        ValueFieldName="PaCodigo"
                                        TextFieldName="PaDescri"
                                        FilteringMode="DataGridFilteringMode.Contains"
                                        ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto" 
                                        EditFormat="{0} {1}">
                        <Columns>
                            <DxListEditorColumn FieldName="PaCodigo" Caption="Código" />
                            <DxListEditorColumn FieldName="PaDescri" Caption="Descripción" />
                            <DxListEditorColumn FieldName="PaTipo" Caption="Tipo" Width="60px" />
                        </Columns>
                    </DxComboBoxSettings>
                </EditSettings>
            </DxGridDataColumn>
           @*  <DxGridDataColumn Caption="Update" FieldName="MpUpdate" VisibleIndex="4" />
            <DxGridDataColumn Caption="Delete" FieldName="MpDelete" VisibleIndex="5" />
            <DxGridDataColumn Caption="Add" FieldName="MpAddFor" VisibleIndex="6" />
            <DxGridDataColumn Caption="Read" FieldName="MpReadFo" VisibleIndex="7" />
            <DxGridDataColumn Caption="Print" FieldName="MpPrint" VisibleIndex="8" />
            <DxGridDataColumn Caption="Mail" FieldName="MpMail" VisibleIndex="9" />
            <DxGridDataColumn Caption="Audit" FieldName="MpAudit" VisibleIndex="10" FilterRowEditorVisible="false" /> *@

        </Columns>
    </DxGrid>
    
}

<h3 class=""></h3>

@code {
    public bool IsModalVisible { get; set; }
    public string Token { get; set; } = "";
    public string ApiBaseUrl { get; set; } ="";
    private bool IsNewRecord = false;
    private void ConfirmToken()
    {
        // Aquí puedes hacer algo con el token, por ejemplo, almacenarlo en una variable global o enviarlo a un servicio
        IsModalVisible = false;
    }

    private void Cancel()
    {
        IsModalVisible = false;
    }
    private void OpenModal()
    {
        IsModalVisible = true;
    }

    DxGrid? MyGrid;
    DateTime DateTimeValue { get; set; } = DateTime.Now;
    private bool IsChecked { get; set; } = false;
    string GetText()
    {
        if (IsChecked) return "Activo";
        else return "Inactivo";
    }
    private List<Frhue000Dto> data;
    private List<Trhem000> empresas { get; set; } = new List<Trhem000>();
    private List<Trhpa000Dto> perfiles { get; set; } = new List<Trhpa000Dto>();
    private List<Trhps000Dto> usuarios { get; set; } = new List<Trhps000Dto>();
    private string SelectedCategoryId { get; set; }
    private Frhue000Dto SelectedItem { get; set; }
    protected override async Task OnInitializedAsync()
    {

        // EikonDataServices eikonDataServices =  null;
        if (Token == "")
        {
            api.ObtenerTokenAsync();
            Token = api.GetToken();
        }
        ApiBaseUrl = api.GetApiBaseUrl();
        HttpClient.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", Token);
        //  data = await HttpClient.GetFromJsonAsync<List<Models.Trhem000>>(ApiBaseUrl + "Trhem000");
        //   empresas = await HttpClient.GetFromJsonAsync<List<Models.Trhem000>>("http://localhost:8081/api/Trhem000");
        data = await HttpClient.GetFromJsonAsync<List<Frhue000Dto>>(ApiBaseUrl + "frhue000");
        usuarios = await HttpClient.GetFromJsonAsync<List<Trhps000Dto>>(ApiBaseUrl + "Trhps000");
        perfiles = await HttpClient.GetFromJsonAsync<List<Trhpa000Dto>>(ApiBaseUrl + "Trhpa000");
        empresas = await HttpClient.GetFromJsonAsync<List<Trhem000>>(ApiBaseUrl + "Trhem000");
    }
    async Task OnDataItemDeleting(GridDataItemDeletingEventArgs e)
    {
        var codigo = ((Frhue000Dto)e.DataItem).IdentityColumn;
        await HttpClient.DeleteAsync(ApiBaseUrl + "frhue000/" + ((Frhue000Dto)e.DataItem).IdentityColumn);
        data = await HttpClient.GetFromJsonAsync<List<Frhue000Dto>>(ApiBaseUrl + "frhue000");
    }
    async Task OnEditModelSaving(GridEditModelSavingEventArgs e)
    {
        if (e.IsNew)
        {
            Frhue000Dto newCategory = new Frhue000Dto();
            SetNewValues(newCategory, (Frhue000Dto)e.EditModel);
            //await HttpClient.PostAsJsonAsync<DTOs.frhue000Dto>(ApiBaseUrl + "frhue000/", newCategory);
            HttpResponseMessage response = await HttpClient.PostAsJsonAsync<Frhue000Dto>(ApiBaseUrl + "frhue000/", newCategory);

            // Verifica si la solicitud fue exitosa
            if (response.IsSuccessStatusCode)
            {
                // La solicitud fue exitosa. Puedes leer el contenido si es necesario.
                string responseContent = await response.Content.ReadAsStringAsync();
                // Puedes deserializar el contenido si es un JSON
                // var result = JsonConvert.DeserializeObject<YourResponseModel>(responseContent);
            }
            else
            {
                // La solicitud falló. Puedes manejar el error aquí.
                string errorContent = await response.Content.ReadAsStringAsync();
                Console.WriteLine($"Error: {response.StatusCode} - {errorContent}");
            }

            data = await HttpClient.GetFromJsonAsync<List<Frhue000Dto>>(ApiBaseUrl + "frhue000");
        }
        else
        {
            var dataItem = (Frhue000Dto)e.DataItem;
            SetEditValues(dataItem, (Frhue000Dto)e.EditModel);
            HttpResponseMessage response = await HttpClient.PutAsJsonAsync(ApiBaseUrl + "frhue000/" + dataItem.IdentityColumn, dataItem);
            if (response.IsSuccessStatusCode)
            {
                // La solicitud fue exitosa. Puedes leer el contenido si es necesario.
                string responseContent = await response.Content.ReadAsStringAsync();
                // Puedes deserializar el contenido si es un JSON
                // var result = JsonConvert.DeserializeObject<YourResponseModel>(responseContent);
            }
            else
            {
                // La solicitud falló. Puedes manejar el error aquí.
                string errorContent = await response.Content.ReadAsStringAsync();
                Console.WriteLine($"Error: {response.StatusCode} - {errorContent}");
            }

            data = await HttpClient.GetFromJsonAsync<List<Frhue000Dto>>(ApiBaseUrl + "frhue000");
        }

        void SetNewValues(Frhue000Dto dataItem, Frhue000Dto newValues)
        {
            dataItem.PasUserid = newValues.PasUserid;

            dataItem.PaCodigo = newValues.PaCodigo; 

            dataItem.EmCodigo = newValues.EmCodigo;
            
            dataItem.CreatedBy = "Eikon";
            dataItem.CreatedOn = DateTime.Today.Date;
            dataItem.ChangedBy = " ";
            dataItem.ChangedOn = DateTime.Today.Date;

        }
        void SetEditValues(Frhue000Dto dataItem, Frhue000Dto newValues)
        {
            dataItem.PasUserid = newValues.PasUserid;
            dataItem.EmCodigo = newValues.EmCodigo;
            dataItem.ChangedBy = "EikonWeb";
            dataItem.ChangedOn = DateTime.Today.Date;
            dataItem.IdentityColumn = newValues.IdentityColumn;
            dataItem.PaCodigo = newValues.PaCodigo;
        }
    }
    

   
}



