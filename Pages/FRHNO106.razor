@page "/FRHNO106"
@inject NavigationManager nv;
@inject HttpClient HttpClient
@inject EIKON.UI.Services.EikonDataServices api
@inject EIKON.UI.Services.AuthenticationService auth

<PageTitle>Relaciones</PageTitle>

<DxTabs ActiveTabIndex="@ActiveTabIndex" ActiveTabIndexChanged="@OnActiveTabIndexChanged">
    <DxTabPage Text="Mantenimiento">
        <div class="header">
            <div style="display:flex;width:auto;gap:20px;">
                <Breadcrumb Title="Relación Beneficios" BackUrl="/dash" />
            </div>
            <Toolbar formulario="FRHNO106" OnProccess="BuscarTool" OnAdd="AgregarTool" OnSave="GuardaTool" OnRemove="EliminarTool" OnAudit="AuditTool" />
        </div>
        <br />
        <EditForm Context="WiContext" Model="@editModel">
            <DataAnnotationsValidator />
            <DxFormLayout>
                <DxFormLayoutItem Caption="Beneficio">
                    <DxComboBox @bind-Value="@editModel.BeCodigo" ValueFieldName="BeCodigo" TextFieldName="BeDescri"
                                Data="@beList" ReadOnly="@IsNewRecord" />
                </DxFormLayoutItem>
                <DxFormLayoutItem Caption="Nómina">
                    <DxComboBox @bind-Value="@editModel.WbCodigo" ValueFieldName="WbCodigo" TextFieldName="WbDescri"
                                Data="@wbList" />
                </DxFormLayoutItem>
                <DxFormLayoutItem Caption="Empleado">
                    <DxComboBox @bind-Value="@editModel.WcCodigo" ValueFieldName="WcCodigo" TextFieldName="WcDescri"
                                Data="@wcListAll" />
                </DxFormLayoutItem>
                <DxFormLayoutItem Caption="Empresa">
                    <DxComboBox @bind-Value="@editModel.WcInvisib" ValueFieldName="WcCodigo" TextFieldName="WcDescri"
                                Data="@wcInvisibList" />
                </DxFormLayoutItem>
                <DxFormLayoutItem Caption="Retroactivo">
                    <DxComboBox @bind-Value="@editModel.WcRetro" ValueFieldName="WcCodigo" TextFieldName="WcDescri"
                                Data="@wcRetroList" />
                </DxFormLayoutItem>
            </DxFormLayout>
        </EditForm>

    </DxTabPage>
    <DxTabPage Text="Consulta">
        <div class="header">
            <div style="display:flex;width:auto;gap:20px;">
                <Breadcrumb Title="Relación Beneficios" BackUrl="/dash" />
            </div>
        </div>
        <DxGrid Data="@wiList" @ref="MyGrid"
                CssClass="mw-1100"
                EditMode="GridEditMode.EditRow"
               
                ShowFilterRow="true" FilterRowCondition="GridFilterRowCondition.Equals">
            <Columns>
                <DxGridCommandColumn Width="160px" VisibleIndex="1">
                    <CellDisplayTemplate>
                        <a @onclick="@(() => ShowEditRecord((Trhwi010Dto)context.DataItem))" style="text-decoration: none;" href="javascript:void(0);"><i class="fi fi-rr-edit"></i></a>
                    </CellDisplayTemplate>
                </DxGridCommandColumn>
                <DxGridDataColumn Caption="WbCodigo" FieldName="WbCodigo" Width="80px" VisibleIndex="3" />
                <DxGridDataColumn Caption="BeCodigo" FieldName="BeCodigo" Width="300px" VisibleIndex="4" />
                <DxGridDataColumn Caption="WcCodigo" FieldName="WcCodigo" Width="300px" VisibleIndex="5" />
                <DxGridDataColumn Caption="WcInvisib" FieldName="WcInvisib" Width="300px" VisibleIndex="6" />
                <DxGridDataColumn Caption="WcRetro" FieldName="WcRetro" Width="300px" VisibleIndex="7" />
@*                 <DxGridDataColumn Caption="Puede Requizar" FieldName="GrIndReq" VisibleIndex="7" Width="130px" />
                <DxGridDataColumn Caption="Activo" FieldName="GrEstatus" VisibleIndex="8" Width="130px" /> *@
            </Columns>
            <ToolbarTemplate>
                <DxToolbar>
                    <DxToolbarItem Text="Export to XLSX" Click="ExportXlsx_Click" BeginGroup="true" />
                    <DxToolbarItem Context="itemGrx" Alignment="ToolbarItemAlignment.Right" BeginGroup="true">
                        <Template>
                            <DxCheckBox @bind-Checked="@ExportSelectedRowsOnly">Export Selected Rows Only</DxCheckBox>
                        </Template>
                    </DxToolbarItem>
                </DxToolbar>
            </ToolbarTemplate>
        </DxGrid>
    </DxTabPage>
</DxTabs>

<ConfirmDialog @ref="confirmDialog" Title="Confirmar Eliminación"
               Message="¿Seguro deseas eliminar este Grupo Ocupacional?"
               OnConfirm="OnConfirmDelete" />

<DxPopup @bind-Visible="@isPopupVisible"
         HeaderText="@popupTitle"
         ShowCloseButton="true"
         ShowFooter="true"
         Width="600px">
    <BodyTemplate Context="popupCtx">
        <DxFormLayout>
            <DxFormLayoutItem Caption="Creado por:">
                <DxTextBox @bind-Text="@editModel.CreatedBy" ReadOnly />
            </DxFormLayoutItem>
            <DxFormLayoutItem Caption="Creado el:">
                <DxDateEdit @bind-Date="@editModel.CreatedOn" ReadOnly />
            </DxFormLayoutItem>
            <DxFormLayoutItem Caption="Modificado por:">
                <DxTextBox @bind-Text="@editModel.ChangedBy" ReadOnly />
            </DxFormLayoutItem>
            <DxFormLayoutItem Caption="Modificado el:">
                <DxDateEdit @bind-Date="@editModel.ChangedOn" ReadOnly />
            </DxFormLayoutItem>
        </DxFormLayout>
    </BodyTemplate>
    <FooterTemplate>
        @*         <DxButton RenderStyle="ButtonRenderStyle.Primary"
                  Text="Guardar"
                  Click="GuardarDatos" /> *@
        <DxButton Text="Salir" RenderStyle="ButtonRenderStyle.Secondary" Click="@OnCancelPopup" />
    </FooterTemplate>
</DxPopup>


