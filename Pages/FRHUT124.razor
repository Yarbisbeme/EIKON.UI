@page "/FRHUT124"

@using EIKON.UI.Components
@using DevExpress.Blazor
@using System.Net.Http.Json
@using System.Net.Http.Headers
@using EIKON.UI.Interfaces
@using DevExpress.AspNetCore.Reporting
@using DevExpress.XtraReports.UI
@using System.ComponentModel.DataAnnotations

@layout MainLayout
@inject HttpClient HttpClient
@inject EIKON.UI.Services.EikonDataServices api
@inject EIKON.UI.Services.AuthenticationService auth
@inject NavigationManager nv
@inject IJSRuntime JS

<div class="page">
    <Breadcrumb Title="FRHUT124 - Reportes del Estado" BackUrl="/dash" />
    
    <div class="page-header">
        <div class="page-toolbar">
            <Toolbar formulario="FRHxxx999" OnClose="HandleClose" />
        </div>
    </div>

    <div class="form-container">
        <!-- Primera Fila - Código y Descripción -->
        <div class="form-row">
            <div class="input-field">
                <label>Código</label>
                <DxTextBox @bind-Text="@CodigoValue"
                           ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Never">
                    <Buttons>
                        <DxEditorButton IconCssClass="fi fi-rr-search" 
                                       Click="@OnSearchCodigoClick" />
                    </Buttons>
                </DxTextBox>
            </div>
            <div class="input-field wide">
                <label>Descripción</label>
                <DxTextBox @bind-Text="@DescripcionValue" />
            </div>
        </div>

        <!-- Segunda Fila - Estatal y Frecuencia -->
        <div class="form-row">
            <div class="input-field">
                <label>Estatal</label>
                <DxComboBox Data="@EstatalsList" 
                           @bind-Value="@SelectedEstatal" 
                           NullText="Seleccionar estatal"
                           TextFieldName="Name" 
                           ValueFieldName="Id" />
            </div>
            <div class="input-field">
                <label>Frecuencia</label>
                <DxComboBox Data="@FrecuenciasList" 
                           @bind-Value="@SelectedFrecuencia" 
                           NullText="Seleccionar frecuencia"
                           TextFieldName="Name" 
                           ValueFieldName="Id" />
            </div>
        </div>

        <!-- Tercera Fila - Reporte y Día Presentación -->
        <div class="form-row">
            <div class="input-field">
                <label>Reporte</label>
                <DxTextBox @bind-Text="@ReporteValue" />
            </div>
            <div class="input-field">
                <label>Día Presentación</label>
                <DxSpinEdit @bind-Value="@DiaPresentacionValue" 
                           MinValue="1" 
                           MaxValue="31" />
            </div>
        </div>

        <!-- Sección de Tabs - Comentario y SQL -->
        <div class="tabs-section">
            <DxTabs @bind-ActiveTabIndex="@ActiveTabIndex" CssClass="custom-tabs">
                <DxTabPage Text="Comentario" CssClass="tab-page">
                    <Content>
                        <div class="tab-content">
                            <DxMemo @bind-Value="@ComentarioValue" 
                                   Rows="15" 
                                   NullText="Escriba sus comentarios aquí..." 
                                   CssClass="full-memo" />
                        </div>
                    </Content>
                </DxTabPage>
                <DxTabPage Text="SQL" CssClass="tab-page">
                    <Content>
                        <div class="tab-content">
                            <DxMemo @bind-Value="@SqlValue" 
                                   Rows="15" 
                                   NullText="Escriba la consulta SQL aquí..." 
                                   CssClass="sql-memo" />
                        </div>
                    </Content>
                </DxTabPage>
            </DxTabs>
        </div>

        <!-- Sección de Checkboxes -->
        <div class="checkbox-section">
            <div class="checkbox-group">
                <div class="checkbox-column">
                    <div class="checkbox-row">
                        <DxCheckBox @bind-Checked="@ActivoOption">Activo</DxCheckBox>
                    </div>
                    <div class="checkbox-row">
                        <DxCheckBox @bind-Checked="@PedirNominaOption">Pedir nómina</DxCheckBox>
                    </div>
                    <div class="checkbox-row">
                        <DxCheckBox @bind-Checked="@RegionalOption">Regional</DxCheckBox>
                    </div>
                    <div class="checkbox-row">
                        <DxCheckBox @bind-Checked="@IdEmpleadoOption">Id Empleado</DxCheckBox>
                    </div>
                </div>
                <div class="checkbox-column">
                    <div class="checkbox-row">
                        <DxCheckBox @bind-Checked="@PedirFechaOption">Pedir fecha</DxCheckBox>
                    </div>
                    <div class="checkbox-row">
                        <DxCheckBox @bind-Checked="@MesOption">Mes</DxCheckBox>
                    </div>
                    <div class="checkbox-row">
                        <DxCheckBox @bind-Checked="@AnoOption">Año</DxCheckBox>
                    </div>
                </div>
            </div>
            
            <!-- Campos adicionales -->
            <div class="additional-fields">
                <div class="input-field">
                    <label>Tipo Empl</label>
                    <DxTextBox @bind-Text="@TipoEmplValue" />
                </div>
                <div class="input-field">
                    <label>Líneas</label>
                    <DxSpinEdit @bind-Value="@LineasValue" 
                               MinValue="0" 
                               MaxValue="999" />
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* Container principal */
    .form-container {
        display: flex;
        flex-direction: column;
        gap: 25px;
        padding: 20px 0;
    }

    /* Form rows */
    .form-row {
        display: flex;
        gap: 20px;
        align-items: flex-end;
        min-height: 60px;
    }

    /* Input fields */
    .input-field {
        display: flex;
        flex-direction: column;
        gap: 6px;
        flex: 1;
        min-width: 150px;
    }

    .input-field.wide {
        flex: 2;
    }

    .input-field label {
        font-weight: 500;
        color: #333;
        font-size: 13px;
        margin-bottom: 5px;
    }

    /* Tabs section - Comentario y SQL */
    .tabs-section {
        margin-top: 15px;
        border: 1px solid #e0e0e0;
        border-radius: 8px;
        overflow: hidden;
    }

    .custom-tabs {
        border: none;
    }

    .tab-content {
        padding: 20px;
        background-color: transparent;
    }

    .full-memo,
    .sql-memo {
        width: 100%;
        border: none;
    }

    .full-memo .dx-memo-container,
    .sql-memo .dx-memo-container {
        background-color: transparent !important;
        border: 1px solid #ced4da !important;
        min-height: 400px !important;
    }

    /* Checkbox section */
    .checkbox-section {
        display: flex;
        gap: 30px;
        margin-top: 20px;
        padding: 20px;
        border: 1px solid #e0e0e0;
        border-radius: 8px;
        background-color: #f8f9fa;
    }

    .checkbox-group {
        display: flex;
        gap: 40px;
        flex: 1;
    }

    .checkbox-column {
        display: flex;
        flex-direction: column;
        gap: 12px;
        flex: 1;
    }

    .checkbox-row {
        display: flex;
        align-items: center;
        min-height: 35px;
    }

    .additional-fields {
        display: flex;
        flex-direction: column;
        gap: 15px;
        flex: 0 0 200px;
        padding-left: 20px;
        border-left: 1px solid #dee2e6;
    }

    /* DevExpress Components */
    .dx-textbox,
    .dx-combobox,
    .dx-spin-edit,
    .dx-memo {
        border-radius: 6px !important;
    }

    .dx-textbox-container,
    .dx-combobox-container,
    .dx-spin-edit-container,
    .dx-memo-container {
        border: 1px solid #ced4da !important;
        border-radius: 6px !important;
        transition: all 0.3s ease !important;
    }

    .dx-textbox-container:focus-within,
    .dx-combobox-container:focus-within,
    .dx-spin-edit-container:focus-within,
    .dx-memo-container:focus-within {
        border-color: #dc3545 !important;
        box-shadow: 0 0 0 0.2rem rgba(220, 53, 69, 0.25) !important;
    }

    /* Memo específico */
    .dx-memo-container {
        min-height: 300px !important;
    }

    .dx-memo-container .dx-texteditor-input {
        font-family: 'Courier New', monospace;
        font-size: 12px;
        line-height: 1.4;
    }

    /* SQL Memo específico */
    .sql-memo .dx-memo-container .dx-texteditor-input {
        font-family: 'Consolas', 'Monaco', 'Courier New', monospace;
        font-size: 13px;
        background-color: transparent !important;
    }

    /* Comentario Memo específico */
    .full-memo .dx-memo-container .dx-texteditor-input {
        background-color: transparent !important;
    }

    /* Tabs específicos */
    .dx-tabs-header {
        background-color: #f8f9fa !important;
        border-bottom: 1px solid #e0e0e0 !important;
    }

    .dx-tab {
        border: none !important;
        background-color: transparent !important;
        color: #6c757d !important;
        font-weight: 500 !important;
    }

    .dx-tab:hover {
        background-color: rgba(220, 53, 69, 0.1) !important;
        color: #dc3545 !important;
    }

    .dx-tab-active {
        background-color: #dc3545 !important;
        color: white !important;
        border-radius: 6px 6px 0 0 !important;
    }

    .dx-tab-content {
        border: none !important;
        padding: 0 !important;
    }

    /* Checkboxes */
    .dx-checkbox {
        font-size: 14px;
        font-weight: 500;
    }

    .dx-checkbox-checked .dx-checkbox-icon {
        background-color: #dc3545 !important;
        border-color: #dc3545 !important;
    }

    .dx-checkbox:hover .dx-checkbox-icon {
        border-color: #dc3545 !important;
    }

    /* Spin Edit específico */
    .dx-spin-edit .dx-texteditor-input {
        text-align: center;
    }

    /* Responsive Design */
    media (max-width: 1024px) {
        .form-container {
            padding: 15px;
            gap: 20px;
        }

        .form-row {
            flex-wrap: wrap;
            gap: 15px;
        }

        .tabs-section {
            margin-top: 12px;
        }

        .checkbox-section {
            gap: 20px;
        }

        .checkbox-group {
            gap: 25px;
        }

        .additional-fields {
            flex: 0 0 180px;
        }
    }

    media (max-width: 768px) {
        .form-container {
            padding: 15px;
            gap: 15px;
        }

        .form-row {
            flex-direction: column;
            gap: 15px;
            align-items: stretch;
            min-height: auto;
        }

        .input-field {
            min-width: auto;
        }

        .input-field.wide {
            flex: 1;
        }

        .tabs-section {
            margin-top: 10px;
        }

        .checkbox-section {
            flex-direction: column;
            gap: 15px;
            padding: 15px;
        }

        .checkbox-group {
            flex-direction: column;
            gap: 15px;
        }

        .additional-fields {
            flex: 1;
            padding-left: 0;
            border-left: none;
            border-top: 1px solid #dee2e6;
            padding-top: 15px;
        }

        .full-memo .dx-memo-container,
        .sql-memo .dx-memo-container {
            min-height: 300px !important;
        }
    }

    media (max-width: 480px) {
        .form-container {
            gap: 12px;
            padding: 12px;
        }

        .form-row {
            gap: 12px;
        }

        .tabs-section {
            margin-top: 8px;
        }

        .checkbox-section {
            gap: 12px;
            padding: 12px;
        }

        .checkbox-group {
            gap: 12px;
        }

        .checkbox-column {
            gap: 8px;
        }

        .additional-fields {
            gap: 12px;
            padding-top: 12px;
        }
    }
</style>

@code {
    // **- private string[] // **- ToolbarOptions = { "add", "save", "remove", "leave" };
    
    // Campos del formulario
    private string CodigoValue { get; set; } = "";
    private string DescripcionValue { get; set; } = "";
    private int? SelectedEstatal { get; set; }
    private int? SelectedFrecuencia { get; set; }
    private string ReporteValue { get; set; } = "";
    private int DiaPresentacionValue { get; set; } = 1;
    private string ComentarioValue { get; set; } = "";
    private string SqlValue { get; set; } = "";
    private string TipoEmplValue { get; set; } = "";
    private int LineasValue { get; set; } = 0;
    
    // Tab index
    private int ActiveTabIndex { get; set; } = 0;
    
    // Opciones de checkbox
    private bool ActivoOption { get; set; } = true;
    private bool PedirFechaOption { get; set; } = false;
    private bool PedirNominaOption { get; set; } = false;
    private bool MesOption { get; set; } = false;
    private bool RegionalOption { get; set; } = false;
    private bool AnoOption { get; set; } = false;
    private bool IdEmpleadoOption { get; set; } = false;

    // Listas de datos
    private List<OptionItem> EstatalsList = new List<OptionItem>
    {
        new OptionItem { Id = 1, Name = "Estatal Tipo A" },
        new OptionItem { Id = 2, Name = "Estatal Tipo B" },
        new OptionItem { Id = 3, Name = "Estatal Tipo C" },
        new OptionItem { Id = 4, Name = "Federal" }
    };

    private List<OptionItem> FrecuenciasList = new List<OptionItem>
    {
        new OptionItem { Id = 1, Name = "Mensual" },
        new OptionItem { Id = 2, Name = "Quincenal" },
        new OptionItem { Id = 3, Name = "Trimestral" },
        new OptionItem { Id = 4, Name = "Semestral" },
        new OptionItem { Id = 5, Name = "Anual" }
    };

    public class OptionItem
    {
        public int Id { get; set; }
        public string Name { get; set; } = "";
    }
    
    // Event handlers
    private void OnSearchCodigoClick() => Console.WriteLine("Buscar código");
    
    private async Task HandleClose()
    {
        await JS.InvokeVoidAsync("alert", "¡Reporte del Estado guardado!");
    }
}