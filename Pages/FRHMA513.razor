        new PuestoItem { Codigo = "000005", Puesto = "Asistente de Recursos Humanos" },
        new PuestoItem { Codigo = "000006", Puesto = "Auxiliar Contable" },
        new PuestoItem { Codigo = "000007", Puesto = "Ayudante de Bodega" },
        new PuestoItem { Codigo = "000008", Puesto = "Ayudante de cocina" }
    };

    private void OnSearchCodigo()
    {
